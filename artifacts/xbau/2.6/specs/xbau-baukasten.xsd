            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="aufAnderemGrundstueckMitBaulast">
            <xs:annotation>
               <xs:documentation>Das Element enthält die Angaben zu Stellplätzen auf anderem Grundstück mit Baulast. Hier gibt es die Möglichkeit, anzugeben, auf welchem Grundstück die Verpflichtung zur Schaffung von Stellplätzen erfüllt wird.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="anzahl" type="xs:positiveInteger">
                     <xs:annotation>
                        <xs:documentation>Anzahl der Stellplätze auf anderem Grundstück mit Baulast</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="grundstueck" type="xbau:Grundstueck">
                     <xs:annotation>
                        <xs:documentation>Hier sind die Angaben zum anderen Grundstück einzutragen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="durchAbloesung" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Anzahl der abgelösten Stellplätze</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="FeuerstaetteArt">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zur Art der Feuerstätte.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element minOccurs="0" name="code" type="xbau:Code.FeuerstaetteArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art der Feuerstätte</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nichtGelisteterWert" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Freitextangabe für die Art der Feuerstätte</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="Feuerstaetten">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp kann Feuerstätten detailliert beschreiben.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="zweck"
                     maxOccurs="2"
                     type="xbau:FeuerungsanlagenZweck">
            <xs:annotation>
               <xs:documentation>Angaben zum Zweck der Feuerungsanlage. Dieser kann Heizung, Warmwasser oder auch beides sein.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="heizung" type="xbau:Heizung">
            <xs:annotation>
               <xs:documentation>Angaben zur Heizung</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nennleistung" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zur Nennleistung</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="aufstellort" type="xbau:Aufstellort">
            <xs:annotation>
               <xs:documentation>Angaben zum Aufstellort</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="brennstoff" type="xbau:Brennstoff">
            <xs:annotation>
               <xs:documentation>Angabe des Brennstoffs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="artDerFeuerstaette" type="xbau:FeuerstaetteArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art der Feuerstätte</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="mitGeblaese" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe zum Gebläse</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Feuerungsanlagen">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu Feuerungsanlagen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="feuerstaetten"
                     maxOccurs="unbounded"
                     type="xbau:Feuerstaetten">
            <xs:annotation>
               <xs:documentation>Angaben zu Feuerungsanlagen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="abgasanlagen" type="xbau:Abgasanlagen">
            <xs:annotation>
               <xs:documentation>Angaben zu Abgasanlagen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="offenerKamin" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angaben zum offenen Kamin</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="FeuerungsanlagenZweck">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zum Zweck von Feuerungsanlagen.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element minOccurs="0" name="code" type="xbau:Code.FeuerungsanlagenZweck">
            <xs:annotation>
               <xs:documentation>Angabe des Zwecks der Feuerungsanlage, wenn dieser entweder die primäre/sekundäre Anlage für Heizung oder Warmwasserbereitung ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nichtGelisteterWert" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Freitextangabe für den Zweck der Feuerungsanlage</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="Flaechen">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Parameter zu den im Bauvorhaben vorgesehenen Flächen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="flaechen.Bauordnungsrecht"
                     type="xbau:XBau.Flaechen">
            <xs:annotation>
               <xs:documentation>Angaben zu den Grundstücksflächen des Vorhabens, soweit sie bauordnungsrechtlichen Charakter haben</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="flaechen.BauNVO" type="xbau:FlaechenBauNVO">
            <xs:annotation>
               <xs:documentation>Daten zur baulichen Nutzung von Grundstücken gemäß Baunutzungsverordnung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="flaechen.DIN277" type="xbau:FlaechenDIN277">
            <xs:annotation>
               <xs:documentation>Daten zu Grundflächen- und Rauminhalten von Bauwerken gemäß DIN 277</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="flaechen.WoFIV" type="xbau:FlaechenWoFlV">
            <xs:annotation>
               <xs:documentation>Daten zu Flächen gemäß Wohnflächenverordnung (Verordnung zur Berechnung der Wohnfläche).</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="FlaechenBauNVO">
      <xs:annotation>
         <xs:documentation>Dieser Typ fasst Angaben zu Grundstücken nach der BauNVO zusammen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="hoeheDerBaulichenAnlage"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Höhe der baulichen Anlage (§ 18 BauNVO). Angabe: Anzahl Meter mit zwei Nachkommastellen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="hoehenBezug" type="xs:token">
            <xs:annotation>
               <xs:documentation>Die maßgebliche Geländeoberfläche kann festgelegt (Vermessungs- Katasterbehörde) sein oder wird durch a) einen Bebauungsplan (Bezugspunkte auf NhN eingemessen), b) einen Verwaltungsakt der Baugenehmigungsbehörde (Baugenehmigung / Baufreistellung / Festsetzungsbescheid) oder – erneut – c) das natürlich vorhandene Gelände (= natürliche Geländeoberfläche) -&gt; festgestellt durch die Vermessungs- oder Katasterbehörde</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="anzahlVollgeschosse" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Geplante Vollgeschosse. Als Vollgeschosse gelten Geschosse, die nach landesrechtlichen Vorschriften Vollgeschosse sind oder auf ihre Zahl angerechnet werden (§ 20 BauNVO).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="zulaessigeAnzahlVollgeschosse"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Im Bebauungsplan festgesetzte Anzahl Vollgeschosse. Als Vollgeschosse gelten Geschosse, die nach landesrechtlichen Vorschriften Vollgeschosse sind oder auf ihre Zahl angerechnet werden (§ 20 BauNVO). Siehe auch § 16 Abs.2 BauNVO und MBO § 87 Abs. 2.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="flaecheDesBaugrundstuecks"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Nach § 19 Abs. 3 BauNVO: Für die Ermittlung der zulässigen Grundfläche ist die Fläche des Baugrundstücks maßgebend, die im Bauland und hinter der im Bebauungsplan festgesetzten Straßenbegrenzungslinie liegt. Ist eine Straßenbegrenzungslinie nicht festgesetzt, so ist die Fläche des Baugrundstücks maßgebend, die hinter der tatsächlichen Straßengrenze liegt oder die im Bebauungsplan als maßgebend für die Ermittlung der zulässigen Grundfläche festgesetzt ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="grundflaechen">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Kennzahlen zu Grundflächen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="grundflaeche" type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Ermittlung der Grundflächen (GR) gemäß §19 Abs. 2 der BauNVO 1962 / 1968 / 1977 / 1990 / 2017 … Ist die ermittelte Grundfläche der geplanten baulichen Anlagen. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="grundflaechenzahlSoll"
                              type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Ist die Grundflächenzahl [GRZI], die der B-Plan festsetzt (§ 19 Abs. 1 BauNVO). Die GRZ wird mit ein oder zwei Dezimalstellen angegeben.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="grundflaechenzahlGeplant"
                              type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Geplante Grundflächenzahl (GRZ). Die GRZ wird mit ein oder zwei Dezimalstellen angegeben.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="geschossflaechen">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Kennzahlen zu Geschossflächen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="geschossflaeche" type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Ist die ermittelte Geschossfläche (GF) gemäß § 20 Abs. 3 und 4 BauNVO. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="geschossflaechenzahlSoll"
                              type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Ist die Geschossflächenzahl (GFZ), die der B-Plan festsetzt (§ 20 BauNVO).Die GFZ ist eine dimensionslose Größe und wird mit ein oder zwei Dezimalstellen angegeben.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="geschossflaechenzahlGeplant"
                              type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Geplante Geschossflächenzahl (GFZ). Die GFZ ist eine dimensionslose Größe und wird mit ein oder zwei Dezimalstellen angegeben.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="baumassen">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Kennzahlen zu Baumassen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="baumasse" type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Baumasse (BM) nach § 21 BauNVO. Angabe: Anzahl Kubikmeter mit zwei Nachkommastellen</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="baumassenzahlSoll" type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Baumassenzahl (BMZ) (Soll) nach § 21 Bau NVO.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="baumassenzahlGeplant" type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Geplante Baumassenzahl (BMZ).</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="FlaechenDIN277">
      <xs:annotation>
         <xs:documentation>Dieser Typ fasst Angaben zu Bauwerken nach der DIN-Norm DIN 277 zusammen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="grundstuecksFlaecheGF"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Die Fläche, die durch die Grundstücksgrenzen gebildet wird und die im Liegenschaftskataster sowie im Grundbuch ausgewiesen ist. Zur Grundstücksfläche gehören die bebaute Grundstücksfläche und die unbebaute Grundstücksfläche.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="bebauteGrundstuecksflaecheBF"
                     type="xbau:BebauteGrundstuecksflaeche">
            <xs:annotation>
               <xs:documentation>Bebaute Fläche (BF). Teilfläche der Grundstücksfläche (GF), die durch ein Bauwerk oberhalb der Geländeoberfläche überbaut oder überdeckt oder unterhalb der Geländeoberfläche unterbaut ist. = ueberbauteFlaecheBF1 + unterbauteFlaecheBF2</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="nichtBebauteGrundstuecksflaecheUF"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Unbebaute Fläche UF. Teilfläche der Grundstücksfläche (GF), die nicht durch ein Bauwerk überbaut, überdeckt oder unterbaut ist. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen = grundstuecksFlaecheGF - bebauteFlaecheBF</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="aussenanlagenFlaecheAF"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Teilfläche der Grundstücksfläche (GF), die sich außerhalb eines Bauwerks bzw. bei unterbauter Grundstücksfläche über einem Bauwerk befindet.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="bruttoGrundflaecheBGF"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Gesamtfläche aller Grundrissebenen des Bauwerks.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="konstruktionsGrundflaecheKGF"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Teilfläche der Brutto-Grundfläche (BGF), die sämtliche Grundflächen der aufgehenden Baukonstruktionen des Bauwerks umfasst.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nettoRaumflaecheNRF" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Teilfläche der Brutto-Grundfläche (BGF), die sämtliche Grundflächen der nutzbaren Räume aller Grundrissebenen des Bauwerks umfasst.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nutzflaechen" type="xbau:Nutzflaechen">
            <xs:annotation>
               <xs:documentation>Daten zu Flächen gemäß Wohnflächenverordnung (Verordnung zur Berechnung der Wohnfläche).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="technikFlaecheTF" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Teilfläche der Netto-Raumfläche (NRF) für die technischen Anlagen zur Versorgung und Entsorgung des Bauwerks.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="verkehrsFlaecheVF" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Teilfläche der Netto-Raumfläche (NRF) für die horizontale und vertikale Verkehrserschließung des Bauwerks.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="bruttoRauminhaltBRI" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe des Brutto-Rauminhalts (BRI)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="konstruktionsRauminhaltKRI"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Teilvolumen des Brutto-Rauminhalts (BRI), das von den Baukonstruktionen des Bauwerks eingenommen wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nettoRauminhaltNRI" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Teilvolumen des Brutto-Rauminhalts (BRI), das sämtliche nutzbaren Räume aller Grundrissebenen des Bauwerks umfasst.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="FlaechenWoFlV">
      <xs:annotation>
         <xs:documentation>Flächen nach der Verordnung zur Berechnung der Wohnfläche (WoFIV).</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="wohnflaecheNeu" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Hier ist die Wohnfläche einzutragen (Einheit: Quadratmeter).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="wohnflaecheAlt" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Bei Änderungen: Hier ist die Wohnfläche vor Umsetzung des Bauvorhabens einzutragen (Einheit: Quadratmeter).</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Gebaeude">
      <xs:annotation>
         <xs:documentation>In diesem Typ sind die nach außen sichtbaren Elemente von Gebäuden zusammengefasst, um die äußere Gestaltung textlich zu beschreiben.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="dach" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zum Dach</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="fassade" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zur Fassade</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="fenster" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zum Fenster</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="tueren" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zu Türen</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Gegenstand">
      <xs:annotation>
         <xs:documentation>Dieser Abschnitt beschreibt, was der Gegenstand des Antrags ist.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="anzahlDerGebaeude"
                     type="xbau:AnzahlDerGebaeude">
            <xs:annotation>
               <xs:documentation>Dieser Datentyp enthält die Anzahl der Gebäude des Bauvorhabens und Informationen zur Identifikation der einzelnen Gebäude.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="artDerMassnahme"
                     maxOccurs="unbounded"
                     type="xbau:Code.BaumassnahmeArt">
            <xs:annotation>
               <xs:documentation>In dieses Element ist einzutragen, von welcher Art (z. B. Errichtung, Änderung, Nutzungsänderung) die Maßnahmen im Rahmen des Bauvorhabens sind. Falls mehrere dieser Charakterisierungen signifikant zutreffen, so ist das Element mehrfach zu instanziieren.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="artDerBaulichenAnlage"
                     type="xbau:ArtDerBaulichenAnlage">
            <xs:annotation>
               <xs:documentation>Für den Gegenstand des Bauvorhabens kann hier die Art der baulichen Anlage näher spezifiziert werden. Es ist aus einer der drei Codelisten eine Auswahl zu treffen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="zweckDerNutzungsaenderung"
                     type="xbau:ZweckDerNutzungsaenderung">
            <xs:annotation>
               <xs:documentation>Wenn das Bauvorhaben eine Nutzungsänderung der baulichen Anlage beabsichtigt, ist in diesem Feld die bisherige und die beabsichtigte Nutzung der baulichen Anlage anzugeben. Es ist jeweils aus einer der drei Codelisten eine Auswahl zu treffen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="bauordnungsrechtlicheKlassifikation"
                     type="xbau:BauordnungsrechtlicheKlassifikation">
            <xs:annotation>
               <xs:documentation>Dieses Element beinhaltet Zahlen zu bauordnungsrechtlichen Parametern des Vorhabens.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="vorhandeneBindungen"
                     maxOccurs="unbounded"
                     type="xbau:Bindungen">
            <xs:annotation>
               <xs:documentation>In diesem Element können Informationen über vorhandene Bindungen zu dem Gegenstand des Bauvorhabens übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="baudenkmalBetroffen" maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>In diesem Element können die Informationen über die vom Bauvorhaben betroffenen Denkmäler enthalten werden.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0"
                              name="artDesBaudenkmals"
                              type="xbau:Code.ArtDesBaudenkmals">
                     <xs:annotation>
                        <xs:documentation>Dieses Element enthält die Informationen über die Art des betroffenen Baudenkmals.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="begruendung" type="xbauk:TextFormatiert">
                     <xs:annotation>
                        <xs:documentation>In diesem Element wird erläutert, warum ein Baudenkmal von dem Bauvorhaben betroffen wird.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="bauvorhabenDatenblatt" type="xbau:Datenblatt">
            <xs:annotation>
               <xs:documentation>Dieses Objekt bietet Felder für die Übermittlung von technischen Daten und Kennzahlen zum Bauvorhaben. Falls das Bauvorhaben eine Errichtung ist, beziehen sich alle aufgeführten Parameter des Datenblatts naturgemäß auf das projektierte Gesamtbauwerk. Falls das Bauvorhaben eine Änderung ist, ist abzuwägen, ob Daten in Bezug auf den Erweiterungsbau oder auf das Gesamtbauwerk anzugeben sind.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="hochbaustatistik" type="xbau:Hochbaustatistik">
            <xs:annotation>
               <xs:documentation>Dieses Objekt stellt die Daten zusammen, die für die Datenlieferung der Bauaufsichtsbehörde (bzw. des Bauherrn) an die amtliche Statistik vorgesehen sind. Hinweis: Dieser Datentyp wird im kommenden Release entfernt.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="baubeschreibung" type="xbau:Baubeschreibung">
            <xs:annotation>
               <xs:documentation>Dieses Element gibt die Gliederung vor, in der das Bauvorhaben thematisch strukturiert beschrieben werden kann.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="betriebsbeschreibung"
                     type="xbau:Betriebsbeschreibung">
            <xs:annotation>
               <xs:documentation>Dieses Objekt nimmt Daten zur Betriebsbeschreibung nach § 5 BauPrüfVO NRW auf.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="pruefungBautechnischeNachweise"
                     maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>Mit diesem Element wird die Angabe in Bezug auf die Prüfung der bautechnischen Nachweise (u.a. Brandschutznachweis) übermittelt.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="pruefungIstErforderlich" type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Enthält das Element den Wert "true", wird beantragt, dass die Bauaufsichtsbehörde prüft bzw. von Haus aus für die Prüfung in der Verantwortung ist. Der Wert "false" bedeutet, dass die Prüfung durch einen Prüfingenieur oder Prüfsachverständigen in Verantwortung des Bauherren veranlasst wird.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="artDesBautechnischenNachweises"
                              type="xbau:Code.BautechnischerNachweisArt">
                     <xs:annotation>
                        <xs:documentation>Die Art des bautechnischen Nachweises, der Gegenstand der Prüfung ist.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0"
                     name="herstellungskosten"
                     type="xbau:Herstellungskosten">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten für die entsprechenden Kostengruppen der DIN 276 einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Genehmigungsdatum">
      <xs:annotation>
         <xs:documentation>Hier können Angaben zum voraussichtlichen Genehmigungsdatum (optional) und spätesten Genehmigungsdatum (obligatorisch) des Antrags gemacht werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="voraussichtlichesGenehmigungsdatum"
                     type="xs:date">
            <xs:annotation>
               <xs:documentation>Hier ist das voraussichtliche Genehmigungsdatum einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="spaetestesGenehmigungsdatum" type="xs:date">
            <xs:annotation>
               <xs:documentation>Hier ist das späteste Genehmigungsdatum einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Gesamtnutzungsflaeche">
      <xs:annotation>
         <xs:documentation>Daten zur Gesamtnutzungsfläche</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="gesamtnutzungsflaecheNeu"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Hier ist die Gesamtnutzungsfläche einzutragen (Einheit: Quadratmeter).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="gesamtnutzungsflaecheAlt"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Bei Änderungen: Hier ist die Gesamtnutzungsfläche vor Umsetzung des Bauvorhabens einzutragen (Einheit: Quadratmeter).</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="GewerblicheBetriebsbeschreibung">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zur gewerblichen Betriebsbeschreibung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="artDesBetriebesOderDerAnlage" type="xs:token">
            <xs:annotation>
               <xs:documentation>Detaillierte Beschreibung des Gewerbebetriebs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="erzeugnisse" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Erzeugnisse / Produkte des Gewerbebetriebs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="dienstleistung" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angebotene Dienstleistungen des Gewerbebetriebs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="materialien" type="xbau:Code.Materialien">
            <xs:annotation>
               <xs:documentation>Materialien, Rohstoffe, Betriebsstoffe, Reststoffe, Waren die vom Gewerbebetrieb zur Produktion eingesetzt bzw. verbraucht werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="artDerRohstoffe" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Angaben zur Art der zu verwendenden Rohstoffe</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="lagerungRohstoffeUndErzeugnisse"
                     type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Angaben zur Lagerung der Rohstoffe und Erzeugnisse, soweit sie explosionsgefährlich oder gesundheitsgefährdend sind.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="chemischeUndPhysikalischeEinwirkungen"
                     type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Angaben zu etwaigen chemischen und physikalischen Einwirkungen auf die Beschäftigten und die Nachbarschaft</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="betriebszeiten" type="xbau:Betriebszeiten">
            <xs:annotation>
               <xs:documentation>Angabe der Betriebszeiten an Werktagen sowie Sonn- und Feiertagen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="gesamtbeschaeftigteAmBetriebsOrt"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Angabe der Gesamtbeschäftigten am Betriebsort</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="artDerTaetigkeit" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Angaben zur Art der Tätigkeit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="immissionsschutz" type="xbau:Immissionsschutz">
            <xs:annotation>
               <xs:documentation>Angaben zum Immissionsschutz</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="verfahrenNachAnderenRechtsvorschriften"
                     type="xbau:VerfahrenNachAnderenRechtsvorschriften">
            <xs:annotation>
               <xs:documentation>Angaben zu Verfahren nach anderen Rechtsvorschriften, die in Verbindung mit dem beantragten Gewerbebetrieb stehen (z.B. Genehmigung, Erlaubnis, Eignungsfeststellung nach Wasser-, Gewerbe-, Immissionsschutzrecht).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="betriebMitPublikumsverkehr"
                     maxOccurs="unbounded"
                     type="xbau:BetriebMitPublikumsverkehr">
            <xs:annotation>
               <xs:documentation>Angaben zum Betrieb mit Publikumsverkehr</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Grundstueck">
      <xs:annotation>
         <xs:documentation>Dieser Typ nimmt Angaben zu einem Grundstück auf.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="anschrift"
                     maxOccurs="unbounded"
                     type="xbau:AnschriftGrundstueckErweitert">
            <xs:annotation>
               <xs:documentation>In diesem Element wird die Anschrift des Grundstücks eingetragen. Falls dem Grundstück von der Kommune keine Anschrift zugewiesen ist, wird dieses Element nicht instanziiert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="flurstueck"
                     maxOccurs="unbounded"
                     type="xbauk:Flurstueckskennzeichen">
            <xs:annotation>
               <xs:documentation>Pro Instanziierung des Elements sind Angaben zu einem Flurstück vorzunehmen, das zum Grundstück gehört.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="verwaltungsgemeinschaft"
                     type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In diesem Element kann bei Bedarf eine Angabe zur Verwaltungsgemeinschaft (Zusammenschluss mehrerer Gemeinden, in manchem Bundesland auch Samtgemeinde oder Verbandsgemeinde genannt) übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="bebauungsplan" maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>In diesem Element können Angaben zu einem Bebauungsplan eingetragen werden, falls das Grundstück von einem solchen betroffen ist.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:choice>
                  <xs:element minOccurs="0" name="nummerBebauungsplan" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>In dieses Element ist die Nummer des Bebauungsplans einzutragen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="bezeichnungBebauungsplan"
                              type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Dieses Element steht für die Bezeichnung des Bebauungsplans.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:choice>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0"
                     name="vorhandeneBaulasten"
                     maxOccurs="unbounded"
                     type="xbau:Bindungen">
            <xs:annotation>
               <xs:documentation>In diesem Element können Angaben zu vorhandenen Baulasten übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="erschliessung" type="xbau:Erschliessung">
            <xs:annotation>
               <xs:documentation>In diesem Element werden Angaben zur Erschließung gemacht.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="GrundstueckBaulast">
      <xs:annotation>
         <xs:documentation>Dieses Element enthält die Angaben des Grundstücks oder der Grundstücke, zu denen die Auskunft angefragt wird.</xs:documentation>
      </xs:annotation>
      <xs:complexContent>
         <xs:extension base="xbau:Grundstueck">
            <xs:sequence>
               <xs:element minOccurs="0"
                           name="artBaulastauskunft"
                           type="xbau:Code.ArtBaulastauskunft">
                  <xs:annotation>
                     <xs:documentation>In diesem Element wird angegeben, ob eine einfache Auskunft gewünscht ist, oder ob bei einem belasteten Grundstück auch eine Abschrift benötigt wird.</xs:documentation>
                  </xs:annotation>
               </xs:element>
            </xs:sequence>
         </xs:extension>
      </xs:complexContent>
   </xs:complexType>
   <xs:complexType name="GrundstueckBaulastauskunft">
      <xs:annotation>
         <xs:documentation>Dieses Element enthält die Daten der Baulastauskunft.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="baulastauskunft" maxOccurs="unbounded">
            <xs:complexType>
               <xs:choice>
                  <xs:element minOccurs="0" name="grundstueckEinfacheAuskunft">
                     <xs:annotation>
                        <xs:documentation>Mit diesem Element werden die Daten zu einem der Grundstücke übermittelt, auf das sich die Anfrage einer einfachen Auskunft bezieht.</xs:documentation>
                     </xs:annotation>
                     <xs:complexType>
                        <xs:sequence>
                           <xs:element minOccurs="0" name="angefragtesGrundstueck" type="xbau:Grundstueck">
                              <xs:annotation>
                                 <xs:documentation>Dieses Element enthält Angaben zu einem der Grundstücke aus der Anfrage bezüglich der Baulastauskunft.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element minOccurs="0" name="baulastVorhanden" type="xs:boolean">
                              <xs:annotation>
                                 <xs:documentation>Mit diesem Element wird angegeben, ob zu dem angefragten Grundstück eine Baulast vorhanden ist.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
                  <xs:element minOccurs="0" name="grundstueckAbschrift">
                     <xs:annotation>
                        <xs:documentation>Mit diesem Element werden die Daten zu einem der Grundstücke übermittelt, auf das sich die Anfrage einer Abschrift bezieht.</xs:documentation>
                     </xs:annotation>
                     <xs:complexType>
                        <xs:sequence>
                           <xs:element minOccurs="0" name="angefragtesGrundstueck" type="xbau:Grundstueck">
                              <xs:annotation>
                                 <xs:documentation>Dieses Element enthält Angaben zu einem der Grundstücke aus der Anfrage bezüglich der Baulastauskunft.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element minOccurs="0" name="baulastVorhanden" type="xs:boolean">
                              <xs:annotation>
                                 <xs:documentation>Mit diesem Element wird angegeben, ob zu dem angefragten Grundstück eine Baulast vorhanden ist.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element minOccurs="0"
                                       name="baulastDaten"
                                       maxOccurs="unbounded"
                                       type="xbau:BaulastErweitert">
                              <xs:annotation>
                                 <xs:documentation>Falls Baulasten vorhanden sind, beinhaltet dieses Element die Daten der Baulast aus dem Baulastenverzeichnis.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element minOccurs="0"
                                       name="baulastInformation"
                                       type="xbau:Code.Baulastauskunft">
                              <xs:annotation>
                                 <xs:documentation>Falls Baulasten vorhanden sind, werden mit diesem Element nähere Informationen zur vorhandenen Baulast übermittelt.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element minOccurs="0" name="anlagen" type="xbau:Anlagen">
                              <xs:annotation>
                                 <xs:documentation>Falls Baulasten vorhanden sind, werden mit diesem Element Anlagen, wie beispielsweise Zeichnungen, Baulastenblatt oder Lageplan, übermittelt.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
               </xs:choice>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Heizenergie">
      <xs:annotation>
         <xs:documentation>Dieses Element enthält die Daten zur primären und sekundären Heizenergie für Heizung und Warmwasseraufbereitung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="primaereHeizenergieHeizung"
                     type="xbau:Brennstoff">
            <xs:annotation>
               <xs:documentation>Angabe der primären Heizenergie (Heizung)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="sekundaereHeizenergieHeizung"
                     type="xbau:Brennstoff">
            <xs:annotation>
               <xs:documentation>Angabe der sekundären Heizenergie (Heizung)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="primaereHeizenergieWasseraufbereitung"
                     type="xbau:Brennstoff">
            <xs:annotation>
               <xs:documentation>Angabe der primären Heizenergie (Wasseraufbereitung)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="sekundaereHeizenergieWasseraufbereitung"
                     type="xbau:Brennstoff">
            <xs:annotation>
               <xs:documentation>Angabe der sekundären Heizenergie (Wasseraufbereitung)</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Heizung">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zur Heizung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="artDerHeizung" type="xbau:Code.HeizungArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art der Heizung</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="ausstattung" type="xbau:Code.Ausstattung">
            <xs:annotation>
               <xs:documentation>Angabe zur Ausstattung</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Herstellungskosten">
      <xs:annotation>
         <xs:documentation>Dieses Objekt biete die Felder für die Übermittlung von Herstellungskosten für die entsprechenden Kostengruppen der DIN 276.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="kostengruppe300" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten aus der Kostengruppe 300 einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostengruppe400" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten aus der Kostengruppe 400 einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostengruppe500" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten aus der Kostengruppe 500 einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostengruppe700" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten aus der Kostengruppe 700 einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostenProBGF" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten pro Bruttogrundfläche (BGF) einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostenProBRI" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten pro Bruttorauminhalt (BRI) einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="summeHerstellungskosten"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier ist die Summe der Herstellungskosten einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostenaufteilungNachGebaeude">
            <xs:annotation>
               <xs:documentation>Hier können die nach Gebäuden aufgegliederten Herstellungskosten eingetragen werden.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0"
                              name="kostenEinzelnesGebauede"
                              maxOccurs="unbounded"
                              type="xbau:KostenEinzelnesGebaeude">
                     <xs:annotation>
                        <xs:documentation>Hier können die aufgegliederten Herstellungskosten des einzelnen Gebäudes eingetragen werden.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Hochbaustatistik">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient zur Zusammenstellung der Daten für die Hochbaustatistik. Hinweis: Dieser Datentyp wird im kommenden Release entfernt.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="ordnungsnummer" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In diesem Element wird die statistische Ordnungsnummer angegeben, die vom zuständigen Landesamt für Statistik zur Verfügung gestellt wird und das Bauvorhaben eindeutig identifiziert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="artDesBauens" type="xbau:Code.ArtDesBauens">
            <xs:annotation>
               <xs:documentation>Hier kann angegeben werden, ob es sich bei der Baumaßnahme um einen Neubau oder um eine Baumaßnahme am Bestand handelt. Ggf. kann sich der Inhalt dieses Element ableiten lassen aus dem Element artDerMassnahme im Datentyp Gegenstand.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="lageGebaeude"
                     type="xbauk:GeoreferenzierteFlaeche">
            <xs:annotation>
               <xs:documentation>In diesem Element sollen ergänzend georeferenzierte Informationen zur genaueren Lage des Gebäudes auf dem Baugrundstück abgebildet werden. Falls beispielsweise ein Umbau geplant ist, und auf dem Grundstück mehrere Gebäude stehen, muss aus diesen Angaben hervorgehen, was der Gegenstand des Anbaus ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="haustypWohngebaeude"
                     type="xbau:Code.HaustypWohngebaeude">
            <xs:annotation>
               <xs:documentation>In diesem Element wird bei neu errichteten Gebäuden der Haustyp (z.B. Einzelhaus, Doppelhaushälfte) angegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="artDesGebaeudes"
                     type="xbau:Code.SystematikDerBauwerkeBautaetigkeit">
            <xs:annotation>
               <xs:documentation>Angabe eines 6-Stelligen Codes zur genauen Klassifizierung von Wohn- und Nichtwohngebäuden für die Statistik. Der Inhalt des Elements ergibt sich aus dem Datentyp Hochbaustatistik der Eingangsnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="baugenehmigung" type="xbau:Baugenehmigung">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält die Daten zur Baugenehmigung, wie z.B. das Datum der Baugenehmigung und die Art der Bautätigkeit.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="statusSozialerWohnungsbau"
                     type="xbau:Code.StatusSozialerWohnungsbau">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält die Angabe zum Status der Beantragung sozialer Wohnraumförderung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="heizenergie" type="xbau:Heizenergie">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält die Daten zur primären und sekundären Heizenergie für Heizung und Warmwasseraufbereitung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="anzahlDerWohnungen"
                     type="xbau:AnzahlDerWohnungen">
            <xs:annotation>
               <xs:documentation>Hier können Angaben zur Anzahl der Wohnungen gemacht werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="erfuellungGEG" type="xbau:ErfuellungGEG">
            <xs:annotation>
               <xs:documentation>Angabe, ob die Verpflichtungen des Gebäudeenergiegesetzes (GEG) erfüllt werden. Diese Daten müssen nur bei Neubauten übermittelt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="gesamtnutzungsflaeche"
                     type="xbau:Gesamtnutzungsflaeche">
            <xs:annotation>
               <xs:documentation>Hier können Angaben zur Gesamtnutzungsfläche gemacht werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Identifikation.Nachricht">
      <xs:annotation>
         <xs:documentation>Identifkationsmerkmale zu einer Nachricht. Dieser Typ kann im ID-Block zu einer Nachricht verwendet werden oder in einem Abschnitt, der auf eine Nachricht referenziert.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="nachrichtenUUID"
                     type="bn-uq-g2g:UUID"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier wird der Universally Unique Identifier (UUID) der Nachricht mitgeteilt, der das primäre Identifikationsmerkmal einer Nachricht darstellt. Der UUID der Nachricht ist weltweit eindeutig. So wird es möglich, Nachrichten hersteller- und anwendungsübergreifend eindeutig zu identifizieren. Für jede Nachricht muss eine neue UUID erzeugt werden, um eine eindeutige Identifikation der Nachricht sicherzustellen. Insbesondere ist es nicht zulässig, in einer korrigierten Nachricht (bspw. nach Erhalt einer RTS-Nachricht) die UUID der ursprünglichen Nachricht wiederzuverwenden. Sofern eine einmal erzeugte Nachricht ein weiteres Mal gesendet werden soll (bspw. aufgrund von Problemen beim Nachrichtentransport), muss die UUID nicht angepasst werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="nachrichtentyp"
                     type="xbau:Code.XBauNachrichten"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Die eindeutige Identifizierungsnummer für einen Nachrichtentyp. Der konkret zu verwendende Datentyp für die Übermittlung des Schlüsselwertes wird durch den Fachstandard auf Schemaebene festgelegt.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="erstellungszeitpunkt"
                     type="xs:dateTime"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Der Zeitpunkt, an dem die Nachricht erstellt wurde. Dieses Feld wird durch das Fachverfahren beim Erstellen der Nachricht gefüllt. Hier ist explizit nicht der Sende- und Empfangszeitpunkt festgehalten, denn die können in der Regel der Transportschicht entnommen werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="IdentifikationGebaeude">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp enthält Angaben zur Identifikation des Gebäudes im Bauvorhaben.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="uuidGebaeude" type="bn-g2g:UUID">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält den „Universally Unique IDentifier (UUID)“ des Gebäudes. Der UUID wird entsprechend rfc4122 gebildet und ermöglicht das Gebäude eindeutig zu identifizieren.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="gebaeudeBezeichnung" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Bezeichnung des einzelnen Gebäudes, z. B. "Reihenendhaus Ost".</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Immissionsschutz">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zum Immissionsschutz.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="luftverunreinigung">
            <xs:annotation>
               <xs:documentation>Dieses Element beinhaltet Angaben zur Luftverunreinigung.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="artDerVerunreinigung" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Art der Verunreinigung (z. B. durch Rauch, Ruß, Staub, Gase, Aerosole, Dämpfe, Geruchsstoffe)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="lageDerEmissionsoeffnungen" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Größe (Länge x Breite) sowie Höhenangabe der Emissionsöffnung</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="massnahmenZurVermeidungL" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Maßnahmen zur Vermeidung schädlicher Luftverunreinigungen</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="geraeusche">
            <xs:annotation>
               <xs:documentation>Dieses Element beinhaltet Angaben zu Geräuschen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="ursacheDauerHaeufigkeit" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Ursache, Dauer, Häufigkeit (z.B. durch Anlagen, Tätigkeiten, Fahrzeugverkehr auf dem Grundstück)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="lageDerGeraeuschquelle" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Lage der Geräuschquelle (Austrittsöffnungen, ggf. Richtungsangaben)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="tageszeit" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angaben zur Tageszeit (von - bis)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="nachtzeit" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angaben zur Tageszeit (von - bis)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="massnahmenZurVermeidungG" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Maßnahmen zur Vermeidung schädlicher Geräusche</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="erschuetterungenMechanischeSchwingungen">
            <xs:annotation>
               <xs:documentation>§66 MBO</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="artUrsacheDauerHaeufigkeit" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Art, Ursache, Dauert und Häufigkeit</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="lageDerErschuetterungsquelle" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Lage der Erschütterungs- oder Schwingungsquellen</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="tageszeit" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angaben zur Tageszeit (von - bis)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="nachtzeit" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angaben zur Tageszeit (von - bis)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="massnahmenZurVermeidungES" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Maßnahmen zur Vermeidung schädlicher Erschütterungen oder Schwingungen</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="abfallstoffe">
            <xs:annotation>
               <xs:documentation>Dieses Element beinhaltet Angaben zu Abfallstoffen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="artMengeProZeiteinheit" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Art und Menge pro Zeiteinheit</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="zwischenlagerungArtOrtMenge" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Zwischenlagerung Art, Ort und Menge</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="artDerBeseitigung" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Art der Beseitigung</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="abwaesser">
            <xs:annotation>
               <xs:documentation>Dieses Element beinhaltet Angaben zu besonders zu behandelnde Abwässer.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="artMengeProZeiteinheit" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Art und Menge pro Zeiteinheit</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="artOrtDerBehandlung" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Art und Ort der Behandlung</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="verbleibDerRueckstaende" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Verbleib der Rückstände</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Kinderspielplaetze">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu Kinderspielplätzen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="anlegungKinderspielplatzIstVerpflichtend"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe, ob eine Pflicht zur Anlegung eines Kinderspielplatzes besteht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="pflichtErfuelltDurch"
                     type="xbau:Code.ErfuellungAnlegungKinderspielplatz">
            <xs:annotation>
               <xs:documentation>Angabe der Art, wie die Pflicht zur Anlegung des Kinderspielplatzes erfüllt wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="grundstueck" type="xbau:Grundstueck">
            <xs:annotation>
               <xs:documentation>Hier sind die Daten zum Grundstück einzutragen, auf dem der Kinderspielplatz errichtet wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="sicherungDurch" type="xs:token">
