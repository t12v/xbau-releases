               <xs:documentation>Angabe zur Sicherung</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="KostenEinzelnesGebaeude">
      <xs:annotation>
         <xs:documentation>Hier können die aufgegliederten Herstellungskosten des einzelnen Gebäudes eingetragen werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="identifikationGebaeude"
                     type="xbau:IdentifikationGebaeude">
            <xs:annotation>
               <xs:documentation>Hier ist die Identifikation des Gebäudes zwecks der Kostenzuordnung einzutragen. Die Informationen müssen zu den im Datentyp "AnzahlDerGebaeude" gemachten Angaben passen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostengruppe300" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten aus der Kostengruppe 300 einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostengruppe400" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten aus der Kostengruppe 400 einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostengruppe500" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten aus der Kostengruppe 500 einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostengruppe700" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten aus der Kostengruppe 700 einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="bruttoGrundflaecheEinzelnesGebaeude"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Hier ist die ermittelte Grundfläche des Gebäudes einzutragen. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="bruttoRauminhaltEinzelnesGebaeude"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Hier ist der Bruttorauminhalt des Gebäudes einzutragen. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostenProBGF" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten pro Bruttogrundfläche (BGF) einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kostenProBRI" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten pro Bruttorauminhalt (BRI) einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="herstellungskostenGebaeude"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten für das entsprechende einzelne Gebäude einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Lagerbehaelter">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zum Lagerbehälter</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="anzahlDerBehaelter" type="xs:positiveInteger">
