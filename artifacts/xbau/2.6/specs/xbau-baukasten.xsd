      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="nachweisBerechtigung" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Hier wird ein Nachweis zur Berechtigung angegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nachweisbezug" type="xbau:NachweisbezugType">
            <xs:annotation>
               <xs:documentation>Mit diesem Element wird der Bezug zum Datenabruf aus dem Kammerregister hergestellt.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="NachweisbezugType">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp dient dazu, von einem Nachrichtenelement auf einen Datenabruf zu verweisen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="abrufId" type="din91379:datatypeC">
            <xs:annotation>
