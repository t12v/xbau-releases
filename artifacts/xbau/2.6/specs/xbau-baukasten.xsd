            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="bauart" type="xbau:Code.LagerbehaelterBauart">
            <xs:annotation>
               <xs:documentation>Angabe der Bauart.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="baustoff" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe des Baustoffs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="art" type="xbau:Code.LagerbehaelterArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art des Lagerbehälters</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="typ" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe des Typs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="schutzvorkehrungen" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zu Schutzvorkehrungen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="auffangwanne" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe zur Auffangwanne</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="artDerBedachung" type="xbau:Code.BedachungArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art der Bedachung.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="LagerortBrennstoff">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zum Lagerort des Brennstoffs.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element minOccurs="0" name="code" type="xbau:Code.LagerortBrennstoff">
            <xs:annotation>
               <xs:documentation>Angabe des Lagerorts des Brennstoffs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nichtGelisteterWert" type="din91379:datatypeC">
