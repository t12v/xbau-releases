   <xs:complexType name="Nutzflaechen">
      <xs:annotation>
         <xs:documentation>Daten zu Flächen gemäß Wohnflächenverordnung (Verordnung zur Berechnung der Wohnfläche). Bei Baumaßnahmen am Bestand ist ebenfalls nutzflaecheAlt zu übermitteln.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="nutzflaecheNeu" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Hier ist die im Bauvorhaben vorgesehene Nutzfläche einzutragen (Einheit: Quadratmeter).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nutzflaecheAlt" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Bei Änderungen: Hier ist die Nutzfläche vor Umsetzung des Bauvorhabens einzutragen (Einheit: Quadratmeter).</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Nutzungen">
      <xs:annotation>
         <xs:documentation>In diesem Datentyp können beliebig viele unterschiedliche Nutzungseinheiten innerhalb eines Bauvorhabens detailliert beschrieben werden. Dies kann einzeln oder auch gruppenweise zusammengefasst geschehen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="anzahlDerNutzungseinheiten" type="xs:integer">
            <xs:annotation>
               <xs:documentation>In dieses Element ist die Anzahl der Nutzungseinheiten anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="nutzungseinheit"
                     maxOccurs="unbounded"
                     type="xbau:Nutzungseinheit">
            <xs:annotation>
               <xs:documentation>Für jede Nutzungseinheit ist ein Element zu füllen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Nutzungseinheit">
      <xs:annotation>
         <xs:documentation>Dieser Typ nimmt Angaben zu einer Nutzungseinheit auf.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="beschreibungDerNutzungseinheit" type="xs:token">
            <xs:annotation>
               <xs:documentation>Optionale textliche Beschreibung der Nutzungseinheit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="nutzungsflaeche"
                     type="xbau:Code.Nutzungsflaechen">
            <xs:annotation>
               <xs:documentation>Angabe der Nutzungsfläche</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="flaecheDerNutzungseinheit"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe der Fläche der Nutzungseinheit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="wohnungsstatus" type="xbau:Code.Wohnungsstatus">
            <xs:annotation>
               <xs:documentation>Angabe des Wohnungsstatus. Der Codelistenwert "Sozialwohnung (auslaufend)" darf für neu zu beantragende Bauvorhaben nicht mehr genutzt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="uneingeschraenktMitRollstuhlNutzbar"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe, ob eine Nutzungseinheit uneingeschränkt mit dem Rollstuhl nutzbar ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="nutzungseinheitIstBarrierefrei"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe, ob eine Nutzungseinheit barrierefrei ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="ausnahmeVonBarrierefreiheitNach"
                     type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Ausnahme von der Barrierefreiheit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="ausnahmeVonBarrierefreiheitBegruendung"
                     type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Begründung für die Ausnahme von der Barrierefreiheit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="nutzungseinheitIstOeffentlichZugaenglich"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe, ob eine Nutzungseinheit öffentlich zugänglich ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Prozessmerkmale">
      <xs:annotation>
         <xs:documentation>Dieser Typ bündelt Parameter zum Verfahren, die für eine Antragstellung relevant sein können.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="verfahrensart" type="xbau:Code.Verfahrensart">
            <xs:annotation>
               <xs:documentation>Dieses Element kann verwendet werden, um die baurechtliche Verfahrensart anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="absehenNachbarbeteiligungBeantragt"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Wenn bei einer Bauvoranfrage beantragt wird, dass von einer Nachbarbeteiligung abzusehen ist, dann ist hier der Wert true zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nachbarbeteiligungForm">
            <xs:annotation>
               <xs:documentation>Dieses Element kann verwendet werden, um Modalitäten der Nachbarbeteiligung anzugeben.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="oeffentlicheBekanntmachung" type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Falls beantragt wird, das Bauvorhaben öffentlich bekannt zu machen, ist in diesem Element "true" zu übermitteln.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="oeffentlichkeitsbeteiligungVerpflichtend"
                              type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Falls eine Öffentlichkeitsbeteiligung verpflichtend durchzuführen ist, wird in diesem Element "true" übermittelt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="zustellungPositiverBescheidAnNachbarn"
                              type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Falls der Nachbarschaft ein positiver Bescheid zugestellt werden soll, ist in diesem Element "true" zu übermitteln.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="einwilligung">
            <xs:annotation>
               <xs:documentation>Dieses Element kann verwendet werden, um Modalitäten der Einwilligung zur öffentlichen Bekanntmachung anzugeben.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:choice>
                  <xs:element minOccurs="0"
                              name="einwilligungOeffentlicheBekanntmachung"
                              fixed="true"
                              type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Falls allgemein eingewilligt wird, das Bauvorhaben öffentlich bekannt zu machen, ist in diesem Element "true" zu übermitteln.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="einwilligungOeffentlicheBekanntmachungArt"
                              maxOccurs="unbounded"
                              type="xbau:Code.OeffentlicheBekanntmachung">
                     <xs:annotation>
                        <xs:documentation>Falls eingewilligt wird, das Bauvorhaben über konkret definierte Medien öffentlich bekannt zu machen, sind in diesem Element diese Medien zu spezifizieren.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:choice>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0"
                     name="nachtragsbaugenehmigung"
                     type="xbau:BezugHauptbaugenehmigung">
            <xs:annotation>
               <xs:documentation>Falls mit der vorliegenden Nachrichteninstanz ein Nachtrag zu einer bereits erteilten Baugenehmigung beantragt werden soll (Nachtragsbaugenehmigung), sind in dieses Element Angaben einzutragen, die die bereits erteilte Baugenehmigung identifizieren. Durch diese Einträge wird der vorliegende Antrag zur Beantragung einer Nachtragsbaugenehmigung (auch Änderungsantrag genannt).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="vorbescheid" type="xbau:BezugVorbescheid">
            <xs:annotation>
               <xs:documentation>Dieses Element erfasst die Angaben zu einem in der Vergangenheit erteilten Vorbescheid.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="bauberatung" type="xbau:BezugBauberatung">
            <xs:annotation>
               <xs:documentation>Dieses Element erfasst die Angaben zu einer in der Vergangenheit stattgefundenen Bauberatung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="istReferenzgebaeude"
                     fixed="true"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Durch die Übermittlung dieses Elements (enthält, falls vorhanden, den Wert true) wird mitgeteilt, dass der Gegenstand des vorliegenden Antragsverfahrens als Referenzgebäude markiert werden soll, so dass in zukünftigen Anträgen oder Anzeigen Bezug auf diesen genommen werden kann.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="referenzgebaeude">
            <xs:annotation>
               <xs:documentation>Im Rahmen eines referenziellen Baugenehmigungsverfahrens sind in dieses Element Angaben einzutragen, die auf das Referenzgebäude (und den entsprechenden durchgeführten Vorgang) verweisen. Dieses Element muss verwendet werden, wenn das Attribut "verfahrensart" den Code "Referenzielles Baugenehmigungsverfahren" enthält.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="bezugReferenzvorgang" type="xbau:Bezug">
                     <xs:annotation>
                        <xs:documentation>Hier ist im referenziellen Baugenehmigungsverfahren das Aktenzeichen des referenzierten Vorgangs einzutragen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="baugrundstueckReferenzgebaeude"
                              type="xbau:Baugrundstueck">
                     <xs:annotation>
                        <xs:documentation>In diesem Element sind Daten enthalten, die das Baugrundstück des Referenzgebäudes identifizieren. Ein Baugrundstück kann mehrere Grundstücke umfassen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="RaumlufttechnischeAnlagen">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu raumlufttechnischen Anlagen</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="lueftungsanlagenFuerGaragen" type="xs:token">
            <xs:annotation>
               <xs:documentation>Nur Mittel- und Großgaragen relevant</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="sonstigeLueftungsanlagen"
                     type="xbau:Code.Lueftungsanlagen">
            <xs:annotation>
               <xs:documentation>Genehmigungspflichtige Lüftungsanlagen die nicht für Mittel- und Großgaragen bestimmt sind</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kuehlung" type="xbau:Code.Kuehlung">
            <xs:annotation>
               <xs:documentation>Angabe zur Kühlung</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="artderAnlage" type="xbau:Code.RltAnlage">
            <xs:annotation>
               <xs:documentation>Angabe der Art der Anlage.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="ueberbrueckungVonWaendenUndDecken">
            <xs:annotation>
               <xs:documentation>aus NRW</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="bauvorlageLiegtBei" type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Angabe zur Bauvorlage</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="RefAnlage">
      <xs:annotation>
         <xs:documentation>Typ für die Bezugnahme auf Bestandteile eines Antrags oder eines Auftrags. Dieser Typ wird im Kontext einer formellen Prüfung eingesetzt.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="bezeichnung" type="din91379:datatypeD">
            <xs:annotation>
               <xs:documentation>Hier wird die Bezeichnung der referenzierten Bauvorlage angegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="versionsnummer" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier ist die Versionsnummer der referenzierten Bauvorlage einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="ReferenzAuftrag">
      <xs:annotation>
         <xs:documentation>Dieser Typ deckt Daten ab, durch die ein Auftrags- oder Beteiligungsvorgang eindeutig gekennzeichnet wird (Auftrag zur Prüfung bautechnischer Nachweise bzw. Aufforderung zur Stellungnahme in der Beteiligung öffentlicher Stellen).</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="referenzAuftrag" type="bn-g2g:UUID">
            <xs:annotation>
               <xs:documentation>Initial eingetragener i.d.R. maschinell erzeugter Identifier, der für den Auftrags- oder Beteiligungsvorgang steht. Dieser Identifier geht mit den Beauftragungsnachrichten an Auftragnehmer bzw. zu beteiligende Stelle zu und muss von einem solchen Kommunikationspartner in den Reaktionsnachrichten referenziert werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="ReferenzBaulast">
      <xs:annotation>
         <xs:documentation>Dieser Typ deckt Daten ab, durch die ein Vorgang zur Baulasteintragung eindeutig gekennzeichnet wird.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="referenzBaulast" type="bn-g2g:UUID">
            <xs:annotation>
               <xs:documentation>Initial eingetragener i.d.R. maschinell erzeugter Identifier, der für den Vorgang der Baulasterklärung steht. Dieser Identifier geht mit der Nachricht zur Baulasterklärung an die Bauaufsichtsbehörde und muss in den weiteren Nachrichten referenziert werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="SachverhaltAbsichtBeseitigung">
      <xs:annotation>
         <xs:documentation>Hier sind Eckdaten zum Sachverhalt der geplanten Beseitigung anzugeben.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="bezeichnungDesBauvorhabens"
                     type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In dieses Element ist die Bezeichnung des Vorhabens einzutragen. Sie wird vom Bauherrn vergeben und später ggf. von der Bauaufsichtsbehörde geändert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="mboGebaeudeklasse"
                     type="xbau:Code.Gebaeudeklasse">
            <xs:annotation>
               <xs:documentation>In diesem Element wird die Art des Gebäudes übermittelt, das beseitigt werden soll. Es wird die Einteilung in Gebäudeklassen gemäß MBO verwendet.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="artDerBaulichenAnlage"
                     type="xbau:ArtDerBaulichenAnlage">
            <xs:annotation>
               <xs:documentation>Hier kann die Art der baulichen Anlage näher spezifiziert werden. Es ist aus einer der drei Codelisten eine Auswahl zu treffen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="grundstueck"
                     maxOccurs="unbounded"
                     type="xbau:Grundstueck">
            <xs:annotation>
               <xs:documentation>In diesem Element werden die Grundstücke und die Anschriften der Gebäude übermittelt, die beseitigt werden sollen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="istFreistehend" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Falls das betreffende Gebäude freistehend ist, wird hier "true" eingetragen, andernfalls "false".</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="hoeheDerBaulichenAnlage"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Falls die bauliche Anlage eine Höhe von mehr als 10 m hat, ist dieses Element zu übermitteln. Es ist die Höhe in Metern einzutragen (ohne Nachkommastellen).</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="SachverhaltBaubeginn">
      <xs:annotation>
         <xs:documentation>Hier ist genau einer von drei möglichen Sachverhalten anzugeben, die einer Anzeige Baubeginn zu Grunde liegen können (MBO § 72 (6, 8)).</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element minOccurs="0" name="baubeginn">
            <xs:annotation>
               <xs:documentation>Falls die Nachricht dazu dient, den Baubeginn (Ausführung eines genehmigten Bauvorhabens oder einer zuvor angezeigten Beseitigung) anzuzeigen, dann ist dieses Element zu wählen unter Angabe des Datums des geplanten Baubeginns.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="datum" type="xs:date">
                     <xs:annotation>
                        <xs:documentation>Hier ist das Datum einzutragen, zu dem die angegebene Aktivität geplant ist.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="ausfuehrungBauabschnitt">
            <xs:annotation>
               <xs:documentation>Falls die Nachricht die Aufnahme von Bauarbeiten zur Ausführung eines bestimmten Bauabschnitts anzeigen soll, dann ist dieses Element zu wählen. Zusätzlich sind weitere Angaben zu machen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0"
                              name="bezeichnungBauabschnitt"
                              type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier ist die Bezeichnung des Bauabschnitts einzutragen, dessen Arbeiten mittels der Nachricht angezeigt werden soll.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="datum" type="xs:date">
                     <xs:annotation>
                        <xs:documentation>Hier ist das Datum einzutragen, zu dem die angegebene Aktivität geplant ist.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="wiederaufnahmeBauarbeiten">
            <xs:annotation>
               <xs:documentation>Falls die Nachricht die Wiederaufnahme von Bauarbeiten anzeigen soll, dann ist dieses Element zu wählen unter Angabe des Datums der geplanten Wiederaufnahme.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="datum" type="xs:date">
                     <xs:annotation>
                        <xs:documentation>Hier ist das Datum einzutragen, zu dem die angegebene Aktivität geplant ist.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="SachverhaltNutzungsaufnahme">
      <xs:annotation>
         <xs:documentation>Dieser Typ deckt den Sachverhalt der geplanten Nutzungsaufnahme ab..</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="geplanteNutzungsaufnahme">
            <xs:annotation>
               <xs:documentation>Dieses Element dient dazu, den Zeitpunkt der geplanten Nutzungsaufnahme zu nennen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="datum" type="xs:date">
                     <xs:annotation>
                        <xs:documentation>Hier ist das Datum einzutragen, zu dem die angegebene Aktivität geplant ist.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Schornstein">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zum Schornstein</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="bemessung" type="xbau:Code.Bemessung">
            <xs:annotation>
               <xs:documentation>Angaben zur Bemessung</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="wirksameHoehe" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angaben zur wirksamen Höhe</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="hoeheUeberDach" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Attika</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="fuehrung" type="xbau:Code.Fuehrung">
            <xs:annotation>
               <xs:documentation>Angabe zur Führung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="muendung" type="xbau:Code.Muendung">
            <xs:annotation>
               <xs:documentation>Angabe zur Mündung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="bauartUndBaustoffe" type="xs:token">
            <xs:annotation>
               <xs:documentation>Beschreibung der Bauart und der Materialien, z. B. einschalig, mehrschalig.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="reinigungsoeffnungen">
            <xs:annotation>
               <xs:documentation>Angaben zu Reinigungsöffnungen</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="anzahl" type="xs:positiveInteger">
                     <xs:annotation>
                        <xs:documentation>Angabe der Anzahl</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0" name="inFolgendenRaeumen" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe der Räume</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="StellungnahmeBelastenderVerwaltungsakt">
      <xs:annotation>
         <xs:documentation>Dieser Typ nimmt die Parameter einer Stellungnahme auf, mit der sich ein Antragsteller zu einem belastenden Verwaltungsakt äußert.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="bezeichnungRegelverstoss"
                     type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier ist die Bezeichnung des betreffenden Regelverstoßes genannt.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="stellungnahme" type="xbauk:TextFormatiert">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält die Stellungnahme des Antragsstellers. Sie nimmt auf die Beanstandung Bezug.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="StellungnahmeStrukturiert">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Parameter einer strukturierten Stellungnahme, den die beteiligte Behörde für die Zustellung ihrer Stellungnahme verwenden kann.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="tenor">
            <xs:annotation>
               <xs:documentation>Hier wird der Tenor der Stellungnahme formuliert. Handelt es sich um eine Zustimmung, kann diese mit oder ohne Nebenbestimmung zugestellt werden. Falls eine Abweichungsentscheidung in diesem Fall vorliegt, kann diese positiv oder negativ ausfallen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="istZustimmung" type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Falls die Stellungnahme positiv ausgefallen ist (Zustimmung), so wird in diesem Element "true" übermittelt, andernfalls "false".</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0" name="rechtsbereich" type="xbau:Code.Rechtsbereich">
            <xs:annotation>
               <xs:documentation>Dieses Element nennt den Rechtsbereich, innerhalb dessen die Stellungnahme zugestellt wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="abweichung"
                     maxOccurs="unbounded"
                     type="xbau:AbweichungBearbeitet">
            <xs:annotation>
               <xs:documentation>Hier werden ggf. die Erläuterungen zur Stellungnahme geliefert, die eine beantragte Abweichung betreffen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="nebenbestimmung"
                     maxOccurs="unbounded"
                     type="xbau:Nebenbestimmung">
            <xs:annotation>
               <xs:documentation>Hier werden ggf. Nebenbestimmungen zur Stellungnahme eingefügt.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="begruendung" type="xbauk:TextFormatiert">
            <xs:annotation>
               <xs:documentation>Falls die Stellungnahme nicht zustimmend ausgefallen ist, wird in diesem Element die entsprechende Begründung geliefert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="anlagen" type="xbau:Anlagen">
            <xs:annotation>
               <xs:documentation>Die für das Verständnis der Stellungnahme notwendigen Bauvorlagen werden in diesem Objekt eingefügt.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="TechnischeGebaeudeausruestung">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zur technischen Gebäudeausrüstung</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="feuerungsanlagen"
                     maxOccurs="unbounded"
                     type="xbau:Feuerungsanlagen">
            <xs:annotation>
               <xs:documentation>Angaben zu Feuerstätten</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="raumlufttechnischeAnlagen"
                     maxOccurs="unbounded"
                     type="xbau:RaumlufttechnischeAnlagen">
            <xs:annotation>
               <xs:documentation>In Krankenhäusern findet man in der Regel mehrere Lüftungsanlagen. [§ 41 MBO] [MLüAR] [MPrüfVO]</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="aufzuege"
                     maxOccurs="unbounded"
                     type="xbau:Aufzuege">
            <xs:annotation>
               <xs:documentation>Angaben zu Aufzügen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="brennstofflager"
                     maxOccurs="unbounded"
                     type="xbau:Brennstofflager">
            <xs:annotation>
               <xs:documentation>Angaben zu Brennstofflagern</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="weitereTGAAnlagen"
                     maxOccurs="unbounded"
                     type="xbau:WeitereTGAAnlagen">
            <xs:annotation>
               <xs:documentation>Angaben zu weiteren TGA-Anlagen</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="UnterlagenAntragVollstaendig">
      <xs:annotation>
         <xs:documentation>Falls im Rahmen der formellen Prüfung alle Merkmale positiv bewertet wurden (Zuständigkeit ist gegeben, Unterlagen liegen vollständig vor usw.), sind die Angaben zur Genehmigungsfrist und zu den eingereichten Unterlagen hier zu machen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="eingereichteBauvorlagen"
                     maxOccurs="unbounded"
                     type="xbau:EingereichteBauvorlagen">
            <xs:annotation>
               <xs:documentation>Hier können Angaben zu den eingereichten Bauvorlagen gemacht werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="genehmigungsdatum"
                     type="xbau:Genehmigungsdatum">
            <xs:annotation>
               <xs:documentation>Hier können Angaben zum voraussichtlichen Genehmigungsdatum (optional) und spätesten Genehmigungsdatum (obligatorisch) des Antrags gemacht werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="VerfahrenNachAnderenRechtsvorschriften">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu Verfahren nach anderen Rechtsvorschriften.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="artDesVerfahrens"
                     type="xbau:Code.Verfahrensart">
            <xs:annotation>
               <xs:documentation>Angabe der Verfahrensart</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="gegenstand" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe des Gegenstands</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="antragsdatum" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe des Antragsdatums</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="verfahrenNachweisdaten"
                     type="xbauk:Nachweisdaten">
            <xs:annotation>
               <xs:documentation>Angabe der zugrundeliegenden Nachweisdaten</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="VorbescheidBeantragt">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Parameter einer Frage, die im Rahmen eines Vorbescheidantrags thematisiert wird. Insoweit diese Frage einen Abweichungsantrag bzw. eine beantragte Erleichterung betrifft, sind in einer Instanz des Typs Daten enthalten, die den entsprechenden Kontext verdeutlichen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="artDerFrage"
                     type="xbau:Code.VorbescheidBetreff">
            <xs:annotation>
               <xs:documentation>Falls dieses Element verwendet wird, ist einzutragen, in welche Kategorie die im Rahmen des Vorbescheidantrags thematisierte Fragestellung einzuordnen ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="vorbescheidfrage" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Beschreibung der Fragestellung(en) im Rahmen eines Vorbescheids</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="beantragteAbweichung"
                     maxOccurs="unbounded"
                     type="xbau:AbweichungBeantragt">
            <xs:annotation>
               <xs:documentation>Hier sind die Daten zu einer möglichen Abweichung eingefügt, falls die Vorbescheidfrage eine solche betrifft.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="angefragteErleichterung"
                     maxOccurs="unbounded"
                     type="xbau:ErleichterungAngefragt">
            <xs:annotation>
               <xs:documentation>Hier sind die Daten zu einer möglichen Erleichterung eingefügt, falls die Vorbescheidfrage eine solche betrifft.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="WeitereBeteiligte">
      <xs:annotation>
         <xs:documentation>Dieser Abschnitt fasst Daten zu weiteren Beteiligten zusammen. Pro Beteiligter ist ein Element zu instanziieren. Hat ein weiterer Beteiligter die Rolle "Fachplaner", "Prüfsachverständiger" oder "Verantwortlicher", dann sollten im Datentyp die Elemente "Berechtigung", "mitgliedschaftInland" und "Berufsbezeichnung" befüllt werden. Falls die Person nicht im Inland niedergelassen ist, sollte „Ausland“ befüllt werden. Hat ein weiterer Beteiligter die Rolle "Prüfingenieur" oder "Prüfsachverständiger", dann sollten im Datentyp die Elemente "Berechtigung" und "Berufsbezeichnung" befüllt werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="beteiligter" type="xbauk:Akteur">
            <xs:annotation>
               <xs:documentation>Hier sind die Personendaten des Beteiligten anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="rolle" type="xbau:BeteiligterRolle">
            <xs:annotation>
               <xs:documentation>Hier ist die Rolle des Beteiligten anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="fachrichtung"
                     type="xbau:BeteiligterFachrichtung">
            <xs:annotation>
               <xs:documentation>Hier ist die Fachrichtung des Beteiligten anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="berechtigung" type="xbau:Berechtigung">
            <xs:annotation>
               <xs:documentation>Hier sind die Daten einzutragen, die die Berechtigung dieser am Bau beteiligten Person belegen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="WeitereTGAAnlagen">
      <xs:annotation>
         <xs:documentation>Hier können weitere Anlagen der Technischen Gebäudeausrüstung beschrieben werden, für die kein eigener Datentyp (wie z. B. Feuerungsanlagen, Raumlufttechnische Anlagen) definiert wurde.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="art" type="xbau:Code.TGAAnlageArt">
            <xs:annotation>
               <xs:documentation>Auswahlliste der möglichen Arten von technischen Anlagen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="text" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Textliche Beschreibung der wesentlichen Merkmale der Anlage.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="WerbeanlageArt">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zur Art von Werbeanlagen.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element minOccurs="0" name="code" type="xbau:Code.WerbeanlageArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art der Werbeanlage.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="nichtGelisteterWert" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Freitextangabe für die Art der Werbeanlage.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="Werbeanlagen">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu Werbeanlagen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="vorhabenAnDerStaetteDerLeistung"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe zum Vorhaben an der Stätte der Leistung</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="artDerWerbeanlage" type="xbau:WerbeanlageArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art der Werbeanlage.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="ausladungDerWerbeanlage" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe zur Ausladung der Werbeanlage</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="abstandVonDerFahrbahnkante" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe zum Abstand von der Fahrbahnkante</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="lichteDurchgangshoehe" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe zur lichten Durchgangshöhe</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="verwendeteWerkstoffe" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe zu verwendeten Werkstoffen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="beleuchtung" type="xbau:Code.Beleuchtung">
            <xs:annotation>
               <xs:documentation>Angabe zur Beleuchtung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="anzahlBeleuchteterFlaechen" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Anzahl beleuchteter Flächen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="herstellungskosten" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Hier sind die Herstellungskosten der Werbeanlage einzutragen (Einheit: Eurocent).</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Wohnungsprofil">
      <xs:annotation>
         <xs:documentation>In diesem Datentyp lässt sich abbilden, wie viele Wohnungen mit 1, 2, 3 oder mehr Wohnungen es in dem Bauvorhaben gibt. Diese Angaben werden von der Statistik in verschiedenen Kontexten angefragt.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="anzahlWohnungen" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Angabe der Anzahl der Wohnungen in dieser Wohnungskategorie.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="kategorie" type="xbau:Code.RaeumeAnzahl">
            <xs:annotation>
               <xs:documentation>Das Gruppierungsmerkmal: Angabe der Anzahl der Räume in diesen Wohnungen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="anzahlRaeumebeiWohnungenMitSiebenOderMehrRaeumen"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Wenn eine Wohnung sieben oder mehr als sieben Räume hat, ist hier die konkrete Anzahl der Räume anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="wohnungsstatus" type="xbau:Code.Wohnungsstatus">
            <xs:annotation>
               <xs:documentation>Angabe des Wohnungsstatus. Der Codelistenwert "Sozialwohnung (auslaufend)" darf für neu zu beantragende Bauvorhaben nicht mehr genutzt werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="XBau.Flaechen">
      <xs:annotation>
         <xs:documentation>Dieser Typ fasst Angaben zu den Grundstücksflächen des Vorhabens zusammen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0" name="spielplatzFlaeche" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Spielplatzfläche nach § 8 Abs. 2 MBO. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="freizeitFlaeche" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Freizeitfläche. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="stellplaetzeUndDerenZufahrten">
            <xs:annotation>
               <xs:documentation>Angaben zu Stellplätzen und deren Zufahrten nach § 19 Abs. 4 Ziffer 1 BauNVO</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element minOccurs="0" name="flaecheZufahrt" type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Größe der Flächen von Zufahrten. Angabe: Anzahl Quadratmeter</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="flaecheKFZStellplaetze"
                              type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Größe aller Stellplatzflächen. Angabe: Anzahl Quadratmeter</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element minOccurs="0"
                              name="flaecheFahrradStellplaetze"
                              type="xbauk:Dezimal.XBau">
                     <xs:annotation>
                        <xs:documentation>Größe aller Stellplatzflächen. Angabe: Anzahl Quadratmeter</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element minOccurs="0"
                     name="flaecheDerNebenanlagen"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Nebenanlagen im Sinne des § 14 BauNVO und § 19 Abs. 4 Ziffer 2 BauNVO. Angabe: Anzahl Quadratmeter.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="versiegelteFlaeche" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Versiegelte Fläche. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0" name="verkaufsflaeche" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Verkaufsfläche. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="ZweckDerNutzungsaenderung">
      <xs:annotation>
         <xs:documentation>Wenn das Bauvorhaben eine Nutzungsänderung der baulichen Anlage beabsichtigt, ist in diesem Feld die bisherige und die beabsichtigte Nutzung der baulichen Anlage anzugeben. Es ist jeweils aus einer der drei Codelisten eine Auswahl zu treffen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element minOccurs="0"
                     name="bisherigeNutzung"
                     type="xbau:ArtDerBaulichenAnlage">
            <xs:annotation>
               <xs:documentation>Um den Zweck der Nutzungsänderung näher zu spezifizieren, ist hier die bisherige Nutzung des Gegenstandes vom Bauvorhaben anzugeben. Es ist aus einer der drei Codelisten eine Auswahl zu treffen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element minOccurs="0"
                     name="beabsichtigteNutzung"
                     type="xbau:ArtDerBaulichenAnlage">
            <xs:annotation>
               <xs:documentation>Um den Zweck der Nutzungsänderung näher zu spezifizieren, ist hier die beabsichtigte Nutzung des Gegenstandes vom Bauvorhaben anzugegeben. Es ist aus einer der drei Codelisten eine Auswahl zu treffen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
</xs:schema>
