<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:xbau="http://www.xleitstelle.de/xbau/2/6"
           xmlns:bn-g2g="http://xoev.de/schemata/basisnachricht/g2g/1_1"
           xmlns:bn-uq-g2g="http://xoev.de/schemata/basisnachricht/unqualified/g2g/1_1"
           xmlns:din91379="urn:xoev-de:kosit:xoev:datentyp:din-91379_2022-08"
           xmlns:xbauk="http://www.xleitstelle.de/xbau/kernmodul/1/3/0"
           xmlns:xoev-lc="http://xoev.de/latinchars/1_1/datatypes"
           targetNamespace="http://www.xleitstelle.de/xbau/2/6"
           version="2.6"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified">
   <xs:annotation>
      <xs:appinfo>
         <standard>
            <nameLang>XBau - Standard für die Datenkommunikation der Bauaufsichtsbehörde</nameLang>
            <nameKurz>XBau</nameKurz>
            <nameTechnisch>xbau</nameTechnisch>
            <kennung>urn:xoev-de:bmk:standard:xbau</kennung>
            <beschreibung>XBau ist der XÖV-Standard für den Datenaustausch der Bauaufsichtsbehörden mit ihren Kommunikationspartnern (Bauherren, Architektenbüros, Behörden zahlreicher Rechtsbereiche). </beschreibung>
         </standard>
         <versionStandard>
            <version>2.6</version>
            <beschreibung>Die Nachrichtenkommunikation im Beteiligungsverfahren wurde erweitert und flexibilisiert. Das Baulastverfahren wurde erweitert um eine Vielzahl von Details, u.a. wurden Nachrichtentypen zur Eintragung und zur Löschung von Baulasten definiert. Die Anzeigeprozesse zum Bauzustand wurden weiterentwickelt zu einer stringent geregelten Nachrichtenkommunikation auf Basis der 900er-Nachrichten. Es wurde die Benachrichtigung über einen Bescheidabruf eingeführt, auch ist in XBau jetzt ein Mechanismus für die generische Zustellquittierung enthalten. Es wurden für die Datenübermittlung an die statistischen Ämter XML-Geschäftsregeln zur technischen Überprüfung auf Basis der Technologie ISO-Schematron bereitgestellt. Die Prozesse der Statistikmeldungen wurden auf genehmigungsfreigestellte Verfahren ausgedehnt. Für den Prozess Nachweis Bauvorlageberechtigung können jetzt aus dem Kammerregister abgerufene Daten als solche gekennzeichnet und in ihrer Anwendung in der Antragstellung nachvollzogen werden. Der Prozess zur Abgeschlossenheitsbescheinigung wurde vervollständigt und ausdifferenziert. Die weiteren Details zu Erweiterungen und Änderungen sind in der Versionshistorie des Spezifikationsdokuments beschrieben.</beschreibung>
            <versionXOEVProfil>3.0.0</versionXOEVProfil>
            <versionXOEVHandbuch>3.0.1</versionXOEVHandbuch>
            <versionXGenerator>3.1.1</versionXGenerator>
            <versionModellierungswerkzeug>19.0</versionModellierungswerkzeug>
            <nameModellierungswerkzeug>MagicDraw</nameModellierungswerkzeug>
         </versionStandard>
      </xs:appinfo>
   </xs:annotation>
   <xs:include schemaLocation="xbau-codes.xsd"/>
   <xs:import schemaLocation="http://xoev.de/latinchars/1_1/datatypes/latinchars.xsd"
              namespace="http://xoev.de/latinchars/1_1/datatypes"/>
   <xs:import schemaLocation="http://xoev.de/schemata/basisnachricht/g2g/1_1/xoev-basisnachricht-g2g_1.1.xsd"
              namespace="http://xoev.de/schemata/basisnachricht/g2g/1_1"/>
   <xs:import schemaLocation="http://xoev.de/schemata/basisnachricht/unqualified/g2g/1_1/xoev-basisnachricht-unqualified-g2g_1.1.xsd"
              namespace="http://xoev.de/schemata/basisnachricht/unqualified/g2g/1_1"/>
   <xs:import schemaLocation="https://xleitstelle.de/xbau/schema/kernmodul/1/3/0/xbau-kernmodul-prozessnachrichten.xsd"
              namespace="http://www.xleitstelle.de/xbau/kernmodul/1/3/0"/>
   <xs:import schemaLocation="https://xleitstelle.de/xbau/schema/kernmodul/1/3/0/xbau-kernmodul-universellerAntrag.xsd"
              namespace="http://www.xleitstelle.de/xbau/kernmodul/1/3/0"/>
   <xs:import schemaLocation="https://xoev.de/schemata/din/91379/2022-08/din-norm-91379-datatypes.xsd"
              namespace="urn:xoev-de:kosit:xoev:datentyp:din-91379_2022-08"/>
   <xs:complexType name="Abgasanlagen">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zu Abgasanlagen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="schornstein" minOccurs="0" type="xbau:Schornstein">
            <xs:annotation>
               <xs:documentation>Angaben zum Schornstein</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="lichterQuerschnitt" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Angaben zum lichten Querschnitt</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="rechteckig" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>(cm * cm)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="rund" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>(cm)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="flaeche" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>(cm2)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="verbindungsstuecke" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Angaben zu Verbindungsstücken</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="artDesVerbindungsstuecks"
                              minOccurs="0"
                              type="xbau:Code.VerbindungsstueckArt">
                     <xs:annotation>
                        <xs:documentation>Angabe der Art des Verbindungsstücks.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="baustoff" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe des Baustoffs</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="dicke" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe der Dicke</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="laenge" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe der Länge</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="anzahlRichtungsaenderungen" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe der Anzahl der Richtungsänderungen</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="andereAbgasanlagen" minOccurs="0">
            <xs:annotation>
               <xs:documentation>(Rheinland Pfalz)</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="lfdNr" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe der laufenden Nummer</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="art" minOccurs="0" type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Genaue Bezeichnung der Art einer Abgasanlage, bei der es sich nicht um einen Schornstein handelt. Diese Abgasanlagen sind in der DIN 18160-1 "Abgasanlagen" gelistet.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="fabrikat" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe des Fabrikats</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AbgrabungenUndAufschuettungen">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Parameter zu Abgrabungen und Aufschüttungen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="flaeche" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe der Fläche.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="volumen" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe des Volumens.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nichtRekultivierteFlaeche"
                     minOccurs="0"
                     type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe der nicht rekultivierten Fläche.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AbweichungBeantragt">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Parameter einer Abweichung von öffentlich-rechtlichen Bestimmungen, die der Bauaufsichtsbehörde zur Zulassung vorgelegt wird.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="id" type="bn-g2g:UUID">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält den „Universally Unique IDentifier (UUID)“ der Abweichung. Der UUID wird entsprechend rfc4122 gebildet und ermöglicht die Abweichung eindeutig zu identifizieren.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="art" type="xbau:Code.AbweichungArt">
            <xs:annotation>
               <xs:documentation>Hier ist die beantragte Abweichungsart gemäß Codeliste einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="vorschrift" minOccurs="0" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>In diesem Element ist die Vorschrift der materiellen Anforderung zu bezeichnen: Es sind Referenzen auf die Rechtsnormen einzutragen, auf die sich die bearbeitete Abweichung bezieht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beschreibung" minOccurs="0" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>In diesem Objekt ist der Abweichungsgegenstand im Detail zu erläutern. Alternativ kann hier auf eine oder mehrere Bauvorlagen verwiesen werden, in denen die detaillierte Spezifikation des Abweichungsgegenstands enthalten ist. Diese Bauvorlagen müssen der vorliegenden Nachrichteninstanz als Anlagen beigefügt und gekennzeichnet sein als Bauvorlagen von der Art, die zur Erläuterung oder Begründung von Abweichungen vorgesehen sind.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="begruendung" minOccurs="0" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>In diesem Element ist zur beantragten Abweichung eine Erläuterung zu geben, warum die beantragte Zulassung aus Sicht des Antragstellers gerechtfertigt ist. Alternativ kann hier auf eine Bauvorlage verwiesen werden, in der die detaillierte Legitimation der beantragten Abweichung enthalten ist. Diese Bauvorlage muss der vorliegenden Nachrichteninstanz als Anlagen beigefügt und gekennzeichnet sein als Bauvorlage von der Art, die zur Erläuterung oder Begründung von Abweichungen vorgesehen sind.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AbweichungBearbeitet">
      <xs:annotation>
         <xs:documentation>Falls die Abweichung eines Bauvorhabens von öffentlich-rechtlichen Bestimmungen bearbeitet (und damit zugelassen bzw. nicht zugelassen) wurde, dient dieser Typ im entsprechenden Kontext zur Übermittlung der relevanten Parameter.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="id" type="bn-g2g:UUID">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält den „Universally Unique IDentifier (UUID)“ der Abweichung. Der UUID wird entsprechend rfc4122 gebildet und ermöglicht die Abweichung eindeutig zu identifizieren.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="istZugelassen" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Falls die beantragte Abweichung zugelassen wurde, ist hier 'true' einzutragen, andernfalls 'false'.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="art" type="xbau:Code.AbweichungArt">
            <xs:annotation>
               <xs:documentation>Hier ist einzutragen, als welche Art von Abweichung die beantragte Abweichung einzustufen ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="vorschrift" type="xbauk:TextFormatiert">
            <xs:annotation>
               <xs:documentation>Vorschrift der materiellen Anforderung: Hier sind Referenzen auf die Rechtsnormen einzutragen, auf die sich die bearbeitete Abweichung bezieht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="begruendung" minOccurs="0" type="xbauk:TextFormatiert">
            <xs:annotation>
               <xs:documentation>In diesem Element wird begründet, warum die Abweichung zugelassen bzw. nicht zugelassen wurde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nebenbestimmung" minOccurs="0" type="xbauk:TextFormatiert">
            <xs:annotation>
               <xs:documentation>Hier werden für den Fall der Zulassung der beantragten Abweichungen ggf. Nebenbestimmungen formuliert, deren Einhaltung die Bauaufsichtsbehörde zur Bedingung für die Zulassung gemacht hat.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AeussereGestaltung">
      <xs:annotation>
         <xs:documentation>Hier können Angaben zur Gestaltung nicht nur des Gebäudes, sondern auch des Grundstücks und der Nebenanlagen gemacht werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="gebaeude" minOccurs="0" type="xbau:Gebaeude">
            <xs:annotation>
               <xs:documentation>[§ 9 MBO] [OZG]</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="spielplatzGestaltung" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>[§ 8 Abs. 2 MBO] Gestaltung und Ausstattung Zielgruppe (klein, mittel, groß)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="freiflaechenGestaltung" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>[OZG][§ 8 Abs. 1 MBO] Gestaltung und Bepflanzung der nicht überbauten Flächen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="stellplatzGestaltung" minOccurs="0">
            <xs:annotation>
               <xs:documentation>[OZG][§ 86 MBO] Befestigung, Gestaltung und Eingrünung</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="derZufahrten" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angaben zu Zufahrten</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="derStellplaetzeimFreien" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angaben zu Stellplätzen im Freien</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Anlagen">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient dazu, die Metadaten zu Dokumenten aufzunehmen, die einer XBau-Kommunikation (z.B. Antragstellung) als Anlagen beigefügt sind. Als Anlagen sind in erster Linie Bauvorlagen zu nennen, in vielen Fällen zusätzlich weitere Anlagen (wie Nachweise und ergänzende Dokumentationen).</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="anlage"
                     maxOccurs="unbounded"
                     type="xbau:MetadatenAnlageErweitert"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Jede Instanz dieses Elements steht für eine Anlage (Bauvorlage, Primärdokument) zum vorliegenden Antrag bzw. zur übermittelten XBau-Fachnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AnliegenBeteiligung">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Parameter eines Beteiligungsanliegens der Bauaufsichtsbehörde gegenüber einem Träger öffentlicher Belange.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="rolle" type="xbau:Code.BeteiligungRolle">
            <xs:annotation>
               <xs:documentation>Aus diesem Element geht die Rolle des Adressaten im Beteiligungsverfahren hervor.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="rechtsbereich" type="xbau:Code.Rechtsbereich">
            <xs:annotation>
               <xs:documentation>Dieses Element nennt den Rechtsbereich, innerhalb dessen Anlass und angeforderte Stellungnahme liegen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="grundDerBeteiligung" type="xbauk:TextFormatiert">
            <xs:annotation>
               <xs:documentation>Hier wird der Grund bzw. das Anliegen der Beteiligung mit Bezug auf die entsprechenden Eigenschaften des Bauvorhabens im Detail formuliert.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AnschriftGrundstueck">
      <xs:annotation>
         <xs:documentation>In diesem Typ sind die Angaben zusammengefasst, die für die Anschrift eines Grundstücks hinreichend sind.</xs:documentation>
      </xs:annotation>
      <xs:complexContent>
         <xs:restriction base="xbauk:Anschrift">
            <xs:sequence>
               <xs:element name="strasse"
                           minOccurs="0"
                           type="din91379:datatypeC"
                           form="unqualified">
                  <xs:annotation>
                     <xs:documentation>In dieses Element wird die Bezeichnung der Straße eingetragen, in der das Baugrundstück liegt. Es ist nach Möglichkeit der amtliche Straßenname aus einem offiziellen Straßenverzeichnis zu nutzen.</xs:documentation>
                  </xs:annotation>
               </xs:element>
               <xs:element name="hausnummer"
                           minOccurs="0"
                           type="din91379:datatypeC"
                           form="unqualified">
                  <xs:annotation>
                     <xs:documentation>Eine Hausnummer dient der genauen Lokalisierung eines Grundstücks, Gebäudes oder Gebäudeteils (Eingang) in einer Straße. Es ist je nach Sachlage eine Zahl einzutragen ("39") oder eine Zahl in Kombination mit einem Buchstaben ("39b").</xs:documentation>
                  </xs:annotation>
               </xs:element>
               <xs:element name="strasseHausnummer"
                           minOccurs="0"
                           type="din91379:datatypeC"
                           form="unqualified">
                  <xs:annotation>
                     <xs:documentation>Element für die Erfassung von Straße und Hausnummer des Grundstücks als undifferenzierte Zeichenkette (nur für bestimmte Kontexte: ersetzt dann die Verwendung der Elemente strasse und hausnummer). Falls sich in einem Kontext der Übernahme von Anschriftsdaten die Bezeichnung der Straße und die Hausnummer nicht maschinell zuverlässig trennen lassen, können diese Informationen in das Element als eine gemeinsame Zeichenkette übernommen werden.</xs:documentation>
                  </xs:annotation>
               </xs:element>
               <xs:element name="postleitzahl"
                           minOccurs="0"
                           type="din91379:datatypeC"
                           form="unqualified">
                  <xs:annotation>
                     <xs:documentation>Angabe der Postleitzahl des Baugrundstücks.</xs:documentation>
                  </xs:annotation>
               </xs:element>
               <xs:element name="ort"
                           minOccurs="0"
                           type="din91379:datatypeC"
                           form="unqualified">
                  <xs:annotation>
                     <xs:documentation>Angabe der Ortsbezeichnung zum Baugrundstück.</xs:documentation>
                  </xs:annotation>
               </xs:element>
               <xs:element name="ortsteil"
                           minOccurs="0"
                           type="din91379:datatypeC"
                           form="unqualified">
                  <xs:annotation>
                     <xs:documentation>Der Ortsteil umfasst ein Teilgebiet des Ortes (der Gemeinde) und dient der Untergliederung.</xs:documentation>
                  </xs:annotation>
               </xs:element>
               <xs:element name="zusatz"
                           minOccurs="0"
                           type="din91379:datatypeC"
                           form="unqualified">
                  <xs:annotation>
                     <xs:documentation>Ein Anschriftenzusatz beinhaltet ggf. erforderliche weitere Präzisierungen zu der Anschrift. Beispiele: Hinterhof, 3. Aufgang, Haus A, 3. Stock, Appartement 25a, 3. Stock - Appartement 25 a, #325a, Raum 77</xs:documentation>
                  </xs:annotation>
               </xs:element>
            </xs:sequence>
         </xs:restriction>
      </xs:complexContent>
   </xs:complexType>
   <xs:complexType name="AnschriftGrundstueckErweitert">
      <xs:annotation>
         <xs:documentation>Dieser Typ erweitert den Datentyp AnschriftGrundstueck um ergänzende Angaben wie Hausnummernbereich und AGS.</xs:documentation>
      </xs:annotation>
      <xs:complexContent>
         <xs:extension base="xbau:AnschriftGrundstueck">
            <xs:sequence>
               <xs:element name="gemeindeschluessel"
                           minOccurs="0"
                           type="xbauk:Code.AmtlicherGemeindeschluessel">
                  <xs:annotation>
                     <xs:appinfo>
                        <implementationHint>Solange die Aktualität der verwendeten Schlüsseltabelle nicht gegeben ist, wird vollständig auf die Plausibilisierung der listVersionID verzichtet.</implementationHint>
                     </xs:appinfo>
                     <xs:documentation>In diesem Element kann der vom Statistischen Bundesamt herausgegebene bundeseinheitliche Gemeindeschlüssel der Gemeinde angegeben werden, in der das Grundstück liegt.</xs:documentation>
                  </xs:annotation>
               </xs:element>
               <xs:element name="hausnummernbereich" minOccurs="0">
                  <xs:annotation>
                     <xs:documentation>Dieses Element umfasst einen Hausnummernbereich.</xs:documentation>
                  </xs:annotation>
                  <xs:complexType>
                     <xs:sequence>
                        <xs:element name="hausnummerVon" type="xs:positiveInteger">
                           <xs:annotation>
                              <xs:documentation>Hier ist der Anfang des Hausnummernbereichs anzugeben.</xs:documentation>
                           </xs:annotation>
                        </xs:element>
                        <xs:element name="hausnummerVonZusatz" minOccurs="0" type="din91379:datatypeC">
                           <xs:annotation>
                              <xs:documentation>Hier kann ein Zusatz zum Anfang des Hausnummernbereichs angegeben werden.</xs:documentation>
                           </xs:annotation>
                        </xs:element>
                        <xs:element name="hausnummerBis" type="xs:positiveInteger">
                           <xs:annotation>
                              <xs:documentation>Hier ist das Ende des Hausnummernbereichs anzugeben.</xs:documentation>
                           </xs:annotation>
                        </xs:element>
                        <xs:element name="hausnummerBisZusatz" minOccurs="0" type="din91379:datatypeC">
                           <xs:annotation>
                              <xs:documentation>Hier kann ein Zusatz zum Ende des Hausnummernbereichs angegeben werden.</xs:documentation>
                           </xs:annotation>
                        </xs:element>
                     </xs:sequence>
                  </xs:complexType>
               </xs:element>
            </xs:sequence>
         </xs:extension>
      </xs:complexContent>
   </xs:complexType>
   <xs:complexType name="AnsprechpartnerBauamt">
      <xs:annotation>
         <xs:documentation>Dieser Typ deckt Namen und Erreichbarkeit des Ansprechpartners im Bauamt für Rückfragen ab. Der Inhalt der Kindelemente wird in der Behörde gepflegt.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="nameNatuerlichePerson" type="xbauk:NameNatuerlichePerson">
            <xs:annotation>
               <xs:documentation>In dieses Element sind die Angaben zu den Namen der Person einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="kommunikation"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbauk:Kommunikation">
            <xs:annotation>
               <xs:documentation>In dieses Objekt sind Angaben einzutragen, die benötigt werden, um mit der Person zu kommunizieren (z. B. per Brief oder per Telefon).</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AnzahlDerGebaeude">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp enthält die Anzahl der Gebäude des Bauvorhabens und Informationen zur Identifikation der einzelnen Gebäude. Die Angabe, die im Element "anzahlDerGebaeudeImBauvorhaben" gemacht wurde, bedingt wie oft der Datentyp "identifikationGebaeude" befüllt werden muss. Beispiel: Bei einer Baugenehmigung für ein Reihenhaus bestehend aus 3 Wohneinheiten (= Gebäuden) wird der Datentyp "identifikationGebaeude" dreimal befüllt.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="anzahlDerGebaeudeImBauvorhaben" type="xs:nonNegativeInteger">
            <xs:annotation>
               <xs:documentation>In diesem Element wird die Anzahl der Gebäude im Bauvorhaben angegeben. Falls der Vorgang keine Gebäude, sondern lediglich bauliche Anlagen wie Aufschüttungen, Abgrabungen, Werbeanlagen, Stell- und Lagerplätze betrifft, ist der Wert 0 einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="identifikationGebaeude"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:IdentifikationGebaeude">
            <xs:annotation>
               <xs:documentation>Dieser Datentyp enthält Angaben zur Identifikation des Gebäudes im Bauvorhaben. Beispiel: Bei einer Baugenehmigung für ein Reihenhaus bestehend aus 3 Wohneinheiten (= Gebäuden) wird dieser Datentyp dreimal befüllt. Zu UUID1 gehört "Reihenendhaus Ost", zu UUID2 gehört "Mittelhaus" und zu UUID3 gehört "Reihenendhaus West". Bei einer Baugenehmigung für bauliche Anlagen wie Aufschüttungen, Abgrabungen, Werbeanlagen, Stell- und Lagerplätze wird dieser Datentyp nicht befüllt.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AnzahlDerWohnungen">
      <xs:annotation>
         <xs:documentation>In diesem Datentyp können Angaben zur Anzahl der Wohnungen gemacht werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="gesamtanzahlWohnungen"
                     minOccurs="0"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält die Gesamtanzahl der Wohnungen im Gebäude.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="gesamtanzahlWohnungenAlt"
                     minOccurs="0"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Bei Baumaßnahmen am Bestand muss die Gesamtanzahl der Wohnungen im Gebäude vor der Baumaßnahme angegeben werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anzahlDerWohnungenNeu"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:Wohnungsprofil">
            <xs:annotation>
               <xs:documentation>Bei Baumaßnahmen (Ausnahme: Bauabgang) muss die Anzahl der Wohnungen nach der Anzahl der Räume innerhalb des Gebäudes angegeben werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anzahlDerWohnungenAlt"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:Wohnungsprofil">
            <xs:annotation>
               <xs:documentation>Bei Baumaßnahmen am Bestand muss die Anzahl der Wohnungen vor der Baumaßnahme nach der Anzahl der Räume innerhalb des Gebäudes angegeben werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anzahlWohnungenBarrierefreiAlt"
                     minOccurs="0"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Bei Baumaßnahmen am Bestand muss die Anzahl der barrierefreien Wohnungen vor der Baumaßnahme angegeben werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="AnzahlDerWohnungenErweitert">
      <xs:annotation>
         <xs:documentation>Dieser Typ erweitert den Datentyp AnzahlDerWohnungen um ergänzende Angaben wie Anzahl der barrierefreien Wohnungen.</xs:documentation>
      </xs:annotation>
      <xs:complexContent>
         <xs:extension base="xbau:AnzahlDerWohnungen">
            <xs:sequence>
               <xs:element name="anzahlWohnungenBarrierefrei"
                           minOccurs="0"
                           type="xs:positiveInteger">
                  <xs:annotation>
                     <xs:documentation>Dieses Element enthält die Anzahl der barrierefreien Wohnungen.</xs:documentation>
                  </xs:annotation>
               </xs:element>
            </xs:sequence>
         </xs:extension>
      </xs:complexContent>
   </xs:complexType>
   <xs:complexType name="AnzahlFahrzeugstellplaetze">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu Fahrzeugstellplätzen nach §§ 49 und 50 MBO.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="kraftfahrzeuge"
                     minOccurs="0"
                     type="xbau:Fahrzeugstellplaetze">
            <xs:annotation>
               <xs:documentation>Angaben zu Fahrzeugstellplätzen für Kraftfahrzeuge</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="fahrraeder" minOccurs="0" type="xbau:Fahrzeugstellplaetze">
            <xs:annotation>
               <xs:documentation>Angabe zu Fahrzeugstellplätzen für Fahrräder</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="ArtDerBaulichenAnlage">
      <xs:annotation>
         <xs:documentation>Für den Gegenstand des Bauvorhabens kann hier die Art der baulichen Anlage näher spezifiziert werden. Es ist aus einer der drei Codelisten eine Auswahl zu treffen.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element name="artDesWohngebaeudes" type="xbau:Code.WohngebaeudeArt">
            <xs:annotation>
               <xs:documentation>Hier wird für bauliche Anlagen, die Wohngebäude sind, eine Klassifizierung vorgenommen gemäß Einteilung der amtlichen Statistik. Die Hauptnutzung muss klar erkennbar sein.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDesNichtwohngebaeudes" type="xbau:Code.NichtwohngebaeudeArt">
            <xs:annotation>
               <xs:documentation>Bauliche Anlagen, die nicht Wohngebäude sind, werden durch dieses Element klassifiziert gemäß Signierschlüsselverzeichnis des Statistischen Bundesamts.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDerSonstigenAnlage" type="xbau:Code.BaulicheAnlagenSonstige">
            <xs:annotation>
               <xs:documentation>Hier ist für sonstige bauliche Anlagen, also solche, die nicht Gebäude sind, eine Klassifizierung vorzunehmen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="Aufstellort">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zum Aufstellort.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="artDesAufstellorts"
                     minOccurs="0"
                     type="xbau:Code.AufstellortArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art des Aufstellorts.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="lueftungDesAufstellraums" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Angaben zur Lüftung des Aufstellraums (BB)</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="artLueftungDesAufstellraums"
                              minOccurs="0"
                              type="xbau:Code.LueftungDesAufstellraums">
                     <xs:annotation>
                        <xs:documentation>Angabe der Art der Lüftung des Aufstellraums</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="freierQuerschnitt" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>für Lüftungsöffnung und Lüftungsleitung</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="mitVentilator" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Volumenstrom (m3/h)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="entlueftung" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Angaben zur Entlüftung</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="artDerEntlueftung"
                              minOccurs="0"
                              type="xbau:Code.EntlueftungArt">
                     <xs:annotation>
                        <xs:documentation>Angabe zur Art der Entlüftung.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="querschnitt" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe zum Querschnitt</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="leistung" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe zur Leistung (in m3/h)</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="rauminhalt" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe des Rauminhalts (in m3)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="hoehe" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe der Höhe</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="grundflaeche" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe der Grunfläche</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="umgebendeBauteile" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>Angaben zu umgebenden Bauteilen</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="artDerUmgebendenBauteile"
                              minOccurs="0"
                              type="xbau:Code.UmgebendeBauteile">
                     <xs:annotation>
                        <xs:documentation>Angabe der Art der umgebenden Bauteile.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="baustoffklasse" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe der Baustoffklasse</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="feuerwiderstandsklasse" minOccurs="0" type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Angabe der Feuerwiderstandsklasse</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Aufzuege">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu Aufzügen</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="personenaufzuege" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zu Personenaufzügen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="lastenaufzuege" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zu Lastenaufzügen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="feuerwehraufzuege" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zu Feuerwehraufzügen</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Barrierefreiheit">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zur Barrierefreiheit.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="barrierefreiheitEingehalten"
                     type="xbau:Code.EinhaltungBarrierefreiheit">
            <xs:annotation>
               <xs:documentation>Angabe, ob die Anforderungen an Barrierefreiheit eingehalten worden sind.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="eingehaltenBei"
                     minOccurs="0"
                     type="xbau:Code.EinhaltungBarrierefreiheitBei">
            <xs:annotation>
               <xs:documentation>Angabe zur Einhaltung der Barrierefreiheit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anzahlWohnungenBarrierefrei"
                     minOccurs="0"
                     type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Anzahl der barrierefreien Wohnungen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="istOeffentlichZugaenglich" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe zur öffentlichen Zugänglichkeit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nichtEingehaltenBegruendung" minOccurs="0" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Angabe der Begründung bei Nichteinhaltung der Barrierefreiheit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nichtEingehaltenWegen" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Angabe des Grundes für Nichteinhaltung</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="schwierigerGelaendeverhaeltnisse"
                              minOccurs="0"
                              type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Grund bei schwierigen Geländeverhältnissen Die erforderlichen Nachweise sind im Datentyp Anlagen beizufügen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="unguenstigerVorhandenerBebauung"
                              minOccurs="0"
                              type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Grund bei ungünstiger vorhandener Bebauung Die erforderlichen Nachweise sind im Datentyp Anlagen beizufügen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="unverhaeltnismaessigerMehraufwand"
                              minOccurs="0"
                              type="xs:token">
                     <xs:annotation>
                        <xs:documentation>Grund bei unverhältnismäßigem Mehraufwand Die erforderlichen Nachweise sind im Datentyp Anlagen beizufügen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BauAmBestand">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Informationen über Nutzungsänderungen mit oder ohne den Umbau bestehender Gebäude.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="aenderungNutzugsschwerpunkt" minOccurs="0" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe zur Änderung des Nutzungsschwerpunkts</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="abgangsbogenNutzung" minOccurs="0" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe zur Abgangsbogen Nutzung</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="fruehereNutzung"
                     minOccurs="0"
                     type="xbau:Code.SystematikDerBauwerkeBautaetigkeit">
            <xs:annotation>
               <xs:documentation>Angaben zur früheren Nutzung</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Bauabgang">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zum Bauabgang.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="abgangszeitraumDatum" type="xbauk:JahrMonat">
            <xs:annotation>
               <xs:documentation>Angabe des Datums zum Abgangszeitraum</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="alterDesGebaeudes" type="xbau:Code.GebaeudeAlter">
            <xs:annotation>
               <xs:documentation>Angabe zum Alter des Gebäudes</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="umfangDesAbgangs" type="xbau:Code.AbgangUmfang">
            <xs:annotation>
               <xs:documentation>Angabe zum Umfang des Abgangs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="ursacheDesAbgangs" type="xbau:Code.AbgangUrsache">
            <xs:annotation>
               <xs:documentation>Angabe zur Ursache des Abgangs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="groesseDesAbgangs" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Angabe der Größe des Abgangs</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="anzahlRaeume"
                              minOccurs="0"
                              maxOccurs="unbounded"
                              type="xbau:Wohnungsprofil">
                     <xs:annotation>
                        <xs:documentation>Hier ist die gruppierte Anzahl von Wohnungen einzutragen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="nutzflaeche" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe der Nutzfläche</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="wohnflaeche" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe der Wohnfläche</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Baubeschreibung">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient zur Zusammenstellung der Daten zur Baubeschreibung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="ueberwiegendVerwendeterBaustoff"
                     minOccurs="0"
                     type="xbau:Code.Baustoff">
            <xs:annotation>
               <xs:documentation>Angabe des überwiegend verwendeten Baustoffs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bauteil"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:Bauteil">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Daten zu Bauteilen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="technischeGebaeudeausruestung"
                     minOccurs="0"
                     type="xbau:TechnischeGebaeudeausruestung">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Daten zur technischen Gebäudeausrüstung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="erneuerbareEnergien"
                     minOccurs="0"
                     type="xbau:ErneuerbareEnergien">
            <xs:annotation>
               <xs:documentation>Angaben zu erneuerbaren Energien nach GEG.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="einhaltungGebaeudeenergiegesetz"
                     minOccurs="0"
                     type="xbau:Code.EinhaltungGebaeudeenergiegesetz">
            <xs:annotation>
               <xs:documentation>Angabe zur Einhaltung des Gebäudeenergiegesetzes (GEG)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anzahlFahrzeugstellplaetze"
                     minOccurs="0"
                     type="xbau:AnzahlFahrzeugstellplaetze">
            <xs:annotation>
               <xs:documentation>Angabe der Anzahl der Fahrzeugstellplätze nach §§ 49 und 50 MBO</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="kinderspielplaetze"
                     minOccurs="0"
                     type="xbau:Kinderspielplaetze">
            <xs:annotation>
               <xs:documentation>Angaben zu Kinderspielplätzen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="aeussereGestaltung"
                     minOccurs="0"
                     type="xbau:AeussereGestaltung">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Daten zur äußeren Gestaltung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="barrierefreiheit" minOccurs="0" type="xbau:Barrierefreiheit">
            <xs:annotation>
               <xs:documentation>Hier ist die barrierefreie Infrastruktur des Gebäudes zu beschreiben: Gebäude-Infrastruktur sind die Bereiche eines Gebäudes, die - einschließlich ihrer Bauteile und technischen Einrichtungen - seiner Erschließung von der öffentlichen Verkehrsfläche aus bis zum Eingang der barrierefreien Wohnung bzw. Ort der zweckmäßigen Nutzung im Gebäude dienen (Zugangsbereiche, Eingangsbereich, Aufzüge, Flure, Treppen usw.).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="oertlicheBauvorschriften"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xs:token">
            <xs:annotation>
               <xs:documentation>In diesem Element ist die Bezeichnung der betreffenden Satzung(en) anzugeben. (§ 86 MBO)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="schutzGegenSchaedlicheEinfluesse"
                     minOccurs="0"
                     type="xs:token">
            <xs:annotation>
               <xs:documentation>Erläuterungen zu bautechnischen Maßnahmen gegen Feuchtigkeit und Einflüsse der Witterung Tierische und pflanzliche Schädlinge Elektrische und magnetische Felder (§ 13 MBO)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="angabenArtenschutz" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angaben zum Artenschutz gemäß § 44 BNatSchG</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="besondereAnforderungen"
                     minOccurs="0"
                     type="xbau:BesondereAnforderungen">
            <xs:annotation>
               <xs:documentation>In dieses Element sind besondere Anforderungen anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="werbeanlagen"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:Werbeanlagen">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Daten zu Werbeanlagen (§ 10 MBO).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anzahlDerWohnungen"
                     minOccurs="0"
                     type="xbau:AnzahlDerWohnungen">
            <xs:annotation>
               <xs:documentation>Hier können Angaben zur Anzahl der Wohnungen gemacht werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Baugenehmigung">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zur Baugenehmigung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bauscheinnummer" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>In diesem Element wird die Bauschein-Nummer angegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="verfahrensart" type="xbau:Code.VerfahrensartAnStatistik">
            <xs:annotation>
               <xs:documentation>Angabe der Art des baurechtlichen Verfahrens.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDerBautaetigkeit" type="xbau:Code.BautaetigkeitArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art der Bautätigkeit</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bauAmBestand" minOccurs="0" type="xbau:BauAmBestand">
            <xs:annotation>
               <xs:documentation>Dieses Element beinhaltet Daten zum Bestandsbau.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="wiederaufbau" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Angaben zum Wiederaufbau</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="jahrDerZerstoerung" minOccurs="0" type="xbauk:Jahr">
                     <xs:annotation>
                        <xs:documentation>Angabe des Jahres der Zerstörung</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="abgangsbogenWiederaufbau" minOccurs="0" type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Angabe Abgangsbogen Wiederaufbau</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="nummerAbgangsbogen" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Nummer des Abgangsbogens</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="voraussichtlicherBaubeginn"
                     minOccurs="0"
                     type="xbauk:JahrMonat">
            <xs:annotation>
               <xs:documentation>Hier kann das Datum des voraussichtlichen Baubeginns eingetragen werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BaugenehmigungErweitert">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zur Baugenehmigung.</xs:documentation>
      </xs:annotation>
      <xs:complexContent>
         <xs:extension base="xbau:Baugenehmigung">
            <xs:sequence>
               <xs:element name="datumBaugenehmigung" type="xbauk:JahrMonat">
                  <xs:annotation>
                     <xs:documentation>In dieses Element ist das Datum der Baugenehmigung einzutragen. Im Falle einer Genehmigungsfreistellung ist hier das Eingangsdatum der Zustimmung der Gemeinde (Nachricht 0603) einzutragen. Der Inhalt des Elements wird in der Behörde gepflegt.</xs:documentation>
                  </xs:annotation>
               </xs:element>
            </xs:sequence>
         </xs:extension>
      </xs:complexContent>
   </xs:complexType>
   <xs:complexType name="Baugrundstueck">
      <xs:annotation>
         <xs:documentation>Das Baugrundstück ist der Ort der Baumaßnahme. Es kann aus mehreren Grundstücken im Sinne des Grundbuchs bestehen. Ein Grundstück kann aus mehreren Flurstücken bestehen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="grundstueck" maxOccurs="unbounded" type="xbau:Grundstueck">
            <xs:annotation>
               <xs:documentation>Hier sind in jedem Fall die Angaben zum Flurstück des Vorhabens einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BauherrBauprojekt">
      <xs:annotation>
         <xs:documentation>Hier ist derjenige einzutragen, der am Verfahren als Bauherr beteiligt ist, inklusive seiner Rolle.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bauherr" type="xbauk:Akteur">
            <xs:annotation>
               <xs:documentation>Hier ist der Akteur einzutragen, der am Verfahren als Bauherr beteiligt ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDesBauherrn"
                     minOccurs="0"
                     type="xbau:Code.BauherrOderEigentuemerArt">
            <xs:annotation>
               <xs:documentation>Angabe zur Art des Bauherrn (oder Eigentümers) für Zwecke der Baustatistik</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Baulast">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zu Anlass und Inhalt einer Baulasterklärung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="id" type="bn-g2g:UUID">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält den „Universally Unique IDentifier (UUID)“ der Baulast. Der UUID wird entsprechend rfc4122 gebildet und ermöglicht die Baulast eindeutig zu identifizieren.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligtePersonen">
            <xs:annotation>
               <xs:documentation>Die am Baulastverfahren beteiligten Personen sind unterhalb dieses Elements einzutragen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="baulastgeber" maxOccurs="unbounded" type="xbauk:Akteur">
                     <xs:annotation>
                        <xs:documentation>Hier sind die Daten des Baulastgebers einzutragen. Pro Person ist ein Element zu instanziieren.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="beguenstigter" maxOccurs="unbounded" type="xbauk:Akteur">
                     <xs:annotation>
                        <xs:documentation>Hier sind die Daten des Begünstigten (im Kontext eines Baugenehmigungsverfahrens ist dies der Bauherr) einzutragen. Pro Person ist ein Element zu instanziieren.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="beteiligteGrundstuecke">
            <xs:annotation>
               <xs:documentation>Hier werden die für das Baulastverfahren relevanten Grundstücke oder Flurstücke eingetragen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="belastetesGrundstueck"
                              minOccurs="0"
                              maxOccurs="unbounded"
                              type="xbau:Grundstueck">
                     <xs:annotation>
                        <xs:documentation>Für jedes aufzuführende belastete Grundstück oder Flurstück ist ein Element zu füllen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="beguenstigtesGrundstueck"
                              maxOccurs="unbounded"
                              type="xbau:Grundstueck">
                     <xs:annotation>
                        <xs:documentation>Für jedes aufzuführende begünstigte Grundstück oder Flurstück ist ein Element zu füllen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="erklaerung" type="xbau:BaulastErklaerung">
            <xs:annotation>
               <xs:documentation>Dieses Element beinhaltet die Daten zu Anlass und Inhalt einer Baulasterklärung. Es wird Zweck der angestrebten Baulast sowie der zu regelnde Sachverhalt beschrieben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDerBaulast" type="xbau:Code.ArtDerBaulast">
            <xs:annotation>
               <xs:documentation>In diesem Element wird die Art der Baulast angegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BaulastErklaerung">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zu Anlass und Inhalt einer Baulasterklärung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="anlass" minOccurs="0" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Hier wird die öffentlich-rechtliche Verpflichtung bezeichnet, die mit der einzutragenden Baulast einhergeht. Es wird der Zweck bzw. das Ziel der einzurichtenden Baulast angegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beschreibung" minOccurs="0" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Hier ist Text einzutragen, der die Baulast mit Bezugnahme auf die in der Nachricht aufgeführten Grundstücke definiert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="sachverhalt" minOccurs="0" maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>Hier wird eine Beschreibung der Verpflichtung im Detail gegeben. Dies geschieht, indem georeferenziert auf die Gegenstände der Baulast Bezug genommen wird. Pro Element wird ein Baulast-Gegenstand genannt.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="baulastgegenstand"
                              minOccurs="0"
                              type="xbauk:GeoreferenzierteFlaeche">
                     <xs:annotation>
                        <xs:documentation>In diesem Element wird ein Baulast-Gegenstand georeferenziert definiert. z.B. eine Baulastfläche (Abstandsfläche, die von der Bebauung freizuhalten ist) oder eine gemeinsame Brandwand (die nicht verändert werden darf in einem Bauvorhaben).</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="beschreibung" type="xbauk:Text">
                     <xs:annotation>
                        <xs:documentation>Zum georeferenzierten Baulast-Gegenstand werden hier Erläuterungen eingefügt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BaulastErweitert">
      <xs:annotation>
         <xs:documentation>Erweiterter Datentyp für Baulasten, die bereits vorliegen und daher über eine zugeordnete Baulastnummer gemäß Baulastenverzeichnis verfügen.</xs:documentation>
      </xs:annotation>
      <xs:complexContent>
         <xs:extension base="xbau:Baulast">
            <xs:sequence>
               <xs:element name="baulastnummer" minOccurs="0" type="xs:string">
                  <xs:annotation>
                     <xs:documentation>Soweit von einer bereits existierenden Baulast die Rede ist (nicht eine neue beantragt wird) und eine Baulastnummer vergeben worden ist, ist sie in dieses Element einzutragen.</xs:documentation>
                  </xs:annotation>
               </xs:element>
            </xs:sequence>
         </xs:extension>
      </xs:complexContent>
   </xs:complexType>
   <xs:complexType name="BaulastLoeschung">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zu Anlass und Inhalt einer Baulastlöschung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="id" type="bn-g2g:UUID">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält den „Universally Unique IDentifier (UUID)“ der zu löschenden Baulast. Der UUID wird entsprechend rfc4122 gebildet und ermöglicht, die zu löschende Baulast eindeutig zu identifizieren.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligtePersonen">
            <xs:annotation>
               <xs:documentation>Die am Baulastverfahren beteiligten Personen sind unterhalb dieses Elements einzutragen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="baulastgeber" maxOccurs="unbounded" type="xbauk:Akteur">
                     <xs:annotation>
                        <xs:documentation>Hier sind die Daten des Baulastgebers einzutragen. Pro Person ist ein Element zu instanziieren.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="beguenstigter" maxOccurs="unbounded" type="xbauk:Akteur">
                     <xs:annotation>
                        <xs:documentation>Hier sind die Daten des Begünstigten (im Kontext eines Baugenehmigungsverfahrens ist dies der Bauherr) einzutragen. Pro Person ist ein Element zu instanziieren.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="beteiligteGrundstuecke">
            <xs:annotation>
               <xs:documentation>Hier werden die für das Baulastverfahren relevanten Grundstücke eingetragen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="belastetesGrundstueck"
                              maxOccurs="unbounded"
                              type="xbau:Grundstueck">
                     <xs:annotation>
                        <xs:documentation>Für jedes aufzuführende belastete Grundstück ist ein Element zu füllen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="beguenstigtesGrundstueck"
                              maxOccurs="unbounded"
                              type="xbau:Grundstueck">
                     <xs:annotation>
                        <xs:documentation>Für jedes aufzuführende begünstigte Grundstück ist ein Element zu füllen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="artDerBaulast" type="xbau:Code.ArtDerBaulast">
            <xs:annotation>
               <xs:documentation>In diesem Element wird die Art der Baulast angegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="begruendungLoeschung" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In diesem Element wird angegeben, warum die Baulast gelöscht werden soll.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="datumEintragung" type="xbauk:JahrMonat">
            <xs:annotation>
               <xs:documentation>Hier ist das Eintragungsdatum der Baulast einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="baulastblatt">
            <xs:annotation>
               <xs:documentation>Hier können Angaben zum Baulastblatt gemacht werden.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="praefix" minOccurs="0" type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier kann der Präfix eines Baulastenverzeichnisses angegeben werden. Der Präfix ist notwendig, wenn eine Behörde mehrere Baulastverzeichnisse führt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="blattnummer" type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier kann die Blattnummer der Baulast angegeben werden.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="blattnummerGrundbuch" minOccurs="0" type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier kann die Blattnummer im Grundbuch angegeben werden.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="nrBestandsverzeichnisGrundbuch"
                              minOccurs="0"
                              type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier kann die Nummer im Bestandsverzeichnis des Grundbuchs angegeben werden.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="blattnummerErbbaugrundbuch"
                              minOccurs="0"
                              type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier kann die Blattnummer im Erbbaugrundbuch angegeben werden.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="nrBestandsverzeichnisErbbaugrundbuch"
                              minOccurs="0"
                              type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier kann die Nummer im Bestandsverzeichnis des Erbbaugrundbuchs angegeben werden.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BauordnungsrechtlicheKlassifikation">
      <xs:annotation>
         <xs:documentation>Eine Instanz dieses Typs stellt in Bezug auf den Gegenstand des Bauvorhabens die wichtigsten bauordnungsrechtlichen Parameter zusammen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="gebaeudeklasse" minOccurs="0" type="xbau:Code.Gebaeudeklasse">
            <xs:annotation>
               <xs:documentation>Für Gebäude: in diesem Element ist die Gebäudeklasse nach MBO des Bauvorhabens anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="hoeheNachMBO" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Höhe des höchsten Aufenthaltsraums</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="istFreistehend" minOccurs="0" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Höhe des höchsten Aufenthaltsraums</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="sonderbau"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:Code.Sonderbauten">
            <xs:annotation>
               <xs:documentation>Für Sonderbauten ist pro Ausprägung ein Element zu füllen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="mittelOderGrossGarage" minOccurs="0" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Angabe, ob das Vorhaben eine Mittel- oder Großgarage gem. § 1 Abs. 7 Satz 1 Nr. 2, 3 GaStellV beinhaltet</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="garage" minOccurs="0" type="xbau:Code.Garagentyp">
            <xs:annotation>
               <xs:documentation>Für Garagen ist der Garagentyp auszuwählen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Bauteil">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp kann das Gebäude detailliert nach seinen Bauteilen (Wände, Decken, Türen, etc.) beschreiben. Dabei können technische Eigenschaften, Bauarten und Produktbezeichnungen angegeben werden. Informationen darüber findet man beim Deutschen Institut für Bautechnik (www.dibt.de).</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bauteilkategorie"
                     minOccurs="0"
                     type="xbau:Code.Bauteilkategorie">
            <xs:annotation>
               <xs:documentation>Angabe der Bauteilkategorie.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="verwendetesBauprodukt" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe des verwendeten Bauprodukts.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bauart" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Bauart.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="feuerwiderstandsklasse" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Feuerwiderstandsklasse.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="baustoffBauteilEigenschaft" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Baustoff-/Bauteileigenschaft.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Bauvorhaben">
      <xs:annotation>
         <xs:documentation>Typ für die Daten eines Bauvorhabens, enthält Informationen zum Wer, Was und Wo des Bauvorhabens bzw. Vorhabens. Der Begriff 'Bauvorhaben' wird hier sehr weit gefasst, so dass auch Nutzungsänderungen ohne Baumaßnahmen abgedeckt sind. Der Typ wird in allen Nachrichten eingesetzt, in denen Eigenschaften eines Bauvorhabens (bzw. Vorhabens) anzugeben sind bzw. geprüft werden sollen. Er wird auch da eingesetzt, wo über ein Bauvorhaben (Vorhaben) oder über Maßnahmen im Zusammenhang eines Bauvorhabens (Vorhabens) zu informieren ist.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bezeichnungDesBauvorhabens" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In dieses Element ist die Bezeichnung des Vorhabens einzutragen. Sie wird vom Bauherrn vergeben und später ggf. von der Bauaufsichtsbehörde geändert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="beteiligte" type="xbau:BeteiligteBauprojekt">
            <xs:annotation>
               <xs:documentation>Dieses Objekt steht für die am Bauvorhaben (Vorhaben) beteiligten Parteien (Personen und Organisationen), soweit sie der Bauaufsichtsbehörde bekannt sein müssen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="gegenstand" type="xbau:Gegenstand">
            <xs:annotation>
               <xs:documentation>Dieser Abschnitt beschreibt, was der Gegenstand des Antrags ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="verortung">
            <xs:annotation>
               <xs:documentation>Dieser Abschnitt beschäftigt sich mit der Lokalisierung des Vorhabens in relevanten Bezugssystemen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="baugrundstueck" type="xbau:Baugrundstueck">
                     <xs:annotation>
                        <xs:documentation>In diesem Element sind Daten enthalten, die das Baugrundstück (ein Grundstück, auf dem das Vorhaben stattfinden soll bzw. auf dem es durchgeführt wurde) identifizieren. Ein Baugrundstück kann mehrere Grundstücke umfassen.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="lageBauvorhaben"
                              minOccurs="0"
                              type="xbauk:GeoreferenzierteFlaeche">
                     <xs:annotation>
                        <xs:documentation>In diesem Element sollen ergänzend georeferenzierte Informationen zur genaueren Lage des Bauvorhabens bzw. Gebäudes auf dem Baugrundstück abgebildet werden. Falls beispielsweise ein Umbau geplant ist und auf dem Grundstück mehrere Gebäude bestehen, muss aus diesen Angaben hervorgehen, was der Gegenstand des Anbaus ist.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="weitereAngaben"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Mit diesem Element können ausschließlich ergänzende textliche Erläuterungen zum Bauvorhaben übermittelt werden, die sich nicht mit den vorhandenen XBau-Attributen ausdrücken lassen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BauvorlageberechtigungSachverhalt.NachweisbezugType">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp beschreibt den Sachverhalt der Bauvorlageberechtigung. Diese Information kann aus dem Kammerregister abgerufen werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="grundlageBauvorlageBerechtigung"
                     type="xbau:Code.BauvorlageberechtigungSachverhalt">
            <xs:annotation>
               <xs:documentation>Hier ist der Sachverhalt anzugeben, aufgrund dessen die Person bauvorlageberechtigt ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nachweisbezug" minOccurs="0" type="xbau:NachweisbezugType">
            <xs:annotation>
               <xs:documentation>Mit diesem Element wird der Bezug zu einem XNachweis-Abruf aus dem Kammernverzeichnis hergestellt. Das Element ist nur bei erfolgreichem Datenabruf zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BebauteGrundstuecksflaeche">
      <xs:annotation>
         <xs:documentation>Bebaute Fläche (BF). Teilfläche der Grundstücksfläche (GF), die durch ein Bauwerk oberhalb der Geländeoberfläche überbaut oder überdeckt oder unterhalb der Geländeoberfläche unterbaut ist. = ueberbauteFlaecheBF1 + unterbauteFlaecheBF2</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="ueberbauteFlaeche" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Flächen der Bauwerke oberhalb der Geländeoberfläche. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="ueberbauteFlaecheAlt" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Ursprünglicher Zustand der Fläche der Bauwerke oberhalb der Geländeoberfläche bei Baumaßnahmen am Bestand vor der Umbaumaßnahme. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="unterbauteFlaeche" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Flächen der Bauwerke unterhalb der Geländeoberfläche. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BefundlisteFormell">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Befunde der formellen Prüfung eines Antrags oder einer Anfrage. Für jeden Befund sind die entsprechenden Parameter gefüllt, die Inhalt und Bezug des Befundes für den Antragsteller bzw. Anfragenden nachvollziehbar machen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="befund" maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>Dieses Element stellt genau einen Befund der Befundliste dar.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="artDesBefundes" type="xbau:Code.FormelleBefundeArt">
                     <xs:annotation>
                        <xs:documentation>In diesem Element wird die Befundkategorie angegeben, der dieser Befund zugeordnet werden kann.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="refAnlage" minOccurs="0" type="xbau:RefAnlage">
                     <xs:annotation>
                        <xs:documentation>Für Befunde, die sich auf eine eingereichte Bauvorlage bzw. eine sonstige Anlage zum Antrag beziehen, wird in diesem Objekt der Bezug hergestellt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="betroffeneAnlage" minOccurs="0" type="xbau:Code.AnlageArt">
                     <xs:annotation>
                        <xs:documentation>Für Befunde, die Mängel an einer eingereichten Bauvorlage oder das Fehlen einer Bauvorlage (einer bestimmten Art) betreffen, wird in diesem Element die Art dieser Bauvorlage angegeben (die den Mangel hat bzw. die nachzureichen ist).</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="beschreibung" type="xbauk:Text">
                     <xs:annotation>
                        <xs:documentation>Hier wird der Sachverhalt des Befundes beschrieben. Dieser Sachverhalt ist eine detailliertere Darstellung im Rahmen der parallel angegebenen Art des Befundes.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BefundlisteMateriell">
      <xs:annotation>
         <xs:documentation>Eine Instanz dieses Typs steht für eine Befundliste der materiellen Prüfung eines Antrags. Jeder Befund beinhaltet die Parameter, die einen belastenden Verwaltungsakt im Kontext eines Baugenehmigungsvorgangs definieren.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="befund" maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>Jedes Element steht für einen belastenden Verwaltungsakt im Kontext des aktuellen Baugenehmigungsvorgang, zu dem der Adressat der Nachricht zu einer Stellungnahme aufgefordert ist.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="rechtsbereich" type="xbau:Code.Rechtsbereich">
                     <xs:annotation>
                        <xs:documentation>Dieses Element nennt den Rechtsbereich, innerhalb dessen der belastende Verwaltungsakt liegt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="bezeichnungRegelverstoss" type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier wird die Bezeichnung des betreffenden Regelverstoßes genannt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="begruendung" type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier wird begründet, inwiefern es sich um einen Regelverstoß handelt.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BefundlistePruefungBauzustand">
      <xs:annotation>
         <xs:documentation>Eine Instanz dieses Typs steht für eine Befundliste der materiellen Prüfung eines Antrags. Jeder Befund beinhaltet die Parameter, die einen belastenden Verwaltungsakt im Kontext eines Baugenehmigungsvorgangs definieren.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="befund" maxOccurs="unbounded">
            <xs:annotation>
               <xs:documentation>Jedes Element steht für einen belastenden Verwaltungsakt im Kontext des aktuellen Baugenehmigungsvorgang, zu dem der Adressat der Nachricht zu einer Stellungnahme aufgefordert ist.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="beschreibung" type="din91379:datatypeC">
                     <xs:annotation>
                        <xs:documentation>Hier wird der festgestellte Mangel beschrieben.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="verweise" minOccurs="0" type="xbauk:Text">
                     <xs:annotation>
                        <xs:documentation>Hier kann ein Verweis auf eine Nebenbestimmung der Baugenehmigung eingefügt werden, oder auf z. B. den Prüfbericht Standsicherheit oder Brandschutz.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="rechtsbereich" minOccurs="0" type="xbau:Code.Rechtsbereich">
                     <xs:annotation>
                        <xs:documentation>Dieses Element nennt (falls zutreffend) den Rechtsbereich, innerhalb dessen die Bestimmung liegt, gegen die im Kontext des Befundes verstoßen wurde.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Berechtigung">
      <xs:annotation>
         <xs:documentation>Hier sind die Daten einzutragen, die die Berechtigung der entsprechenden Rolle belegen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="grundlageBauvorlageBerechtigung"
                     minOccurs="0"
                     type="xbau:BauvorlageberechtigungSachverhalt.NachweisbezugType">
            <xs:annotation>
               <xs:documentation>Hier ist der Sachverhalt anzugeben, aufgrund dessen die Person bauvorlageberechtigt ist.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="mitgliedschaftInland" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Hier sind die Daten einer inländischen Kammernzugehörigkeit anzugeben (Berechtigung als Mitglied einer Kammer). Das geschieht auch für Personen, deren Daten in einem Kammernverzeichnis gespeichert sind, sie aber nicht im engeren Sinne Mitglied dieser Kammer sind (personennummer für im Kammernverzeichnis geführte Nichtmitglieder).</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:choice>
                  <xs:element name="nummernKammer"
                              type="xbau:MerkmaleKammerneintrag.NachweisbezugType">
                     <xs:annotation>
                        <xs:documentation>Angabe von Mitgliedsnummer bzw. Personennummer mit Angabe der Bezeichnung der Kammer, in deren Verzeichnis die Nummer gespeichert ist. Von den Elementen mitgliedsnummer und personennummer ist im Rahmen des Datentyps mindestens eines zu übermitteln.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="mitgliedsnummerBundesland">
                     <xs:annotation>
                        <xs:documentation>Angabe der Mitgliedsnummer mit Angabe des Bundeslandes, in dem die Kammer ihren Sitz hat</xs:documentation>
                     </xs:annotation>
                     <xs:complexType>
                        <xs:sequence>
                           <xs:element name="mitgliedsnummer" type="xs:token">
                              <xs:annotation>
                                 <xs:documentation>Eine Instanz dieses Elements nimmt die Mitgliedsnummer (Nummer der Eintragungsliste in einer Kammer) auf.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                           <xs:element name="bundesland" type="xbauk:Code.Bundesland">
                              <xs:annotation>
                                 <xs:documentation>Dieses Element enthält das Bundesland, in dem die Kammer liegt.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
               </xs:choice>
            </xs:complexType>
         </xs:element>
         <xs:element name="nachweisBerechtigung"
                     minOccurs="0"
                     type="xbau:NachweisBerechtigung.NachweisbezugType">
            <xs:annotation>
               <xs:documentation>Hier kann ggf. ein Nachweis zur Berechtigung angegeben werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="berufsbezeichnung"
                     minOccurs="0"
                     type="xbau:Berufsbezeichnung.NachweisbezugType">
            <xs:annotation>
               <xs:documentation>In dieses Element kann eine Angabe zur Berufsbezeichnung der Person eingetragen werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="ausland" minOccurs="0">
            <xs:annotation>
               <xs:documentation>Falls die Person nicht im Inland niedergelassen ist, sind hier Angaben zur Niederlassung im Ausland einzutragen.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="niederlassungStaat" type="xbauk:Code.Staat">
                     <xs:annotation>
                        <xs:documentation>Dieses Elements nennt den Staat der Niederlassung.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="bescheinigtIn" type="xbauk:Code.Bundesland">
                     <xs:annotation>
                        <xs:documentation>In dieses Element ist das Bundesland einzutragen, in dem beim ausländisch niedergelassenen Berechtigten eine Anzeige bzw. Bescheinigung erfolgt ist.</xs:documentation>
                     </xs:annotation>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Berufsbezeichnung.NachweisbezugType">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp enthält die Berufsbezeichnung einer Person. Diese Information kann aus dem Kammerregister abgerufen werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="berufsbezeichnung" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In dieses Element wird eine Angabe zur Berufsbezeichnung der Person eingetragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nachweisbezug" minOccurs="0" type="xbau:NachweisbezugType">
            <xs:annotation>
               <xs:documentation>Mit diesem Element wird der Bezug zu einem XNachweis-Abruf aus dem Kammernverzeichnis hergestellt. Das Element ist nur bei erfolgreichem Datenabruf zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Bescheid">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Parameter eines Bescheides, den die Bauaufsichtsbehörde nach Prüfung eines Antrags erlässt.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="tenor">
            <xs:annotation>
               <xs:documentation>Hier wird der Bescheid formuliert. Es handelt sich entweder um eine Genehmigung oder um eine Ablehnung.</xs:documentation>
            </xs:annotation>
            <xs:complexType>
               <xs:sequence>
                  <xs:element name="istGenehmigung" type="xs:boolean">
                     <xs:annotation>
                        <xs:documentation>Falls der Tenor positiv ist (Genehmigung), so ist in diesem Element "true" zu übermitteln, andernfalls (Ablehnung) "false".</xs:documentation>
                     </xs:annotation>
                  </xs:element>
                  <xs:element name="kommentareFachrecht" minOccurs="0">
                     <xs:annotation>
                        <xs:documentation>Unterhalb dieses Elements sind - falls solche vorliegen - zur Information die Kommentare bzw. Bewertungen aus den beteiligten Stellen nach Fachrecht festgehalten. Sie sind im Verfahren der Bauaufsichtsbehörde berücksichtigt worden, das zum vorliegenden Bescheid geführt hat.</xs:documentation>
                     </xs:annotation>
                     <xs:complexType>
                        <xs:sequence>
                           <xs:element name="kommentarFachrecht" maxOccurs="unbounded" type="xbauk:Text">
                              <xs:annotation>
                                 <xs:documentation>Pro Kommentar aus einem Fachbereich ist ein eigenes Element (welches mehrere Absätze Text enthalten kann) zu füllen.</xs:documentation>
                              </xs:annotation>
                           </xs:element>
                        </xs:sequence>
                     </xs:complexType>
                  </xs:element>
               </xs:sequence>
            </xs:complexType>
         </xs:element>
         <xs:element name="abweichung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:AbweichungBearbeitet">
            <xs:annotation>
               <xs:documentation>Hier werden ggf. die Erläuterungen zur Genehmigung einer beantragten Abweichung eingetragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nebenbestimmung"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:Nebenbestimmung">
            <xs:annotation>
               <xs:documentation>Hier werden ggf. die Nebenbestimmungen zum Bescheid eingefügt.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="begruendung" minOccurs="0" type="xbauk:TextFormatiert">
            <xs:annotation>
               <xs:documentation>Falls der Bescheid ablehnend ausgefallen ist, wird in diesem Element die entsprechende Begründung geliefert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="baufreigabeschein"
                     minOccurs="0"
                     type="xbau:DatenBaufreigabeschein">
            <xs:annotation>
               <xs:documentation>Hier sind die Daten zum Baufreigabeschein (sog. "Roter Punkt") zu übermitteln. Falls die Baugenehmigung, auf die sich der Bescheid bezieht, Auflagen und Bedingungen enthält, ist die Baufreigabe separat mittels Nachricht anzeige.baubeginnBaufreigabe.0902 zu übermitteln.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="rechtshelfsbelehrung" type="xbauk:Text">
            <xs:annotation>
               <xs:documentation>Hier werden die Rechtshelfsbelehrungen zum Bescheid gegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="hinweise" minOccurs="0" type="xbauk:TextFormatiert">
            <xs:annotation>
               <xs:documentation>Hier werden ggf. ergänzende Hinweise zum Bescheid gegeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BesondereAnforderungen">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu besonderen Anforderungen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="anforderungen" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Anforderungen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anhang" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Anhang</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BeteiligteBauprojekt">
      <xs:annotation>
         <xs:documentation>Typ für die an einem Bauprojekt direkt oder indirekt beteiligten Parteien (Personen und Organisationen).</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bauherr" maxOccurs="unbounded" type="xbau:BauherrBauprojekt">
            <xs:annotation>
               <xs:documentation>Hier ist derjenige einzutragen, der am Verfahren als Bauherr beteiligt ist, inklusive seiner Rolle. Pro Bauherrn ist ein Element zu instanziieren. Bei mehreren Bauherren sollte das Element artdesBauherren mindestens bei einer Instanziierung befüllt sein.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="gruppenname" minOccurs="0" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Sofern eine Personengruppe vorliegt, kann in diesem Element der entsprechende Gruppenname dieser Personengruppe erfasst werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bevollmaechtigter" minOccurs="0" type="xbauk:Akteur">
            <xs:annotation>
               <xs:documentation>Hier ist eine (natürliche oder juristische) Person einzutragen, die vom Bauherrn bevollmächtigt wurde.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="entwurfsverfasser"
                     minOccurs="0"
                     type="xbau:Entwurfsverfasser">
            <xs:annotation>
               <xs:documentation>Hier ist die Person einzutragen, die am Verfahren als Entwurfsverfasser beteiligt ist. Falls kein Entwurfsverfasser für das Bauvorhaben benötigt wird, kann dieses Element entfallen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bauunternehmer" minOccurs="0" type="xbauk:Organisation">
            <xs:annotation>
               <xs:documentation>Als Bauunternehmer ist der Rohbau-Unternehmer einzutragen, benötigt wird die Firma mit Ansprechpartner.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nachbar"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:Nachbarschaft">
            <xs:annotation>
               <xs:documentation>Hier sind ggf. Nachbarn des Baugrundstücks einzutragen, soweit sie in die Prüfung des Bauvorhabens durch die Bauaufsichtsbehörde einzubeziehen sind. Pro zu berücksichtigenden Nachbarn ist ein Element zu instanziieren.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="weitereBeteiligte"
                     minOccurs="0"
                     maxOccurs="unbounded"
                     type="xbau:WeitereBeteiligte">
            <xs:annotation>
               <xs:documentation>Dieser Abschnitt fasst Daten zu weiteren Beteiligten zusammen. Pro Beteiligtem ist ein Element zu instanziieren.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="gebuehrenpflichtiger" type="xbauk:Akteur">
            <xs:annotation>
               <xs:documentation>Hier sind die Personendaten des Gebührenpflichtigen anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BeteiligterFachrichtung">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient der Angabe der Fachrichtung eines am Bauprojekt Beteiligten.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element name="code" type="xbau:Code.BeteiligterFachrichtung">
            <xs:annotation>
               <xs:documentation>Angabe für die Fachrichtung des Beteiligten.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nichtGelisteterWert" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Freitextangabe für die Fachrichtung des Beteiligten.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="BeteiligterRolle">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient der Angabe der Rolle eines am Bauprojekt Beteiligten.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element name="code" type="xbau:Code.BeteiligterRolle">
            <xs:annotation>
               <xs:documentation>Angabe für die Rolle des Beteiligten.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nichtGelisteterWert" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Freitextangabe für die Rolle des Beteiligten.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="BetriebMitPublikumsverkehr">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zum Betrieb mit Publikumsverkehr.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="artDesBetriebs" minOccurs="0" type="xbau:Code.BetriebArt">
            <xs:annotation>
               <xs:documentation>Art des Betriebes</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="gesamtflaeche" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Angabe zur Gesamtfläche</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="gesamtanzahl" minOccurs="0" type="xs:positiveInteger">
            <xs:annotation>
               <xs:documentation>Angabe der Gesamtanzahl</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nachVerordnung" minOccurs="0" type="xbau:Code.Verordnung">
            <xs:annotation>
               <xs:documentation>Angabe der Verordnung</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Betriebsbeschreibung">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient zur Zusammenstellung der Daten zur Betriebsbeschreibung nach § 5 BauPrüfVO NRW.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="gewerblicheBetriebsbeschreibung"
                     minOccurs="0"
                     type="xbau:GewerblicheBetriebsbeschreibung">
            <xs:annotation>
               <xs:documentation>Dieses Element beinhaltet Angaben zur gewerblichen Betriebsbeschreibung.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Betriebszeiten">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet die Daten zu Betriebszeiten.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="anfangszeitAnWerktagen" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Anfangszeit an Werktagen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="endezeitAnWerktagen" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Endezeit an Werktagen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anfangszeitAnSonnUndFeiertagen" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Anfangszeit an Sonn- und Feiertagen</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="endezeitAnSonnUndFeiertagen" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Anfangszeit an Sonn- und Feiertagen</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Bezug">
      <xs:annotation>
         <xs:documentation>Dieser Typ gestattet Eintragungen, um auf einen Antrag, einen Vorgang und ggf. auf eine Nachricht, die im Rahmen dieses Vorgangs gesendet worden ist, Bezug zu nehmen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="referenz"
                     minOccurs="0"
                     type="bn-g2g:UUID"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Hier ist der Identifier des Antragsservice (der mit dem Antrag bzw. der Anzeige bei der Bauaufsichtsbehörde eingegangen ist) oder der Abfrage (auf die die vorliegende Nachricht eine Antwort ist) anzugeben. Falls die vorliegende Nachricht an ein Online-Portal gerichtet ist, kann so der Projektraum bzw. Postkorb angesteuert werden. Falls die vorliegende Nachricht an die Statistik gerichtet ist, muss das Kindelement "referenz" befüllt sein.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="vorgang"
                     minOccurs="0"
                     type="din91379:datatypeC"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Eine Instanz dieses Elements enthält, falls ein solches vergeben wurde, das Zeichen (Aktenzeichen) des von der Bauaufsichtsbehörde geführten Vorgangs, innerhalb dessen diese Nachricht übermittelt wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bezugNachricht"
                     minOccurs="0"
                     type="xbau:Identifikation.Nachricht"
                     form="unqualified">
            <xs:annotation>
               <xs:documentation>Falls ein solcher Zusammenhang vorliegt, sind hier die Kennungen der Nachricht einzutragen, auf die sich diese Nachricht bezieht.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BezugBauberatung">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient der Bezugnahme auf eine in der Vergangenheit stattgefundene Bauberatung.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="vorgang" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In dieses Element ist das Zeichen (Aktenzeichen) der vorangegangenen Bauberatung einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BezugHauptbaugenehmigung">
      <xs:annotation>
         <xs:documentation>Dieser Typ nimmt Eintragungen im Rahmen der Beantragung eines Nachtrags zu einer bereits erteilten Baugenehmigung auf. Diese Eintragungen dienen dazu, auf die bereits erteilte Baugenehmigung Bezug zu nehmen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="vorgang" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In dieses Element ist das Zeichen (Aktenzeichen) der Hauptbaugenehmigung einzutragen, also des Vorgangs, im Rahmen dessen die Bauaufsichtsbehörde die Baugenehmigung erteilt hat, zu der mit der vorliegenden Nachrichteninstanz ein Nachtrag beantragt wird.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="BezugVorbescheid">
      <xs:annotation>
         <xs:documentation>Dieser Typ nimmt im Rahmen der Beantragung einer Baugenehmigung den Bezug auf einen in der Vergangenheit erteilten Vorbescheid auf.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="vorgang" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In dieses Element ist das Zeichen (Aktenzeichen) des erteilten Vorbescheids einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="datum" type="xs:date">
            <xs:annotation>
               <xs:documentation>In dieses Element ist das Datum des erteilten Vorbescheids einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="referenz" minOccurs="0" type="bn-g2g:UUID">
            <xs:annotation>
               <xs:documentation>In dieses Element ist die Referenz des erteilten Vorbescheids einzutragen. Dies ist der Identifier des Antragsservice (der mit dem Antrag bzw. der Anzeige bei der Bauaufsichtsbehörde (bzw. Aufsichtsbehörde für den Breitbandausbau) eingegangen ist) oder der Abfrage (auf die die vorliegende Nachricht eine Antwort ist). Falls die vorliegende Nachricht an ein Online-Portal gerichtet ist, kann so der Projektraum bzw. Postkorb angesteuert werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Bindungen">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp enthält Informationen zu den früher getroffenen Entscheidungen über das Bauvorhaben und diesbezüglich vorliegende Bescheide, an die das Bauvorhaben gebunden ist und die es daher beeinflussen.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bindungsbescheidArt"
                     minOccurs="0"
                     type="xbau:Code.BindungsbescheidArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art des Bescheids oder der Entscheidung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bindungNachweisdaten"
                     minOccurs="0"
                     type="xbauk:Nachweisdaten">
            <xs:annotation>
               <xs:documentation>Angabe der zugrundeliegenden Nachweisdaten.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bindungsbescheidBaulastnummer" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe der Baulastnummer (falls die Bindung eine Baulast ist).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bindungBeschreibung" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Beschreibung der Bindung.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Brennstoff">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zum Brennstoff.</xs:documentation>
      </xs:annotation>
      <xs:choice>
         <xs:element name="code" type="xbau:Code.Brennstoff">
            <xs:annotation>
               <xs:documentation>Angabe des Brennstoffs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nichtGelisteterWert" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Freitextangabe für den Brennstoff</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:choice>
   </xs:complexType>
   <xs:complexType name="Brennstofflager">
      <xs:annotation>
         <xs:documentation>Dieser Typ beinhaltet Daten zu Brennstofflagern.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="brennstoff" minOccurs="0" type="xbau:Brennstoff">
            <xs:annotation>
               <xs:documentation>Angabe des Brennstoffs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="lagermengeBrennstoff" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Angabe des Gesamt-Volumen in Liter (BB) / in m3 (BW)</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="lagerortBrennstoff"
                     minOccurs="0"
                     type="xbau:LagerortBrennstoff">
            <xs:annotation>
               <xs:documentation>Angabe des Lagerorts des Brennstoffs</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="lagerbehaelter" minOccurs="0" type="xbau:Lagerbehaelter">
            <xs:annotation>
               <xs:documentation>Angaben zum Lagerbehälter</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="DatenBauabgang">
      <xs:annotation>
         <xs:documentation>Dieser Typ enthält die Daten, die zum Anlass 'Bauabgang' gehören.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="lageBaugrundstueck"
                     minOccurs="0"
                     type="xbauk:VerwaltungspolitischeKodierung">
            <xs:annotation>
               <xs:documentation>In dieses Element ist die Lage des Baugrundstücks gemäß Gemeindegliederung (bis hinunter zum Gemeindeteil) einzutragen. Der Inhalt des Elements wird in der Behörde gepflegt.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="strassenschluessel" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Hier ist entweder der kommunale Straßenschlüssel oder der offizielle ALKIS-Schlüssel (Amtliches Liegenschaftskatasterinformationssystem) einzutragen. Der Inhalt des Elements wird in der Behörde gepflegt.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bauabgang" minOccurs="0" type="xbau:Bauabgang">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält weitere Daten zum Bauabgang. Der Inhalt des Elements ergibt sich aus dem Datentyp DatenBauabgangEingeschraenkt der Eingangsnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDesEigentuemers"
                     minOccurs="0"
                     type="xbau:Code.BauherrOderEigentuemerArt">
            <xs:annotation>
               <xs:documentation>Angabe der Art des Eigentümers Der Inhalt des Elements ergibt sich aus dem Inhalt des Elements "artDesAnzeigenden" im Datentyp AnzeigenderBeseitigung der Eingangsnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDesWohngebaeudes"
                     minOccurs="0"
                     type="xbau:Code.WohngebaeudeArt">
            <xs:annotation>
               <xs:documentation>Hier wird für bauliche Anlagen, die Wohngebäude sind, eine Klassifizierung vorgenommen gemäß Einteilung der amtlichen Statistik. Die Hauptnutzung muss klar erkennbar sein. Der Inhalt des Elements ergibt sich aus dem Datentyp DatenBauabgangEingeschraenkt der Eingangsnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="artDesNichtwohngebaeudes"
                     minOccurs="0"
                     type="xbau:Code.NichtwohngebaeudeArt">
            <xs:annotation>
               <xs:documentation>Bauliche Anlagen, die nicht Wohngebäude sind, werden durch dieses Element klassifiziert gemäß Signierschlüsselverzeichnis des Statistischen Bundesamts. Der Inhalt des Elements ergibt sich aus dem Datentyp DatenBauabgangEingeschraenkt der Eingangsnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="ueberbauteFlaeche" minOccurs="0" type="xbauk:Dezimal.XBau">
            <xs:annotation>
               <xs:documentation>Flächen der Bauwerke oberhalb der Geländeoberfläche. Angabe: Anzahl Quadratmeter mit zwei Nachkommastellen Der Inhalt des Elements ergibt sich aus dem Datentyp DatenBauabgangEingeschraenkt der Eingangsnachricht.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="datumAntragstellung" minOccurs="0" type="xbauk:JahrMonat">
            <xs:annotation>
               <xs:documentation>Hier ist das Datum der Antragstellung einzutragen. Der Inhalt des Elements wird in der Behörde gepflegt.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="DatenBaufreigabeschein">
      <xs:annotation>
         <xs:documentation>Dieser Typ enthält die Daten des Baufreigabescheins (sog. "Roter Punkt").</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="bezeichnungDesBauvorhabens" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält die Bezeichnung des Vorhabens.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="entwurfsverfasser" type="xbauk:Akteur">
            <xs:annotation>
               <xs:documentation>In dieses Element sind die Personendaten des Entwurfsverfassers einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bauleiter" type="xbauk:Akteur">
            <xs:annotation>
               <xs:documentation>In dieses Element sind die Personendaten des Bauleiters einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="teilbaufreigabe" minOccurs="0" type="xs:token">
            <xs:annotation>
               <xs:documentation>Sofern ein Teilbaufreigabeschein erteilt wird, ist hier der Umfang des Teilbaufreigabescheins anzugeben.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="anlage" minOccurs="0" type="xbau:Anlagen">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält die Metadaten zum Baufreigabeschein.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="DatenabrufType">
      <xs:annotation>
         <xs:documentation>Dieser Datentyp enthält die Metadaten eines XNachweis-Abrufs. Die im Rahmen dieses Abrufs übermittelten Nachrichtenelemente werden über die Abruf-ID referenziert.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="abrufId" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Dieses Element ist die ID eines XNachweis-Datenabrufs. Sie entspricht der in der XNachweis-Nachricht übermittelten requestId. Daten, die aus diesem Abruf stammen, wird die ID im Element nachweisbezug beigefügt.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zeitstempel" type="xs:dateTime">
            <xs:annotation>
               <xs:documentation>In diesem Element werden Datum und Zeit des Abrufs dokumentiert.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="quelle" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier wird die Quelle des Datenabrufs angegeben, z.B. das Register.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="nachweissubjekt" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In diesem Element ist das Nachweissubjekt (Person oder Unternehmen) zu nennen, zu dem die Daten abgerufen wurden. Die Angabe sollte hinreichend genau sein, um eine zweifelsfreie Zuordnung zu ermöglichen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="zweck" minOccurs="0" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>In diesem Element kann angegeben werden, welchem Zweck der Datenabruf dient, z.B. Bauvorlageberechtigung Entwurfsverfasser.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Datenblatt">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient zur Zusammenstellung von technischen Daten und Kennzahlen zum Bauvorhaben. Seine Daten werden für die Prüfung des Bauvorhabens durch die Bauaufsichtsbehörde erhoben, aber ggf. auch im Hinblick auf eine Datenlieferung an weitere Stellen. Die Elemente des Typs sind optional, um ihn in den Ländern je nach rechtlicher Situation und Prioritätensetzung durch Behörden flexibel einsetzbar zu machen. Die Angaben im Datenblatt sind auf den jeweils neuen Zustand (Zustand nach Durchführung des Bauvorhabens) zu beziehen und decken so alle Arten von Bauvorhaben (nicht nur die Errichtung, sondern auch Erweiterung und Nutzungsänderung) ab. Veränderungen (also bspw. das Delta zwischen Zustand alt und neu bei einer Erweiterung) sind nicht im vorliegenden Typ abgebildet, sondern sind aus der Historisierung der Daten erkennbar.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="nutzungen" minOccurs="0" type="xbau:Nutzungen">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Angaben zur Nutzung.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="abgrabungenUndAufschuettungen"
                     minOccurs="0"
                     type="xbau:AbgrabungenUndAufschuettungen">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Angaben zu Abgrabungen und Aufschüttungen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="flaechen" minOccurs="0" type="xbau:Flaechen">
            <xs:annotation>
               <xs:documentation>Dieses Element enthält Angaben zu Flächen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="EingereichteBauvorlagen">
      <xs:annotation>
         <xs:documentation>Hier kann die Kategorie der eingereichten Bauvorlage und die Bezeichnung der eingereichten Datei eingetragen werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="kategorieBauvorlage" type="xbau:Code.AnlageArt">
            <xs:annotation>
               <xs:documentation>Hier kann die Kategorie der eingereichten Bauvorlage eingetragen werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="bezeichnungDatei" type="din91379:datatypeC">
            <xs:annotation>
               <xs:documentation>Hier kann die Bezeichnung der eingereichten Bauvorlage eingetragen werden.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="Entwurfsverfasser">
      <xs:annotation>
         <xs:documentation>Dieser Typ dient dazu, die Daten des Entwurfsverfassers zu übermitteln, der verantwortlich an der Vorbereitung des Bauprojekts mitwirkt bzw. mitgewirkt hat.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="personendaten" type="xbauk:Akteur">
            <xs:annotation>
               <xs:documentation>Hier sind die Daten zur natürlichen oder juristischen Person in der Rolle Entwurfsverfasser einzutragen.</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="berechtigung" minOccurs="0" type="xbau:Berechtigung">
            <xs:annotation>
               <xs:documentation>Hier sind die Daten einzutragen, die die Berechtigung des Entwurfsverfassers belegen.</xs:documentation>
            </xs:annotation>
         </xs:element>
      </xs:sequence>
   </xs:complexType>
   <xs:complexType name="ErfuellungGEG">
      <xs:annotation>
         <xs:documentation>Angabe, ob die Verpflichtungen des Gebäudeenergiegesetzes (GEG) erfüllt werden. Diese Daten müssen nur bei Neubauten übermittelt werden.</xs:documentation>
      </xs:annotation>
      <xs:sequence>
         <xs:element name="erneuerbareEnergieFesteBiomasse"
                     minOccurs="0"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Durch die Übermittlung dieses Elements/Attributs wird mitgeteilt, dass feste Biomasse nach § 71ff GEG genutzt wird. In diesem Element/Attribut ist nur der Wert "true" zulässig (fixed-Wert).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="erneuerbareEnergieFluessigeBiomasse"
                     minOccurs="0"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Durch die Übermittlung dieses Elements/Attributs wird mitgeteilt, dass flüssige Biomasse nach § 71ff GEG genutzt wird. In diesem Element/Attribut ist nur der Wert "true" zulässig (fixed-Wert).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="erneuerbareEnergieGasfoermigeBiomasse"
                     minOccurs="0"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Durch die Übermittlung dieses Elements/Attributs wird mitgeteilt, dass gasförmige Biomasse nach § 71ff GEG genutzt wird. In diesem Element/Attribut ist nur der Wert "true" zulässig (fixed-Wert).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="erneuerbareEnergieSolarthermie"
                     minOccurs="0"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Durch die Übermittlung dieses Elements/Attributs wird mitgeteilt, dass solarthermische Anlagen nach § 71ff GEG genutzt werden. In diesem Element/Attribut ist nur der Wert "true" zulässig (fixed-Wert).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="erneuerbareEnergieStrom" minOccurs="0" type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Durch die Übermittlung dieses Elements/Attributs wird mitgeteilt, dass Strom aus erneuerbaren Energien nach § 71ff GEG genutzt wird. In diesem Element/Attribut ist nur der Wert "true" zulässig (fixed-Wert).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="erneuerbareEnergieWaermepumpe"
                     minOccurs="0"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Durch die Übermittlung dieses Elements/Attributs wird mitgeteilt, dass erneuerbare Energie mittels Wärmepumpen nach § 71ff GEG genutzt wird. In diesem Element/Attribut ist nur der Wert "true" zulässig (fixed-Wert).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="erneuerbareEnergieGeothermieUmweltwaerme"
                     minOccurs="0"
                     type="xs:boolean">
            <xs:annotation>
               <xs:documentation>Durch die Übermittlung dieses Elements/Attributs wird mitgeteilt, dass Geothermie oder Umweltwärme nach § 71ff GEG genutzt wird. In diesem Element/Attribut ist nur der Wert "true" zulässig (fixed-Wert).</xs:documentation>
            </xs:annotation>
         </xs:element>
         <xs:element name="erneuerbareEnergieKraftWaermeKopplung"
                     minOccurs="0"
                     type="xs:boolean">
            <xs:annotation>
