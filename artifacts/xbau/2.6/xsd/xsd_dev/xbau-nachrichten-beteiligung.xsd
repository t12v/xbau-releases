                  <xs:element name="rechtsfolgeFristversaeumnis" minOccurs="0" type="xbauk:Text">
                     <xs:annotation>
                        <xs:documentation>Ggf. können hier gemäß geltendem Recht Angaben zu den Konsequenzen bei Fristversäumnis eingetragen werden (Zustimmung durch Untätigkeit).</xs:documentation>
                     </xs:annotation>
                  </xs:element>
