        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163578725265_389339_1270" name="xsdgroup on Simpletype or Complextype" visibility="public" constrainedElement="magicdraw_1046683708328_985822_255">
