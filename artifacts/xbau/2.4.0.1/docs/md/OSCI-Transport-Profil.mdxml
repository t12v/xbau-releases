					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1445441338427_848998_2990' body='Mit dieser Eigenschaft kann der Namensraumbestandteil des WSDL-Dokuments bestimmt werden, welcher zusammen mit dem Namen der WSDL-Datei den vollständigen Namensraum bildet.&#10;&#10;Wird diese Eigenschaft nicht befüllt, wird der Namensraum nach einem festen Muster (aus Projektnamensraum, Projektpräfix, Projektversion und Dienstname) gebildet.'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1445441254453_81289_2986'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1445441271730_827301_2988'/>
