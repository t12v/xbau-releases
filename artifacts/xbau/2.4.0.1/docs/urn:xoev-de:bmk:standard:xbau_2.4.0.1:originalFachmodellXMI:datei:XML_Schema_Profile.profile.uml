        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163575564875_842586_1230" name="" visibility="public">
          <language>OCL2.0</language>
          <body>(not type.oclIsUndefined()) implies type.oclIsKindOf(XSDsimpleType) or type.oclIsKindOf(XSDcomplexType) or (type.oclIsKindOf(XSDcomponent) and name='anyType')</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163578065437_960718_1249" name="No xsdattribute in xsdsimpletype" visibility="public" constrainedElement="magicdraw_1046682040730_843189_181">
        <ownedComment xmi:id="_12_0_8f90291_1163578065437_986038_1251" annotatedElement="_12_0_8f90291_1163578065437_960718_1249" body="No XSDAttributes in XSDSimpleTypes"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163578065437_66190_1250" name="" visibility="public">
          <language>OCL2.0</language>
          <body>not owner.appliedStereotypeInstance.oclIsUndefined() and
owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') ->size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163576703203_207632_1239" name="No xsdelement in xsdsimpletype" visibility="public" constrainedElement="magicdraw_1046682074970_241068_216">
