        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499768519879_314747_4019" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499768519879_828992_4017" name="" visibility="public" value="*"/>
