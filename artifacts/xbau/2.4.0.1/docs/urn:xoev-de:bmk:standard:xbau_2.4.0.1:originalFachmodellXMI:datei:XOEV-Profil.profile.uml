      <ownedAttribute xmi:id="_9_5_6370212_1124307269772_141955_11" name="pattern" visibility="private">
        <ownedComment xmi:id="_12_1_8b00279_1240229372299_623916_607" annotatedElement="_9_5_6370212_1124307269772_141955_11" body="&lt;para>xs:pattern&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-pattern&quot;>http://www.w3.org/TR/xmlschema-2/#rf-pattern&lt;/ulink>&lt;/para>&lt;/footnote> definiert ein Muster, das auf einen String angewendet wird.&lt;/para>&#xA;&lt;para>Zulässig ist die Angabe einer solchen Facette im XML-Schema für die folgenden W3C-Datentypen&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&quot;>http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&lt;/ulink> und &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-derived&quot;>http://www.w3.org/TR/xmlschema-2/#built-in-derived&lt;/ulink>&lt;/para>&lt;/footnote>: xs:anyURI, xs:base64Binary, xs:boolean, xs:byte, xs:date, xs:dateTime, xs:decimal, xs:double, xs:duration, xs:ENTITY, xs:float, xs:gDay, xs:gMonth, xs:gYear, xs:gYearMonth, xs:hexBinary, xs:ID, xs:IDREF, xs:int, xs:integer, xs:language, xs:long, xs:Name, xs:NCName, xs:negativeInteger, xs:NMTOKEN, xs:nonNegativeInteger, xs:nonPositiveInteger, xs:normalizedString, xs:NOTATION, xs:positiveInteger, xs:QName, xs:short, xs:string, xs:time, xs:token, xs:unsignedByte, xs:unsignedInt, xs:unsignedLong, xs:unsignedShort.&lt;/para>&#xA;&#xA;&lt;para>Hinweis: Sonderzeichen sind ggf. mit den üblichen XML-Mitteln zu maskieren, sodass ungültige &lt;quote>pattern&lt;/quote>-Werte vermieden werden.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1169814957687_432119_1160" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_11_5_6370212_1169814957687_206788_1161" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_12_1_8b00279_1240231554618_187455_633" name="totalDigits" visibility="private">
        <ownedComment xmi:id="_12_1_8b00279_1240231816641_117760_637" annotatedElement="_12_1_8b00279_1240231554618_187455_633" body="&lt;para>xs:totalDigits&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-totalDigits&quot;>http://www.w3.org/TR/xmlschema-2/#rf-totalDigits&lt;/ulink>&lt;/para>&lt;/footnote> definiert die maximale Anzahl von Dezimalziffern.&lt;/para>&#xA;&lt;para>Zulässig ist die Angabe einer solchen Facette im XML-Schema für die folgenden W3C-Datentypen&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&quot;>http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&lt;/ulink> und &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-derived&quot;>http://www.w3.org/TR/xmlschema-2/#built-in-derived&lt;/ulink>&lt;/para>&lt;/footnote>: xs:byte, xs:decimal, xs:int, xs:integer, xs:long, xs:negativeInteger, xs:nonNegativeInteger, xs:nonPositiveInteger, xs:positiveInteger, xs:short, xs:unsignedByte, xs:unsignedInt, xs:unsignedLong, xs:unsignedShort.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
