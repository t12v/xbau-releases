    <packagedElement xmi:type="uml:Stereotype" xmi:id="_18_0_6_5b501fb_1563113608422_755298_12224" name="xsdWithAnyAttribute" visibility="public">
      <ownedComment xmi:id="_18_0_6_5b501fb_1563113608422_811068_12226" annotatedElement="_18_0_6_5b501fb_1563113608422_755298_12224" body="&lt;para>Eine mit diesem Stereotyp versehene UML-Klasse wird im XML-Schema als Typ umgesetzt, der beliebige XML-Elemente enthalten kann.&lt;/para>&#xA;&lt;para>Die Umsetzung des Stereotyps wird im XML-Schema durch xs:any&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Wildcards&quot;>http://www.w3.org/TR/xmlschema-1/#Wildcards&lt;/ulink>&lt;/para>&lt;/footnote> realisiert.&lt;/para>"/>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1563113608422_816733_12248" name="base_Class" visibility="private" association="_18_0_6_5b501fb_1563113608422_500696_12247">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1563113608422_317263_12229" name="namespace" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1563113608422_585203_12240" annotatedElement="_18_0_6_5b501fb_1563113608422_317263_12229" body="&lt;para>Die Eigenschaft legt den XML-Namensraum fest, aus dem die Inhalte kommen dürfen. Standardwert ist der Namensraum &lt;quote>##any&lt;/quote>.&lt;/para>&#xA;  &lt;para>Der Wert wird direkt in das XML-Schema übernommen.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1563113608422_911258_12241" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1563113608422_861400_12239" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:LiteralString" xmi:id="_18_0_6_5b501fb_1563113608422_829184_12242" name="" visibility="public" value="##any"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1563113608422_62626_12230" name="processContents" visibility="private" type="_16_5_4_b7102e0_1316421278144_216181_537">
        <ownedComment xmi:id="_18_0_6_5b501fb_1563113608422_248168_12244" annotatedElement="_18_0_6_5b501fb_1563113608422_62626_12230" body="&lt;para>Mit dieser Eigenschaft kann der Wert des Attributs processContents definiert werden, der standardmäßig auf &lt;quote>strict&lt;/quote> (Namensraum muss verfügbar sein und Validierung findet statt) eingestellt ist. Mögliche Werte sind ausserdem &lt;quote>lax&lt;/quote> (Validierung nur wenn der Namensraum verfügbar ist) und &lt;quote>skip&lt;/quote> (keine Validierung).&lt;/para>&#xA;&lt;para>Der Wert wird direkt in das XML-Schema übernommen.&lt;/para>"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1563113608422_544346_12245" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1563113608422_744264_12243" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:LiteralString" xmi:id="_18_0_6_5b501fb_1563113608422_397254_12246" name="" visibility="public" value="strict"/>
      </ownedAttribute>
      <icon xmi:id="_18_0_6_5b501fb_1563113608422_172671_12225" content="" format="" location=""/>
    </packagedElement>
