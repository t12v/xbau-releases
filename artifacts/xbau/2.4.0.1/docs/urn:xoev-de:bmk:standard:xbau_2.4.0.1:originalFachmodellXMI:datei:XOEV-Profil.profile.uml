    <packagedElement xmi:type="uml:Stereotype" xmi:id="_11_5_6370212_1157547867034_698291_2" name="xsdMessage" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169816674250_883090_17" annotatedElement="_11_5_6370212_1157547867034_698291_2" body="&lt;para>Der Stereotyp &quot;xsdMessage&quot; kennzeichnet die Instanzen dieser UML-Klasse als Nachrichten im XÖV-Sinne, also einer elektronischen Datenübermittlung innerhalb und mit der Verwaltung.&lt;/para>&#xA;&lt;para>Da XÖV-Nachrichten XML-Instanzen darstellen, sind diese mittels des Stereotyps &quot;xsdGlobalElement&quot; immer als globale XML-Elemente zu definieren.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1157547876320_334985_5" name="base_Class" visibility="private" association="_11_5_6370212_1157547876320_487443_4">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1169816586562_669702_7" name="leser" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169816736546_935010_19" annotatedElement="_11_5_6370212_1169816586562_669702_7" body=""/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1169816595859_581097_11" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1590752516126_234356_4232" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1169816597703_721827_13" name="rechtsgrundlagen" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169816707703_160789_18" annotatedElement="_11_5_6370212_1169816597703_721827_13" body="&lt;para>Die Rechtsgrundlage(n) wie beispielsweise  Gesetze, Verordnungen oder Satzungen zu dieser Nachricht.&lt;/para>&#xA;&lt;para>Die Information dient nur zu Dokumentationszwecken und hat keine Auswirkung auf die Struktur des XML-Schemas: Es erfolgt eine Ausgabe in der Dokumentation des jeweiligen xs:element&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;>http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink>&lt;/para>&lt;/footnote>-Eintrags im XML-Schema.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_12_1_8b00279_1240219392990_920357_586" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_12_1_8b00279_1240219392990_283329_587" name="" visibility="public" value="*"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1169816557656_753260_1" name="autor" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169816772343_218412_20" annotatedElement="_11_5_6370212_1169816557656_753260_1" body=""/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1169816580687_120891_5" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1590752520812_763553_4233" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_5b501fb_1326204703881_778395_389" name="wsdlVorlagedatei" visibility="private" type="_18_0_6_5b501fb_1590767326933_253997_4232">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1590767420540_678049_4236" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1590767420540_55174_4237" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="_18_0_6_5b501fb_1590767430014_781313_4238" name="" visibility="public" instance="_18_0_6_5b501fb_1590767382572_405930_4233"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124307426007_721881_130" name="xsdImport" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1179674784156_14714_6" annotatedElement="_9_5_6370212_1124307426007_721881_130" body="&lt;para>Die mit dem Stereotyp gekennzeichnete UML-Abhängigkeit bildet eine Import-Beziehung zwischen zwei &quot;xsdSchema&quot;-UML-Paketen ab.&lt;/para>&#xA;&lt;para>Das XML-Schema des Anbieter-Pakets (Ende mit Pfeilspitze) wird durch ein xs:import&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;>http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink>&lt;/para>&lt;/footnote> in das XML-Schema des abhängigen Pakets eingebunden.&lt;/para>"/>
      <ownedAttribute xmi:id="_9_5_6370212_1124307488998_373216_144" name="prefix" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1179674808890_881389_7" annotatedElement="_9_5_6370212_1124307488998_373216_144" body="&lt;para>Das XML-Präfix, mit dem der Namensraum des importierten Schemas angesprochen werden soll.&lt;/para>&#xA;&lt;para>Der Wert wird direkt in das XML-Schema übernommen.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1169814309640_74715_388" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_11_5_6370212_1169814309640_177159_389" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_10_5_6370212_1135160639817_719288_78" name="base_Dependency" visibility="private" association="_10_5_6370212_1135160639817_199799_77">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1360231538062_197764_414" name="schemaLocationDeployment" visibility="private">
        <ownedComment xmi:id="_16_5_4_b7102e0_1360231703547_510180_415" annotatedElement="_16_5_4_b7102e0_1360231538062_197764_414" body="Mit dieser Eigenschaft kann die SchemaLocation für ein importiertes Schema angegeben werden, die bei einem Release (deployment=true) ausgegeben wird.&#xA;Die Eigenschaft ist vor allem für eingebundene XÖV-kompatible Modelle gedacht bei denen nur das komplette Schema vorliegt."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1360231722513_617741_416" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1360231722513_115052_417" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1360231736150_325481_418" name="schemaLocationLocal" visibility="private">
        <ownedComment xmi:id="_16_5_4_b7102e0_1360231822857_189671_419" annotatedElement="_16_5_4_b7102e0_1360231736150_325481_418" body="Mit dieser Eigenschaft kann die SchemaLocation für ein importiertes Schema angegeben werden, die bei einem Arbeitsbuild (deployment=false) ausgegeben wird.&#xA;Die Eigenschaft ist vor allem für eingebundene XÖV-kompatible Modelle gedacht bei denen nur das komplette Schema vorliegt und die Validierung des resultierenden Schemas nicht mit den vom XGenerator erzeugten Fragmenten funktionieren würde."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1360231848051_636417_420" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1360231848051_74401_421" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638885_199327_21" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124265393034_976238_33" name="xsdAnyContents" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169806628859_282358_122" annotatedElement="_9_5_6370212_1124265393034_976238_33" body="&lt;para>Eine mit diesem Stereotyp versehene UML-Klasse wird im XML-Schema als Typ umgesetzt, der beliebige XML-Elemente enthalten kann.&lt;/para>&#xA;&lt;para>Die Umsetzung des Stereotyps wird im XML-Schema durch xs:any&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Wildcards&quot;>http://www.w3.org/TR/xmlschema-1/#Wildcards&lt;/ulink>&lt;/para>&lt;/footnote> realisiert.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1169814709562_250547_654" name="base_Class" visibility="private" association="_11_5_6370212_1169814709562_7309_653">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1310993138097_235326_352" name="maxOccurs" visibility="private">
        <ownedComment xmi:id="_16_5_4_b7102e0_1314795253830_668437_623" annotatedElement="_16_5_4_b7102e0_1310993138097_235326_352" body="&lt;para>Mit dieser Eigenschaft wird die maximale Anzahl der Elemente aus dem in der Eigenschaft &quot;namespace&quot; definierten Namensraum festgelegt.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1310993186798_556223_354" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1310993186798_505412_355" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:LiteralString" xmi:id="_16_5_4_b7102e0_1310993186798_396431_356" name="" visibility="public" value="unbounded"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1310992868923_31184_344" name="minOccurs" visibility="private">
        <ownedComment xmi:id="_16_5_4_b7102e0_1314795216218_759617_622" annotatedElement="_16_5_4_b7102e0_1310992868923_31184_344" body="&lt;para>Mit dieser Eigenschaft wird die minimale Anzahl der Elemente aus dem in der Eigenschaft &quot;namespace&quot; definierten Namensraum festgelegt.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1310993133509_42252_349" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1310993133509_10323_350" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:LiteralString" xmi:id="_16_5_4_b7102e0_1310993133510_677074_351" name="" visibility="public" value="0"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_9_5_6370212_1124265422386_530314_47" name="namespace" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1179674140843_551404_2" annotatedElement="_9_5_6370212_1124265422386_530314_47" body="&lt;para>Die Eigenschaft legt den XML-Namensraum fest, aus dem die Inhalte kommen dürfen. Standardwert ist der Namensraum &lt;quote>##any&lt;/quote>.&lt;/para>&#xA;  &lt;para>Der Wert wird direkt in das XML-Schema übernommen.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_12_1_8b00279_1248762679031_229268_204" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_12_1_8b00279_1248762679031_575587_205" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:LiteralString" xmi:id="_16_5_4_5b501fb_1280399424738_398872_921" name="" visibility="public" value="##any"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_5b501fb_1280399248925_4946_530" name="processContents" visibility="private" type="_16_5_4_b7102e0_1316421278144_216181_537">
        <ownedComment xmi:id="_16_5_4_5b501fb_1280399669190_271673_922" annotatedElement="_16_5_4_5b501fb_1280399248925_4946_530" body="&lt;para>Mit dieser Eigenschaft kann der Wert des Attributs processContents definiert werden, der standardmäßig auf &lt;quote>strict&lt;/quote> (Namensraum muss verfügbar sein und Validierung findet statt) eingestellt ist. Mögliche Werte sind ausserdem &lt;quote>lax&lt;/quote> (Validierung nur wenn der Namensraum verfügbar ist) und &lt;quote>skip&lt;/quote> (keine Validierung).&lt;/para>&#xA;&lt;para>Der Wert wird direkt in das XML-Schema übernommen.&lt;/para>"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1280400428684_880553_923" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1280400428684_505762_924" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:LiteralString" xmi:id="_16_5_4_5b501fb_1280400428686_180432_925" name="" visibility="public" value="strict"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638885_804587_15" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_11_5_6370212_1161246056421_346423_2" name="xsdUnique" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169817055265_31879_138" annotatedElement="_11_5_6370212_1161246056421_346423_2" body="&lt;para>Eine mit diesem Stereotyp gekennzeichnete UML-Abhängigkeit modelliert ein xs:unique-Constraint&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> in XML. Der Name der UML-Abhängigkeit wird als Name des xs:unique&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> verwendet.&lt;/para>&#xA;&lt;para>Die Anwendung auf eine UML-Abhängigkeit im UML-Modell erfolgt analog zum Stereotyp &quot;xsdKey&quot;.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1161246159625_177555_26" name="fields" visibility="private" isOrdered="true">
        <ownedComment xmi:id="_11_5_6370212_1169817186937_272180_144" annotatedElement="_11_5_6370212_1161246159625_177555_26" body="&lt;para>Die Pfadausdrücke für die xs:field-Elemente&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1161951520376_248301_2" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_14_0_5b501fb_1208802571735_164011_103" name="" visibility="public" value="*"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1161345127734_606639_1" name="selector" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169817135937_52723_141" annotatedElement="_11_5_6370212_1161345127734_606639_1" body="&lt;para>Der Pfadausdruck für das xs:selector-Element&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1161345141437_23528_3" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_11_5_6370212_1161345141437_333094_4" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1161952263197_459667_2" name="base_Dependency" visibility="private" association="_11_5_6370212_1161952263197_98404_1">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_11_5_6370212_1161955620211_19087_2" name="xsdKey" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169817041843_242072_137" annotatedElement="_11_5_6370212_1161955620211_19087_2" body="&lt;para>Eine mit diesem Stereotyp gekennzeichnete UML-Abhängigkeit modelliert ein xs:key-Constraint&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> im XML-Schema. Der Name der UML-Abhängigkeit wird als Name des xs:key&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> verwendet.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1161955674284_91755_30" name="fields" visibility="private" isOrdered="true">
        <ownedComment xmi:id="_11_5_6370212_1169817181234_213353_143" annotatedElement="_11_5_6370212_1161955674284_91755_30" body="&lt;para>Die Pfadausdrücke für die xs:field-Elemente&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1161955679342_943667_32" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_14_0_5b501fb_1208802571719_772649_100" name="" visibility="public" value="*"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1161955706749_578258_34" name="selector" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169817116984_724064_140" annotatedElement="_11_5_6370212_1161955706749_578258_34" body="&lt;para>Der Pfadausdruck für das xs:selector-Element&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1161955713801_154905_36" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_11_5_6370212_1161955713801_197537_37" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1161955766315_452751_39" name="base_Dependency" visibility="private" association="_11_5_6370212_1161955766315_561948_38">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_11_5_6370212_1162384324470_855386_103" name="xsdKeyref" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169817067500_277666_139" annotatedElement="_11_5_6370212_1162384324470_855386_103" body="&lt;para>Die mit diesem Stereotyp gekennzeichnete UML-Abhängigkeit modelliert ein xs:keyref&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>-Constraint in XML. Der Name der UML-Abhängigkeit wird als Name des xs:keyref&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> verwendet.&lt;/para>&#xA;&lt;para>Da sich die Key-Constraints in XML-Schema immer auf ein XML-Element (und nicht auf einen XML-Typen) beziehen, werden sie auch in UML entsprechend an eine mit &quot;xsdElement&quot; versehene Klasseneigenschaft (UML-Attribut oder -Kompositition) annotiert.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1162384324474_206626_111" name="base_Dependency" visibility="private" association="_11_5_6370212_1162384324473_942719_110">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1162384324471_629412_104" name="fields" visibility="private" isOrdered="true">
        <ownedComment xmi:id="_11_5_6370212_1169817195750_360131_145" annotatedElement="_11_5_6370212_1162384324471_629412_104" body="&lt;para>Die Pfadausdrücke für die xs:field-Elemente&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1162384324472_857424_107" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_14_0_5b501fb_1208802571719_122612_101" name="" visibility="public" value="*"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1169739604296_404318_1" name="refer" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1179674976093_318592_129" annotatedElement="_11_5_6370212_1169739604296_404318_1" body="&lt;para>Der Name des xs:key- oder xs:unique-Constraints&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>, auf das sich dieses xs:keyref-Constraint&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> bezieht.&lt;/para>&#xA;&lt;para>Die Umsetzung erfolgt als Attribut &quot;refer&quot; des xs:keyref-Elements&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1169739617281_781037_3" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_11_5_6370212_1169739617281_573413_4" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1162384324471_388832_105" name="selector" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169817142828_451375_142" annotatedElement="_11_5_6370212_1162384324471_388832_105" body="&lt;para>Der Pfadausdruck für das 'refer'-Attribut im xs:keyref&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>. Es muss ein xs:key- oder xs:unique-Constraint&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> mit diesem Namen im Modell geben.&lt;/para>&#xA;&lt;para>Die Umsetzung erfolgt als xs:selector&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
