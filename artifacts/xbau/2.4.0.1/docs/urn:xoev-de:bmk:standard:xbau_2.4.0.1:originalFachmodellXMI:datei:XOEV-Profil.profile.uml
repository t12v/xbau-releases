        <ownedComment xmi:id="_18_0_6_5b501fb_1499769708695_918493_4440" annotatedElement="_18_0_6_5b501fb_1499769708695_478570_4410" body="Der Name (kurz) ist die &quot;sprechende&quot; Kurzbezeichnung eines Datentyps. Dieser Name wird beispielsweise im XRepository in Listendarstellungen von Inhalten verwendet oder kann zur Bezeichnung des Datentyps in Texten (Spezifikationsdokument) verwendet werden."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
