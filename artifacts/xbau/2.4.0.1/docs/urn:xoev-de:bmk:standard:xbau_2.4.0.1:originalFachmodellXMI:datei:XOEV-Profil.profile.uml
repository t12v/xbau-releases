    <packagedElement xmi:type="uml:Stereotype" xmi:id="_18_0_6_5b501fb_1499768519864_957106_4009" name="xoevCodeliste" visibility="public">
      <ownedComment xmi:id="_18_0_6_5b501fb_1501330831621_171704_4113" annotatedElement="_18_0_6_5b501fb_1499768519864_957106_4009" body="Mittels dieses Stereotyps wird die UML-Enumeration einer Codeliste annotiert. Er erlaubt die Angabe der versionsunabhängigen Metadaten der Codeliste."/>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499768519879_82614_4039" name="base_Enumeration" visibility="private" association="_18_0_6_5b501fb_1499768519879_512125_4038">
