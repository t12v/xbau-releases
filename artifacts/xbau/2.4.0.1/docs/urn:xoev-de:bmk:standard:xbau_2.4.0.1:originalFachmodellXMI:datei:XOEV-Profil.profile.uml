    <packagedElement xmi:type="uml:Stereotype" xmi:id="_11_5_6370212_1181826329822_66722_3772" name="xsdTitled" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1207143051046_441558_3" annotatedElement="_11_5_6370212_1181826329822_66722_3772" body="&lt;para>Ein mit diesem Stereotyp gekennzeichnetes UML-Element (z.B. eine UML-Klasse) erhält in der Dokumentation des XÖV-Standards einen anderen Titel als seinen Namen im UML-Modell (z.B. den UML-Klassennamen). Dies ist insbesondere dann sinnvoll, wenn der Titel in der Dokumentation beispielsweise Leerzeichen oder Umlaute enthalten soll.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1181826329822_358801_3774" name="base_Element" visibility="private" association="_11_5_6370212_1181826329822_317572_3773">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Element"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1170240822453_184342_1" name="title" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1179674937750_328255_11" annotatedElement="_11_5_6370212_1170240822453_184342_1" body="&lt;para>Der Prosa-Titel in der Dokumentation.&lt;/para>&#xA;&lt;para>Im XML-Schema wird die Eigenschaft in xs:annotation des jeweiligen XML-Schema-Bestandteils abgebildet.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_14_0_5b501fb_1239108443131_132845_1103" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_14_0_5b501fb_1239108443131_719273_1104" name="" visibility="public" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_11_5_6370212_1181825895666_44096_93" name="xsdWithImplementationHint" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1207143171921_571560_4" annotatedElement="_11_5_6370212_1181825895666_44096_93" body="&lt;para>Ein mit diesem Stereotyp gekennzeichnetes UML-Element erhält in der Dokumentation neben der normalen Beschreibung einen Abschnitt mit Implementierungshinweisen.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1181826014072_327233_113" name="base_Element" visibility="private" association="_11_5_6370212_1181826014072_287792_112">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Element"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1181827583119_960162_4154" name="implementationHint" visibility="private">
        <ownedComment xmi:id="_12_1_8b00279_1240319752226_284628_285" annotatedElement="_11_5_6370212_1181827583119_960162_4154" body="&lt;para>Der Implementierungshinweis zu dem XML-Bestandteil.&lt;/para>&#xA;&lt;para>Im XML-Schema wird die Eigenschaft in xs:annotation des jeweiligen XML-Schema-Bestandteils abgebildet.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_14_0_5b501fb_1239108495983_830996_1106" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_14_0_5b501fb_1239108495983_28614_1107" name="" visibility="public" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_11_5_6370212_1197040199062_390349_11" name="xoevCodelisteneintrag" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1207142970046_935815_2" annotatedElement="_11_5_6370212_1197040199062_390349_11" body="&lt;para>Mit diesem Stereotyp werden Literale einer  UML-Enumeration als Wert einer &amp;clst; (UML-Enumeration mit dem Stereotyp &quot;xsdCodeList&quot;)  gekennzeichnet.&lt;/para>&#xA;&lt;para>Die Umsetzung des Stereotyps im XML-Schema erfolgt als xs:enumeration&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&quot;>http://www.w3.org/TR/xmlschema-2/#rf-enumeration&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1197040223296_174154_31" name="base_EnumerationLiteral" visibility="private" association="_11_5_6370212_1197040223296_689223_30">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#EnumerationLiteral"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_11_5_6370212_1197040232437_934738_35" name="wertErsteBeschreibungsspalte" visibility="private">
        <ownedComment xmi:id="_12_1_8b00279_1240306708182_393937_212" annotatedElement="_11_5_6370212_1197040232437_934738_35" body=""/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_12_1_8b00279_1241704661212_722338_514" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_12_1_8b00279_1241704661212_729451_515" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1500890405977_823523_4113" name="wertZweiteBeschreibungsspalte" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1500890405977_232079_4115" annotatedElement="_18_0_6_5b501fb_1500890405977_823523_4113" body=""/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1500890405977_422192_4116" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1500890405977_221679_4114" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_5b501fb_1322499063960_322188_432" name="obsolet" visibility="private">
        <ownedComment xmi:id="_16_5_4_5b501fb_1322501557543_392565_366" annotatedElement="_16_5_4_5b501fb_1322499063960_322188_432" body="&lt;para>Mit diesem Schalter können veraltete, nicht mehr zu übermittelnde Codes gekennzeichnet werden (obsolete = true). Deartig gekennzeichnete Codes, d. h. Literale einer Enumeration, werden im Kontext einer Standard-Codeliste nicht mehr in das Schema herausgeschrieben. Auf diese Weise kann die (unbemerkte) Wiederverwendung alter Codes für neue Zwecke, d. h. mit neuer Bedeutung, vermieden werden, da doppelte Codes in einer Enumeration in UML nicht zugelassen werden.&lt;/para> &lt;para>Der Default-Wert der Eigenschaft &quot;obsolete&quot; ist &quot;false&quot;.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1322499081816_700799_435" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1322499081816_852808_436" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="_16_5_4_5b501fb_1322499094610_756063_440" name="" visibility="public"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_12_1_8b00279_1240305730667_765894_120" name="xsdCode" visibility="public">
      <ownedComment xmi:id="_12_1_8b00279_1240305907173_196075_157" annotatedElement="_12_1_8b00279_1240305730667_765894_120" body="&lt;para>Eine UML-Klasse, die mit dem Stereotypen &quot;xsdCode&quot; versehen ist, stellt einen Code-Datentyp dar, der eine einzusetzende &amp;clst; näher beschreibt.&lt;/para>&#xA;&lt;para>Die Umsetzung der so stereotypisierten UML-Klasse im XML-Schema erfolgt als xs:complexType&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> mit xs:complexContent&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#declare-type&quot;>http://www.w3.org/TR/xmlschema-1/#declare-type&lt;/ulink>&lt;/para>&lt;/footnote> im XML-Schema.&lt;/para>&#xA;&lt;para>In Abhängigkeit von der zusätzlichen Vergabe des Stereotypen &quot;xsdNamedType&quot; wird der Code-Datentyp als benannter Typ im XML-Schema umgesetzt, ansonsten als anonymer Typ.&lt;/para>"/>
      <ownedAttribute xmi:id="_12_1_8b00279_1240305834261_735373_145" name="base_Class" visibility="private" association="_12_1_8b00279_1240305834261_832017_144">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_12_1_8b00279_1240306417404_766333_161" name="xsdCodeList" visibility="public">
      <ownedComment xmi:id="_12_1_8b00279_1240306628661_568772_211" annotatedElement="_12_1_8b00279_1240306417404_766333_161" body="&lt;para>Die Umsetzung des Stereotyps im XML-Schema erfolgt als xs:simpleType&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> mit dem durch xs:enumeration&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&quot;>http://www.w3.org/TR/xmlschema-2/#rf-enumeration&lt;/ulink>&lt;/para>&lt;/footnote> eingeschränkten Basistyp &quot;xs:token&quot;&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#token&quot;>http://www.w3.org/TR/xmlschema-2/#token&lt;/ulink>&lt;/para>&lt;/footnote>, es sei denn die Eigenschaft &lt;emphasis>base&lt;/emphasis> definiert einen anderen Basistypen. Wird die Codeliste in einem Code Datentyp verwendet, muss der Basistyp vom Typ xs:token oder einer Unterklasse sein.&lt;/para>&#xA;&lt;para>In Abhängigkeit von der zusätzlichen Vergabe des Stereotypen &quot;xsdNamedType&quot; wird die &amp;clst; als benannter Typ im XML-Schema umgesetzt, ansonsten als anonymer Typ.&lt;/para>"/>
      <ownedAttribute xmi:id="_12_1_8b00279_1240306518157_213767_205" name="base_Enumeration" visibility="private" association="_12_1_8b00279_1240306518157_731879_204">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Enumeration"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1310464347811_201332_328" name="base" visibility="private">
        <ownedComment xmi:id="_16_5_4_b7102e0_1316429565493_495332_461" annotatedElement="_16_5_4_b7102e0_1310464347811_201332_328" body="&lt;para>Bestimmt den Obertypen der Enumeration. Dieser muss ein einfacher Typ sein. Bei der Verwendung innerhalb eines XÖV-Codes muss er zusätzlich vom Typ xs:token order ein davon abgeleiteter Typ sein.&lt;/para>"/>
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1310464635387_157256_328" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1310464635388_364329_329" name="" visibility="public" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_16_5_4_8b00279_1264582309240_225915_526" name="xsdLocalStructure" visibility="public">
      <ownedComment xmi:id="_16_5_4_8b00279_1264582638551_280009_554" annotatedElement="_16_5_4_8b00279_1264582309240_225915_526" body="&lt;para>Eine UML-Eigenschaft, die mit &quot;xsdLocalStructure&quot; versehen ist, kennzeichnet, dass die Strukturen der anonymen referenzierten UML-Klasse, die einen Typ mit komplexen Inhalt darstellt, im XML-Schema direkt, ohne Angabe von &quot;xs:complexType&quot;&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> in die darüberliegende Struktur eingebunden werden.&lt;/para>&#xA;&lt;para>Verwendung ohne &quot;xsdLocalStructure&quot;:&lt;/para>&#xA;&lt;programlisting>&lt;![CDATA[&lt;xs:complexType name=&quot;Beispiel&quot;>&#xA;  &lt;xs:sequence>&#xA;    &lt;xs:element name=&quot;ergebnis&quot;>&#xA;      &lt;xs:complexType>&#xA;        &lt;xs:choice>&#xA;          &lt;xs:element name=&quot;grundFuerAusfallDesWettbewerbs&quot; type=&quot;xs:string&quot;/>&#xA;          &lt;xs:element name=&quot;teilnehmer&quot; type=&quot;xhz:Teilnehmer&quot; maxOccurs=&quot;unbounded&quot;/>&#xA;       &lt;/xs:choice>&#xA;     &lt;/xs:complexType>&#xA;   &lt;/xs:element>&#xA;   ...&#xA;  &lt;/xs:sequence>&#xA;&lt;/xs:complexType>]]>&lt;/programlisting>&lt;para>&lt;/para>&#xA;&lt;para>Verwendung mit &quot;xsdLocalStructure&quot;:&lt;/para>&#xA;&lt;programlisting>&lt;![CDATA[&lt;xs:complexType name=&quot;Beispiel&quot;>&#xA;  &lt;xs:sequence>&#xA;    &lt;xs:choice>&#xA;      &lt;xs:element name=&quot;grundFuerAusfallDesWettbewerbs&quot; type=&quot;xs:string&quot;/>&#xA;      &lt;xs:element name=&quot;teilnehmer&quot; type=&quot;xhz:Teilnehmer&quot; maxOccurs=&quot;unbounded&quot;/>&#xA;     &lt;/xs:choice>&#xA;     ...&#xA;  &lt;/xs:sequence>&#xA;&lt;/xs:complexType>]]>&lt;/programlisting>"/>
      <ownedAttribute xmi:id="_16_5_4_8b00279_1264582391052_265825_550" name="base_Property" visibility="private" association="_16_5_4_8b00279_1264582391052_582065_549">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Property"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_5b501fb_1270208088006_335639_526" name="position" visibility="private">
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1270208104074_432819_528" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1270208104074_120801_529" name="" visibility="public" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="_16_5_4_8b00279_1264582391052_582065_549" name="" visibility="public" memberEnd="_16_5_4_8b00279_1264582391052_265825_550 _16_5_4_8b00279_1264582391052_609645_551" navigableOwnedEnd="_16_5_4_8b00279_1264582391052_609645_551">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="_16_5_4_8b00279_1264582391052_609645_551" name="extension_xsdLocalStructure" visibility="private" type="_16_5_4_8b00279_1264582309240_225915_526" aggregation="composite" association="_16_5_4_8b00279_1264582391052_582065_549">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8b00279_1264582391052_729212_552" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8b00279_1264582391052_196587_553" name="" visibility="public" value="1"/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_16_5_4_5b501fb_1276693051258_429282_547" name="xsdDeprecated" visibility="public">
      <ownedComment xmi:id="_16_5_4_5b501fb_1276693182429_121388_577" annotatedElement="_16_5_4_5b501fb_1276693051258_429282_547" body="&lt;para>Dieser Stereotyp kann bei der Dokumentationsgenerierung berücksichtigt werden, um bestimmte Teile eines Standards abzukündigen.&lt;/para>&#xA;&lt;para>Der Stereotyp hat keine Auswirkungen auf die generierten XML-Schemata.&lt;/para>"/>
      <ownedAttribute xmi:id="_16_5_4_5b501fb_1276693051260_841685_549" name="base_Element" visibility="private" association="_16_5_4_5b501fb_1276693051260_225562_548">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Element"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_5b501fb_1276693121229_470354_570" name="deprecatedContext" visibility="private">
        <ownedComment xmi:id="_16_5_4_5b501fb_1276693194740_950700_578" annotatedElement="_16_5_4_5b501fb_1276693121229_470354_570" body="&lt;para>Diese Eigenschaft kann dazu genutzt werden, um mehrere abgekündigte Bestandteile zu gruppieren, da diese z. B. durch einen einzigen Änderungeantrag wegfallen. Innerhalb der generierten Dokumentation kann dann auf einen beschreibenden Abschnitt verwiesen werden.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1276693167382_532928_575" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1276693167382_120464_576" name="" visibility="public" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="_16_5_4_5b501fb_1276693051260_225562_548" name="" visibility="public" memberEnd="_16_5_4_5b501fb_1276693051260_841685_549 _16_5_4_5b501fb_1276693051260_440941_550" navigableOwnedEnd="_16_5_4_5b501fb_1276693051260_440941_550">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="_16_5_4_5b501fb_1276693051260_440941_550" name="extension_unbenannt1" visibility="private" type="_16_5_4_5b501fb_1276693051258_429282_547" aggregation="composite" association="_16_5_4_5b501fb_1276693051260_225562_548">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1276693051260_752970_551" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1276693051260_858826_552" name="" visibility="public" value="1"/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_16_5_4_b7102e0_1282131963663_958424_532" name="xsdXModelImport" visibility="public">
      <ownedComment xmi:id="_16_5_4_b7102e0_1282131963670_843674_534" annotatedElement="_16_5_4_b7102e0_1282131963663_958424_532" body="&lt;para>Dieser Stereotyp wird für die Dokumentation von Datentypen aus eingebundenen externen Modellen benötigt. Bei der Verwendung eines externen Datentyps kann die Dokumentation auf die hier definierten Daten zurückgreifen und so einen Verweis auf ein externes Dokument erzeugen.&lt;/para>&#xA;&lt;para>Der Stereotyp hat keine Auswirkungen auf die generierten XML-Schemata.&lt;/para>"/>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1282131963681_712136_539" name="base_Dependency" visibility="private" association="_16_5_4_b7102e0_1282131963681_472501_538">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1282131963669_347065_533" name="bezeichnung" visibility="private">
        <ownedComment xmi:id="_16_5_4_b7102e0_1282131963670_561191_536" annotatedElement="_16_5_4_b7102e0_1282131963669_347065_533" body="&lt;para>Bei Verweisen verwendeter Bezeichner. Beispiel: [XOEV-Basisdatentypen]&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1282131963670_531828_535" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1282131963670_187054_537" name="" visibility="public" value="1"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="_16_5_4_b7102e0_1282131963681_472501_538" name="" visibility="public" memberEnd="_16_5_4_b7102e0_1282131963681_712136_539 _16_5_4_b7102e0_1282131963681_229370_540" navigableOwnedEnd="_16_5_4_b7102e0_1282131963681_229370_540">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="_16_5_4_b7102e0_1282131963681_229370_540" name="extension_xsdXModelImport" visibility="private" type="_16_5_4_b7102e0_1282131963663_958424_532" aggregation="composite" association="_16_5_4_b7102e0_1282131963681_472501_538">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1282131963681_710655_541" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1282131963681_788166_542" name="" visibility="public" value="1"/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_16_5_4_b7102e0_1310393084388_456884_533" name="xsdGroup" visibility="public">
      <ownedComment xmi:id="_16_5_4_b7102e0_1314793033333_842787_619" annotatedElement="_16_5_4_b7102e0_1310393084388_456884_533" body="&lt;para>Eine UML-Klasse, die mit diesem Stereotyp versehen ist, wird im XML-Schema durch ein xs:group&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cModel_Group_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cModel_Group_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>- oder xs:attributeGroup&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cAttribute_Group_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#cAttribute_Group_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>-Elementmodell umgesetzt (anstelle von xs:complexType). Die Gruppe enthält alle Eigenschaften der mit &lt;emphasis>xsdGroup&lt;/emphasis> gekennzeichneten Klasse, die mit &lt;emphasis>xsdElement&lt;/emphasis> bzw. &lt;emphasis>xsdAttribute&lt;/emphasis> gekennzeichnet sind.&lt;/para>"/>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1310393119067_490352_540" name="base_Class" visibility="private" association="_16_5_4_b7102e0_1310393119067_145127_539">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="_16_5_4_b7102e0_1310393119067_145127_539" name="" visibility="public" memberEnd="_16_5_4_b7102e0_1310393119067_490352_540 _16_5_4_b7102e0_1310393119067_217681_541" navigableOwnedEnd="_16_5_4_b7102e0_1310393119067_217681_541">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="_16_5_4_b7102e0_1310393119067_217681_541" name="extension_xsdGroup" visibility="private" type="_16_5_4_b7102e0_1310393084388_456884_533" aggregation="composite" association="_16_5_4_b7102e0_1310393119067_145127_539">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1310393119067_622256_542" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1310393119067_424107_543" name="" visibility="public" value="1"/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_16_5_4_b7102e0_1310551667488_613356_328" name="xsdGlobalElementType" visibility="public">
      <ownedComment xmi:id="_16_5_4_b7102e0_1314792541184_758204_618" annotatedElement="_16_5_4_b7102e0_1310551667488_613356_328" body="&lt;para>Eine UML-Abhängigkeit zwischen einer als &lt;emphasis>xsdGlobalElement&lt;/emphasis> ausgezeichneten UML-Klasse und einer als &lt;emphasis>xsdNamedType&lt;/emphasis> ausgezeichneten UML-Klasse, die mit dem Stereotyp &lt;emphasis>xsdGlobalElementType&lt;/emphasis> versehen ist bewirkt, dass im XML-Schema als Datentyp des globalen Elements der bebannte Typ der als Ziel der Abhängigkteit angegeben ist festgelegt wird&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;>http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>&#xA;&lt;para>Der Stereotyp muss im Zusammenspiel mit den Stereotypen &lt;emphasis>xsdGlobalElement&lt;/emphasis> und &lt;emphasis>xsdNamedType&lt;/emphasis> verwendet werden.&lt;/para>"/>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1310551689818_544499_335" name="base_Dependency" visibility="private" association="_16_5_4_b7102e0_1310551689818_138115_334">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="_16_5_4_b7102e0_1310551689818_138115_334" name="" visibility="public" memberEnd="_16_5_4_b7102e0_1310551689818_544499_335 _16_5_4_b7102e0_1310551689818_91508_336" navigableOwnedEnd="_16_5_4_b7102e0_1310551689818_91508_336">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="_16_5_4_b7102e0_1310551689818_91508_336" name="extension_xsdGlobalElementType" visibility="private" type="_16_5_4_b7102e0_1310551667488_613356_328" aggregation="composite" association="_16_5_4_b7102e0_1310551689818_138115_334">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1310551689818_999397_337" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1310551689818_614624_338" name="" visibility="public" value="1"/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_16_5_4_b7102e0_1310654548871_451816_514" name="xsdUnion" visibility="public">
      <ownedComment xmi:id="_16_5_4_b7102e0_1314793735035_598605_620" annotatedElement="_16_5_4_b7102e0_1310654548871_451816_514" body="&lt;para>Angewendet auf eine UML-Klasse bewirkt dieser Stereotyp, dass eine xs:union&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> als Inhaltsmodell des simple Types festgelegt wird. Die Mitglieder der Union werden über Abhängigkeiten die mit dem Stereotyp &quot;xsdUnionMember&quot; annotiert sind modelliert.&lt;/para>"/>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1310654564840_14479_521" name="base_Class" visibility="private" association="_16_5_4_b7102e0_1310654564840_795792_520">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="_16_5_4_b7102e0_1310654564840_795792_520" name="" visibility="public" memberEnd="_16_5_4_b7102e0_1310654564840_14479_521 _16_5_4_b7102e0_1310654564840_381530_522" navigableOwnedEnd="_16_5_4_b7102e0_1310654564840_381530_522">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="_16_5_4_b7102e0_1310654564840_381530_522" name="extension_xsdUnion" visibility="private" type="_16_5_4_b7102e0_1310654548871_451816_514" aggregation="composite" association="_16_5_4_b7102e0_1310654564840_795792_520">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1310654564840_715038_523" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1310654564840_70422_524" name="" visibility="public" value="1"/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_16_5_4_b7102e0_1310654589264_996878_525" name="xsdUnionMember" visibility="public">
      <ownedComment xmi:id="_16_5_4_b7102e0_1314794513127_157917_621" annotatedElement="_16_5_4_b7102e0_1310654589264_996878_525" body="&lt;para>Mit diesem Stereotypen werden die Mitglieder einer xs:union festgelegt. Der simple Type an der Pfeilspitze der Abhängigkeit wird als möglicher Datentyp in die Union aufgenommen.&lt;/para>"/>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1310654625292_746918_532" name="base_Dependency" visibility="private" association="_16_5_4_b7102e0_1310654625292_608082_531">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="_16_5_4_b7102e0_1310654625292_608082_531" name="" visibility="public" memberEnd="_16_5_4_b7102e0_1310654625292_746918_532 _16_5_4_b7102e0_1310654625292_563777_533" navigableOwnedEnd="_16_5_4_b7102e0_1310654625292_563777_533">
      <ownedEnd xmi:type="uml:ExtensionEnd" xmi:id="_16_5_4_b7102e0_1310654625292_563777_533" name="extension_xsdUnionMember" visibility="private" type="_16_5_4_b7102e0_1310654589264_996878_525" aggregation="composite" association="_16_5_4_b7102e0_1310654625292_608082_531">
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1310654625293_555248_534" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1310654625293_556283_535" name="" visibility="public" value="1"/>
      </ownedEnd>
    </packagedElement>
    <packagedElement xmi:type="uml:Extension" xmi:id="_16_5_4_b7102e0_1315386820198_165407_328" name="" visibility="public" memberEnd="_16_5_4_b7102e0_1315386820199_794796_329 _16_5_4_b7102e0_1315386820199_450014_330" navigableOwnedEnd="_16_5_4_b7102e0_1315386820199_450014_330">
