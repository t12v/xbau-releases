      <ownedAttribute xmi:id="_12_1_8b00279_1240229452306_446364_608" name="whitespace" visibility="private">
        <ownedComment xmi:id="_12_1_8b00279_1240229623961_334821_612" annotatedElement="_12_1_8b00279_1240229452306_446364_608" body="&lt;para>xs:whitespace&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-whiteSpace&quot;>http://www.w3.org/TR/xmlschema-2/#rf-whiteSpace&lt;/ulink>&lt;/para>&lt;/footnote> legt fest, wie Whitespace (z.B. Leerzeichen, Tabs, Linefeeds, Carriage Returns) behandelt werden sollen.&lt;/para>&#xA;&lt;para>Mögliche Werte sind:&#xA;&lt;itemizedlist>&#xA;&lt;listitem>&lt;para>preserve - Whitespace wird unverändert beibehalten&lt;/para>&lt;/listitem>&#xA;&lt;listitem>&lt;para>replace - alle Whitespace-Zeichen werden durch ein Leerzeichen ersetzt&lt;/para>&lt;/listitem>&#xA;&lt;listitem>&lt;para>collapse - am Anfang und am Ende stehende Whitespaces werden entfernt sowie zusammenhängende Whitespaces durch ein Leerzeichen ersetzt&lt;/para>&lt;/listitem>&#xA;&lt;/itemizedlist>&#xA;&lt;/para>&#xA;&lt;para>Zulässig ist die Angabe einer solchen Facette im XML-Schema für die folgenden W3C-Datentypen&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&quot;>http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&lt;/ulink> und &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-derived&quot;>http://www.w3.org/TR/xmlschema-2/#built-in-derived&lt;/ulink>&lt;/para>&lt;/footnote>: xs:ENTITY, xs:ID, xs:IDREF, xs:language, xs:Name, xs:NCName, xs:NMTOKEN,  xs:normalizedString, xs:string, xs:token.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_12_1_8b00279_1240229513780_162871_610" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_12_1_8b00279_1240229513780_454346_611" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_5b501fb_1269956472128_113335_14304" name="enumeration" visibility="private">
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1269956481660_332962_14306" name="" visibility="public"/>
