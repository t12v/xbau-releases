    <packagedElement xmi:type="uml:Stereotype" xmi:id="_18_0_6_5b501fb_1499769384988_38071_4313" name="xoevBibliothek" visibility="public">
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499769384988_782365_4314" name="nameLang" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1499769385004_877042_4322" annotatedElement="_18_0_6_5b501fb_1499769384988_782365_4314" body="Der Name (lang) ist die &quot;sprechende&quot; Bezeichnung der XÖV-Bibliothek."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499769385004_91411_4323" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499769385004_654866_4321" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499769384988_176277_4315" name="nameKurz" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1499769385004_598261_4325" annotatedElement="_18_0_6_5b501fb_1499769384988_176277_4315" body="Der Name (kurz) ist die &quot;sprechende&quot; Kurzbezeichnung der XÖV-Bibliothek. Dieser Name wird beispielsweise im XRepository in Listendarstellungen von Inhalten verwendet oder kann zur Bezeichnung der XÖV-Bibliothek in Texten (Spezifikationsdokument) verwendet werden."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499769385004_419267_4326" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499769385004_223155_4324" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499769384988_442647_4316" name="nameTechnisch" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1499769385004_440609_4328" annotatedElement="_18_0_6_5b501fb_1499769384988_442647_4316" body="Neben den Namen (lang) und Namen (kurz) besitzt die XÖV-Bibliothek einen technischen Namen. Dieser Name soll &quot;sprechend&quot; und gleichzeitig zur technischen Verarbeitung optimiert sein. In der Regel ist der technische Name vom Namen (kurz) abgeleitet.&#xA;&#xA;Die Regeln zur Bildung des technischen Namens sind im XÖV-Handbuch detailliert dargestellt."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499769385004_499327_4329" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499769385004_575470_4327" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499769384988_66211_4317" name="kennung" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1499769385004_814181_4331" annotatedElement="_18_0_6_5b501fb_1499769384988_66211_4317" body="Mittels einer Kennung wird die XÖV-Bibliothek versionsübergreifend eindeutig identifiziert.&#xA;&#xA;Die Regeln zur Bildung von Kennungen sind im XÖV-Handbuch detailliert dargestellt.&#xA;"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499769385004_645350_4332" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499769385004_437337_4330" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499769384988_996925_4318" name="beschreibung" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1499769385004_822583_4334" annotatedElement="_18_0_6_5b501fb_1499769384988_996925_4318" body="Zur XÖV-Bibliothek liegt eine Beschreibung in Form eines unformatierten Fließtextes vor."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499769385004_790668_4335" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499769385004_189991_4333" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499769384988_460031_4319" name="herausgebernameLang" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1499769385004_283112_4337" annotatedElement="_18_0_6_5b501fb_1499769384988_460031_4319" body="Der Herausgeber der XÖV-Bibliothek ist eine natürliche Person oder eine Organisation. Sie ist verantwortlich für die fachlichen Inhalte und deren Fortschreibung. Der Herausgebername (lang) ist der vollständige und ungekürzte Name des Herausgebers."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499769385004_641353_4338" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499769385004_764724_4336" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499769384988_477798_4320" name="herausgebernameKurz" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1499769385004_775965_4340" annotatedElement="_18_0_6_5b501fb_1499769384988_477798_4320" body="Der Herausgebername (kurz) ist der gekürzte oder umgangssprachliche Name des Herausgebers."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499769385004_406388_4341" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499769385004_875940_4339" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_18_0_6_5b501fb_1499769429509_143923_4347" name="externeWebsite" visibility="private">
        <ownedComment xmi:id="_18_0_6_5b501fb_1499769429524_737297_4349" annotatedElement="_18_0_6_5b501fb_1499769429509_143923_4347" body="Zur XÖV-Bibliothek kann ein URL zu einer externen Webseite angegeben werden, auf der weitere Informationen zur XÖV-Bibliothek zur Verfügung stehen."/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_6_5b501fb_1499769429524_60388_4350" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_6_5b501fb_1499769429509_149962_4348" name="" visibility="public" value="1"/>
      </ownedAttribute>
