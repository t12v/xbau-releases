      </ownedAttribute>
      <ownedAttribute xmi:id="_12_1_8b00279_1241763404546_398541_253" name="schemaFile" visibility="private">
        <ownedComment xmi:id="_12_1_8b00279_1241763570859_987315_257" annotatedElement="_12_1_8b00279_1241763404546_398541_253" body="&lt;para>Der physische Dateiname des XML-Schemas ohne eine Pfadangabe, der zur Benennung des XML-Schemas auf Dateiebene herangezogen wird.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_12_1_8b00279_1241763421515_183573_255" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_12_1_8b00279_1241763421515_491351_256" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_9_5_6370212_1131634883583_726833_151" name="schemaLocation" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169806733453_497600_124" annotatedElement="_9_5_6370212_1131634883583_726833_151" body="&lt;para>Der physische Speicherort (URL inklusive Dateiname), an dem das Schema später gefunden werden kann. Dieses Schema-Attribut wird auf xs:import&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;>http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink>&lt;/para>&lt;/footnote> und xs:include&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;>http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink>&lt;/para>&lt;/footnote> abgebildet.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_12_1_8b00279_1241758916656_596700_254" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_12_1_8b00279_1241758916656_234261_255" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_9_5_6370212_1124197424367_6512_162" name="version" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169806811343_493601_125" annotatedElement="_9_5_6370212_1124197424367_6512_162" body="&lt;para>Die Version des XML-Schemas.&lt;/para>&#xA;&lt;para>Dieser Wert wird auf das Attribut &quot;version&quot; des xs:schema-Elements&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;>http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink>&lt;/para>&lt;/footnote> abgebildet.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1169812645078_146804_109" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_11_5_6370212_1169812645078_883049_110" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_5b501fb_1431011091489_223136_576" name="elementFormDefault" visibility="private" type="_16_5_4_1d100e5_1382428090839_769482_556">
        <ownedComment xmi:id="_16_5_4_5b501fb_1431015606873_632467_718" annotatedElement="_16_5_4_5b501fb_1431011091489_223136_576" body="&lt;para>Mittels dieser Eigenschaft kann die standardmäßige Qualifizierung der XML-Elemente in der ausgezeichneten XML Schema-Definition vorgegeben werden, also der Wert für das XML Schema-Attribut elementFormDefault.&#xA;&#xA;Falls der Eigenschaft kein Wert oder der Wert 'default' zugewiesen ist, wird die Vorgabe aus der gleichnamigen Eigenschaft des Stereotyps xsdXModel übernommen.&lt;/para>"/>
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="_16_5_4_5b501fb_1431015046783_564763_717" name="" visibility="public" instance="_16_5_4_5b501fb_1431014209419_453152_578"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638865_811303_3" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124266425909_961504_7" name="xsdInclude" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1179674885531_662107_8" annotatedElement="_9_5_6370212_1124266425909_961504_7" body="&lt;para>Die mit dem Stereotyp gekennzeichnete UML-Abhängigkeit bildet eine Beziehung zwischen zwei &quot;xsdSchema&quot;-Paketen ab, wobei das eine Paket von dem anderen eingebunden wird.&lt;/para>&#xA;&lt;para>Das XML-Schema des Anbieter-Pakets wird durch ein xs:include&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;>http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink>&lt;/para>&lt;/footnote> in das XML-Schema des abhängigen Pakets eingebunden.&lt;/para>"/>
      <ownedAttribute xmi:id="_10_5_6370212_1135160639787_614481_63" name="base_Dependency" visibility="private" association="_10_5_6370212_1135160639787_431082_62">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Dependency"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638885_128560_12" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124265352966_791641_19" name="xsdGlobalElement" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169806339578_782293_118" annotatedElement="_9_5_6370212_1124265352966_791641_19" body="&lt;para>Eine UML-Klasse oder -Enumeration, die mit dem Stereotyp &quot;xsdGlobalElement&quot; versehen ist, wird im XML-Schema als globales Element, d.h. als mögliches Wurzelelement-xs:element&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;>http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink>&lt;/para>&lt;/footnote> ('document root') umgesetzt.&lt;/para>&#xA;&lt;para>Der Stereotyp kann in Zusammenspiel mit dem Stereotypen &quot;xsdMessage&quot; zur Kennzeichnung von XÖV-Nachrichten verwendet werden.&lt;/para>"/>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1315386820199_794796_329" name="base_Classifier" visibility="private" association="_16_5_4_b7102e0_1315386820198_165407_328">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Classifier"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638885_184292_14" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124196478227_708100_1" name="xsdAttribute" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169806433375_745396_120" annotatedElement="_9_5_6370212_1124196478227_708100_1" body="&lt;para>Eine mit diesem Stereotyp gekennzeichnete UML-Eigenschaft (UML-Attribut oder -Assozationsende) wird als xs:attribute&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cAttribute_Declarations&quot;>http://www.w3.org/TR/xmlschema-1/#cAttribute_Declarations&lt;/ulink>&lt;/para>&lt;/footnote> umgesetzt. UML-Klassenattribute, die mit diesem Stereotyp gekennzeichnet sind, dürfen als Multiplizität nur 1 (dies ist der Standard-Wert) oder 0..1 besitzen, d.h. sie sind somit entweder obligatorisch oder optional.&lt;/para>"/>
      <ownedAttribute xmi:id="_10_5_6370212_1135160639847_389881_108" name="base_Property" visibility="private" association="_10_5_6370212_1135160639847_299101_107">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Property"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1311680132156_358790_346" name="isRef" visibility="private">
        <ownedComment xmi:id="_16_5_4_b7102e0_1314795487558_406109_625" annotatedElement="_16_5_4_b7102e0_1311680132156_358790_346" body="&lt;para>Falls die als xsdAttribute markierte Eigenschaft auf eine globale Attributgruppe verweisen soll, muss für diese Eigenschaft der Wert true angegeben werden. Andernfalls wird ein lokales Attribut erzeugt.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1311680143226_814268_348" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1311680143226_334547_349" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638865_164754_1" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124265313409_433757_5" name="xsdChoice" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169806589437_828417_121" annotatedElement="_9_5_6370212_1124265313409_433757_5" body="&lt;para>Eine UML-Klasse, die mit diesem Stereotyp versehen ist, wird im XML-Schema durch ein xs:choice&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Model_Groups&quot;>http://www.w3.org/TR/xmlschema-1/#Model_Groups&lt;/ulink>&lt;/para>&lt;/footnote>-Elementmodell umgesetzt (anstelle von xs:sequence&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Model_Groups&quot;>http://www.w3.org/TR/xmlschema-1/#Model_Groups&lt;/ulink>&lt;/para>&lt;/footnote>). Der &quot;choice&quot; erstreckt sich über alle Eigenschaften der mit &quot;xsdChoice&quot; gekennzeichneten UML-Klasse, die mit &quot;xsdElement&quot; gekennzeichnet sind.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1169814699046_210081_649" name="base_Class" visibility="private" association="_11_5_6370212_1169814699046_370226_648">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Class"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638885_409632_13" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124197274712_758074_19" name="xsdNamedType" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169805981640_797237_117" annotatedElement="_9_5_6370212_1124197274712_758074_19" body="&lt;para>Eine UML-Klasse, die mit &quot;xsdNamedType&quot; versehen ist, wird im XML-Schema als benannter Typ (xs:complexType&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> oder xs:simpleType&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>) umgesetzt.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1170922896187_582585_20" name="base_Classifier" visibility="private" association="_11_5_6370212_1170922896171_36314_18">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Classifier"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638865_245295_2" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124265621682_674591_142" name="xsdElement" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1169806396828_772109_119" annotatedElement="_9_5_6370212_1124265621682_674591_142" body="&lt;para>Eine mit diesem Stereotyp gekennzeichnete UML-Eigenschaft (UML-Attribut oder -Assoziationsende einer Aggregation) legt fest, dass sie als xs:element&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;>http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink>&lt;/para>&lt;/footnote> umgesetzt wird.&lt;/para>"/>
      <ownedAttribute xmi:id="_11_5_6370212_1157021169533_511715_2" name="nillable" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169809067203_692248_1" annotatedElement="_11_5_6370212_1157021169533_511715_2" body="&lt;para>Wenn diese Eigenschaft mit &quot;true&quot; angegeben wird, wird dieses Element im entsprechenden xs:complexType&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink>&lt;/para>&lt;/footnote> als &quot;nillable='true'&quot;&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#xsi_nil&quot;>http://www.w3.org/TR/xmlschema-1/#xsi_nil&lt;/ulink>&lt;/para>&lt;/footnote> deklariert.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_12_1_8b00279_1239983029031_47950_270" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_12_1_8b00279_1239983029031_85648_271" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_10_5_6370212_1135160639837_429169_98" name="base_Property" visibility="private" association="_10_5_6370212_1135160639837_352518_97">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Property"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_9_5_6370212_1124265642542_581447_156" name="position" visibility="private">
        <ownedComment xmi:id="_11_5_6370212_1169806848765_985885_126" annotatedElement="_9_5_6370212_1124265642542_581447_156" body="&lt;para>Die Eigenschaft bestimmt die Position einer als xs:element&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;>http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink>&lt;/para>&lt;/footnote> umgesetzten UML-Eigenschaft innerhalb der Elementsequenz xs:sequence&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Model_Groups&quot;>http://www.w3.org/TR/xmlschema-1/#Model_Groups&lt;/ulink>&lt;/para>&lt;/footnote> im entsprechenden xs:complexType&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;>http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>&#xA;&lt;para>Die Nummierung der Eigenschaft position muss für alle &quot;xsdElement&quot;-Eigenschaften einer UML-Klasse eindeutig und als positiver ganzzahliger Wert hinterlegt sein.&lt;/para>&#xA;&lt;para>Die Nummern werden nicht in der Dokumentation des jeweiligen xs:element&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;>http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink>&lt;/para>&lt;/footnote> ausgegeben. Sie dient zur Bildung der xs:element&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;>http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink>&lt;/para>&lt;/footnote>-Reihenfolge.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_11_5_6370212_1169814723375_635684_662" name="" visibility="public" value="1"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_11_5_6370212_1169814723375_97767_663" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_8b00279_1259845446213_525900_763" name="form" visibility="private" type="_16_5_4_1d100e5_1382428090839_769482_556">
        <ownedComment xmi:id="_16_5_4_8b00279_1259845566578_581339_768" annotatedElement="_16_5_4_8b00279_1259845446213_525900_763" body="&lt;para>Mittels dieser Eigenschaft kann die Qualifizierung des ausgezeichneten XML-Elements bestimmt werden. Standardmäßig (form = default) gilt für das Element die Vorgabe der zugrundeliegenden XML Schema-Definition, gesteuert über das XML Schema-Attribut elementFormDefault (siehe die Eigenschaft elementFormDefault des Stereotyps xsdSchema bzw. xsdXModel). Die Qualifizierung des Elements kann jedoch über die Werte 'qualified' und 'unqualified' auch explizit festgelegt werden.&lt;/para>&#xA;&#xA;&lt;para>Unqualifizierte Elemente werden bei der Ableitung (XML-Restriktion) eines Basistyps benötigt, der sich in einem fremden Namensraum befindet.&lt;/para>&#xA;"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8b00279_1259845549267_89032_766" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8b00279_1259845549267_423589_767" name="" visibility="public" value="1"/>
        <defaultValue xmi:type="uml:InstanceValue" xmi:id="_16_5_4_1d100e5_1382428184415_369572_579" name="" visibility="public" instance="_16_5_4_5b501fb_1431014209419_453152_578"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_16_5_4_b7102e0_1310635978408_761139_343" name="isRef" visibility="private">
        <ownedComment xmi:id="_16_5_4_b7102e0_1314795439719_195684_624" annotatedElement="_16_5_4_b7102e0_1310635978408_761139_343" body="&lt;para>Falls die als xsdElement markierte Eigenschaft auf ein globales Element oder eine Elementgruppe verweisen soll, muss für diese Eigenschaft der Wert true angegeben werden. Andernfalls wird ein lokales Element erzeugt.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_b7102e0_1310636580794_288910_502" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_b7102e0_1310636580794_674516_503" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <icon xmi:id="_10_5_6370212_1135160638885_150077_18" content="" format="" location=""/>
    </packagedElement>
    <packagedElement xmi:type="uml:Stereotype" xmi:id="_9_5_6370212_1124307083424_342810_23" name="xsdRestriction" visibility="public">
      <ownedComment xmi:id="_11_5_6370212_1179674571562_832490_4" annotatedElement="_9_5_6370212_1124307083424_342810_23" body="&lt;para>Wird eine UML-Generalisierung mit diesem Stereotyp gekennzeichnet, wird ein Hinzufügen von Informationen in der Unterklasse verboten. Die Instanzen der Unterklasse dürfen nur noch die Eigenschaften der Oberklasse verwenden, die explizit noch einmal in der Unterklasse aufgezählt werden. Die Vererbung wird hiermit eingeschränkt. Die Multiplizitäten (d. h. Häufigkeiten) der wiederverwendeten Eigenschaften dürfen zwar verändert, aber lediglich verschärft werden (z.B. von 0..1 zu 1 oder von 0..* zu 1..*).&lt;/para>&#xA;&lt;para>Für Typen mit einfachem Inhalt können die als Eigenschaften abgebildeten Facetten&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-facets&quot;>http://www.w3.org/TR/xmlschema-2/#rf-facets&lt;/ulink>&lt;/para>&lt;/footnote> zur Einschränkung genutzt werden. Sie werden direkt im XML-Schema abgebildet.&lt;/para>"/>
      <ownedAttribute xmi:id="_12_1_8b00279_1240232113886_828286_638" name="fractionDigits" visibility="private">
        <ownedComment xmi:id="_12_1_8b00279_1240232281433_104033_642" annotatedElement="_12_1_8b00279_1240232113886_828286_638" body="&lt;para>xs:fractionDigits&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-fractionDigits&quot;>http://www.w3.org/TR/xmlschema-2/#rf-fractionDigits&lt;/ulink>&lt;/para>&lt;/footnote> definiert die maximal mögliche Anzahl von Ziffern nach dem Dezimalpunkt.&lt;/para>&#xA;&lt;para>Zulässig ist die Angabe einer solchen Facette im XML-Schema nur für  xs:decimal&lt;footnote>&lt;para>siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#decimal&quot;>http://www.w3.org/TR/xmlschema-2/#decimal&lt;/ulink>&lt;/para>&lt;/footnote>.&lt;/para>"/>
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
        <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_12_1_8b00279_1240232155984_418178_640" name="" visibility="public"/>
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_12_1_8b00279_1240232155984_700339_641" name="" visibility="public" value="1"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_10_5_6370212_1135160639776_620610_58" name="base_Generalization" visibility="private" association="_10_5_6370212_1135160639776_697561_57">
        <type xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Generalization"/>
      </ownedAttribute>
      <ownedAttribute xmi:id="_12_1_8b00279_1240223313517_317525_592" name="length" visibility="private">
