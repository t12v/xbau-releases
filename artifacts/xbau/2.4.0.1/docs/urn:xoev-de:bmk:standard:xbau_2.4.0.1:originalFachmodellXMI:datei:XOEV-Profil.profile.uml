        <ownedComment xmi:id="_18_0_6_5b501fb_1499769708695_714807_4446" annotatedElement="_18_0_6_5b501fb_1499769708695_288915_4412" body="Mittels einer Kennung wird ein Datentyp versionsübergreifend eindeutig identifiziert.&#xA;&#xA;Die Regeln zur Bildung von Kennungen sind im XÖV-Handbuch detailliert dargestellt.&#xA;"/>
