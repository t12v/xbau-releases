   <xs:element name="informationsempfaenger.statistikBauueberhang.0413">
      <xs:annotation>
         <xs:appinfo>
            <rechtsgrundlage>§ 1 (2) Nr. 3 HBauStatG</rechtsgrundlage>
            <title>Datenübermittlung an die amtliche Statistik bei Bauüberhang</title>
         </xs:appinfo>
         <xs:documentation>Diese Nachricht übermittelt Daten zum Bauüberhang an die amtliche Statistik.</xs:documentation>
      </xs:annotation>
      <xs:complexType>
         <xs:complexContent>
            <xs:extension base="xbau:Nachricht.G2G">
               <xs:sequence>
