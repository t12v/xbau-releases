        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163576860328_549439_1240" name="">
          <language>OCL2.0</language>
          <body>not owner.appliedStereotypeInstance.oclIsUndefined() and
owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') -> size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163579728187_658670_1301" name="xsdattribute in xsdsimplecontent" constrainedElement="magicdraw_1046682040730_843189_181">
