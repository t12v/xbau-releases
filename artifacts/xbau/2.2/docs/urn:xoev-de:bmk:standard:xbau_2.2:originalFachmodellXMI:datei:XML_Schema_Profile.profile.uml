        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163579728187_69197_1302" name="">
          <language>OCL2.0</language>
          <body>not owner.appliedStereotypeInstance.oclIsUndefined() and owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleContent') ->asSet()->size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163578227171_428030_1260" name="Simple Type Derived by Extension" constrainedElement="magicdraw_1046684263597_121702_458">
        <ownedComment xmi:id="_12_0_8f90291_1163578556218_779910_1269" annotatedElement="_12_0_8f90291_1163578227171_428030_1260" body="SimpleType can not be derived by extension"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163578287609_871345_1261" name="">
          <language>OCL2.0</language>
          <body>not specific.appliedStereotypeInstance.oclIsUndefined() and specific.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') ->size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163579507359_662856_1290" name="xsdattributegroup on Simpletype or Complextype" constrainedElement="magicdraw_1046684505444_590497_493">
