        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163574251343_528213_1076" name="No targetNamespace on Schema" constrainedElement="magicdraw_1046691534852_460080_805">
        <ownedComment xmi:id="_12_0_8f90291_1163574515796_398242_1085" annotatedElement="_12_0_8f90291_1163574251343_528213_1076" body="targetNamespace tag should be defined on schema element"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163574392828_587326_1080" name="">
          <language>OCL2.0</language>
          <body>not targetNamespace.oclIsUndefined()</body>
