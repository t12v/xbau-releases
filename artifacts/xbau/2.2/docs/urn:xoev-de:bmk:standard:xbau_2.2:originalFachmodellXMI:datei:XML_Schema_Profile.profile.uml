      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163528180656_366939_778" name="No Link to Namespace" constrainedElement="magicdraw_1046691534852_460080_805">
        <ownedComment xmi:id="_12_0_8f90291_1163574208890_231056_1075" annotatedElement="_12_0_8f90291_1163528180656_366939_778" body="Properties should not use the primitive types from UML standard profile, should use corresponding classes from XML schema profile"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163528263890_148581_779" name="">
          <language>OCL2.0</language>
          <body>let owners : Set(UML2_Metamodel::ElementImport)=ownedElement->select(oclIsKindOf(xmlns))->collect(oclAsType(UML2_Metamodel
::ElementImport))->asSet() in owners.importedElement.name -> exists (n|n='http://www.w3.org/2001/XMLSchema')</body>
        </specification>
      </ownedRule>
