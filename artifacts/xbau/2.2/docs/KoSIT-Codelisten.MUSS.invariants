    <invariant context='Enumeration' name='MetadatenelementVersionCodelisteVersionXOEVHandbuchMussBefuelltSein'>
			<body><![CDATA[
			let m = self.extension_xoevVersionCodeliste.versionXOEVHandbuch in
			self.hlpIsPartOfXModel() and self.extension_xoevVersionCodeliste.isDefined and self.extension_kositGeneriereGenericode.isDefined() implies m.isDefined and m <> ''
		]]></body>
