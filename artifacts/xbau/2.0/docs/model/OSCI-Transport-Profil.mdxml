				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1287395686258_528623_346' name='Leistungserbringer' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1287396077285_450575_620' body='Mit dieser Eigenschaft kann der Leistungserbringer bezüglich des ausgewählten Dienstes angegeben werden. Diese Information wird momentan in der Übersichtstabelle zu den Diensten genutzt.'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1287395686258_528623_346'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
