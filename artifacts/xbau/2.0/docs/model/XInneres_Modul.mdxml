					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364478035868_379202_2697' name='Code.SGS.Staat.1970' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364478035871_354693_2705' body='&lt;para&gt;Diese Codeliste enthält alle Staatsangehörigkeiten im vollen politischen Sinne und entspricht dem &lt;quote&gt;Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote&gt; des Auswärtigen Amtes. Darüber hinaus enthält die Codeliste zusätzliche Einträge für ehemalige Staaten ab 1970. Für die enthaltenen Ersatzwerte (wie staatenlos, ungeklärt und ohne Angabe) sowie für den Eintrag für die Palästinensischen Gebiete enthält die Codeliste Einträge, deren Bedeutung aber nicht definiert ist.&lt;/para&gt;&#10;&lt;para&gt;Die Bedeutung des übermittelten Schlüssels ergibt sich aus der Spalte &lt;quote&gt;Staatsname_kurz&lt;/quote&gt; der veröffentlichten Genericcode-Datei.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364478035868_379202_2697'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1eeb04c1_1364478035869_716099_2699'>
							<general xmi:type='uml:Class' href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625280047_322339_5028'>
								<xmi:Extension extender='MagicDraw UML 16.5'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Code::1.0::Code' referentType='Class'/>
								</xmi:Extension>
							</general>
						</generalization>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364478035869_760711_2701' name='code' visibility='private'>
							<type xmi:type='uml:Class' href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191873500_204582_1633'>
								<xmi:Extension extender='MagicDraw UML 16.5'>
