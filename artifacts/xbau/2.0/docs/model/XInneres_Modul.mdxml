							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1392817805440_652270_2446' visibility='public' value='1'/>
							</modelExtension>
						</xmi:Extension>
