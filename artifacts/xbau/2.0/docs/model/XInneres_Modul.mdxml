					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1391428737087_943181_1267' name='weiterleitendeStelle' visibility='private' type='_16_5_4_1eeb04c1_1391427646335_481996_1191'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1391428737089_152319_1270' body='&lt;para&gt;In diesem Element wird die vollständige Liste der Behörden übermittelt, die im Laufe des Prozesses die fachliche Nachricht weitergeleitet haben.&lt;/para&gt;&#10;&lt;para&gt;Diese Liste wird gebildet, indem die Behörde, die die Weiterleitungsnachricht erstellt, sich selbst an die (ggf. leere) Liste der &lt;code&gt;weiterleitendeStellen&lt;/code&gt; anhängt.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1391428737087_943181_1267'/>
						</ownedComment>
