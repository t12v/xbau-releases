					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1371546519804_685664_2271' name='weitergeleiteteNachricht' visibility='private'>
						<type xmi:type='uml:Class' href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191711843_120906_985'>
							<xmi:Extension extender='MagicDraw UML 16.5'>
								<referenceExtension referentPath='XOEV-Profil::W3C Data Types::base64Binary' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1371555546066_665351_2601' body='&lt;para&gt;In diesem Element wird die unveränderte fachliche Nachricht übermittelt, wie sie von der den Prozess auslösenden Behörde erstellt wurde.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1371546519804_685664_2271'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 16.5'>
