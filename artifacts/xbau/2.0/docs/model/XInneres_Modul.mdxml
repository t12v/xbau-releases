				</packagedElement>
				<packagedElement xmi:type='uml:Dependency' xmi:id='_16_5_4_127f0398_1432803517557_305508_2781' visibility='public'>
					<supplier xmi:type='uml:Package' href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625280030_115253_5005'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Code::1.0' referentType='Package'/>
						</xmi:Extension>
					</supplier>
					<client xmi:idref='_16_5_4_1eeb04c1_1364305973268_219502_1046'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Dependency' xmi:id='_16_5_4_127f0398_1432803548087_620952_2816' visibility='public'>
					<supplier xmi:type='uml:Package' href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625280030_115253_5005'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Code::1.0' referentType='Package'/>
						</xmi:Extension>
					</supplier>
					<client xmi:idref='_16_5_4_1eeb04c1_1364305973268_219502_1046'/>
				</packagedElement>
			</packagedElement>
			<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_1eeb04c1_1364476328403_189808_1246' name='Codes' visibility='public'>
				<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_1eeb04c1_1364477284016_472414_2524' name='Gemeindeverzeichnis' visibility='public'>
