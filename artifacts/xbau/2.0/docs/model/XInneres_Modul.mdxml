								<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Code::1.0::Code' referentType='Class'/>
							</xmi:Extension>
						</general>
					</generalization>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1392816690322_393510_2187' name='code' visibility='private' type='_16_5_4_1eeb04c1_1392816805317_775359_2248'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
