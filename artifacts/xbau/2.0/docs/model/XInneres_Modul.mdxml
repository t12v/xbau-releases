					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364476550233_66087_2455' name='Code.SGS.Staatsangehoerigkeit' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364476550236_982543_2462' body='&lt;para&gt;Diese Codeliste enthält alle Staatsangehörigkeiten im vollen politischen Sinne und entspricht dem &lt;quote&gt;Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote&gt; des Auswärtigen Amtes. Darüber hinaus enthält die Codeliste zusätzliche Einträge für ehemalige Staaten ab 1970 sowie Ersatzwerte (wie staatenlos, ungeklärt und ohne Angabe) sowie einen Eintrag für die Palästinensischen Gebiete.&lt;/para&gt;&#10;&lt;para&gt;Die Bedeutung des übermittelten Schlüssels ergibt sich aus der Spalte &lt;quote&gt;Staatsangehoerigkeit&lt;/quote&gt; der veröffentlichten Genericcode-Datei.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364476550233_66087_2455'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1eeb04c1_1364476550234_365114_2457'>
							<general xmi:type='uml:Class' href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625280047_322339_5028'>
								<xmi:Extension extender='MagicDraw UML 16.5'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Code::1.0::Code' referentType='Class'/>
								</xmi:Extension>
							</general>
						</generalization>
