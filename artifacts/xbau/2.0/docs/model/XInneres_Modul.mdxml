				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_1eeb04c1_1347638519909_11033_1331' visibility='public'>
					<memberEnd xmi:idref='_16_5_4_1eeb04c1_1347638519909_729017_1332'/>
					<memberEnd xmi:idref='_16_5_4_1eeb04c1_1347638519909_817994_1333'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1347638519909_817994_1333' visibility='private' type='_16_5_4_1eeb04c1_1347638390029_466451_1265' association='_16_5_4_1eeb04c1_1347638519909_11033_1331'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1351595172450_828165_1636' name='Auslandsanschrift.Anschriftzone' visibility='public'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1351600989591_582888_1717' body='&lt;para&gt;Dieser Datentyp enthält die für die Zustellung im Ausland erforderlichen Angaben zur Anschriftzone, außer der Angabe des Staates. Diese Angaben beinhalten alle zur Adressierung erforderlichen Angaben inkl. dem Namen des Empfängers und  bestehen aus bis zu fünf Zeilen. Diese Zeilen sind beginnend mit der Nummer 4 lückenlos zu durchzunummerieren.&lt;/para&gt;&#10;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1351595172450_828165_1636'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1351595179570_314586_1662' name='zeile.anschrift' visibility='private' aggregation='composite' type='_16_5_4_1eeb04c1_1347638390029_466451_1265' association='_16_5_4_1eeb04c1_1351595179570_752732_1660'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1351595179570_160925_1665' body='&lt;para&gt;Hier sind pro Zeile der Anschriftzone jeweils der eigentliche &lt;emphasis role=&quot;code&quot;&gt;inhalt&lt;/emphasis&gt; und die &lt;emphasis role=&quot;code&quot;&gt;zeilennummer&lt;/emphasis&gt; zu übermitteln. &lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1351595179570_314586_1662'/>
						</ownedComment>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1387198665514_578920_1704' visibility='public' value='5'/>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1387198665513_393364_1703' visibility='public' value='2'/>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_1eeb04c1_1351595179570_752732_1660' visibility='public'>
					<memberEnd xmi:idref='_16_5_4_1eeb04c1_1351595179570_314586_1662'/>
