				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_28e205cd_1296203866609_175384_921' name='Meldeanschrift.HausnummerBuchstabeZusatzziffer' visibility='public'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_28e205cd_1296205714234_492628_1301' body='Dies ist der Typ für das Element &#39;buchstabeZusatzziffer&#39; im Typ Meldeanschrift.'>
						<annotatedElement xmi:idref='_16_5_4_28e205cd_1296203866609_175384_921'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_28e205cd_1296204365812_63564_1192'>
						<general xmi:type='uml:Class' href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
