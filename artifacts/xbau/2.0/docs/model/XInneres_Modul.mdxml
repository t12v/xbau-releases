				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1386161210447_393163_1615' name='weiterleitung.weiterleitung.0030' visibility='public'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1386163985094_253348_2035' body='&lt;para&gt;Mit dieser Nachricht leitet eine nicht (mehr) zuständige Stelle eine Nachricht an die aus ihrer Sicht aktuell zuständige Stelle weiter.&lt;/para&gt;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1386161210447_393163_1615'/>
