				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1431418888868_232307_2181' name='Code.Nachrichtentyp.Typ4' visibility='public'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1431418888874_623738_2188' body='&lt;para&gt;Typ-4 Code-Datentyp für die Übermittlung von Nachrichtentypen, wo die zugrundeliegenden Schlüsseltabellen und deren Version erst zum Zeitpunkt der Nachrichtenerstellung festgelegt werden.&lt;/para&gt;'>
