					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364476474329_483363_1841' name='Code.GemeindeVZ.Kreis' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364476474332_593674_1848' body='&lt;para&gt;Die Bundesrepublik Deutschland ist ein Zusammenschluss von Bundesländern. Die meisten Bundesländer umfassen mehrere Kreise und Bezirke.Diese Codeliste stellt die Kreise der deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS).&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364476474329_483363_1841'/>
						</ownedComment>
