				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364372067428_126125_9749' name='Code.Praefix' visibility='public'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364372298604_449563_9789' body='&lt;para&gt;Diese Codeliste enthält alle Präfixe, welche im DVDV zum Einsatz kommen. Diese Präfixe werden für die fachliche Adressierung über das DVDV verwendet.&lt;/para&gt;&#10;&#10;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364372067428_126125_9749'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1eeb04c1_1364372067428_396641_9750'>
