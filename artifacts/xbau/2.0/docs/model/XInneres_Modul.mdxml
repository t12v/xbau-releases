								<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364378060442_879253_1246' visibility='public' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364378060442_872753_1245' visibility='public'/>
					</ownedAttribute>
