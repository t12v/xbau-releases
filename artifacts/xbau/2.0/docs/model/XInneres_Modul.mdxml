	<uml:Model xmi:id='eee_1045467100313_135436_1' name='XInneres' visibility='public'>
		<packagedElement xmi:type='uml:Model' xmi:id='_16_5_4_b7102e0_1292419822540_950613_464' name='XInneres' visibility='public'>
			<xmi:Extension extender='MagicDraw UML 16.5'>
				<moduleExtension moduleRoot='Externe Modelle::XInneres' moduleName='XInneres_Modul.mdxml' remoteProjectID='' remoteModuleVersion='1454689581484' moduleUsedByProject='true'/>
