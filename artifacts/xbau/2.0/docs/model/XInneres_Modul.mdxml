					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364476536488_324647_2421' name='Code.SGS.Gebiet' visibility='public'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364476536491_887316_2428' body='&lt;para&gt;Diese Codeliste für &lt;quote&gt;Staatsgebiete und deren unselbständigen Teile&lt;/quote&gt; umfasst Staatsgebiete sowie ggf. auch exterritoriale Teile mit eigenem ISO-Code. Sie entspricht den Einträgen im Länderverzeichnis des Auswärtigen Amtes und wird durch die Gebietsbezeichnung als Codename und durch numerische ID markiert. Enthält z.B. Einträge für Frankreich (Mutterland, das Hexagon), Französisch-Guayana (exterritoriales Übersee-Departement), Italien (Gebiet des Stiefels + Inseln), Vereinigtes Königreich (Mutterland: England, Schottland, Wales + Nordirland), britische Jungferninseln (Überseegebiet des Vereinigten Königreichs), Schottland.&lt;/para&gt;&#10;&lt;para&gt;Die Bedeutung des übermittelten Schlüssels ergibt sich aus der Spalte &lt;quote&gt;Gebietsbezeichnung_kurz&lt;/quote&gt; der veröffentlichten Genericcode-Datei.&lt;/para&gt;&#10;&#10;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364476536488_324647_2421'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1eeb04c1_1364476536489_966484_2423'>
							<general xmi:type='uml:Class' href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625280047_322339_5028'>
								<xmi:Extension extender='MagicDraw UML 16.5'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Code::1.0::Code' referentType='Class'/>
								</xmi:Extension>
							</general>
						</generalization>
