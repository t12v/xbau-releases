					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1375775410206_840180_1736' name='ausloesendeStelle' visibility='private' type='_16_5_4_1eeb04c1_1364382738190_314891_1582'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1375775538525_847983_1746' body='&lt;para&gt;In diesem Element werden Informationen zu der den Prozess auslösenden Behörde übermittelt.&lt;/para&gt;'>
