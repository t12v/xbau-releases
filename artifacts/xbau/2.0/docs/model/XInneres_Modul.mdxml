	<XOEV_Profil:xsdElement xmi:id='_16_5_4_b7102e0_1292420010066_427249_531' base_Property='_16_5_4_b7102e0_1292420010058_143599_509' form='unqualified' position='3'/>
	<XOEV_Profil:xoevBBIE xmi:id='_16_5_4_b7102e0_1292420010066_427249_531application1' base_Element='_16_5_4_b7102e0_1292420010058_143599_509' MotivationDerAbweichung='In der Meldeanschrift werden die Bestandteile einer Hausnummer stukturiert übermittelt. D.h. eigentliche Hausnummer wird getrennt von etwaigen Zusatzbuchstaben (bspw. 4b) oder Teilnummern (1 1/3).&#10;&#10;Diese Aufteilung erfolgt entsprechend der Vorgaben aus den DSMeld-Blättern 1206, 1208, 1209.'/>
