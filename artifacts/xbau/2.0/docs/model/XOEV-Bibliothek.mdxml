								<memberEnd xmi:idref='_16_5_4_5b501fb_1389522351590_656723_1990'/>
								<memberEnd xmi:idref='_16_5_4_5b501fb_1389522351739_301124_2681'/>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351739_31285_2680' body='Hier kann angegeben werden, welche Sprachen eine natürliche Person als Muttersprache beherrscht.'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1389522351521_124823_1767'/>
								</ownedComment>
								<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1389522351739_301124_2681' visibility='private' type='_16_5_4_5b501fb_1389522351506_805713_1690' association='_16_5_4_5b501fb_1389522351521_124823_1767'/>
							</packagedElement>
							<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_5b501fb_1389522351522_889864_1768' visibility='public'>
								<memberEnd xmi:idref='_16_5_4_5b501fb_1389522351575_791927_1931'/>
								<memberEnd xmi:idref='_16_5_4_5b501fb_1389522351739_735591_2684'/>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351739_281707_2683' body='Die &quot;gueltigkeit&quot; gibt mit Beginn- und/oder Endzeitpunkt den Zeitraum an, für den eine Auskunftssperre besteht.'>
