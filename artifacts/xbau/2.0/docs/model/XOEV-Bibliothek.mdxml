										</modelExtension>
									</xmi:Extension>
									<xmi:Extension extender='MagicDraw UML 16.5'>
										<modelExtension>
											<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1389522351739_825779_2687' visibility='public' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1389522351523_522019_1771' name='hierarchieebene' visibility='private'>
									<type xmi:type='uml:Class' href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191803156_348252_1327'>
										<xmi:Extension extender='MagicDraw UML 16.5'>
											<referenceExtension referentPath='XOEV-Profil::W3C Data Types::integer' referentType='Class'/>
										</xmi:Extension>
									</type>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351740_987921_2692' body='&lt;para&gt;Kennzeichnung der Hierarchieebene der Organisationseinheit.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1389522351523_522019_1771'/>
									</ownedComment>
									<xmi:Extension extender='MagicDraw UML 16.5'>
										<modelExtension>
