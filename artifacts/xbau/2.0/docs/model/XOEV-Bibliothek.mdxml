								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291325_321573_6185' body='&lt;para&gt;In Deutschland bezeichnet der Kreis eine bestimmt Region, einen Stadt- oder Landkreis.&lt;/para&gt;&#10;&#10;&lt;para&gt;Die Bezeichnung eines Kreises erfolgt durch die Angabe eines Schlüssels zur Identifikation des Kreises innerhalb des Landes.&lt;/para&gt;&#10;&#10;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291130_893565_5272'/>
								</ownedComment>
