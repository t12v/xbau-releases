								<memberEnd xmi:idref='_16_5_4_5b501fb_1389522351737_412823_2639'/>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351737_33006_2638' body='Die &quot;organisationsstruktur&quot; eröffnet die Möglichkeit, ergänzend interne Organisations- und Hierarchieebenen einer Behörde für ihre Erreichbarkeit aber auch für Zwecke der Dienstaufsicht im Rahmen des Geschäftsprozesses  zu beschreiben. &#10;'>
