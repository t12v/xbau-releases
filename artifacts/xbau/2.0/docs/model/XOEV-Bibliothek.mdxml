								<memberEnd xmi:idref='_16_5_4_5b501fb_1389522351739_181133_2672'/>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351739_408598_2671' body='Der frühere Familienname ist der Nachname, den eine Person vor einer Nachnamensänderung geführt hat. &#10;'>
