										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1389522351764_113731_2949' visibility='public' value='1'/>
										</modelExtension>
									</xmi:Extension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1389522351764_305560_2947' visibility='public'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1389522351589_381317_1985' name='geschlecht' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1389522351511_52509_1701' association='_16_5_4_5b501fb_1389522351520_170313_1757'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351764_950474_2952' body='&lt;para&gt;Die Komponente &quot;geschlecht&quot; repräsentiert die Angaben zum Geschlecht einer natürlichen Person.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1389522351589_381317_1985'/>
									</ownedComment>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1389522351764_87845_2953' visibility='public' value='*'/>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1389522351764_354528_2951' visibility='public'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1389522351589_984330_1986' name='tod' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1389522351510_527135_1698' association='_16_5_4_5b501fb_1389522351516_225847_1721'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351764_135987_2956' body='&lt;para&gt;Hier werden Angaben zum Tod einer natürlichen Person gemacht.&lt;/para&gt;'>
