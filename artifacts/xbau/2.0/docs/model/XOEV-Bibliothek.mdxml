							<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_5b501fb_1389522351519_342080_1745' visibility='public'>
								<memberEnd xmi:idref='_16_5_4_5b501fb_1389522351721_370090_2470'/>
								<memberEnd xmi:idref='_16_5_4_5b501fb_1389522351736_148106_2615'/>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351736_238954_2614' body='Der Vorname ist der Name bzw. der Teil des Namens, der nicht die Zugehörigkeit zu einer Familie ausdrückt, sondern das Individuum innerhalb der Familie bezeichnet und dazu dient, es von anderen Familienmitgliedern zu unterscheiden. '>
