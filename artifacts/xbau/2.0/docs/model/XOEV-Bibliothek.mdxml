							<memberEnd xmi:idref='_16_5_4_5b501fb_1387625291320_889940_6106'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291320_977908_6105' body='Der Geburtsname ist der Nachname einer Person, der sich jeweils aus dem Geburtseintrag für diese Person ergibt. Der Geburtsname ist i.d.R. der Nachname, der vor der ersten Eheschließung oder Lebenspartnerschaft geführt wurde.&#10;'>
