					<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_5b501fb_1387625291095_496421_5153' name='VorlagenFachlicheBausteine' visibility='public'>
						<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_5b501fb_1389522351491_788525_1681' name='fachuebergreifend' visibility='public'>
							<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1389522351494_224447_1682' name='Organisationseinheit' visibility='public'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351523_172733_1773' body='&lt;para&gt;Die Organisationseinheit fasst Angaben zur Darstellung der internen hierarchischen Organisationsstruktur einer Institution zusammen, z.B. zur Darstellung von Abteilungen oder Referaten.&lt;/para&gt; '>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1389522351494_224447_1682'/>
								</ownedComment>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1389522351522_399447_1770' name='name' visibility='private' type='_16_5_4_5b501fb_1387625271095_781237_4845'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1389522351740_767048_2688' body='&lt;para&gt;Bezeichnung der Organisationseinheit.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1389522351522_399447_1770'/>
									</ownedComment>
									<xmi:Extension extender='MagicDraw UML 16.5'>
