							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465323422313_646977_6742' name='referenzPrimaerdokument' visibility='private'>
						<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191702187_214129_966'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='XOEV-Profil::W3C Data Types::anyURI' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465323422313_390618_6745' body='&lt;para&gt;Hier ist der Link auf das Primärdokument in einem Quellsystem einzutragen, der die Anlage (Datei) identifiziert bzw. als Ressource verfügbar macht.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1465323422313_646977_6742'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465323422313_849553_6744'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
