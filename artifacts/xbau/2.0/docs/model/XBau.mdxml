									<modelExtension>
										<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475683193723_459427_6422' value='1'/>
									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
