								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468415498263_302492_5528' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468416340267_170061_5954' name='rechtsbereich' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467881020760_671045_5646'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468416340267_288139_5957' body='&lt;para&gt;Dieses Element nennt den  Rechtsbereich, innerhalb dessen Anlass und angeforderte Stellungnahme liegen. &lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468416340267_170061_5954'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468416340267_590428_5956' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468416340267_924066_5958' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468415540067_481917_5543' name='grundDerBeteiligung' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468415540067_608162_5546' body='&lt;para&gt;Hier wird der Grund bzw. das Anliegen der Beteiligung mit Bezug auf die entsprechenden Eigenschaften des Bauvorhabens im Detail formuliert.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468415540067_481917_5543'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468415540067_919300_5545' value='1'/>
								</modelExtension>
							</xmi:Extension>
