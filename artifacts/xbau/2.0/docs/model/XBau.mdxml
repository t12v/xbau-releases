				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1467878653841_502297_5169' name='Code.FormelleBefundeArt'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467878653841_564739_5175' body='&lt;para&gt;In dieser Codeliste sind Kategorien von Befunden einer formellen Prüfung notiert. Es geht hier um Befundlisten, die das Ergebnis der formellen Prüfung eines Bauantrags, Abweichungsantrags, Vorbescheidsantrags, Prüfauftrags (bautechnische Nachweise) oder einer vorgelegten Baulasterklärung sind. &lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1467878653841_502297_5169'/>
					</ownedComment>
