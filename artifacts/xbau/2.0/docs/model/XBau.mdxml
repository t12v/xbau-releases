							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469949980871_1038_5759' name='auftrag' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469949980871_554082_5767' body='&lt;para&gt;Dieses Element enthält die Formulierung des Prüfauftrags.&lt;/para&gt;&#10;'>
									<annotatedElement xmi:idref='_16_5_4_940029b_1469949980871_1038_5759'/>
								</ownedComment>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469950855248_528164_5793' value='1'/>
									</modelExtension>
