				<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_940029b_1475788011145_184309_6775' name='Bauzustand'>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1475788011145_680098_6777' name='bauzustand.anzeige.0920'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475788011145_342408_6787' body='&lt;para&gt;Mittels dieser Nachricht kündigt der  Bauherr der Bauaufsichtsbehörde den Zeitpunkt des Erreichens eines bestimmten Bauzustandes an.&lt;/para&gt;&#10;&#10;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1475788011145_680098_6777'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1475788011145_134420_6785' general='_16_5_4_940029b_1461154142365_974763_4934'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475991889489_682821_6120' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475991889489_810325_6123' body='&lt;para&gt;In diesem Elements werden Eintragungen vorgenommen, um auf die Baugenehmigung Bezug zu nehmen, die der aktuellen Baumaßnahmen zugrundliegen. Ggf. wird auf die entsprechende XBau-Nachricht referenziert.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1475991889489_682821_6120'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1475991889489_79163_6122' value='1'/>
								</modelExtension>
