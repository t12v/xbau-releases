						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467899960094_262689_5829' name='rechtsbereich' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467881020760_671045_5646'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467899960094_429933_5835' body='&lt;para&gt;Dieses Element nennt den  Rechtsbereich, innerhalb dessen die Nebenbestimmung erlassen ist. &lt;/para&gt;'>
