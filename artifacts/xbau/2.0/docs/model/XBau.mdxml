						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467899960094_268144_5832' body='&lt;para&gt;Dieser Typ beinhaltet die Parameter, die eine Nebenbestimmung definieren. &lt;/para&gt;'>
