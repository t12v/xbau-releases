						<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1465388336485_502829_5716' name='Anonym_Sachverhalt'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465388336485_721743_5722' body='&lt;para&gt;Nur eine natürliche Person mit einer Bauvorlageberechtigung kann einen Baunatrag unterschreiben. Dieser Typ definiert die Angaben zum Nachweis der Bauvorlageberechtigung.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465388336485_502829_5716'/>
							</ownedComment>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465388627157_358715_5818' name='baubeginn' visibility='private' aggregation='composite' type='_16_5_4_940029b_1465388521993_510280_5790' association='_16_5_4_940029b_1465388627157_986790_5817'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465390119619_788885_6116' body='&lt;para&gt;Falls die Nachricht dazu dient, den  Baubeginn eines genehmigten Bauvorhabens anzuzeigen, dann ist dieses Element zu wählen unter Angabe des Datums des geplanten Baubeginns.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_940029b_1465388627157_358715_5818'/>
								</ownedComment>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465388943424_505727_5920' value='1'/>
									</modelExtension>
								</xmi:Extension>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465388943424_737944_5921' value='1'/>
									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465388662917_766335_5833' name='wiederaufnahmeBauarbeiten' visibility='private' aggregation='composite' type='_16_5_4_940029b_1465388521993_510280_5790' association='_16_5_4_940029b_1465388662917_85317_5832'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465390246445_919961_6119' body='&lt;para&gt;Falls die Nachricht die Wiederaufnahme von Bauarbeiten anzeigen soll, dann ist dieses Element zu wählen unter Angabe des Datums der geplanten Wiederaufnahme.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_940029b_1465388662917_766335_5833'/>
								</ownedComment>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465388953729_147259_5924' value='1'/>
									</modelExtension>
								</xmi:Extension>
