						<memberEnd xmi:idref='_16_5_4_940029b_1467843283923_737799_5635'/>
						<memberEnd xmi:idref='_16_5_4_940029b_1467843283923_268709_5634'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467843283923_268709_5634' visibility='private' type='_16_5_4_940029b_1467843232886_870322_5578' association='_16_5_4_940029b_1467843283923_190241_5633'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1467880682692_826535_5579' name='Anonym_BelastenderVerwaltungsaktGrund'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467881357405_42046_5676'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1467880682692_826535_5579'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467880682692_48585_5580' name='rechtsbereich' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467881020760_671045_5646'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467880682692_666174_5586' body='&lt;para&gt;Dieses Element nennt den  Rechtsbereich, innerhalb dessen der belastende Verwaltungsakt liegt. &lt;/para&gt;'>
