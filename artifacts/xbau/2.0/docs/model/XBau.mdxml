					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1408619391062_185340_3007' name='bauvorlageart' visibility='private' type='_16_5_4_940029b_1475588555524_74161_6543'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1410188132361_100082_3209' body='&lt;para&gt;Unterhalb dieses Elements wird die Art dieser Bauvorlage oder sonstigen Anlage näher spezifiziert.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_8a30247_1408619391062_185340_3007'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
