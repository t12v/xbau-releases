						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422955529766_536500_5916' name='name' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
