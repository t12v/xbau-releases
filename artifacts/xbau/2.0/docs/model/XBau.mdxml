						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1461086810275_166760_5375' name='identifikation.nachricht' visibility='private' aggregation='composite' type='_16_5_4_940029b_1461085771571_78551_5204' association='_16_5_4_940029b_1461086810275_947390_5374'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1461162229211_61829_5895' body='&lt;para&gt;Hier werden die Identifkationsmerkmale zur vorliegenden Nachricht genannt.&lt;/para&gt;'>
