							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475992874561_915923_7418' name='pruefer' visibility='private' type='_16_5_4_940029b_1460619307903_831925_3517'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475993367682_458917_7436' body='&lt;para&gt;Hier werden die Daten der Person genannt, die die Prüfung durchgeführt hat.&lt;/para&gt;&#10;'>
