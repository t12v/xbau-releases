							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422955529797_243429_5968' body='&lt;para&gt;Diese Komponente beinhaltet eine Feststellung (wahr oder falsch), ob zu Recht kein Name angegeben wurde. Ueber das Setzen auf TRUE, wird angezeigt, dass zurecht kein Name angegeben wurde.&lt;/para&gt; '>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422955529766_12705_5917'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422955529797_108430_5967'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
