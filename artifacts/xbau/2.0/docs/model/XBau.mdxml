						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422884384004_253575_4235' name='staat' visibility='private' aggregation='composite' type='_16_5_4_940029b_1422888807308_342425_3010'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422884384082_208972_4317' body='&lt;para&gt;Der Staat, dem die Anschrift postalisch zugeordnet wird.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422884384004_253575_4235'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_29934_4316'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8a30247_1422884384082_809940_4318' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422884384004_806120_4239' name='strasse' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422884384082_250735_4333' body='&lt;para&gt;Eine Straße ist ein planmäßig angelegter, im allgemeinen befestigter Verkehrsweg innerhalb eines Ortes.&lt;/para&gt; &#10;&#10;&lt;para&gt;Das Element strasse enthält den Namen (die Bezeichnung) einer Straße.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422884384004_806120_4239'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_323635_4332'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_34049_4334' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422884384004_451688_4240' name='hausnummer' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422884384082_264227_4337' body='&lt;para&gt;Eine Hausnummer dient der genauen Lokalisierung eines Grundstücks, Gebäudes oder Gebäudeteils (Eingang) in einer Straße.&lt;/para&gt; &#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422884384004_451688_4240'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_682001_4336'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_892535_4338' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422884384004_212723_4241' name='postfach' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422884384082_549186_4341' body='&lt;para&gt;Ein Postfach (oft Postfachnummer) ist ein Schlüssel zur Identifikation eines Postfaches in einer Postfiliale.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422884384004_212723_4241'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_784010_4340'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_913439_4342' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422884384004_802917_4242' name='postleitzahl' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422884384082_588674_4345' body='&lt;para&gt;Eine Postleitzahl ist eine Angabe, um postalische Zustellgebiete unabhängig von Gebietskörperschaften (Gemeinde, Kreis) zu bezeichnen.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422884384004_802917_4242'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_467767_4344'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_224431_4346' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422884384004_979617_4243' name='ort' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422884384082_612642_4349' body='&lt;para&gt;Der &quot;ort&quot; enthält den Namen eines Ortes (Gemeinde, Ortschaft oder Stadt).&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422884384004_979617_4243'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_46680_4348'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_775087_4350' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422884384004_337175_4246' name='wohnungsgeber' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422884384082_10646_4361' body='&lt;para&gt;Die Komponente &quot;wohnungsgeber&quot; enthält Angaben (Name/Bezeichnung) zum Hauptmieter oder Eigentümer einer Immobilie.&lt;/para&gt;&#10;&#10;&lt;para&gt;Die Angabe eines Wohnungsgebers im Kontext der Anschrift dient der genaueren oder leichteren Adressierung. Sie darf nicht genutzt werden um Mietverhältnisse oder ähnliche rechtliche Beziehungen zwischen Personen auszudrücken.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiel: bei Meyer&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422884384004_337175_4246'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_415657_4360'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_381478_4362' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422884384004_320565_4247' name='zusatz' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422884384082_765934_4365' body='&lt;para&gt;Ein Anschriftenzusatz beinhaltet ggf. erforderliche weitere Präzisierungen zu einer Anschrift.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiele: Hinterhof, 3. Aufgang, Haus A, 3. Stock, Appartement 25a,  3. Stock - Appartement 25 a, #325a, Raum 77&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422884384004_320565_4247'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_837226_4364'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422884384082_511194_4366' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_8a30247_1422894619924_503273_3379' name='Kommunikation'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422894619924_612939_3385' body='&lt;para&gt;&quot;Kommunikation&quot; fasst Angaben zur Erreichbarkeit über elektronische Kommunikationskanäle (z.B. Telefon, Fax, E-Mail) zusammen.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_8a30247_1422894619924_503273_3379'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
