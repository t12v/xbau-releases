								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1470150896189_777415_5868' name='ergebnisDesVerfahrens' visibility='private' aggregation='composite' type='_16_5_4_940029b_1470154418625_431141_6144'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1470150896189_237118_5871' body='&lt;para&gt;Die Gemeinde trägt in dieses Element ein, welches Ergebnis die gemeindliche Prüfung der Anzeige ergeben hat.&lt;/para&gt;&#10;'>
