							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475991889489_421826_6124' value='1'/>
								</modelExtension>
