							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476036643713_107737_7777' name='begruendung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476036643713_112608_7786' body='&lt;para&gt;Falls die Baulast durch die Behörde nicht akzeptiert und eingetragen wurde, wird in diesem Element die Begründung für diese Entscheidung geliefert.&lt;/para&gt;&#10;&#10;'>
									<annotatedElement xmi:idref='_16_5_4_940029b_1476036643713_107737_7777'/>
								</ownedComment>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476036732771_166023_7798'/>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476036732771_802106_7799' value='1'/>
									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
						</packagedElement>
					</packagedElement>
				</packagedElement>
				<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_940029b_1475787797941_867272_6679' name='UeberwachungspflichtigeAnlagen'>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1475787797941_348773_6681' name='ueberwachungspflichtigeAnlagen.pruefbescheinigung.0800'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475787797957_323695_6691' body='&lt;para&gt;Diese Nachricht dient zur Übermittlung der Prüfbescheinigung an die Bauaufsichtsbehörde. Sie enthält alle relevanten Informationen zur Bewertung der Wirksamkeit und Betriebssicherheit der überwachungspflichtigen Anlagen.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1475787797941_348773_6681'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1475787797957_686967_6689' general='_16_5_4_940029b_1461154142365_974763_4934'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476071161612_359923_6541' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476071161612_423425_6544' body='&lt;para&gt;In diesem Element wird die Vorgangsnummer bzw. das Aktenzeichen zur erteilten Baugenehmigung übermittelt, die der Errichtung des Gebäudes und der technischen Anlage(n) zu Grunde lag.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476071161612_359923_6541'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476071161612_861538_6543' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476071161612_722962_6545' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1477926836011_430371_4781' name='gebaeude' visibility='private' type='_16_5_4_940029b_1460650473351_39062_3594'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477926836058_899596_4784' body='&lt;para&gt;Hier wird der Ort der Prüfung bezeichnet, nämlich Anschrift und Flurstück zum Gebäude, in dem die geprüfte technische Anlage (bzw. die geprüften technischen Anlagen)  installiert ist (sind).&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1477926836011_430371_4781'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1477926836043_825815_4783' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1477926836058_213416_4785' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476071641330_487967_6682' name='pruefgegenstand' visibility='private' type='_16_5_4_940029b_1476071320283_102133_6652'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476071641330_200090_6685' body='&lt;para&gt;Dieses Element bezeichnet den Gegenstand der Prüfung, eine bestimmte technische Anlage in dem lokalisierten Gebäude. Pro Element wird genau eine technische Anlage referenziert. Die Prüfung kann mehrere technische Anlagen in dem Gebäude zum Gegenstand haben.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476071641330_487967_6682'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1477927172218_812720_4788' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1477927172218_297343_4789' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476072133185_168795_6709' name='anlassDerPruefung' visibility='private' type='_16_5_4_940029b_1476071806236_935553_6689'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476072133185_239755_6712' body='&lt;para&gt;In diesem Element wird der Anlass der durchgeführten Prüfung genannt, über deren Ergebnis berichtet wird.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476072133185_168795_6709'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476072133185_405504_6711' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476072133185_372606_6713' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476072197571_935301_6716' name='anlagen' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476072197571_990795_6719' body='&lt;para&gt;Die Anlagen enthalten den Prüfbericht, der auch die Bewertung des Prüfergebnisses vornimmt und Konsequenzen empfiehlt. Der Inhalt des Prüfberichts ist in den Musterprüfgrundsätzen definiert (Anlage zur Musterprüfverordnung Ziffer 4). Der Betreiber der technischen Anlagen hat den Prüfbericht typischerweise als Papierdokument vom Prüfsachverständigen erhalten.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476072197571_935301_6716'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476072197571_435460_6718' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476072197571_806625_6720' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Dependency' xmi:id='_16_5_4_940029b_1475787797957_970832_6682'>
						<client xmi:idref='_16_5_4_940029b_1475787797941_867272_6679'/>
						<supplier xmi:idref='_16_5_4_1d100e5_1384794877872_302539_331'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1475787797957_934854_6684' name='ueberwachungspflichtigeAnlagen.erinnerung.0801'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475787797957_295334_6699' body='&lt;para&gt;Diese Nachricht dient der Information des Betreibers, dass eine Prüfbescheinigung überfällig ist.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1475787797957_934854_6684'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1475787797957_357678_6695' general='_16_5_4_940029b_1461155848215_275954_5270'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475787797957_940393_6696' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475787797957_698472_6721' body='&lt;para&gt;In diesem Element wird die Vorgangsnummer bzw. das Aktenzeichen zur erteilten Baugenehmigung übermittelt, die der Errichtung des Gebäudes und der technischen Anlage(n) zu Grunde lag.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1475787797957_940393_6696'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1475787797957_839365_6720' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475787797957_497721_6722' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476072284887_285728_6726' name='pruefgegenstand' visibility='private' type='_16_5_4_940029b_1476071320283_102133_6652'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476072284887_79764_6729' body='&lt;para&gt;Dieses Element bezeichnet den Gegenstand der Prüfung, eine bestimmte technische Anlage in dem lokalisierten Gebäude. Pro Element wird genau eine technische Anlage referenziert. Die Prüfung kann mehrere technische Anlagen in dem Gebäude zum Gegenstand haben.&lt;/para&gt;'>
