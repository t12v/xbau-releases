				<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_940029b_1462348527561_832432_4895' name='Baulasten'>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<ownedDiagram xmi:type='uml:Diagram' xmi:id='_16_5_4_940029b_1462348528108_494948_4992' name='Baulasten' visibility='public' ownerOfDiagram='_16_5_4_940029b_1462348527561_832432_4895'>
