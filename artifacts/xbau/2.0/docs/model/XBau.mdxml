							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1478973756024_43092_5140' name='listURI' visibility='private'>
						<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191702187_214129_966'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='XOEV-Profil::W3C Data Types::anyURI' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1478973756024_309727_5152' body='&lt;para&gt;Hier ist die URI einer Codeliste einzutragen, die dadurch hier eingebunden ist. Es ist die Codeliste dafür auszuwählen, auf deren Basis der übermittelte Schlüssel durch den Leser der Nachricht interpretiert werden soll.&lt;/para&gt;&#10;'>
