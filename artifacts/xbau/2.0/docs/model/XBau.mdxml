							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467899960094_37751_5839' body='&lt;para&gt;Hier wird die Art genannt, von der die erlassene Nebenbestimmung ist.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467899960094_859221_5830'/>
