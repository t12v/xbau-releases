							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422955529797_194605_5964' body='&lt;para&gt;Die Komponente &quot;name&quot; ist der  Familien- oder Vorname als Zeichenkette.&lt;/para&gt; &#10;&lt;para&gt;Nachnamen, z.B.  mit Adelstiteln bzw. ausländische Nachnamen werden als ein Name übermittelt und nicht in verschiedene Bestandteile aufgeteilt.&lt;/para&gt; &#10;&#10;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_8a30247_1422955529766_536500_5916'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422955529797_512651_5963'/>
