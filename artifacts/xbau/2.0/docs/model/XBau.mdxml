						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476117219455_43420_6025' body='&lt;para&gt;Dieser Typ fasst die städtebaulichen Kennzahlen des Vorhabens zusammen.&lt;/para&gt;'>
