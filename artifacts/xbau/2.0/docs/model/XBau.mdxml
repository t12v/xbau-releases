							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467842875383_23903_5545' body='&lt;para&gt;Hier ist die Versionsnummer der referenzierten Bauvorlage einzutragen. &lt;/para&gt;'>
