								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468415498263_290412_5522' name='strukturierteStellungnahme' visibility='private'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191716468_578747_1004'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='XOEV-Profil::W3C Data Types::boolean' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468415498263_886338_5531' body='&lt;para&gt;Gewünschte Form der angeforderten Stellungnahme: Falls eine strukturierte Stellungnahme gefordert wird, ist hier &quot;true&quot; einzutragen. Anderenfalls genügt der Bauaufsichtsbehörde eine Stellungnahme in einem formlosen Schreiben.&lt;/para&gt;&#10;&lt;para&gt;Das entsprechende Format wird in der späteren Lieferung der Stellungnahme durch die beteiligte Behörde mit &#10;&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot;&#10;linkend=&quot;XBau.Nachrichten.Beteiligung.beteiligung.stellungnahme.0303&quot;&gt;Nachricht 0303&lt;/link&gt; eingehalten. &lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468415498263_290412_5522'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468415498263_850588_5530' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468415498263_751716_5532' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1468483048397_160283_5901' name='Anonym_Stellungnahme'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468483048412_65404_5906'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1468483048397_160283_5901'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468483092774_168609_5931' name='stellungnahmeFormlos' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468483092774_709437_5935' body='&lt;para&gt;Die Stellungnahme ist in dieses Element als Fließtext einzufügen, falls eine formlose Stellungnahme angefordert wurde.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468483092774_168609_5931'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468483092774_963550_5934' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468483092774_152680_5936' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468483092774_263776_5932' name='stellungnahmeStrukturiert' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467896012971_615347_5228'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468483092774_423646_5939' body='&lt;para&gt;Falls eine strukturierte Stellungnahme angefordert wurde, ist eine bestimmte Form bei der Dokumentation der Stellungnahme einzuhalten.  Es sind die Parameter dieses Objekts zu füllen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468483092774_263776_5932'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468483092774_887556_5938' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468483092774_160796_5940' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
				</packagedElement>
				<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_940029b_1476089545293_858396_5697' name='DatentypenBaulast'>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1476035195880_924265_7679' name='BaulastErklaerung'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476035195884_184657_7687' body='&lt;para&gt;Dieser Typ beinhaltet die Daten zu Anlass und Inhalt einer Baulasterklärung.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1476035195880_924265_7679'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476035195884_93646_7682' name='anlass' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476035195884_547703_7694' body='&lt;para&gt;Hier wird die öffentlich-rechtliche Verpflichtung bezeichnet, die mit der einzutragenden Baulast einhergeht. Es wird der  Zweck bzw. das Ziel der einzurichtenden Baulast angegeben.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476035195884_93646_7682'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476036632490_9679_7773' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476036632490_879678_7774' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476035195884_669763_7683' name='beschreibung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476035195884_693195_7698' body='&lt;para&gt;Hier ist Text einzutragen, der die Baulast mit Bezugnahme auf die in der Nachricht aufgeführten Grundstücke definiert.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476035195884_669763_7683'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476035195884_69497_7697' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476035195884_641727_7699' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476036535283_837924_7764' name='sachverhalt' visibility='private' type='_16_5_4_940029b_1476035380312_138234_7724'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476036535283_843961_7767' body='&lt;para&gt;Hier wird eine Beschreibung der Verpflichtung im Detail gegeben. Dies geschieht, indem georeferenziert auf die Gegenstände der Baulast Bezug genommen wird. Pro Element wird ein Baulast-Gegenstand genannt.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476036535283_837924_7764'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476036621928_4894_7771' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476036621928_797043_7772' value='*'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1476035380312_138234_7724' name='Anonym_Gegenstand'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476035380312_721443_7727' body='&lt;para&gt;Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1476035380312_138234_7724'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476035380312_805281_7725' name='baulastgegenstand' visibility='private' type='_16_5_4_940029b_1460651165974_293124_3777'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476035380312_6317_7730' body='&lt;para&gt;In diesem Element wird ein Baulast-Gegenstand georeferenziert definiert. z.B. eine Baulastfläche (Abstandsfläche, die von der Bebauung freizuhalten ist) oder eine gemeinsame Brandwand (die nicht verändert werden darf in einem Bauvorhaben).&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476035380312_805281_7725'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476035380312_10838_7729' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476035380312_220881_7731' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476035380312_970392_7726' name='beschreibung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476035380312_299863_7734' body='&lt;para&gt;Zum georeferenzierten Baulast-Gegenstand werden hier Erläuterungen eingefügt.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476035380312_970392_7726'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476035380312_505582_7733' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476035380312_269185_7735' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
				</packagedElement>
				<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_940029b_1476117107068_322185_6000' name='DatenblattBaugegenstand'>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1476117186433_933286_6004' name='Nutzungseinheiten'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476117186433_934421_6008' body='&lt;para&gt;Dieser Typ fasst Angaben zu den Nutzungseinheiten des Vorhabens zusammen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1476117186433_933286_6004'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476117695755_715318_6103' name='wohneinheitenGesamt' visibility='private' aggregation='composite'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191855828_468108_1536'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='XOEV-Profil::W3C Data Types::positiveInteger' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476117695755_746043_6106' body='&lt;para&gt;Anzahl Wohneinheiten (gesamt)&lt;/para&gt;&#10;'>
