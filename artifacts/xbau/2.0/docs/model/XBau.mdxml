						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467899754926_723683_5816' name='abweichung' visibility='private' type='_16_5_4_940029b_1467898745212_460254_5732'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467899754926_689793_5819' body='&lt;para&gt;Hier werden ggf. die Erläuterungen zur Genehmigung einer beantragten Abweichung eingetragen.&lt;/para&gt;'>
