								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465393881878_339250_6279' body='&lt;para&gt;Dieses Element steht für eine Unterlage, auf deren Fehlen hingewiesen wird. &lt;/para&gt;'>
