					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1465320233547_555419_6283' name='Anonym_Bauvorlageberechtigung'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465320233563_422510_6288'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1465320233547_555419_6283'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465321337380_140631_6353' name='sachverhalt' visibility='private' type='_16_5_4_8a30247_1408526420047_574553_2278'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465321337396_627951_6356' body='&lt;para&gt;In diesem Element  ist zu kennzeichnen, aufgrund welchen Sachverhalts&#9; der Entwurfsverfasser seine  Bauvorlageberechtigung innehat.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465321337380_140631_6353'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465321337396_127699_6355' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465321337396_370594_6357' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465320233547_302105_6285' name='kammer' visibility='private' type='_16_5_4_940029b_1465319949338_111677_6242'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465320233563_384943_6291' body='&lt;para&gt;Falls der Entwurfsverfasser seine Bauvorlageberechtigung als Architekt, Innenarchitekt oder Ingenieur innehat, ist dieses Element mit den Angaben aus der Zugehörigkeit zur entsprechenden Kammer zu füllen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465320233547_302105_6285'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1483105068731_47953_5137'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1483105068731_999514_5138' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1465368877212_444325_5428' name='Bezug'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465369587050_970021_5510' body='&lt;para&gt;Dieser Typ gestattet Eintragungen, um auf einen Vorgang (Geschäftsprozess) und ggf. auf eine Nachricht, die im Rahmen dieses Vorgangs gesendet worden ist, Bezug zu nehmen. &lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1465368877212_444325_5428'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465369045932_696516_5487' name='vorgang' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465369445636_190258_5508' body='&lt;para&gt;Hier ist das Zeichen eines von der Bauaufsichtsbehörde geführten Vorgangs einzutragen, in dessen Kontext mit dieser Nachricht eine Aktion im Prozess durchgeführt wird. &lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465369045932_696516_5487'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465369058452_265785_5489' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465369058452_98569_5490' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465368962951_95865_5473' name='bezugNachricht' visibility='private' aggregation='composite' type='_16_5_4_940029b_1461085771571_78551_5204' association='_16_5_4_940029b_1465368962951_267124_5472'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465369491950_429402_5509' body='&lt;para&gt;Falls ein solcher Zusammenhang vorliegt, sind hier die Kennungen der Nachricht einzutragen, auf die sich diese Nachricht bezieht.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465368962951_95865_5473'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1483344604197_808975_5297'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1483344604197_502792_5298' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_940029b_1465368962951_267124_5472'>
						<memberEnd xmi:idref='_16_5_4_940029b_1465368962951_95865_5473'/>
						<memberEnd xmi:idref='_16_5_4_940029b_1465368962951_915832_5474'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465368962951_915832_5474' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428' association='_16_5_4_940029b_1465368962951_267124_5472'/>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1465389414760_979926_6071' name='BeteiligteBauprojektUmsetzung'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465389414760_107104_6077' body='&lt;para&gt;Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1465389414760_979926_6071'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465389414760_258948_6073' name='bauherr' visibility='private' type='_16_5_4_8a30247_1408703057450_27821_3423'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465389414760_844763_6080' body='&lt;para&gt;Hier sind Angaben zur Person des  Bauherrn zu machen, falls diese nicht identisch ist mit dem Bauherrn, der den Bescheid zum Bauantrag erhalten hat.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465389414760_258948_6073'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465389573417_929380_6106'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465389573417_763503_6107' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465389414760_429445_6074' name='bauleiter' visibility='private' type='_16_5_4_8a30247_1408703057450_27821_3423'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465389414760_699851_6084' body='&lt;para&gt;Hier sind Angaben zur Person und ggf. Firma des Bauleiters zu machen.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465389414760_429445_6074'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465389541231_548859_6104' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465389541231_272512_6105' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465389414760_590_6075' name='bauunternehmer' visibility='private' type='_16_5_4_8a30247_1422977426041_172815_6757'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465389414760_466876_6088' body='&lt;para&gt;Als Bauunternehmer ist der Rohbau-Unternehmer einzutragen, benötigt wird die Firma mit Ansprechpartner.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465389414760_590_6075'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465389414760_668981_6087' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465389414760_816775_6089' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465389414760_954276_6076' name='fachbauleiter' visibility='private' type='_16_5_4_8a30247_1408703057450_27821_3423'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465389414760_194241_6092' body='&lt;para&gt;Hier sind ggf. die Fachbauleiter zu nennen, die auf einzelnen Teilgebieten an die Stelle des Bauleiters treten.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465389414760_954276_6076'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465389528640_341362_6102'/>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465389528640_404082_6103' value='*'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1467842445378_570661_5400' name='Anonym_BefundFormell'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467842445394_510974_5406'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1467842445378_570661_5400'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467842445378_959445_5402' name='artDesBefundes' visibility='private' type='_16_5_4_940029b_1467878653841_502297_5169'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467842445394_187112_5409' body='&lt;para&gt;In diesem Element wird die Befundkategorie angegeben, der dieser Befund zugeordnet werden kann.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467842445378_959445_5402'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467879824604_405201_5561' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467879824604_329319_5562' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467842445394_688125_5403' name='refAnlage' visibility='private' type='_16_5_4_940029b_1467842624105_925789_5453'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467842445394_286618_5413' body='&lt;para&gt;Für Befunde, die sich auf eine eingereichte Bauvorlage bzw. eine sonstige Anlage zum Antrag beziehen, wird in diesem Objekt der Bezug hergestellt.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467842445394_688125_5403'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467842998545_917651_5558'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467842998545_132167_5559' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467842977089_248652_5552' name='betroffeneAnlage' visibility='private' aggregation='composite' type='_16_5_4_8a30247_1408530241706_68973_2543'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467879267029_945752_5558' body='&lt;para&gt;Für Befunde, die Mängel an einer eingereichten Bauvorlage oder das Fehlen einer Bauvorlage (einer bestimmten Art) betreffen, wird in diesem Element die Art dieser Bauvorlage angegeben (die den Mangel hat bzw. die nachzureichen ist).&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467842977089_248652_5552'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467842989812_77180_5556'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467842989812_115219_5557' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467843013793_549083_5560' name='beschreibung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467843013793_631994_5563' body='&lt;para&gt;Hier wird der Sachverhalt des Befundes beschrieben. Dieser Sachverhalt ist eine detialliertere Darstellung im Rahmen der parallel angegebenen Art des Befundes.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467843013793_549083_5560'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467843013793_252774_5562' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467843013793_784635_5564' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1467842624105_925789_5453' name='RefAnlage'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469955948657_527861_6074' body='&lt;para&gt;Typ für die Bezugnahme auf Bestandteile eines Antrags oder eines Auftrags. Dieser Typ wird im Kontext einer formellen Prüfung eingesetzt.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1467842624105_925789_5453'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467842761727_594467_5522' name='art' visibility='private' aggregation='composite' type='_16_5_4_8a30247_1408530241706_68973_2543' association='_16_5_4_940029b_1467842761727_550967_5520'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467879371270_198765_5559' body='&lt;para&gt;Hier wird die Art der referenzierten  Bauvorlage oder sonstigen Anlage zum vorliegenden Antrag genannt.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467842761727_594467_5522'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467842761727_440391_5524' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467842761727_217530_5525' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467842810328_89873_5526' name='bezeichnung' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
