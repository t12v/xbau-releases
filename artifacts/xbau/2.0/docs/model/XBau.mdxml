					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1467904417963_15998_6086' name='Gebuehrenbescheid'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467904417963_446498_6094' body='&lt;para&gt;Dieser Typ beinhaltet die Parameter eines Gebührenbescheids der Bauaufsichtsbehörde. Es sind die Daten zu Gegenstand, Herleitung, Betrag und Bezahlung der Gebühren enthalten.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1467904417963_15998_6086'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467904417963_810785_6088' name='istVorauszahlungsbescheid' visibility='private'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191716468_578747_1004'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='XOEV-Profil::W3C Data Types::boolean' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467904417963_207101_6097' body='&lt;para&gt;Falls es sich nicht um den abschließenden Gebührenbescheid, sondern um einen Vorauszahlungsbescheid handelt, ist hier true einzutragen. Dann weiß der Empfänger, dass weitere Gebührenbescheide zum angegebenen Vorgang zu erwarten sind.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467904417963_810785_6088'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467904417963_35437_6096' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467904417963_914128_6098' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467904417963_833770_6089' name='begruendung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467904417963_443469_6101' body='&lt;para&gt;Hier ist die Rechtsgrundlage für die Gebühr bzw. eine sonstige Begründung einzutragen.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467904417963_833770_6089'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467905211426_687154_6153' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467905211426_886686_6154' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467904798167_281550_6138' name='kostenberechnung' visibility='private' type='_16_5_4_940029b_1467902966126_526268_5914'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467904798167_224756_6141' body='&lt;para&gt;Dieses Objekt enthält alle Informationen zu den Positionen des Gebührenbescheids und deren Summierung zu einem Geldbetrag.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467904798167_281550_6138'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467904798167_522177_6140'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467904798167_352424_6142' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467904837994_276507_6145' name='zahlungsdaten' visibility='private' type='_16_5_4_940029b_1467902983357_400947_5945'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467904837994_535056_6148' body='&lt;para&gt;Dieses Element enthält die Angaben, die der Anwender zur Veranlassung einer bargeldlosen Bezahlung gemäß SEPA benötigt. &lt;/para&gt;&#10;'>
