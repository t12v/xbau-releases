								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475787171548_559022_6088' name='befundliste' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467843232886_870322_5578'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475787171564_27124_6152' body='&lt;para&gt;Hier sind die Ergebnisse der formellen Prüfung enthalten. Die Liste nennt die  Mängel, die bei der Prüfung der Baulast-Erklärung aufgefallen sind.&lt;/para&gt;&#10;'>
