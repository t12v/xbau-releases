					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1469909667809_97639_5945' name='bautechnischeNachweise.pruefauftrag.0500'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_926851_5966' body='&lt;para&gt;Diese Nachricht enthält alle Auftragsinformationen und die zu prüfenden Dokumente (die bautechnischen Nachweise zu Brandschutz und / oder zu Standsicherheit).&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1469909667809_97639_5945'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1469909667825_221799_5962' general='_16_5_4_940029b_1461155848215_275954_5270'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469909667825_566467_5963' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_545414_6024' body='&lt;para&gt;Hier trägt die Bauaufsichtsbehörde die Vorgangsnumme (Beauftragung und damit zusammenhängende Kommunikation) für künftige Referenzierung ein.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469909667825_566467_5963'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469909667825_809308_6023' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469909667825_365757_6025' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469949298512_323921_5732' name='bezugZuPruefauftrag' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469949298512_682160_5735' body='&lt;para&gt;Dieses Element wird verwendet, falls eine Referenz auf einen vorhergehenden Prüfauftrag (bezogen auf ggf. dasselbe bzw. erweiterte Gebäude) übermittelt werden soll.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469949298512_323921_5732'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469949420439_456019_5739'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469949420439_532610_5740' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469950213207_886460_5775' name='pruefauftrag' visibility='private' type='_16_5_4_940029b_1469949980871_187287_5756'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469950213207_611321_5778' body='&lt;para&gt;In diesem Element wird ein Prüfauftrag abgebildet. Jeder Prüfauftrag bezieht sich auf genau einen bautechnischen Nachweis.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469950213207_886460_5775'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469950942264_943919_5797' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469950942264_711766_5798' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469952132793_164810_5956' name='rahmendatenGebuehrenberechnung' visibility='private' type='_16_5_4_940029b_1475680854021_621117_6026'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469952132793_844701_5959' body='&lt;para&gt;In diesem Element sind Rahmendaten zur Gebührenberechnung aus Sicht der Bauaufsichtsbehörde abgebildet, soweit sie auf den hier erteilten Auftrag anwendbar sind. Sie geben dem Auftragnehmer die Möglichkeit, die Komplexität des Bauvorhabens einzuschätzen, in dessen Kontext der Auftrag erteilt wird, und entsprechend Aufwand und Auftragswert des Prüfauftrags zu kalkulieren.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469952132793_164810_5956'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1475680494588_632382_6024'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475680494588_259823_6025' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469949543928_251973_5741' name='bauvorhaben' visibility='private' aggregation='composite' type='_16_5_4_940029b_1461084279278_496533_4827'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469949543928_189314_5744' body='&lt;para&gt;Hier sind die Daten zum Bauvorhaben (Wer, Was, Wo) enthalten.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469949543928_251973_5741'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469949543928_612162_5743' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469949543928_35068_5745' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469949584052_908578_5748' name='anlagen' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469949584052_187798_5751' body='&lt;para&gt;Dieses Objekt enthält die Unterlagen (bzw. deren Metadaten), die für die Erfüllung des Prüfauftrags benötigt werden. Auch die zu prüfenden bautechnischen Nachweis gehören zu diesen Unterlagen.&lt;/para&gt;&#10;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469949584052_908578_5748'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469949584052_917196_5750' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469949584052_322289_5752' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1469909667809_758060_5948' name='bautechnischeNachweise.pruefauftragKorrektur.0503'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_442747_5985' body='&lt;para&gt;Diese Nachricht enthält geänderte oder ergänzte Daten des Prüfauftrags bzw. seiner Anlagen. Sie bezieht sich auf einen bereits erteilten Prüfauftrag und auf eine zu diesem&#10;vorliegende Mängel- bzw. Befundliste.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1469909667809_758060_5948'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1469909667825_706368_5981' general='_16_5_4_940029b_1461155848215_275954_5270'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469909667825_813568_5982' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_986729_6070' body='&lt;para&gt;Hier ist die Vorgangsnummer (Beauftragung) einzutragen (analog zu Nachricht 0500). Außerdem ist auf die Nachricht 0502 zu verweisen, auf deren Basis die Beauftragung angepasst worden ist.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469909667825_813568_5982'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469909667825_388247_6069' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469909667825_347932_6071' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469985012845_395835_5887' name='bezugZuPruefauftrag' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469985012849_708505_5894' body='&lt;para&gt;Hier kann eine korrigierte Referenz auf einen vorhergehenden Prüfauftrag stehen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469985012845_395835_5887'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469985012849_605190_5893'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469985012849_99987_5895' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469985012845_938861_5888' name='pruefauftrag' visibility='private' type='_16_5_4_940029b_1469949980871_187287_5756'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469985012849_651205_5898' body='&lt;para&gt;In diesem Element wird der ggf. angepasste Prüfauftrag übermittelt. &lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469985012845_938861_5888'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469985012849_126291_5897' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469985012849_614112_5899' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469985012849_153054_5889' name='rahmendatenGebuehrenberechnung' visibility='private' type='_16_5_4_940029b_1475680854021_621117_6026'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469985012853_963345_5902' body='&lt;para&gt;Hier können die ggf. korrigierten Rahmendaten zur Gebührenberechnung eingetragen werden.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469985012849_153054_5889'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469985012853_614707_5901' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469985012853_661082_5903' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469985012849_987517_5890' name='bauvorhaben' visibility='private' aggregation='composite' type='_16_5_4_940029b_1461084279278_496533_4827'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469985012853_638702_5906' body='&lt;para&gt;Hier werden angepasste Daten zum Bauvorhaben (Wer, Was, Wo) eingetragen, falls eine solche Anpassung in einem Bereich notwendig war (Bruttoprinzip).&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469985012849_987517_5890'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469985318946_166488_5922'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469985318946_86315_5923' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469985012849_74941_5891' name='anlagen' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469985012853_104544_5910' body='&lt;para&gt;Hier können korrigierte bzw. ergänzte Unterlagen, die für die Erfüllung des Prüfauftrags benötigt werden, eingetragen werden.&lt;/para&gt;&#10;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469985012849_74941_5891'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469985326729_743800_5924'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469985326729_462485_5925' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1469909667809_586604_5949' name='bautechnischeNachweise.formellePruefung.0502'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_89392_5993' body='&lt;para&gt;Diese Nachricht nennt Mängel bzw. Nachbesserungsbedarf zu einem erteilten Prüfauftrag.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1469909667809_586604_5949'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1469909667825_115778_5987' general='_16_5_4_940029b_1461154142365_974763_4934'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469909667825_536985_5988' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_291750_6084' body='&lt;para&gt;Hier trägt der Auftragnehmer die Vorgangsnumme der Bauaufsichtsbehörde ein, die ihm mit der Beauftragung (Nachricht 0500) zugestellt wurde. Außerdem wird die Referenz auf die Nachricht 0500 eingetragen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469909667825_536985_5988'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469909667825_721573_6083' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469909667825_133030_6085' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469954130145_707787_6026' name='befundliste' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467843232886_870322_5578'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469954130145_268432_6029' body='&lt;para&gt;Nach der Prüfiung des Auftrags durch den Auftragnehmer: Hier sind die Ergebnisse der formellen Prüfung als Befundliste enthalten. Für jeden Befund sind die entsprechenden Parameter gefüllt, die Inhalt und Bezug des Befundes nachvollziehbar machen.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469954130145_707787_6026'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469954130145_704820_6028' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469954130145_146807_6030' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1469909667825_764937_5950' name='bautechnischeNachweise.pruefbericht.0506'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_868541_6000' body='&lt;para&gt;Diese Nachricht nennt die Ergebnisse der Prüfung der vorgelegten bautechnischen Nachweise.&lt;/para&gt;&#10;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1469909667825_764937_5950'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1469909667825_183802_5995' general='_16_5_4_940029b_1461154142365_974763_4934'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469909667825_196036_5996' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_548327_6106' body='&lt;para&gt;In diesem Element wird auf Vorgang und Prüfauftrag Bezug genommen. &lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469909667825_196036_5996'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469909667825_856146_6105' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469909667825_119089_6107' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469909667825_382413_5997' name='pruefbericht' visibility='private' aggregation='composite' type='_16_5_4_940029b_1470064704646_498940_5928'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_45665_6110' body='&lt;para&gt;In diesem Element werden die Prüfergebnisse dargestellt und durch Nebensbestimmungen und weitere Anmerkungen ergänzt.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469909667825_382413_5997'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469909667825_124404_6109' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469909667825_284753_6111' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469909667825_636205_5999' name='anlagen' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469909667825_293187_6118' body='&lt;para&gt;Hier sind, soweit zutreffend, die  durch den Prüfingenieur überarbeiteten beziehungsweise kommentierten Bauvorlagen angefügt.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469909667825_636205_5999'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469909667825_588796_6117'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469909667825_483806_6119' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1469910026518_152820_6186' name='bautechnischeNachweise.rechnung.0507'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469910026518_886623_6193' body='&lt;para&gt;Diese Nachricht enthält die Rechnung für die erbrachten Leistungen des Auftragnehmers.&lt;/para&gt;&#10;&#10;&#10;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1469910026518_152820_6186'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1469910026518_205840_6188' general='_16_5_4_940029b_1461154142365_974763_4934'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469910026518_379308_6189' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469910026518_128293_6198' body='&lt;para&gt;In diesem Element wird auf Vorgang und Prüfauftrag Bezug genommen. &lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469910026518_379308_6189'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469910026518_997932_6197' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469910026518_806626_6199' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1470083850344_995328_6004' name='zeitaufwand' visibility='private' aggregation='composite'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191855828_468108_1536'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='XOEV-Profil::W3C Data Types::positiveInteger' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1470083850344_957967_6007' body='&lt;para&gt;In dieses Element trägt der Auftragnehmer den Aufwand für die Leistungserbringung in Minuten ein.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1470083850344_995328_6004'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1470083850344_323677_6006' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1470083850344_314425_6008' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1470083755646_970279_5997' name='rahmendatenGebuehrenberechnung' visibility='private' type='_16_5_4_940029b_1475680854021_621117_6026'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1470083755646_710522_6000' body='&lt;para&gt;In diesem Element sind Rahmendaten zur Gebührenberechnung aus Sicht des Auftragnehmers nach abgeschlossener Leistung abgebildet.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1470083755646_970279_5997'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1470083755646_426010_5999' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1470083755646_892684_6001' value='*'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1469910063190_204364_6222' name='bautechnischeNachweise.auftragsbestaetigung.0501'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469910063206_479498_6230' body='&lt;para&gt;Der Prüfingenieur bestätigt mit dieser Nachricht, dass er den Auftrag erhalten und angenommen hat.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1469910063190_204364_6222'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1469910063190_756788_6224' general='_16_5_4_940029b_1461154142365_974763_4934'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1469910063190_112133_6225' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1469910063206_810644_6235' body='&lt;para&gt;Dieses Elements stellt den Bezug zum erteilten Auftrag (Vorgangsnummer) und zur entsprechenden &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; linkend=&quot;XBau.Nachrichten.BautechnischeNachweise.bautechnischeNachweise.pruefauftrag.0500&quot;&gt;Nachricht 0500&lt;/link&gt; her. Dieser Auftrag wird mit dieser Nachricht bestätigt.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1469910063190_112133_6225'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
