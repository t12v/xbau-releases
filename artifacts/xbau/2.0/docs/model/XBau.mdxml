							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476071806236_711433_6690' name='anlass' visibility='private' type='_16_5_4_43c01ae_1406133066375_719523_2502'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476071806237_823395_6695' body='&lt;para&gt;Dieses Element nennt den Anlass der durchgeführten Prüfung. Es deckt eine Reihe von Standardfällen ab.&lt;/para&gt;'>
