									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467903020454_476250_5979' body='&lt;para&gt;Hier ist das Kassenzeichen einzutragen, unter dem die Sollstellung durch die Baubehörde bei der lokalen Finanzverwaltung veranlasst wurde. Ist vom Bauherrn bei der Zahlung im Überweisungsformular in das Feld &quot;Verwendungszweck&quot; einzutragen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467903020454_231000_5976'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467903180941_133981_5985' value='1'/>
								</modelExtension>
							</xmi:Extension>
