							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465327539581_806168_6764' value='1'/>
