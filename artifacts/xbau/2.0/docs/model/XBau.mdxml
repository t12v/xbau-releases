					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1475787171532_608660_6069' name='baulasten.nachforderung.0701'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475787171548_431360_6090' body='&lt;para&gt;Diese Nachricht enthält die Befunde der Bauaufsichtsbehörde zu der eingereichten Baulasterklärung bzw. den beigefügten Unterlagen.&lt;/para&gt;&#10;'>
