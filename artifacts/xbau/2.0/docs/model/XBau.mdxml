						<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1476071320283_102133_6652' name='Anonym_Pruefgegenstand'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476071320283_917862_6656' body='&lt;para&gt;Dieser Typ beinhaltet die Parameter eines Bescheides, den die Bauaufsichtsbehörde nach Prüfung eines Antrags erlässt.&lt;/para&gt;'>
