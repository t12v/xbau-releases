							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467904417963_451437_6109' body='&lt;para&gt;Hier werden Angaben zu Zuschlägen bei Fristversäumnis eingetragen.&lt;/para&gt;'>
