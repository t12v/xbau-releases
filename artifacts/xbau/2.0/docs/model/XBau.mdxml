								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1461088077048_161321_5534' name='leser' visibility='private' aggregation='composite' association='_16_5_4_940029b_1461088077048_639685_5533'>
							<type href='XInneres_Modul.mdxml#_16_5_4_1eeb04c1_1364313722451_850604_9366'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XInneres::Behoerde::Behoerde' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1461162284632_319357_5898' body='&lt;para&gt;Hier wird die Fachbehörde bzw. Organisation genannt, für die die vorliegende Nachricht bestimmt ist.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1461088077048_161321_5534'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
