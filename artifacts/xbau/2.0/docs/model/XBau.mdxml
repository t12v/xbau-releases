						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1467896417302_199580_5413' name='Anonym_Tenor'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467896417302_79764_5416' body='&#10;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1467896417302_199580_5413'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1483174208250_220105_4993' name='istGenehmigung' visibility='private' aggregation='composite' association='_16_5_4_940029b_1483174208250_292936_4991'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191716468_578747_1004'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='XOEV-Profil::W3C Data Types::boolean' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1483174208250_221227_4996' body='&lt;para&gt;Falls der Tenor positiv  ist (Genehmigung), so ist in diesem Element &quot;true&quot; zu übermitteln, andernfalls (Ablehnung) &quot;false&quot;.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1483174208250_220105_4993'/>
							</ownedComment>
