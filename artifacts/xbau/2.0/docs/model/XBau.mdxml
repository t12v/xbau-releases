									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8a30247_1422955529797_277543_5969' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
