							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476071320283_243150_6655' name='artDerTechnischenAnlage' visibility='private' type='_16_5_4_8a30247_1408528824829_316950_2466'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476071320283_605640_6667' body='&lt;para&gt;Dieses Element enthält Angaben zur Art der geprüften technischen Anlage.&lt;/para&gt;'>
