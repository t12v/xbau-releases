							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465319467561_616051_6203' body='&lt;para&gt;Hier ist die Nummer der Eintragungsliste der jeweiligen Kammer einzutragen.&lt;/para&gt;'>
