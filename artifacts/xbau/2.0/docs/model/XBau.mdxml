								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422955529766_12705_5917' name='nichtVorhanden' visibility='private'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191716468_578747_1004'>
