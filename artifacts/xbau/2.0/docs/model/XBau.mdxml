							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465323220009_117547_6735' name='dateinameAnhang' visibility='private'>
						<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
