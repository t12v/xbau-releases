0247_1422977426041_172815_6757"></elementID>		<properties>			<mdElement elementClass="ColorProperty">				<propertyID>FILL_COLOR</propertyID>				<propertyDescriptionID>FILL_COLOR_DESCRIPTION</propertyDescriptionID>				<value xmi:value="-6697729"></value></mdElement>			<mdElement elementClass="BooleanProperty">				<propertyID>HTML_TEXT</propertyID>				<propertyDescriptionID>HTML_TEXT_DESCRIPTION</propertyDescriptionID>				<value xmi:value="true"></value></mdElement></properties>		<geometry>42, 49, 378, 133</geometry>		<text>&lt;html&gt;  &lt;head&gt;      &lt;/head&gt;  &lt;body&gt;    &lt;p&gt;      &lt;b&gt;Die XBau-Klasse Organisation wurde ersetzt durch die Kernkomponente       Organisation (refactored). Letzterer wurde au&amp;#223;erdem ein Attribut       &amp;quot;vertreter&amp;quot; des komplexen Kernkomponenten-Typs &amp;quot;NatuerlichePerson&amp;quot;       hinzugef&amp;#252;gt, um den im urspr&amp;#252;nglichen Entwurf vorgesehenen       Informationsgehalt nicht zu schm&amp;#228;lern.&lt;/b&gt;    &lt;/p&gt;  &lt;/body&gt;&lt;/html&gt;</text>		<active xmi:idref="_16_5_4_8a30247_1422980555455_560271_7969"></active></mdElement>	<mdElement elementClass="NoteAnchor" xmi:id="_16_5_4_8a30247_1422980555455_560271_7969">		<properties>			<mdElement elementClass="ColorProperty">				<propertyID>PEN_COLOR</propertyID>				<propertyDescriptionID>PEN_COLOR_DESCRIPTION</propertyDescriptionID>				<value xmi:value="-13395457"></value></mdElement></properties>		<linkFirstEndID xmi:idref="_16_5_4_8a30247_1422977828544_702486_7703"></linkFirstEndID>		<linkSecondEndID xmi:idref="_16_5_4_8a30247_1422980372852_304021_7958"></linkSecondEndID>		<geometry>346, 282; 277, 182; </geometry></mdElement>	<mdElement elementClass="Note" xmi:id="_16_5_4_8a30247_1422980614239_438044_7970">		<elementID xmi:idref="_16_5_4_8a30247_1408704210206_416523_3867"></elementID>		<properties>			<mdElement elementClass="ColorProperty">				<propertyID>FILL_COLOR</propertyID>				<propertyDescriptionID>FILL_COLOR_DESCRIPTION</propertyDescriptionID>				<value xmi:value="-6697729"></value></mdElement>			<mdElement elementClass="BooleanProperty">				<propertyID>HTML_TEXT</propertyID>				<propertyDescriptionID>HTML_TEXT_DESCRIPTION</propertyDescriptionID>				<value xmi:value="true"></value></mdElement></properties>		<geometry>553, 854, 392, 140</geometry>		<text>&lt;html&gt;  &lt;head&gt;      &lt;/head&gt;  &lt;body&gt;    &lt;p&gt;      &lt;b&gt;Die Klasse &amp;quot;Vertreter&amp;quot; ist damit eigentlich ebenfalls obsolet, da sie       lediglich ein Attribut des Typs &amp;quot;NatuerlichePerson&amp;quot; enthieltt und zudem       au&amp;#223;er von Organisation nur noch ein einziges weiteres Mal, n&amp;#228;mlich von       &amp;quot;Bauherr&amp;quot; verwendet wird -- dort k&amp;#246;nnte in gleicher Weise direkt ein       entsprechendes Attribut des Typs &amp;quot;NatuerlichePerson&amp;quot; verwendet und       &amp;quot;Vertreter&amp;quot; damit eingespart werden.&lt;/b&gt;    &lt;/p&gt;  &lt;/body&gt;&lt;/html&gt;</text>		<active xmi:idref="_16_5_4_8a30247_1422980763492_716630_7981"></active></mdElement>	<mdElement elementClass="NoteAnchor" xmi:id="_16_5_4_8a30247_1422980763492_716630_7981">		<properties>			<mdElement elementClass="ColorProperty">				<propertyID>PEN_COLOR</propertyID>				<propertyDescriptionID>PEN_COLOR_DESCRIPTION</propertyDescriptionID>				<value xmi:value="-13395457"></value></mdElement></properties>		<linkFirstEndID xmi:idref="_16_5_4_8a30247_1422977837061_996989_7732"></linkFirstEndID>		<linkSecondEndID xmi:idref="_16_5_4_8a30247_1422980614239_438044_7970"></linkSecondEndID>		<geometry>455, 913; 553, 917; </geometry></mdElement>	<mdElement elementClass="Class" xmi:id="_16_5_4_8ae0277_1427191914600_992201_5916">		<elementID xmi:idref="_16_5_4_8a30247_1422957408723_400098_8364"></elementID>		<properties>			<mdElement elementClass="BooleanProperty">				<propertyID>AUTOSIZE</propertyID>				<propertyDescriptionID>AUTOSIZE_DESCRIPTION</propertyDescrip