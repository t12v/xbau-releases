						<memberEnd xmi:idref='_16_5_4_940029b_1461088077048_161321_5534'/>
						<memberEnd xmi:idref='_16_5_4_940029b_1461088077048_773537_5535'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1461088077048_773537_5535' visibility='private' type='_16_5_4_940029b_1461085754575_118769_5184' association='_16_5_4_940029b_1461088077048_639685_5533'/>
					</packagedElement>
