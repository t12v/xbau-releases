							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465323220025_277318_6738' body='&lt;para&gt;Hier ist der Name der Datei (Primärdokument) einzutragen, als die die Bauvorlage als Anlage zum Antrag übermittelt wird.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1465323220009_117547_6735'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465323220025_553837_6737'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465323220025_978224_6739' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_8a30247_1408705895800_629557_4010' name='Entwurfsverfasser'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1408705928504_523657_4029' body='&lt;para&gt;Dieser Typ dient dazu, die Daten des  Entwurfsverfassers zu übermitteln, der verantwortlich an der Vorbereitung des  Bauprojekts mitwirkt bzw. mitgewirkt hat.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_8a30247_1408705895800_629557_4010'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1460625640639_216405_4876' name='personendaten' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460619307903_831925_3517' association='_16_5_4_940029b_1460625640639_113817_4874'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1460625640639_676913_4879' body='&lt;para&gt;Hier sind die Daten zur Person des  Entwurfsverfassers einzutragen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1460625640639_216405_4876'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1460625640639_757998_4878'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1460625640639_579127_4880' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465320433717_159041_6330' name='bauvorlageberechtigung' visibility='private' aggregation='composite' type='_16_5_4_940029b_1465320233547_555419_6283' association='_16_5_4_940029b_1465320433717_376869_6328'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465320433717_41803_6333' body='&lt;para&gt;Hier sind die Daten einzutragen, die die Bauvorlageberechtigung des Entwurfsverfassers belegen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1465320433717_159041_6330'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465320433717_683269_6332'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465320433717_987034_6334' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_8a30247_1408964097602_950511_3483' name='FlurstueckKennzeichnung'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1408964140406_260187_3502' body='&lt;para&gt;Typ zur eindeutigen Identifikation eines Flurstücks.&lt;/para&gt;&#10;&lt;para&gt;Ein Flurstück ist ein amtlich vermessener Teil der Erdoberfläche. Das Liegenschaftskataster ordnet jedem Flurstück des jeweiligen Nummerierungsbezirks (Flur oder Gemarkung) eine Flurstücksnummer zu.&#10;&lt;/para&gt;&#10;&#10;&#10;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_8a30247_1408964097602_950511_3483'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1408964599802_91559_3503' name='bundesland' visibility='private' type='_16_5_4_8a30247_1423044461203_939066_6394'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1410188461488_459574_3290' body='&lt;para&gt;Hier wird das Bundesland genannt, in dem sich das Flurstück befindet.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_8a30247_1408964599802_91559_3503'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465375451399_94626_5521' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465375451399_21960_5522' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422969627950_52913_6195' name='flurstueck' visibility='private' type='_16_5_4_940029b_1422888990355_651351_3077' association='_16_5_4_8ae0277_1427194978142_462923_7460'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468227329223_484000_5573' body='&lt;para&gt;Hier sind in jedem Fall die Angaben zum Flustück einzutragen, auf dem gemäß Antrag gebaut werden soll. Es sind die identifzierenden Angaben zum Flurstück einzutragen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_8a30247_1422969627950_52913_6195'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465375445297_154803_5519' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465375445297_803876_5520' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
