						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467896136646_712173_5266' name='hinweise' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467896136646_733530_5269' body='&lt;para&gt;Hier werden ggf. ergänzende Hinweise zum Bescheid gegeben.&lt;/para&gt;'>
