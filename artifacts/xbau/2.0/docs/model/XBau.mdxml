					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1470126244519_809943_6030' name='genehmigungsfreistellung.ergebnis.0602'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1470126244535_117382_6062' body='&lt;para&gt;Mittels dieser Nachricht teilt die Gemeinde dem Bauherrn das Ergebnis der Prüfung seiner Anzeige mit. Der Bauherr erfährt, ob sein Vorhaben genehmigungspflichtig ist. Auch erhält er Informationen, ob die Gemeinde eine Untersagung gemäß § 15 BauGB beantragt hat.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1470126244519_809943_6030'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1470126244535_150476_6058' general='_16_5_4_940029b_1461155848215_275954_5270'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1470126244535_764192_6060' name='bezug' visibility='private' type='_16_5_4_940029b_1465368877212_444325_5428'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1470126244535_995070_6143' body='&lt;para&gt;Bezug auf die Anzeige des Bauherrn gegenüber der Gemeinde. Nachricht 0600, auf die die Gemeinde mit dieser Nachricht antwortet.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1470126244535_764192_6060'/>
							</ownedComment>
