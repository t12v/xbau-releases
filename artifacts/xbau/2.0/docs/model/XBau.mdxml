								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476117711927_336855_6113' body='&lt;para&gt;Die Geschossflächenzah (GFZl, BauNVO, § 20) gibt das Verhältnis der gesamten Geschossfläche aller Vollgeschosse der baulichen Anlagen auf einem Grundstück zu der Fläche des Baugrundstücks an. Die GFZ ist eine dimensionslose Größe und wird mit ein oder zwei Dezimalstellen angegeben.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476117711927_419475_6110'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1476117711927_618576_6112' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1476117711927_259148_6114' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1476117799391_975132_6117' name='grundflaechenzahl' visibility='private' aggregation='composite'>
