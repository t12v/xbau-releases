								<referenceExtension referentPath='XOEV-Profil::W3C Data Types::date' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1408619298264_17580_3006' body='&lt;para&gt;Hier ist das Datum der Erstellung bzw. der letzten Bearbeitung dieser Bauvorlage bzw. sonstigen Anlage einzutragen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_8a30247_1408619236437_124908_2999'/>
						</ownedComment>
