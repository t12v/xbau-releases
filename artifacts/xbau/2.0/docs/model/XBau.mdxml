							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465388714024_39250_5868' name='ausfuehrungBauabschnitt' visibility='private' aggregation='composite' type='_16_5_4_940029b_1465388698765_786178_5845' association='_16_5_4_940029b_1465388714024_490230_5867'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465390251415_440798_6120' body='&lt;para&gt;Falls die Nachricht die Aufnahme von Bauarbeiten zur Ausführung eines bestimmten Bauabschnitts anzeigen soll, dann ist dieses Element zu wählen. Zusätzlich sind weitere Angaben zu machen.&lt;/para&gt;'>
