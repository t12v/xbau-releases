								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467880682692_589206_5581' name='bezeichnungRegelverstoss' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467880682692_82739_5590' body='&lt;para&gt;Hier wird die Bezeichnung des betreffenden Regelverstoßes genannt.&lt;/para&gt;&#10;'>
