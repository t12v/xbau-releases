						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1408619147449_70100_2997' body='&lt;para&gt;Hier ist eine deskriptive Bezeichnung der Bauvorlage bzw. sonstigen Anlage einzutragen, z. B. &quot;Grundriss 3. OG&quot;. &lt;/para&gt;'>
