				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527545_39080_4882' name='Bauaufsichtsbehörde'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_785374_4959' body='&lt;para&gt;Die Bauaufsichtsbehörde (BAB) prüft die Einhaltung der öffentlich-rechtlichen Vorschriften (vgl. §58 Abs.2 MBO).&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527545_39080_4882'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527545_777321_4883' name='Bauherr'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_379588_4960' body='&lt;para&gt;Natürliche oder juristische  Person mit Bauvorhaben oder Bauprojekt. Verantwortlich für das Stellen von Anträgen., Anzeigen und Nachweisen. Bestellung der am Bau Beteiligten. (vgl. §53 MBO)&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527545_777321_4883'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527545_424508_4884' name='Prüfsachverständiger'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_919257_4961' body='&lt;para&gt;Prüft im Auftrag des Bauherrn an Stelle der Bauaufsichtsbehörde. Verantwortlich für die Prufung von bautechnischen Nachweisen unter Beachtung der Schutzziele.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527545_424508_4884'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527561_393609_4885' name='Entwurfsverfasser'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_871954_4962' body='&lt;para&gt;Vom Bauherrn mit der fachlichen Betreuung des Bauvorhabens beauftragt. Kann ein Architekt sein / kann ein  Ingenieur sein.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527561_393609_4885'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527561_375727_4886' name='Fachbehörde'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_699060_4963' body='&lt;para&gt;Behörde mit Expertise für ein Fachgebiet. Nimmt im Beteiligungsverfahren Stellung zu entsprechenden Sach- und Fachfragen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527561_375727_4886'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527561_853870_4887' name='Fachplaner'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_99710_4964' body='&lt;para&gt;Arbeitet im Auftrag des Entwurfsverfassers. Hat Sachkunde auf speziellen Gebieten.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527561_853870_4887'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527561_560883_4888' name='Prüfingenieur'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_903431_4965' body='&lt;para&gt;Prüft im Auftrag der Bauaufsichtsbehörde als beliehener Unternehmer. Verantwortlich für die Prufung von bautechnischen Nachweisen unter Beachtung der Schutzziele.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527561_560883_4888'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527561_509484_4889' name='zuständige Behörde'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_635062_4966' body='&lt;para&gt;Diese Behörde prüft, ob die öffentlich-rechtlichen Vorschriften ihres Zuständigkeitsbereichs eingehalten sind.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527561_509484_4889'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527561_384987_4890' name='Informationsempfänger'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_787302_4967' body='&lt;para&gt;Datenempfänger im Rahmen eines Informationsverfahrens.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527561_384987_4890'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527561_281394_4891' name='Nachbar'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_670384_4968' body='&lt;para&gt;Eigentümer eines benachbarten (nach SEVESO III betroffenen) Grundstücks (vgl. §70 Abs. 1). / &lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527561_281394_4891'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Actor' xmi:id='_16_5_4_940029b_1462348527561_753421_4892' name='Gemeinde'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1462348527561_854320_4969' body='&lt;para&gt;Gemeinde, in der das Bauvorhaben gelegen ist. Sie ist Trägerin der kommunalen Planungshoheit.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1462348527561_753421_4892'/>
					</ownedComment>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_940029b_1478121976053_839247_4754'>
					<memberEnd xmi:idref='_16_5_4_940029b_1478121976053_195483_4755'/>
					<memberEnd xmi:idref='_16_5_4_940029b_1478121976053_491921_4756'/>
					<navigableOwnedEnd xmi:idref='_16_5_4_940029b_1478121976053_195483_4755'/>
					<navigableOwnedEnd xmi:idref='_16_5_4_940029b_1478121976053_491921_4756'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1478121976053_195483_4755' visibility='private' type='_16_5_4_940029b_1478121888401_325474_4678' association='_16_5_4_940029b_1478121976053_839247_4754'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1478121976053_491921_4756' visibility='private' type='_16_5_4_940029b_1462348527545_777321_4883' association='_16_5_4_940029b_1478121976053_839247_4754'/>
				</packagedElement>
			</packagedElement>
