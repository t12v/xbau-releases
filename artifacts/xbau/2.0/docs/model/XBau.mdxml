							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467903020454_231000_5976' name='verwendungszweck' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
