						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1461085803478_212359_5225' name='produkt' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1461085803478_728817_5243' body='&lt;para&gt;In diesem Attribut ist der Name des Produktes (der Software) einzutragen, mit dem diese Nachricht erstellt worden ist.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1461085803478_212359_5225'/>
							</ownedComment>
