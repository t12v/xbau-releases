						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467902966126_196065_5920' body='[nd]'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1467902966126_526268_5914'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467902966126_595037_5917' name='gebuehrenposition' visibility='private' type='_16_5_4_940029b_1467903514732_364801_6020'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467902966126_118786_5927' body='&lt;para&gt;Dieses Element steht für eine Gebührenposition.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467902966126_595037_5917'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467903716595_159517_6070'/>
