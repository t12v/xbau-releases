							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467900508054_419827_5899' body='&lt;para&gt;Hier werden ggf. die Nebenbestimmungen zum Bescheid eingefügt.&lt;/para&gt;'>
