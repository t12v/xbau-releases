								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468095951200_970357_5567' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1477414687178_700359_4863' name='vorschrift' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477414687178_93340_4866' body='&lt;para&gt;In diesem Element ist die Vorschrift der materiellen Anforderung zu bezeichnen: Es sind Referenzen auf die Rechtsnormen einzutragen, auf die sich die bearbeitete Abweichung bezieht.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1477414687178_700359_4863'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1477414687178_842513_4865' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1477414687178_372032_4867' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468095951196_511790_5560' name='beschreibung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468095951200_497666_5570' body='&lt;para&gt;In diesen Objekt ist der Abweichungsgegenstand im Detail zu erläutern.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468095951196_511790_5560'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468095951200_187319_5569' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468095951200_873398_5571' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468095951200_819943_5561' name='begruendung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468095951200_681462_5574' body='&lt;para&gt;In diesem Element ist zur beantragten Abweichung eine Erläuterung zu geben, warum die beantragte Zulassung aus Sicht des Antragstellers gerechtfertigt ist.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468095951200_819943_5561'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468095951200_590143_5573' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468095951200_177256_5575' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1468234354477_21931_5653' name='VorbescheidBeantragt'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468234354477_785240_5658' body='&lt;para&gt;Dieser Typ beinhaltet die Parameter einer Frage, die im Rahmen eines Vorbescheidantrags thematisiert wird. Insoweit diese Frage einen Abweichungsantrag bzw. eine beantragte Erleichterung betrifft, sind in einer Instanz des Typs Daten enthalten, die den entsprechenden Kontext verdeutlichen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1468234354477_21931_5653'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468234354477_312707_5655' name='artDerFrage' visibility='private' type='_16_5_4_940029b_1468234098881_686844_5623'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468234354477_17954_5661' body='&lt;para&gt;Hier ist einzutragen, in welche Kategorie die im Rahmen des Vorbescheidantrags thematisierte Fragestellung einzuordnen ist. &lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468234354477_312707_5655'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468234354477_794779_5660' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468234354477_97916_5662' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468235962721_846336_5792' name='vorbescheidfrage' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468235962721_637394_5797' body='&lt;para&gt;Beschreibung der Fragestellung(en) im Rahmen eines Vorbescheids&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468235962721_846336_5792'/>
							</ownedComment>
