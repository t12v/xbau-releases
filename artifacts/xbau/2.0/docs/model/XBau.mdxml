					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1461085754575_118769_5184' name='Nachrichtenkopf.G2G'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1461160746932_100908_5865' body='&lt;para&gt;Nachrichtenkopf für Nachrichten von Behörden an andere Behörden.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1461085754575_118769_5184'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_940029b_1461085871758_144702_5331'>
