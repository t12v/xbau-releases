					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1467843232886_870322_5578' name='BefundlisteFormell'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468226410169_570540_5568' body='&lt;para&gt;Dieser Typ beinhaltet die Befunde der formellen Prüfung eines Antrags oder einer Anfrage. Für jeden Befund sind die entsprechenden Parameter gefüllt, die Inhalt und Bezug des Befundes für den Antragsteller bzw. Anfragenden nachvollziehbar machen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1467843232886_870322_5578'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1467843283923_737799_5635' name='befund' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467842445378_570661_5400' association='_16_5_4_940029b_1467843283923_190241_5633'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467879574842_759782_5560' body='&lt;para&gt;Dieses Element stellt genau einen Befund der Befundliste dar.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467843283923_737799_5635'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467843315561_553642_5642' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1467843315561_39694_5643' value='*'/>
						</ownedAttribute>
					</packagedElement>
