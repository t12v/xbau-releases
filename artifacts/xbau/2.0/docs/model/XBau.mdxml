									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475683090953_235033_6414' name='zuschlaege' visibility='private' type='_16_5_4_940029b_1483136949034_455812_4978'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475683388853_549099_6424' body='&lt;para&gt;In diesem Element sind die Zuschläge zu nennen, die bei der Berechnung der anrechenbaren Bauwerte zu berücksichtigen sind, gemäß zutreffender Verordnung für die Prüfingenieure und Prüfsachverständige.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_940029b_1475683090953_235033_6414'/>
								</ownedComment>
