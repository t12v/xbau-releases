									<referenceExtension referentPath='XOEV-Profil::W3C Data Types::short' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476117799391_845557_6120' body='&lt;para&gt;Die Grundflächenzahl (GRZ, BauNVO, § 19) gibt den Flächenanteil eines Baugrundstückes an, der überbaut werden darf; sie wird mit ein oder zwei Dezimalstellen angegeben.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1476117799391_975132_6117'/>
							</ownedComment>
