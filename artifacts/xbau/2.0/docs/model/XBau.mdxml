								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1476071352293_234807_6678' body='&lt;para&gt;Hier wird die Bezeichnung des Prüfgegenstands eingetragen.&lt;/para&gt;&#10;'>
