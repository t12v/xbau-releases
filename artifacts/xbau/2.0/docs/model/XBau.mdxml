							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1467902983357_14526_5962' body='&lt;para&gt;Angabe zur Bank (BIC), bei der das Konto eingerichtet ist, auf das die Gebühr einzuzahlen ist. Für Überweisungen des Anwenders aus dem Ausland.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1467902983357_991281_5949'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1467902983357_999013_5961'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
