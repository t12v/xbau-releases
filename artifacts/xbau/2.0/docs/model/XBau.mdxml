								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1469644175736_402589_5675' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1469644175736_637697_5676' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468234506946_62529_5679' name='beantragteAbweichung' visibility='private' aggregation='composite' type='_16_5_4_940029b_1468095951196_331249_5557'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468234506962_947930_5682' body='&lt;para&gt;Hier sind die Daten zu einer möglichen Abweichung eingefügt, falls die Vorbescheidfrage eine solche betrifft.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468234506946_62529_5679'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468236044140_711048_5813'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468236044140_731193_5814' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468235962721_471439_5794' name='angefragteErleichterung' visibility='private' aggregation='composite' type='_16_5_4_940029b_1468234557055_465841_5686'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468235962721_72284_5805' body='&lt;para&gt;Hier sind die Daten zu einer möglichen Erleichterung eingefügt, falls die Vorbescheidfrage eine solche betrifft.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468235962721_471439_5794'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468235962721_24417_5804'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468235962721_248033_5806' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1468234557055_465841_5686' name='ErleichterungAngefragt'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468234557055_443329_5691' body='&lt;para&gt;Dieser Typ beinhaltet die Parameter einer beantragten Erleichterung, die der Bauaufsichtsbehörde zur Genehmigung vorgelegt werden soll.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1468234557055_465841_5686'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468234557055_894333_5688' name='gegenstand' visibility='private' type='_16_5_4_940029b_1483376802440_144041_4921'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468234557055_701697_5694' body='&lt;para&gt;Hier wird angezeigt, auf welchen Aspekt des Bauvorhabens sich die beantragte Erleichterung bezieht.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468234557055_894333_5688'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468234557055_396465_5693' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468234557055_986832_5695' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468234557055_464140_5689' name='beschreibung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468234557055_629887_5698' body='&lt;para&gt;Hier ist der Erleichterungsgegenstand zu konkretisieren. Es wird im Detail verdeutlicht, worum es bei dem Anliegen geht).&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468234557055_464140_5689'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468234557055_7751_5697' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468234557055_661634_5699' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468234557055_407548_5690' name='begruendung' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468234557055_556565_5702' body='&lt;para&gt;In diesem Element wird ggf. eine Begründung zur beantragten Erleichterung gegeben, d.h. es wird erläutert, warum die beantragte Erleichterung benötigt wird bzw. gerechtfertigt ist.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468234557055_407548_5690'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1468235448925_27700_5763'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1468235448925_329059_5764' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1475588555524_74161_6543' name='Anonym_VorlageArt'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475588555540_819428_6549'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1475588555524_74161_6543'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475588555524_228815_6545' name='vorlageBauvorhaben' visibility='private' type='_16_5_4_940029b_1475588088450_490142_6509'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475588555540_512182_6552' body='&lt;para&gt;Für Anlagen zu einem Antrag oder einer Anzeige, die zur Beurteilung des Bauvorhabens (Vorhabens) dienen, wird hier die Art der Vorlage (bzw. Anlage) genannt.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1475588555524_228815_6545'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1475588555540_475865_6551' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475588555540_909626_6553' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475588555540_640277_6546' name='vorlageBauantragBearbeitung' visibility='private' type='_16_5_4_8a30247_1408530241706_68973_2543'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475588555540_467309_6556' body='&lt;para&gt;Für sonstige Anlagen, die zur Bearbeitung des Bauantrags notwendig sind (sich also nicht auf das Bauvorhaben beziehen), wird hier die Art der Vorlage (bzw. Anlage) genannt.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1475588555540_640277_6546'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1475588555540_727705_6555' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475588555540_554659_6557' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475588555540_568318_6547' name='vorlageBauzustand' visibility='private' type='_16_5_4_940029b_1475159895898_998624_6483'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475588555540_750002_6560' body='&lt;para&gt;Für Bauvorlagen, deren Zweck ist,  die Anzeige eines Bauzustands zu belegen, wird hier die Art der Vorlage genannt.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1475588555540_568318_6547'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1475588555540_278164_6559' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475588555540_138725_6561' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1475592596655_193877_6574' name='Anonym_ArtDerBaulichenAnlage'>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475592596655_291999_6576' name='artDesGebaeudes' visibility='private' type='_16_5_4_940029b_1475164426407_736819_6878'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475592596655_383269_6585' body='&lt;para&gt;Hier wird für bauliche Anlagen, die Gebäude sind, eine Klassifizierung vorgenommen.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1475592596655_291999_6576'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1475592596655_323750_6584' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475592596655_958121_6586' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1475592596655_616097_6577' name='artDerSonstigenAnlage' visibility='private' type='_16_5_4_940029b_1478973756024_756938_5136'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1475592596655_601256_6589' body='&lt;para&gt;Hier ist für sonstige bauliche Anlagen, also solche, die nicht Gebäude sind, eine Klassifizierung vorzunehmen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1475592596655_616097_6577'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1475592596655_823356_6588' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1475592596655_59344_6590' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1477944131500_703757_4834' name='artNichtAufgefuehrt' visibility='private' aggregation='composite'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477944131500_391176_4837' body='&lt;para&gt;Falls die Codelisten der anderen Elemente die Art der baulichen Anlage des Vorhabens nicht kennzeichnen können (und nur dann), ist hier die Angabe als Freitext einzutragen. &lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1477944131500_703757_4834'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1483378041247_747258_4948' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1483378041247_400288_4949' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1477928375350_829581_4792' name='BefundlistePruefungBauzustand'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477928375379_528002_4795' body='&lt;para&gt;Eine Instanz diesen Typs steht für eine Befundliste der materiellen Prüfung eines Antrags. Jeder Befund beinhaltet die Parameter, die einen  belastenden Verwaltungsakt im Kontext eines Baugenehmigungsvorgangs definieren. &lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1477928375350_829581_4792'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1477928375379_682741_4794' name='befund' visibility='private' aggregation='composite' type='_16_5_4_940029b_1477928417510_526532_4802'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477928375379_488596_4798' body='&lt;para&gt;Jedes Element steht für einen  belastenden Verwaltungsakt im Kontext des aktuellen Baugenehmigungsvorgang, zu dem der Adressat der Nachricht zu einer Stellungnahme aufgefordert ist.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1477928375379_682741_4794'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1477928375379_134966_4797' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1477928375379_4901_4799' value='*'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1477928417510_526532_4802' name='Anonym_BefundPruefungBauzustand'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477928417510_98460_4806'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1477928417510_526532_4802'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1477928417510_622788_4804' name='beschreibung' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477928417510_824193_4813' body='&lt;para&gt;Hier wird der festgestellt Mangel beschrieben.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1477928417510_622788_4804'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1477928417510_998881_4812' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1477928417510_34072_4814' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1477928417510_722577_4805' name='verweise' visibility='private' type='_16_5_4_940029b_1467895898882_574009_5195'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477928417510_165732_4817' body='&lt;para&gt;Hier kann ein Verweis auf eine Nebenbestimmung der Baugenehmigung eingefügt werden, oder auf z. B. den Prüfbericht Standsicherheit oder Brandschutz.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1477928417510_722577_4805'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1477928647430_91777_4827'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1477928647430_413581_4828' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1477928417510_709191_4803' name='rechtsbereich' visibility='private' aggregation='composite' type='_16_5_4_940029b_1467881020760_671045_5646'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1477928417510_961772_4809' body='&lt;para&gt;Dieses Element nennt (falls zutreffend) den  Rechtsbereich, innerhalb dessen die Bestimmung liegt, gegen die im Kontext des Befundes verstoßen wurde. &lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1477928417510_709191_4803'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1477928451695_571477_4825'/>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1477928451695_986504_4826' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_940029b_1483174208250_292936_4991'>
						<memberEnd xmi:idref='_16_5_4_940029b_1483174208250_220105_4993'/>
						<memberEnd xmi:idref='_16_5_4_940029b_1483174208250_476558_4992'/>
						<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1483174208250_476558_4992' visibility='private' type='_16_5_4_940029b_1467896417302_199580_5413' association='_16_5_4_940029b_1483174208250_292936_4991'/>
					</packagedElement>
				</packagedElement>
				<packagedElement xmi:type='uml:Dependency' xmi:id='_16_5_4_940029b_1462266604624_778766_8289'>
					<client xmi:idref='_16_5_4_1d100e5_1384794877872_302539_331'/>
					<supplier href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625256714_228692_1513'>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::XOEV-Adapter::Geography Markup Language::3.2' referentType='Package'/>
						</xmi:Extension>
					</supplier>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1462299055656_708712_5047' name='Anonym_Geometrie'>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465269124067_598733_5018' visibility='private' aggregation='composite' association='_16_5_4_940029b_1465269124036_718978_5016'>
						<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625256936_106257_2159'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek 30.05.2014::XOEV-Datentypen::XOEV-Adapter::Geography Markup Language::3.2::Polygon' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465270668196_604854_5535' body='&lt;para&gt;Das Element (globales Element gml:Polygon) enthält die GML-Darstellung einer Grundfläche (es können Außenkanten und Innenkanten dargestellt werden).&lt;/para&gt;&#10;&lt;para&gt;Aus der GML-Dokumentation: &quot;A Polygon is a special surface that is defined by a single surface patch. The boundary of this patch is coplanar and the polygon uses planar interpolation in its interior. The elements exterior and interior describe the surface boundary of the polygon.&quot; Quelle: &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&quot;&gt;http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&lt;/link&gt;  &lt;/para&gt;&#10;&#10;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1465269124067_598733_5018'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465269124067_392495_5020' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465269124067_248877_5021' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_940029b_1465269124036_718978_5016'>
					<memberEnd xmi:idref='_16_5_4_940029b_1465269124067_598733_5018'/>
					<memberEnd xmi:idref='_16_5_4_940029b_1465269124067_795564_5017'/>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465540439858_361794_5449' body='&lt;para&gt;Doku an der Assoziation zum globalen Element Polygon.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_940029b_1465269124036_718978_5016'/>
					</ownedComment>
					<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465269124067_795564_5017' visibility='private' type='_16_5_4_940029b_1462299055656_708712_5047' association='_16_5_4_940029b_1465269124036_718978_5016'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_940029b_1465320433717_376869_6328'>
					<memberEnd xmi:idref='_16_5_4_940029b_1465320433717_159041_6330'/>
					<memberEnd xmi:idref='_16_5_4_940029b_1465320433717_718640_6329'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465320433717_718640_6329' visibility='private' type='_16_5_4_8a30247_1408705895800_629557_4010' association='_16_5_4_940029b_1465320433717_376869_6328'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_8a30247_1408703057450_27821_3423' name='Akteur'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1408706838747_261394_4377' body='&lt;para&gt;Durch den Typ Akteur wird eine Differenzierung zwischen  natürlichen Einzelpersonen, Personengruppen und juristischen Personen definiert.&lt;/para&gt;&#10;&lt;para&gt;Im Namen einer Firma handelt eine natürliche Person als Vertreter. Bei mehreren Personen (z.B. Eigentümergemeinschaften) wird jede Person (juristisch oder nätürlich) als Akteur definiert. Eine Person dieser Gruppe kann als Vertreter definiert werden.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_8a30247_1408703057450_27821_3423'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422977828419_207131_7447' name='organisation' visibility='private' aggregation='composite' type='_16_5_4_8a30247_1422977426041_172815_6757' association='_16_5_4_8a30247_1422977828419_100798_7445'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422977828419_864327_7450' body='[nd]'>
							<annotatedElement xmi:idref='_16_5_4_8a30247_1422977828419_207131_7447'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8a30247_1422977828419_180743_7449'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8a30247_1422977828419_252084_7451' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1460622920874_103982_4471' name='natuerlichePerson' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460619307903_831925_3517' association='_16_5_4_940029b_1460622920874_846896_4469'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1460622920874_478403_4474' body='[nd]'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1460622920874_103982_4471'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1460622920874_265752_4473'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1460622920874_805149_4475' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Package' xmi:id='_16_5_4_940029b_1467902902355_494210_5910' name='DatentypenGebuehren'>
