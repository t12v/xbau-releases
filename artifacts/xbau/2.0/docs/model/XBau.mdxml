					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1468095951196_331249_5557' name='AbweichungBeantragt'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468095951200_292499_5563' body='&lt;para&gt;Dieser Typ beinhaltet die Parameter einer Abweichung von öffentlich-rechtlichen Bestimmungen, die der Bauaufsichtsbehörde zur Zulassung vorgelegt wird.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1468095951196_331249_5557'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1468095951196_464435_5559' name='art' visibility='private' type='_16_5_4_940029b_1467899588074_956585_5786'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1468095951200_502251_5566' body='&lt;para&gt;Hier ist einzutragen, als welche Art von Abweichung die beantragte Abweichung einzustufen ist.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1468095951196_464435_5559'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
