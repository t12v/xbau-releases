			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_b7102e0_1310654589264_996878_525' name='xsdUnionMember' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314794513127_157917_621' body='&lt;para&gt;Mit diesem Stereotypen werden die Mitglieder einer xs:union festgelegt. Der simple Type an der Pfeilspitze der Abhängigkeit wird als möglicher Datentyp in die Union aufgenommen.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_b7102e0_1310654589264_996878_525'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310654625292_746918_532' name='base_Dependency' visibility='private' association='_16_5_4_b7102e0_1310654625292_608082_531'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Dependency'>
