					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310654564840_70422_524' visibility='public' value='1'/>
