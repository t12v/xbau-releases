			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_14_0_1_6370212_1213859870390_667705_948' name='xsdXModel' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240237192966_510870_653' body='&lt;para&gt;Das mit diesem Stereotyp annotierte UML-Modell stellt den &amp;xoevstd; dar und enthält alle &quot;xsdSchema&quot;-Pakete des &amp;xoevstds; sowie weitere relevante Informationen (z.B. xsdImport, xsdInclude).&lt;/para&gt;'>
					<annotatedElement xmi:idref='_14_0_1_6370212_1213859870390_667705_948'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_1_6370212_1213859900312_713314_955' name='base_Model' visibility='private' association='_14_0_1_6370212_1213859900312_197952_954'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Model'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::Models::Model' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8b00279_1263994461162_348485_883' name='deployment' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Boolean'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8b00279_1263995069209_607048_889' body='&lt;para&gt;Der Schalter zur Angabe, ob der Standard sich noch in der lokalen Entwicklung befindet (false) oder das Deployment mit der Veröffentlichung des Standards (true) bevorsteht und somit auch die XML-Schemata über öffentlich zugängliche URLs angesprochen werden können.&lt;/para&gt;&#10;&lt;para&gt;Bei Angabe des Wertes &quot;true&quot; wird im Normalfall für das Attribut &quot;schemaLocation&quot; für xs:import&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;&gt;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; und xs:include&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;&gt;http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; der Wert der Eigenschaft &quot;schemaLocation&quot; im Stereotyp &quot;xsdSchema&quot; verwendet. Ist &quot;schemaLocation&quot; für das &quot;xsdSchema&quot;-Paket nicht angegeben so wird eine Kombination der Eigenschaftswerte aus &quot;schemaFile&quot; (&quot;xsdSchema&quot;-Paket) und &quot;schemaLocationBase&quot; (&quot;xsdXModel&quot;-Modell) gebildet.&lt;/para&gt;&#10;&lt;para&gt;Bei Angabe des Wertes &quot;false&quot; wird für das Attribut &quot;schemaLocation&quot; für xs:import&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;&gt;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; und xs:include&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;&gt;http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; der Wert der Eigenschaft &quot;schemaFile&quot; im Stereotyp &quot;xsdSchema&quot; übernommen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_8b00279_1263994461162_348485_883'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8b00279_1263994533481_363297_888' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8b00279_1263994533481_443019_887' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='_16_5_4_8b00279_1263994503141_733913_886' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_5b501fb_1237903753480_733112_969' name='fassungVom' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_14_0_5b501fb_1237903982552_435664_972' body='&lt;para&gt;Datum der Fassung.&lt;/para&gt;&#10;&lt;para&gt;Die Information dient nur zu Dokumentationszwecken und hat keine Auswirkung auf die Struktur des XML-Schema.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_14_0_5b501fb_1237903753480_733112_969'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240237334885_414278_655' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240237334885_75529_654' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_5b501fb_1237365404662_216699_969' name='namespace' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_14_0_5b501fb_1237369051599_420578_1105' body='&lt;para&gt;Der gültige Namensraum für alle &quot;xsdSchema&quot;-Pakete des Standards, sofern für das einzelne &quot;xsdSchema&quot;-Paket die gleichnamige Stereotyp-Eigenschaft nicht mit einem eigenen Wert versehen ist.&lt;/para&gt;&#10;&lt;para&gt;Bei der Erzeugung der XML-Schemata wird dieser Wert für das &quot;targetNamespace&quot;-Attribut des xs:schema-Elements&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; verwendet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_14_0_5b501fb_1237365404662_216699_969'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240237616020_575934_663' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240237616020_891781_662' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_5b501fb_1234272099126_652191_968' name='prefix' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_14_0_5b501fb_1235567275350_424334_1101' body='&lt;para&gt;Der gültige Prefix für alle &quot;xsdSchema&quot;-Pakete des Standards, sofern für das einzelne &quot;xsdSchema&quot;-Paket die gleichnamige Stereotyp-Eigenschaft nicht mit einem eigenem Wert versehen ist.&lt;/para&gt;&#10;&lt;para&gt;Bei der Angabe der Eigenschaft wird dessen Wert für den Namespace als XML-Präfix für die xs:schema-Elemente&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; verwendet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_14_0_5b501fb_1234272099126_652191_968'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1249472935357_108043_269' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1249472935341_989803_268' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_1_5b501fb_1217425644380_990309_964' name='rootpath' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_14_0_5b501fb_1235566756185_63452_966' body='&lt;para&gt;Der absolute Pfad zum jeweiligen Projektverzeichnis des &amp;xoevstds; für den XGenerator. Der Parameter bestimmt somit, an welchen Ort die generierten Dateien geschrieben werden.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_14_0_1_5b501fb_1217425644380_990309_964'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8b00279_1267177788779_680047_658' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8b00279_1267177788779_378938_657' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1241798590027_403877_126' name='schemaLocationBase' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1241799137757_23444_130' body='&lt;para&gt;Der Basispfad der SchemaLocations (z.B. &quot;http://xoev.de/schemata/xhamsterzucht/1_0&quot;).&lt;/para&gt;&#10;&lt;para&gt;Der physische Speicherort (URL exklusive Dateiname), an dem die Schemata später gefunden werden können. Bildet zusammen mit der Eigenschaft &quot;schemaFile&quot; (z.B. &quot;xhz-baukasten.xsd&quot;) des Stereotyps &quot;xsdSchema&quot; auf das Schema-Attribut &quot;schemaLocation&quot; (z.B. &quot;http://xoev.de/schemata/xhamsterzucht/1_0 xhz-baukasten.xsd&quot;) für xs:import&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;&gt;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; und xs:include&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;&gt;http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; ab - sofern für das einzelne Schema kein konkreter Wert für die Eigenschaft &quot;schemaLocation&quot; im Stereotyp &quot;xsdSchema&quot; angegeben ist.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_12_1_8b00279_1241798590027_403877_126'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1241798631541_326823_129' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1241798631541_121928_128' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_5b501fb_1237903359014_139589_966' name='version' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_14_0_5b501fb_1237903836754_570401_971' body='&lt;para&gt;Die gültige Version für alle XML-Schemata des Standards, sofern für das einzelne &quot;xsdSchema&quot;-Paket die gleichnamige Stereotyp-Eigenschaft nicht mit einem eigenem Wert versehen ist.&lt;/para&gt;&#10;&lt;para&gt;Der Wert bildet auf das &quot;version&quot;-Attribut der zugeordneten xs:schema-Elemente&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; ab.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_14_0_5b501fb_1237903359014_139589_966'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1249472948045_660920_273' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1249472948045_29153_272' visibility='public'/>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_14_0_1_6370212_1213859900312_197952_954' visibility='public'>
				<memberEnd xmi:idref='_14_0_1_6370212_1213859900312_713314_955'/>
				<memberEnd xmi:idref='_14_0_1_6370212_1213859900312_342969_956'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_14_0_1_6370212_1213859900312_342969_956' name='extension_xsdXModel' visibility='private' aggregation='composite' type='_14_0_1_6370212_1213859870390_667705_948' association='_14_0_1_6370212_1213859900312_197952_954'>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_14_0_1_6370212_1213859900312_941739_958' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_14_0_1_6370212_1213859900312_479266_957' visibility='public'/>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_12_1_8b00279_1240305834261_832017_144' visibility='public'>
				<memberEnd xmi:idref='_12_1_8b00279_1240305834261_735373_145'/>
				<memberEnd xmi:idref='_12_1_8b00279_1240305834261_608391_146'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_12_1_8b00279_1240305834261_608391_146' name='extension_xsdCode' visibility='private' aggregation='composite' type='_12_1_8b00279_1240305730667_765894_120' association='_12_1_8b00279_1240305834261_832017_144'>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240305834261_810502_148' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240305834261_493285_147' visibility='public'/>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_12_1_8b00279_1240306518157_731879_204' visibility='public'>
				<memberEnd xmi:idref='_12_1_8b00279_1240306518157_213767_205'/>
				<memberEnd xmi:idref='_12_1_8b00279_1240306518157_514542_206'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_12_1_8b00279_1240306518157_514542_206' name='extension_xsdCodeList' visibility='private' aggregation='composite' type='_12_1_8b00279_1240306417404_766333_161' association='_12_1_8b00279_1240306518157_731879_204'>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240306518157_953835_208' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240306518157_363360_207' visibility='public'/>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1181826329822_66722_3772' name='xsdTitled' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1207143051046_441558_3' body='&lt;para&gt;Ein mit diesem Stereotyp gekennzeichnetes UML-Element (z.B. eine UML-Klasse) erhält in der Dokumentation des XÖV-Standards einen anderen Titel als seinen Namen im UML-Modell (z.B. den UML-Klassennamen). Dies ist insbesondere dann sinnvoll, wenn der Titel in der Dokumentation beispielsweise Leerzeichen oder Umlaute enthalten soll.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1181826329822_66722_3772'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1181826329822_358801_3774' name='base_Element' visibility='private' association='_11_5_6370212_1181826329822_317572_3773'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Element'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Element' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1170240822453_184342_1' name='title' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1179674937750_328255_11' body='&lt;para&gt;Der Prosa-Titel in der Dokumentation.&lt;/para&gt;&#10;&lt;para&gt;Im XML-Schema wird die Eigenschaft in xs:annotation des jeweiligen XML-Schema-Bestandteils abgebildet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1170240822453_184342_1'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_14_0_5b501fb_1239108443131_719273_1104' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_14_0_5b501fb_1239108443131_132845_1103' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1181825895666_44096_93' name='xsdWithImplementationHint' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1207143171921_571560_4' body='&lt;para&gt;Ein mit diesem Stereotyp gekennzeichnetes UML-Element erhält in der Dokumentation neben der normalen Beschreibung einen Abschnitt mit Implementierungshinweisen.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1181825895666_44096_93'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1181826014072_327233_113' name='base_Element' visibility='private' association='_11_5_6370212_1181826014072_287792_112'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Element'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Element' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1181827583119_960162_4154' name='implementationHint' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240319752226_284628_285' body='&lt;para&gt;Der Implementierungshinweis zu dem XML-Bestandteil.&lt;/para&gt;&#10;&lt;para&gt;Im XML-Schema wird die Eigenschaft in xs:annotation des jeweiligen XML-Schema-Bestandteils abgebildet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1181827583119_960162_4154'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_14_0_5b501fb_1239108495983_28614_1107' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_14_0_5b501fb_1239108495983_830996_1106' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1197040199062_390349_11' name='xsdCodeListEntry' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1207142970046_935815_2' body='&lt;para&gt;Mit diesem Stereotyp werden Literale einer  UML-Enumeration als Wert einer &amp;clst; (UML-Enumeration mit dem Stereotyp &quot;xsdCodeList&quot;)  gekennzeichnet.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung des Stereotyps im XML-Schema erfolgt als xs:enumeration&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1197040199062_390349_11'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1197040223296_174154_31' name='base_EnumerationLiteral' visibility='private' association='_11_5_6370212_1197040223296_689223_30'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#EnumerationLiteral'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::EnumerationLiteral' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1197040232437_934738_35' name='name' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240306708182_393937_212' body='&lt;para&gt;Der ausgeschriebene Name für einen Code.&lt;/para&gt;&#10;&lt;para&gt;Die Information dient nur zu Dokumentationszwecken und hat keine Auswirkung auf die Struktur des XML-Schemas: Es erfolgt eine Ausgabe in der Dokumentation der jeweiligen xs:enumeration&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; im XML-Schema.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1197040232437_934738_35'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1241704661212_729451_515' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1241704661212_722338_514' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1322499063960_322188_432' name='obsolete' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Boolean'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1322501557543_392565_366' body='&lt;para&gt;Mit diesem Schalter können veraltete, nicht mehr zu übermittelnde Codes gekennzeichnet werden (obsolete = true). Deartig gekennzeichnete Codes, d. h. Literale einer Enumeration, werden im Kontext einer Standard-Codeliste nicht mehr in das Schema herausgeschrieben. Auf diese Weise kann die (unbemerkte) Wiederverwendung alter Codes für neue Zwecke, d. h. mit neuer Bedeutung, vermieden werden, da doppelte Codes in einer Enumeration in UML nicht zugelassen werden.&lt;/para&gt; &lt;para&gt;Der Default-Wert der Eigenschaft &quot;obsolete&quot; ist &quot;false&quot;.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1322499063960_322188_432'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1322499081816_852808_436' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1322499081816_700799_435' visibility='public'/>
					<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='_16_5_4_5b501fb_1322499094610_756063_440' visibility='public'/>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_12_1_8b00279_1240305730667_765894_120' name='xsdCode' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240305907173_196075_157' body='&lt;para&gt;Eine UML-Klasse, die mit dem Stereotypen &quot;xsdCode&quot; versehen ist, stellt einen Code-Datentyp dar, der eine einzusetzende &amp;clst; näher beschreibt.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung der so stereotypisierten UML-Klasse im XML-Schema erfolgt als xs:complexType&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; mit xs:complexContent&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#declare-type&quot;&gt;http://www.w3.org/TR/xmlschema-1/#declare-type&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; im XML-Schema.&lt;/para&gt;&#10;&lt;para&gt;In Abhängigkeit von der zusätzlichen Vergabe des Stereotypen &quot;xsdNamedType&quot; wird der Code-Datentyp als benannter Typ im XML-Schema umgesetzt, ansonsten als anonymer Typ.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_12_1_8b00279_1240305730667_765894_120'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240305834261_735373_145' name='base_Class' visibility='private' association='_12_1_8b00279_1240305834261_832017_144'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Class'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240305849571_542223_149' name='listAgencyName' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240306337465_218726_158' body='&lt;para&gt;Der Herausgeber der &amp;clst;.&lt;/para&gt;&#10;&lt;para&gt;Die Information dient nur zu Dokumentationszwecken und hat keine Auswirkung auf die Struktur des XML-Schemas: Es erfolgt eine Ausgabe in der Dokumentation des Code-Datentyps im XML-Schema.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_12_1_8b00279_1240305849571_542223_149'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240305864897_817509_152' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240305864897_13803_151' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240305871036_570464_153' name='listName' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240306393357_418172_159' body='&lt;para&gt;Der offizielle Name der &amp;clst;.&lt;/para&gt;&#10;&lt;para&gt;Die Information dient nur zu Dokumentationszwecken und hat keine Auswirkung auf die Struktur des XML-Schema: Es erfolgt eine Ausgabe in der Dokumentation des Code-Datentyps im XML-Schema.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_12_1_8b00279_1240305871036_570464_153'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240305885128_511779_156' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240305885128_158749_155' visibility='public'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1276693199764_694665_579' name='documentationCodeList' visibility='private'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Enumeration'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Enumeration' referentType='Class'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1276693367723_280496_584' body='&lt;para&gt;Für Codelisten vom Typ 2 (nicht schemavalidierend) kann über diese Eigenschaft eine Verbindung zu einer Codeliste hergestellt werden. Dadurch kann bei der Dokumentationsgenerierung trotzdem auf eine Codeliste verwiesen werden.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1276693199764_694665_579'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1276693259009_351448_583' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1276693259009_972456_582' visibility='public'/>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_12_1_8b00279_1240306417404_766333_161' name='xsdCodeList' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240306628661_568772_211' body='&lt;para&gt;Die Umsetzung des Stereotyps im XML-Schema erfolgt als xs:simpleType&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; mit dem durch xs:enumeration&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; eingeschränkten Basistyp &quot;xs:token&quot;&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#token&quot;&gt;http://www.w3.org/TR/xmlschema-2/#token&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;, es sei denn die Eigenschaft &lt;emphasis&gt;base&lt;/emphasis&gt; definiert einen anderen Basistypen. Wird die Codeliste in einem Code Datentyp verwendet, muss der Basistyp vom Typ xs:token oder einer Unterklasse sein.&lt;/para&gt;&#10;&lt;para&gt;In Abhängigkeit von der zusätzlichen Vergabe des Stereotypen &quot;xsdNamedType&quot; wird die &amp;clst; als benannter Typ im XML-Schema umgesetzt, ansonsten als anonymer Typ.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_12_1_8b00279_1240306417404_766333_161'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240306518157_213767_205' name='base_Enumeration' visibility='private' association='_12_1_8b00279_1240306518157_731879_204'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Enumeration'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Enumeration' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310464347811_201332_328' name='base' visibility='private'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Class'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1316429565493_495332_461' body='&lt;para&gt;Bestimmt den Obertypen der Enumeration. Dieser muss ein einfacher Typ sein. Bei der Verwendung innerhalb eines XÖV-Codes muss er zusätzlich vom Typ xs:token order ein davon abgeleiteter Typ sein.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1310464347811_201332_328'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310464635388_364329_329' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310464635387_157256_328' visibility='public'/>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_8b00279_1264582309240_225915_526' name='xsdLocalStructure' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8b00279_1264582638551_280009_554' body='&lt;para&gt;Eine UML-Eigenschaft, die mit &quot;xsdLocalStructure&quot; versehen ist, kennzeichnet, dass die Strukturen der anonymen referenzierten UML-Klasse, die einen Typ mit komplexen Inhalt darstellt, im XML-Schema direkt, ohne Angabe von &quot;xs:complexType&quot;&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; in die darüberliegende Struktur eingebunden werden.&lt;/para&gt;&#10;&lt;para&gt;Verwendung ohne &quot;xsdLocalStructure&quot;:&lt;/para&gt;&#10;&lt;programlisting&gt;&lt;![CDATA[&lt;xs:complexType name=&quot;Beispiel&quot;&gt;&#10;  &lt;xs:sequence&gt;&#10;    &lt;xs:element name=&quot;ergebnis&quot;&gt;&#10;      &lt;xs:complexType&gt;&#10;        &lt;xs:choice&gt;&#10;          &lt;xs:element name=&quot;grundFuerAusfallDesWettbewerbs&quot; type=&quot;xs:string&quot;/&gt;&#10;          &lt;xs:element name=&quot;teilnehmer&quot; type=&quot;xhz:Teilnehmer&quot; maxOccurs=&quot;unbounded&quot;/&gt;&#10;       &lt;/xs:choice&gt;&#10;     &lt;/xs:complexType&gt;&#10;   &lt;/xs:element&gt;&#10;   ...&#10;  &lt;/xs:sequence&gt;&#10;&lt;/xs:complexType&gt;]]&gt;&lt;/programlisting&gt;&lt;para&gt;&lt;/para&gt;&#10;&lt;para&gt;Verwendung mit &quot;xsdLocalStructure&quot;:&lt;/para&gt;&#10;&lt;programlisting&gt;&lt;![CDATA[&lt;xs:complexType name=&quot;Beispiel&quot;&gt;&#10;  &lt;xs:sequence&gt;&#10;    &lt;xs:choice&gt;&#10;      &lt;xs:element name=&quot;grundFuerAusfallDesWettbewerbs&quot; type=&quot;xs:string&quot;/&gt;&#10;      &lt;xs:element name=&quot;teilnehmer&quot; type=&quot;xhz:Teilnehmer&quot; maxOccurs=&quot;unbounded&quot;/&gt;&#10;     &lt;/xs:choice&gt;&#10;     ...&#10;  &lt;/xs:sequence&gt;&#10;&lt;/xs:complexType&gt;]]&gt;&lt;/programlisting&gt;'>
					<annotatedElement xmi:idref='_16_5_4_8b00279_1264582309240_225915_526'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8b00279_1264582391052_265825_550' name='base_Property' visibility='private' association='_16_5_4_8b00279_1264582391052_582065_549'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Property'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Property' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1270208088006_335639_526' name='position' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Integer'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::Integer' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1270208104074_120801_529' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1270208104074_432819_528' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_8b00279_1264582391052_582065_549' visibility='public'>
				<memberEnd xmi:idref='_16_5_4_8b00279_1264582391052_265825_550'/>
				<memberEnd xmi:idref='_16_5_4_8b00279_1264582391052_609645_551'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_8b00279_1264582391052_609645_551' name='extension_xsdLocalStructure' visibility='private' aggregation='composite' type='_16_5_4_8b00279_1264582309240_225915_526' association='_16_5_4_8b00279_1264582391052_582065_549'>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8b00279_1264582391052_196587_553' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8b00279_1264582391052_729212_552' visibility='public'/>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_5b501fb_1276693051258_429282_547' name='xsdDeprecated' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1276693182429_121388_577' body='&lt;para&gt;Dieser Stereotyp kann bei der Dokumentationsgenerierung berücksichtigt werden, um bestimmte Teile eines Standards abzukündigen.&lt;/para&gt;&#10;&lt;para&gt;Der Stereotyp hat keine Auswirkungen auf die generierten XML-Schemata.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_5b501fb_1276693051258_429282_547'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1276693051260_841685_549' name='base_Element' visibility='private' association='_16_5_4_5b501fb_1276693051260_225562_548'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Element'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Element' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1276693121229_470354_570' name='deprecatedContext' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1276693194740_950700_578' body='&lt;para&gt;Diese Eigenschaft kann dazu genutzt werden, um mehrere abgekündigte Bestandteile zu gruppieren, da diese z. B. durch einen einzigen Änderungeantrag wegfallen. Innerhalb der generierten Dokumentation kann dann auf einen beschreibenden Abschnitt verwiesen werden.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1276693121229_470354_570'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1276693167382_120464_576' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1276693167382_532928_575' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_5b501fb_1276693051260_225562_548' visibility='public'>
				<memberEnd xmi:idref='_16_5_4_5b501fb_1276693051260_841685_549'/>
				<memberEnd xmi:idref='_16_5_4_5b501fb_1276693051260_440941_550'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_5b501fb_1276693051260_440941_550' name='extension_unbenannt1' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1276693051258_429282_547' association='_16_5_4_5b501fb_1276693051260_225562_548'>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1276693051260_858826_552' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1276693051260_752970_551' visibility='public'/>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_b7102e0_1282131963663_958424_532' name='xsdXModelImport' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1282131963670_843674_534' body='&lt;para&gt;Dieser Stereotyp wird für die Dokumentation von Datentypen aus eingebundenen externen Modellen benötigt. Bei der Verwendung eines externen Datentyps kann die Dokumentation auf die hier definierten Daten zurückgreifen und so einen Verweis auf ein externes Dokument erzeugen.&lt;/para&gt;&#10;&lt;para&gt;Der Stereotyp hat keine Auswirkungen auf die generierten XML-Schemata.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_b7102e0_1282131963663_958424_532'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1282131963681_712136_539' name='base_Dependency' visibility='private' association='_16_5_4_b7102e0_1282131963681_472501_538'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Dependency'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Dependencies::Dependency' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1282131963669_347065_533' name='bezeichnung' visibility='private'>
					<type xmi:type='uml:PrimitiveType' href='http://schema.omg.org/spec/UML/2.2/uml.xml#String'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::AuxiliaryConstructs::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1282131963670_561191_536' body='&lt;para&gt;Bei Verweisen verwendeter Bezeichner. Beispiel: [XOEV-Basisdatentypen]&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1282131963669_347065_533'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1282131963670_187054_537' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1282131963670_531828_535' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_b7102e0_1282131963681_472501_538' visibility='public'>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1282131963681_712136_539'/>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1282131963681_229370_540'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_b7102e0_1282131963681_229370_540' name='extension_xsdXModelImport' visibility='private' aggregation='composite' type='_16_5_4_b7102e0_1282131963663_958424_532' association='_16_5_4_b7102e0_1282131963681_472501_538'>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1282131963681_788166_542' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1282131963681_710655_541' visibility='public'/>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_b7102e0_1310393084388_456884_533' name='xsdGroup' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314793033333_842787_619' body='&lt;para&gt;Eine UML-Klasse, die mit diesem Stereotyp versehen ist, wird im XML-Schema durch ein xs:group&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cModel_Group_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cModel_Group_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;- oder xs:attributeGroup&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cAttribute_Group_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cAttribute_Group_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;-Elementmodell umgesetzt (anstelle von xs:complexType). Die Gruppe enthält alle Eigenschaften der mit &lt;emphasis&gt;xsdGroup&lt;/emphasis&gt; gekennzeichneten Klasse, die mit &lt;emphasis&gt;xsdElement&lt;/emphasis&gt; bzw. &lt;emphasis&gt;xsdAttribute&lt;/emphasis&gt; gekennzeichnet sind.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_b7102e0_1310393084388_456884_533'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310393119067_490352_540' name='base_Class' visibility='private' association='_16_5_4_b7102e0_1310393119067_145127_539'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Class'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Kernel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_b7102e0_1310393119067_145127_539' visibility='public'>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310393119067_490352_540'/>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310393119067_217681_541'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_b7102e0_1310393119067_217681_541' name='extension_xsdGroup' visibility='private' aggregation='composite' type='_16_5_4_b7102e0_1310393084388_456884_533' association='_16_5_4_b7102e0_1310393119067_145127_539'>
					<xmi:Extension extender='MagicDraw UML 16.5'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310393119067_424107_543' visibility='public' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310393119067_622256_542' visibility='public'/>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_b7102e0_1310551667488_613356_328' name='xsdGlobalElementType' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314792541184_758204_618' body='&lt;para&gt;Eine UML-Abhängigkeit zwischen einer als &lt;emphasis&gt;xsdGlobalElement&lt;/emphasis&gt; ausgezeichneten UML-Klasse und einer als &lt;emphasis&gt;xsdNamedType&lt;/emphasis&gt; ausgezeichneten UML-Klasse, die mit dem Stereotyp &lt;emphasis&gt;xsdGlobalElementType&lt;/emphasis&gt; versehen ist bewirkt, dass im XML-Schema als Datentyp des globalen Elements der bebannte Typ der als Ziel der Abhängigkteit angegeben ist festgelegt wird&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;&#10;&lt;para&gt;Der Stereotyp muss im Zusammenspiel mit den Stereotypen &lt;emphasis&gt;xsdGlobalElement&lt;/emphasis&gt; und &lt;emphasis&gt;xsdNamedType&lt;/emphasis&gt; verwendet werden.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_b7102e0_1310551667488_613356_328'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310551689818_544499_335' name='base_Dependency' visibility='private' association='_16_5_4_b7102e0_1310551689818_138115_334'>
					<type xmi:type='uml:Class' href='http://schema.omg.org/spec/UML/2.2/uml.xml#Dependency'>
						<xmi:Extension extender='MagicDraw UML 16.5'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classes::Dependencies::Dependency' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_b7102e0_1310551689818_138115_334' visibility='public'>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310551689818_544499_335'/>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310551689818_91508_336'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_b7102e0_1310551689818_91508_336' name='extension_xsdGlobalElementType' visibility='private' aggregation='composite' type='_16_5_4_b7102e0_1310551667488_613356_328' association='_16_5_4_b7102e0_1310551689818_138115_334'>
