			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_5b501fb_1323953127468_896135_366' name='xsdDraft' visibility='public'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1323953313708_332611_372' body='&lt;para&gt;Mit dem Stereotyp &quot;xsdDraft&quot; versehene UML-Klassen werden nicht in die Schema- und ggf. DocBook-Generierung einbezogen. Auf diese Weise können Inhalte (d. h. benannte Typen, Element- und Attributgruppen und globale Elemente) , die bereits mit XÖV-Stereotypen versehen sind und damit in die Generierung einbezogen würden, auf einfache Weise &quot;auskommentiert&quot; werden. Auskommentierte Inhalte dürfen nicht von &quot;aktiven&quot; Inhalten genutzt werden.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_5b501fb_1323953127468_896135_366'/>
				</ownedComment>
