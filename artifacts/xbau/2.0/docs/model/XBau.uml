                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351738_724525_2650" body="Die Komponente &quot;geschlecht&quot; repräsentiert die Angaben zum Geschlecht einer natürlichen Person. " annotatedElement="_16_5_4_5b501fb_1389522351520_170313_1757"/>
                  <ownedEnd xmi:id="_16_5_4_5b501fb_1389522351738_506523_2651" name="" visibility="private" type="_16_5_4_5b501fb_1389522351506_805713_1690" association="_16_5_4_5b501fb_1389522351520_170313_1757"/>
