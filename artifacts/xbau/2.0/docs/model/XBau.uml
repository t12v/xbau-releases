              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291117_964398_5188" name="" memberEnd="_16_5_4_5b501fb_1387625291315_420801_5998 _16_5_4_5b501fb_1387625291303_552513_5943">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291315_37518_5997" body="Der Lebenspartnerschaftsname ist der von beiden Lebenspartnern durch Erklärung bestimmte gemeinsame Name der Lebenspartner. Zum Lebenspartnerschaftsnamen kann der Geburtsname eines der Lebenspartner oder der zur Zeit der Erklärung von einem Lebenspartner geführte Name bestimmt werden." annotatedElement="_16_5_4_5b501fb_1387625291117_964398_5188"/>
