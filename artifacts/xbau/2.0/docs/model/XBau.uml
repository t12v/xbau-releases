                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351736_506784_2611" body="Die Behördenkennung ist ein System zur eindeutigen Identifikation einer Behörde bspw. im DVDV.&#xA;" annotatedElement="_16_5_4_5b501fb_1389522351519_988727_1744"/>
                  <ownedEnd xmi:id="_16_5_4_5b501fb_1389522351736_455782_2612" name="" visibility="private" type="_16_5_4_5b501fb_1389522351514_479861_1706" association="_16_5_4_5b501fb_1389522351519_988727_1744"/>
