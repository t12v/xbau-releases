                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291323_27376_6159" body="Die &quot;gueltigkeit&quot; gibt mit Beginn- und/oder Endzeitpunkt den Zeitraum an, für den eine Auskunftssperre besteht." annotatedElement="_16_5_4_5b501fb_1387625291123_740309_5242"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291323_615474_6160" name="" visibility="private" type="_16_5_4_5b501fb_1387625291101_627617_5162" association="_16_5_4_5b501fb_1387625291123_740309_5242"/>
