            <ownedComment xmi:id="_16_5_4_940029b_1467902966126_196065_5920" body="[nd]" annotatedElement="_16_5_4_940029b_1467902966126_526268_5914"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467902966126_595037_5917" name="gebuehrenposition" visibility="private" type="_16_5_4_940029b_1467903514732_364801_6020">
              <ownedComment xmi:id="_16_5_4_940029b_1467902966126_118786_5927" body="&lt;para>Dieses Element steht für eine Gebührenposition.&lt;/para>" annotatedElement="_16_5_4_940029b_1467902966126_595037_5917"/>
