                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351737_408885_2641" body="Hier kann angegeben werden, welche Sprachen eine natürliche Person als Fremdsprache beherrscht." annotatedElement="_16_5_4_5b501fb_1389522351520_432666_1754"/>
