                <ownedComment xmi:id="_16_5_4_940029b_1465390183440_905147_6118" body="&lt;para>Hier ist das Datum einzutragen, zu dem die angegebene Aktivität geplant ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1465388757695_649115_5902"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
