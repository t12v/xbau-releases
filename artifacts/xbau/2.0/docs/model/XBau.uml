                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291321_861103_6126" body="Die Komponente &quot;geschlecht&quot; repräsentiert die Angaben zum Geschlecht einer natürlichen Person. " annotatedElement="_16_5_4_5b501fb_1387625291122_749287_5231"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291321_437152_6127" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_608193_5164" association="_16_5_4_5b501fb_1387625291122_749287_5231"/>
