            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467902966126_723291_5918" name="auslagenposition" visibility="private" type="_16_5_4_940029b_1467903641356_163050_6046">
              <ownedComment xmi:id="_16_5_4_940029b_1467902966126_914849_5931" body="&lt;para>Dieses Element steht für eine Auslagenposition.&lt;/para>" annotatedElement="_16_5_4_940029b_1467902966126_723291_5918"/>
