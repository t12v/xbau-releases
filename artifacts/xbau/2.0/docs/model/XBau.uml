            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364478035868_379202_2697" name="Code.SGS.Staat.1970">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364478035871_354693_2705" body="&lt;para>Diese Codeliste enthält alle Staatsangehörigkeiten im vollen politischen Sinne und entspricht dem &lt;quote>Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote> des Auswärtigen Amtes. Darüber hinaus enthält die Codeliste zusätzliche Einträge für ehemalige Staaten ab 1970. Für die enthaltenen Ersatzwerte (wie staatenlos, ungeklärt und ohne Angabe) sowie für den Eintrag für die Palästinensischen Gebiete enthält die Codeliste Einträge, deren Bedeutung aber nicht definiert ist.&lt;/para>&#xA;&lt;para>Die Bedeutung des übermittelten Schlüssels ergibt sich aus der Spalte &lt;quote>Staatsname_kurz&lt;/quote> der veröffentlichten Genericcode-Datei.&lt;/para>&#xA;" annotatedElement="_16_5_4_1eeb04c1_1364478035868_379202_2697"/>
              <generalization xmi:id="_16_5_4_1eeb04c1_1364478035869_716099_2699" isSubstitutable="true" general="_16_5_4_5b501fb_1387625280047_322339_5028"/>
              <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364478035869_760711_2701" name="code" visibility="private">
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364478035874_248306_2718" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364478035873_709156_2717" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364478035870_668119_2702" name="name" visibility="private">
