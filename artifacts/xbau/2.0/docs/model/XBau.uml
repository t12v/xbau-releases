                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351736_662341_2608" body="Die Komponente &quot;alternativeRepraesentation&quot; beinhaltet den Namen einer natürlichen Person in einer Form, die einer festgelegten Konvention folgt. Die in der Komponente  &quot;AlternativeRepraesentation&quot; übermittelten Informationen müssen redundant zu den anderen Elementen der Komponente &quot;NameNatuerlichePerson&quot; sein, sie dürfen diese nicht ersetzen. &#xA;" annotatedElement="_16_5_4_5b501fb_1389522351519_688190_1743"/>
                  <ownedEnd xmi:id="_16_5_4_5b501fb_1389522351736_942632_2609" name="" visibility="private" type="_16_5_4_5b501fb_1389522351514_923302_1707" association="_16_5_4_5b501fb_1389522351519_688190_1743"/>
                </packagedElement>
