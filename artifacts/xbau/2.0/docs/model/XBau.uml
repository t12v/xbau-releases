              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465392458377_31723_6151" name="bezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1465392458377_984674_6154" body="&lt;para>Hier ist die Bezeichnung der Unterlage einzutragen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465392458377_31723_6151"/>
