              <ownedComment xmi:id="_16_5_4_940029b_1461162291158_909672_5900" body="&lt;para>Hier wird die Fachbehörde bzw. Organisation genannt, für die die vorliegende Nachricht bestimmt ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1461154163204_446007_4980"/>
