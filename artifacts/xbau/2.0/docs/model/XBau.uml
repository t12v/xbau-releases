              <ownedComment xmi:id="_16_5_4_1eeb04c1_1415191695958_269496_2568" body="&lt;para>Es wird angegeben, über welches Kommunikationsmedium (z. B. Telefon, E-Mail) die Erreichbarkeit gegeben ist.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1415191695956_934970_2565"/>
