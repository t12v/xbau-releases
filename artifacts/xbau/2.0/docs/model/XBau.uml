                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291321_496008_6114" body="Die &quot;organisationsstruktur&quot; eröffnet die Möglichkeit, ergänzend interne Organisations- und Hierarchieebenen einer Behörde für ihre Erreichbarkeit aber auch für Zwecke der Dienstaufsicht im Rahmen des Geschäftsprozesses  zu beschreiben. &#xA;" annotatedElement="_16_5_4_5b501fb_1387625291121_542606_5227"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291321_137278_6115" name="" visibility="private" type="_16_5_4_5b501fb_1387625291115_477657_5180" association="_16_5_4_5b501fb_1387625291121_542606_5227"/>
