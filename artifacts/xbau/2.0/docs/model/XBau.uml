              <ownedComment xmi:id="_16_5_4_1eeb04c1_1375775538525_847983_1746" body="&lt;para>In diesem Element werden Informationen zu der den Prozess auslösenden Behörde übermittelt.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1375775410206_840180_1736"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1375775427072_896051_1739" name="" value="1"/>
