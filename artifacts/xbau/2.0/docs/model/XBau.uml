                <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1389522351519_866837_1748" name="" memberEnd="_16_5_4_5b501fb_1389522351737_546546_2624 _16_5_4_5b501fb_1389522351723_65889_2479">
                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351737_329801_2623" body="Ein weiterer Name ist ein Name, der nicht Bestandteil des Vor- oder Nachnamens einer Person und weder Künstlername noch Ordensname ist. " annotatedElement="_16_5_4_5b501fb_1389522351519_866837_1748"/>
