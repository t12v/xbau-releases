          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476117219455_694363_6021" name="StaedtebaulicheKennzahlen">
            <ownedComment xmi:id="_16_5_4_940029b_1476117219455_43420_6025" body="&lt;para>Dieser Typ fasst die städtebaulichen Kennzahlen des Vorhabens zusammen.&lt;/para>" annotatedElement="_16_5_4_940029b_1476117219455_694363_6021"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476117711927_419475_6110" name="geschossflaechenzahl" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476117711927_336855_6113" body="&lt;para>Die Geschossflächenzah (GFZl, BauNVO, § 20) gibt das Verhältnis der gesamten Geschossfläche aller Vollgeschosse der baulichen Anlagen auf einem Grundstück zu der Fläche des Baugrundstücks an. Die GFZ ist eine dimensionslose Größe und wird mit ein oder zwei Dezimalstellen angegeben.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476117711927_419475_6110"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191862437_185349_1574"/>
