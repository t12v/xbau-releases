            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467902983357_400947_5945" name="Zahlungsdaten">
            <ownedComment xmi:id="_16_5_4_940029b_1467902983357_784193_5951" body="&lt;para>Dieser Typ enthält die Angaben, die für die bargeldlose Bezahlung gemäß SEPA benötigt werden. &lt;/para>" annotatedElement="_16_5_4_940029b_1467902983357_400947_5945"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467902983357_724954_5947" name="iban" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467902983357_270168_5954" body="&lt;para>IBAN des Kontos, auf das die Gebühr einzuzahlen ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1467902983357_724954_5947"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467903173393_222641_5984" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467903173393_508250_5983" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467902983357_991281_5949" name="bic" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467902983357_14526_5962" body="&lt;para>Angabe zur Bank (BIC), bei der das Konto eingerichtet ist, auf das die Gebühr einzuzahlen ist. Für Überweisungen des Anwenders aus dem Ausland.&lt;/para>" annotatedElement="_16_5_4_940029b_1467902983357_991281_5949"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467902983357_103822_5963" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467902983357_999013_5961" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467903020454_231000_5976" name="verwendungszweck" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467903020454_476250_5979" body="&lt;para>Hier ist das Kassenzeichen einzutragen, unter dem die Sollstellung durch die Baubehörde bei der lokalen Finanzverwaltung veranlasst wurde. Ist vom Bauherrn bei der Zahlung im Überweisungsformular in das Feld &quot;Verwendungszweck&quot; einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1467903020454_231000_5976"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467903180941_558067_5986" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467903180941_133981_5985" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467903322701_974436_5987" name="Position">
            <ownedComment xmi:id="_16_5_4_940029b_1467903322701_819141_5993" body="&lt;para>Dieser Typ entält die Daten zu einer Position des Gebührenbescheids.&lt;/para>" annotatedElement="_16_5_4_940029b_1467903322701_974436_5987"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467903322701_564115_5991" name="erlaeuterung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467903322701_785324_6004" body="&lt;para>Hier ist eine Begründung bzw. eine Herleitung (Bsp. Stückpreis mal Anzahl; Bsp. Rahmen mit Bezug auf Aufwand; Bsp. Grund bzw. Gegenstand der Auslage ) zur Position einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1467903322701_564115_5991"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467903604418_29812_6045" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467903604418_957260_6044" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467903322701_628012_5992" name="betrag" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467903322701_718689_6008" body="&lt;para>Hier ist der Betrag in Eurocent einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1467903322701_628012_5992"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467903431217_688078_6019" name="" value="1"/>
