            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476117799391_975132_6117" name="grundflaechenzahl" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476117799391_845557_6120" body="&lt;para>Die Grundflächenzahl (GRZ, BauNVO, § 19) gibt den Flächenanteil eines Baugrundstückes an, der überbaut werden darf; sie wird mit ein oder zwei Dezimalstellen angegeben.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476117799391_975132_6117"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191862437_185349_1574"/>
