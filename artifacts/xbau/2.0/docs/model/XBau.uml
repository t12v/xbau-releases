          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467904417963_15998_6086" name="Gebuehrenbescheid">
            <ownedComment xmi:id="_16_5_4_940029b_1467904417963_446498_6094" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Gebührenbescheids der Bauaufsichtsbehörde. Es sind die Daten zu Gegenstand, Herleitung, Betrag und Bezahlung der Gebühren enthalten.&lt;/para>" annotatedElement="_16_5_4_940029b_1467904417963_15998_6086"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467904417963_810785_6088" name="istVorauszahlungsbescheid" visibility="private">
              <ownedComment xmi:id="_16_5_4_940029b_1467904417963_207101_6097" body="&lt;para>Falls es sich nicht um den abschließenden Gebührenbescheid, sondern um einen Vorauszahlungsbescheid handelt, ist hier true einzutragen. Dann weiß der Empfänger, dass weitere Gebührenbescheide zum angegebenen Vorgang zu erwarten sind.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467904417963_810785_6088"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467904417963_914128_6098" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467904417963_35437_6096" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467904417963_833770_6089" name="begruendung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467904417963_443469_6101" body="&lt;para>Hier ist die Rechtsgrundlage für die Gebühr bzw. eine sonstige Begründung einzutragen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467904417963_833770_6089"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467905211426_886686_6154" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467905211426_687154_6153" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467904798167_281550_6138" name="kostenberechnung" visibility="private" type="_16_5_4_940029b_1467902966126_526268_5914">
              <ownedComment xmi:id="_16_5_4_940029b_1467904798167_224756_6141" body="&lt;para>Dieses Objekt enthält alle Informationen zu den Positionen des Gebührenbescheids und deren Summierung zu einem Geldbetrag.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467904798167_281550_6138"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467904798167_352424_6142" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467904798167_522177_6140" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467904837994_276507_6145" name="zahlungsdaten" visibility="private" type="_16_5_4_940029b_1467902983357_400947_5945">
              <ownedComment xmi:id="_16_5_4_940029b_1467904837994_535056_6148" body="&lt;para>Dieses Element enthält die Angaben, die der Anwender zur Veranlassung einer bargeldlosen Bezahlung gemäß SEPA benötigt. &lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467904837994_276507_6145"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467904837994_255789_6149" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467904837994_607361_6147" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467904417963_226240_6091" name="informationVerspaetungszuschlag" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467904417963_451437_6109" body="&lt;para>Hier werden Angaben zu Zuschlägen bei Fristversäumnis eingetragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1467904417963_226240_6091"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467904417963_897403_6110" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467904417963_700478_6108" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467904417963_766246_6090" name="rechtshelfsbelehrung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467904417963_253888_6105" body="&lt;para>Hier werden die Rechtshelfsbelehrungen zum Bescheid gegeben.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467904417963_766246_6090"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467904417963_936603_6106" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467904417963_750828_6104" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1468415489664_259141_5515" name="Beteiligung">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1468415498263_156080_5519" name="AnliegenBeteiligung">
            <ownedComment xmi:id="_16_5_4_940029b_1468415498263_793111_5524" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Beteiligungsanliegens der Bauaufsichtsbehörde gegenüber einem Träger öffentlicher Belange.&lt;/para>" annotatedElement="_16_5_4_940029b_1468415498263_156080_5519"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468415498263_49949_5521" name="rolle" visibility="private" type="_16_5_4_940029b_1468416052656_204217_5565">
              <ownedComment xmi:id="_16_5_4_940029b_1468415498263_868134_5527" body="&lt;para>Aus diesem Element geht die Rolle des Adressaten im Beteiligungsverfahren hervor.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468415498263_49949_5521"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468415498263_302492_5528" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468415498263_440123_5526" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468416340267_170061_5954" name="rechtsbereich" visibility="private" type="_16_5_4_940029b_1467881020760_671045_5646" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1468416340267_288139_5957" body="&lt;para>Dieses Element nennt den  Rechtsbereich, innerhalb dessen Anlass und angeforderte Stellungnahme liegen. &lt;/para>" annotatedElement="_16_5_4_940029b_1468416340267_170061_5954"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468416340267_924066_5958" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468416340267_590428_5956" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468415540067_481917_5543" name="grundDerBeteiligung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1468415540067_608162_5546" body="&lt;para>Hier wird der Grund bzw. das Anliegen der Beteiligung mit Bezug auf die entsprechenden Eigenschaften des Bauvorhabens im Detail formuliert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468415540067_481917_5543"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468415540067_422756_5547" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468415540067_919300_5545" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468415498263_290412_5522" name="strukturierteStellungnahme" visibility="private">
              <ownedComment xmi:id="_16_5_4_940029b_1468415498263_886338_5531" body="&lt;para>Gewünschte Form der angeforderten Stellungnahme: Falls eine strukturierte Stellungnahme gefordert wird, ist hier &quot;true&quot; einzutragen. Anderenfalls genügt der Bauaufsichtsbehörde eine Stellungnahme in einem formlosen Schreiben.&lt;/para>&#xA;&lt;para>Das entsprechende Format wird in der späteren Lieferung der Stellungnahme durch die beteiligte Behörde mit &#xA;&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot;&#xA;linkend=&quot;XBau.Nachrichten.Beteiligung.beteiligung.stellungnahme.0303&quot;>Nachricht 0303&lt;/link> eingehalten. &lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468415498263_290412_5522"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468415498263_751716_5532" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468415498263_850588_5530" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1468483048397_160283_5901" name="Anonym_Stellungnahme">
            <ownedComment xmi:id="_16_5_4_940029b_1468483048412_65404_5906" body="" annotatedElement="_16_5_4_940029b_1468483048397_160283_5901"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468483092774_168609_5931" name="stellungnahmeFormlos" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1468483092774_709437_5935" body="&lt;para>Die Stellungnahme ist in dieses Element als Fließtext einzufügen, falls eine formlose Stellungnahme angefordert wurde.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468483092774_168609_5931"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468483092774_152680_5936" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468483092774_963550_5934" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468483092774_263776_5932" name="stellungnahmeStrukturiert" visibility="private" type="_16_5_4_940029b_1467896012971_615347_5228" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1468483092774_423646_5939" body="&lt;para>Falls eine strukturierte Stellungnahme angefordert wurde, ist eine bestimmte Form bei der Dokumentation der Stellungnahme einzuhalten.  Es sind die Parameter dieses Objekts zu füllen.&lt;/para>" annotatedElement="_16_5_4_940029b_1468483092774_263776_5932"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468483092774_160796_5940" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468483092774_887556_5938" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1476089545293_858396_5697" name="DatentypenBaulast">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476035195880_924265_7679" name="BaulastErklaerung">
            <ownedComment xmi:id="_16_5_4_940029b_1476035195884_184657_7687" body="&lt;para>Dieser Typ beinhaltet die Daten zu Anlass und Inhalt einer Baulasterklärung.&lt;/para>" annotatedElement="_16_5_4_940029b_1476035195880_924265_7679"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035195884_93646_7682" name="anlass" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1476035195884_547703_7694" body="&lt;para>Hier wird die öffentlich-rechtliche Verpflichtung bezeichnet, die mit der einzutragenden Baulast einhergeht. Es wird der  Zweck bzw. das Ziel der einzurichtenden Baulast angegeben.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476035195884_93646_7682"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036632490_879678_7774" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036632490_9679_7773" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035195884_669763_7683" name="beschreibung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1476035195884_693195_7698" body="&lt;para>Hier ist Text einzutragen, der die Baulast mit Bezugnahme auf die in der Nachricht aufgeführten Grundstücke definiert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476035195884_669763_7683"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476035195884_641727_7699" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476035195884_69497_7697" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476036535283_837924_7764" name="sachverhalt" visibility="private" type="_16_5_4_940029b_1476035380312_138234_7724">
              <ownedComment xmi:id="_16_5_4_940029b_1476036535283_843961_7767" body="&lt;para>Hier wird eine Beschreibung der Verpflichtung im Detail gegeben. Dies geschieht, indem georeferenziert auf die Gegenstände der Baulast Bezug genommen wird. Pro Element wird ein Baulast-Gegenstand genannt.&lt;/para>" annotatedElement="_16_5_4_940029b_1476036535283_837924_7764"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036621928_797043_7772" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036621928_4894_7771" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476035380312_138234_7724" name="Anonym_Gegenstand">
            <ownedComment xmi:id="_16_5_4_940029b_1476035380312_721443_7727" body="&lt;para>Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para>" annotatedElement="_16_5_4_940029b_1476035380312_138234_7724"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035380312_805281_7725" name="baulastgegenstand" visibility="private" type="_16_5_4_940029b_1460651165974_293124_3777">
              <ownedComment xmi:id="_16_5_4_940029b_1476035380312_6317_7730" body="&lt;para>In diesem Element wird ein Baulast-Gegenstand georeferenziert definiert. z.B. eine Baulastfläche (Abstandsfläche, die von der Bebauung freizuhalten ist) oder eine gemeinsame Brandwand (die nicht verändert werden darf in einem Bauvorhaben).&lt;/para>" annotatedElement="_16_5_4_940029b_1476035380312_805281_7725"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476035380312_220881_7731" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476035380312_10838_7729" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035380312_970392_7726" name="beschreibung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1476035380312_299863_7734" body="&lt;para>Zum georeferenzierten Baulast-Gegenstand werden hier Erläuterungen eingefügt.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476035380312_970392_7726"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476035380312_269185_7735" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476035380312_505582_7733" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1476117107068_322185_6000" name="DatenblattBaugegenstand">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476117186433_933286_6004" name="Nutzungseinheiten">
            <ownedComment xmi:id="_16_5_4_940029b_1476117186433_934421_6008" body="&lt;para>Dieser Typ fasst Angaben zu den Nutzungseinheiten des Vorhabens zusammen.&lt;/para>" annotatedElement="_16_5_4_940029b_1476117186433_933286_6004"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476117695755_715318_6103" name="wohneinheitenGesamt" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476117695755_746043_6106" body="&lt;para>Anzahl Wohneinheiten (gesamt)&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476117695755_715318_6103"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476117695755_15962_6107" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476117695755_396943_6105" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476117960773_468063_6131" name="wohneinheitenEigentumswohnungen" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476117960773_315449_6134" body="&lt;para>Anzahl Wohneinheiten Eigentumswohnungen&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476117960773_468063_6131"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476117960773_751736_6135" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476117960773_877734_6133" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476117960977_176766_6138" name="wohneinheitenMietwohnungen" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476117960977_936362_6141" body="&lt;para>Anzahl Wohneinheiten Mietwohnungen &lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476117960977_176766_6138"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476117960977_978861_6142" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476117960977_686233_6140" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476117961164_188332_6145" name="wohneinheitenSozialwohnungen" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476117961164_740738_6148" body="&lt;para>Anzahl Wohneinheiten geförderte soziale Wohnungen &lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476117961164_188332_6145"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476117961164_345870_6149" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476117961164_279113_6147" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476117961352_86807_6152" name="wohnungenGewerblich" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476117961352_165644_6155" body="&lt;para>Anzahl Wohnungen, die gewerblich genutzt werden sollen&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476117961352_86807_6152"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
