              </ownedAttribute>
            </packagedElement>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1478886262978_841475_5524" name="bautechnischeNachweise.anforderungNachbesserung.0504">
            <ownedComment xmi:id="_16_5_4_940029b_1478886262978_466020_5529" body="&lt;para>Diese Nachricht nennt Mängel bzw. Nachbesserungsbedarf zu einem erteilten Prüfauftrag.&lt;/para>" annotatedElement="_16_5_4_940029b_1478886262978_841475_5524"/>
            <generalization xmi:id="_16_5_4_940029b_1478886262978_730709_5526" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886262978_407424_5527" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1478886262978_756016_5534" body="&lt;para>Hier trägt der Auftragnehmer die Vorgangsnumme der Bauaufsichtsbehörde ein, die ihm mit der Beauftragung (Nachricht 0500) zugestellt wurde. Außerdem wird die Referenz auf die Nachricht 0500 eingetragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1478886262978_407424_5527"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886262978_49214_5535" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886262978_797144_5533" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886594514_888914_5596" name="aufforderungZurStellungnahme" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1478886594514_957013_5600" body="&lt;para>Hier ist die Aufforderung zu Stellungnahme bzw. Kommentar formuliert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1478886594514_888914_5596"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886594514_173915_5601" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886594514_913068_5599" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886262978_174180_5528" name="befundliste" visibility="private" type="_16_5_4_940029b_1467881984463_299931_5687" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1478886262978_631871_5538" body="&lt;para>Nach der Prüfiung des Auftrags durch den Auftragnehmer: Hier sind die Ergebnisse der Prüfung als Befundliste enthalten. Jeder Befund wird mit den nötigen Details erläutert.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1478886262978_174180_5528"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886262978_703763_5539" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886262978_337123_5537" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1478886366456_622274_5546" name="bautechnischeNachweise.nachbesserung.0505">
            <ownedComment xmi:id="_16_5_4_940029b_1478886366471_729317_5555" body="&lt;para>Diese Nachricht enthält nachgebesserte Unterlagen zum Prüfauftrags. Sie bezieht sich auf den erteilten Prüfauftrag und auf eine Mängelliste, die bei Prüfung der technischen Planungsdokumente erarbeitet wurde.&lt;/para>" annotatedElement="_16_5_4_940029b_1478886366456_622274_5546"/>
            <generalization xmi:id="_16_5_4_940029b_1478886366456_177784_5548" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886366456_575439_5549" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1478886366471_3810_5560" body="&lt;para>Hier ist die Vorgangsnummer (Beauftragung) einzutragen (analog zu Nachricht 0500). Außerdem ist auf die Nachricht 0504 zu verweisen, auf die mit dieser Nachricht geantwortet wird.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1478886366456_575439_5549"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886366471_321921_5561" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886366471_449902_5559" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886366471_970658_5554" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1478886366471_523871_5580" body="&lt;para>Hier sind ggf. die korrigierten Unterlagen eingetragen.&lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1478886366471_970658_5554"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886366471_376437_5581" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886366471_359384_5579" name=""/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1470126244519_424350_6023" name="Genehmigungsfreistellung" clientDependency="_16_5_4_940029b_1470126244519_302796_6026">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470126244519_807784_6025" name="genehmigungsfreistellung.anzeige.0600">
            <ownedComment xmi:id="_16_5_4_940029b_1470126244535_724494_6041" body="&lt;para>Mit dieser Nachricht zeigt der Bauherr der Gemeinde wg. möglicher Freistellung von der Genehmigungspflicht sein Vorhaben an. Die Nachricht enthält die einschlägigen Daten zum Vorhaben, ergänzend dokumentiert durch Unterlagen, die Bauvorlagen entsprechen sowie sonstige Unterlagen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1470126244519_807784_6025"/>
            <generalization xmi:id="_16_5_4_940029b_1470126244519_873499_6036" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126244519_969163_6037" name="bauvorhaben" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" aggregation="composite" association="_16_5_4_940029b_1470126244519_988083_6027">
              <ownedComment xmi:id="_16_5_4_940029b_1470126244535_700970_6089" body="&lt;para>Dies ist die Dokumentation zum Bauvorhaben, für das der Bauherr die Genehmigungsfreistellung anzeigt. Die nötigen Daten (Wer, Was, Wo) sind enthalten.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470126244519_969163_6037"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126244535_789584_6090" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126244535_740423_6088" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126244535_149627_6040" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470126244535_798415_6101" body="&lt;para>Die für die Planung des Vorhabens notwendigen Unterlagen sind hier als Anlage beigefügt (MBO, MBauVorlV). In diesem Element sind die nötigen Metadaten und ggf. auch das Primärdokument enthalten. &lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1470126244535_149627_6040"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126244535_173472_6102" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126244535_323235_6100" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126244535_848763_6039" name="alsBauantragWeiterzufuehren" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470126244535_233251_6097" body="&lt;para>Hier kann der Bauherr kennzeichnen (&quot;true&quot;, andernfalls &quot;false&quot;), dass der Vorgang bei abschlägiger Entscheidung in ein Baugenehmigungsverfahren übergehen soll und die eingereichten Unterlagen dann als Bauvorlagen verwendet werden sollen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470126244535_848763_6039"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470160712671_184452_6183" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470160712671_862962_6182" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1470126244519_302796_6026" name="" supplier="_16_5_4_1d100e5_1384794877872_302539_331" client="_16_5_4_940029b_1470126244519_424350_6023"/>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1470126244519_988083_6027" name="" memberEnd="_16_5_4_940029b_1470126244535_199390_6043 _16_5_4_940029b_1470126244519_969163_6037">
            <ownedEnd xmi:id="_16_5_4_940029b_1470126244535_199390_6043" name="" visibility="private" type="_16_5_4_940029b_1470126244519_807784_6025" association="_16_5_4_940029b_1470126244519_988083_6027"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470126244519_809943_6030" name="genehmigungsfreistellung.ergebnis.0602">
            <ownedComment xmi:id="_16_5_4_940029b_1470126244535_117382_6062" body="&lt;para>Mittels dieser Nachricht teilt die Gemeinde dem Bauherrn das Ergebnis der Prüfung seiner Anzeige mit. Der Bauherr erfährt, ob sein Vorhaben genehmigungspflichtig ist. Auch erhält er Informationen, ob die Gemeinde eine Untersagung gemäß § 15 BauGB beantragt hat.&lt;/para>" annotatedElement="_16_5_4_940029b_1470126244519_809943_6030"/>
            <generalization xmi:id="_16_5_4_940029b_1470126244535_150476_6058" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126244535_764192_6060" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1470126244535_995070_6143" body="&lt;para>Bezug auf die Anzeige des Bauherrn gegenüber der Gemeinde. Nachricht 0600, auf die die Gemeinde mit dieser Nachricht antwortet.&lt;/para>" annotatedElement="_16_5_4_940029b_1470126244535_764192_6060"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126244535_365039_6144" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126244535_635201_6142" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470150896189_777415_5868" name="ergebnisDesVerfahrens" visibility="private" type="_16_5_4_940029b_1470154418625_431141_6144" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470150896189_237118_5871" body="&lt;para>Die Gemeinde trägt in dieses Element ein, welches Ergebnis die gemeindliche Prüfung der Anzeige ergeben hat.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470150896189_777415_5868"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470150988791_373330_5883" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470150988791_447245_5882" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470126429774_41805_6269" name="genehmigungsfreistellung.anzeigeBAB.0601">
            <ownedComment xmi:id="_16_5_4_940029b_1470126429790_850115_6278" body="&lt;para>Mit dieser Nachricht unterrichtet die Gemeinde die Bauaufsichtsbehörde über die eingegangene Anzeige der Genehmigungsfreistellung.&lt;/para>" annotatedElement="_16_5_4_940029b_1470126429774_41805_6269"/>
            <generalization xmi:id="_16_5_4_940029b_1470126429774_956813_6271" isSubstitutable="true" general="_16_5_4_940029b_1461085723092_220631_5163"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126429774_582085_6272" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1470126429790_976529_6283" body="&lt;para>Bezug auf die Anzeige des Bauherrn gegenüber der Gemeinde. Nachricht 0600, die die Gemeinde erhalten hat.&lt;/para>" annotatedElement="_16_5_4_940029b_1470126429774_582085_6272"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126429790_256609_6284" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126429790_463436_6282" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126429774_809448_6274" name="bauvorhaben" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470126429790_749441_6291" body="&lt;para>Dies ist die Dokumentation zum Bauvorhaben, für das der Bauherr die Genehmigungsfreistellung anzeigt.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470126429774_809448_6274"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126429790_751261_6292" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126429790_393018_6290" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126429790_186432_6275" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470126429790_23855_6295" body="&lt;para>In diesem Element sind die durch den Bauherrn beigefügten Anlagen enthalten.&lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1470126429790_186432_6275"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126429790_301771_6296" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126429790_948038_6294" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470150408076_125263_5861" name="alsBauantragWeiterzufuehren" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470150408076_957686_5864" body="&lt;para>Hier ist dokumentiert, ob der  Bauherr wünscht, dass der Vorgang bei abschlägiger Entscheidung als ein Baugenehmigungsverfahren weitergeführt werden soll  (&quot;true&quot;, andernfalls &quot;false&quot;).&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470150408076_125263_5861"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470150996165_730992_5885" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470150996165_45481_5884" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470126430634_353642_6319" name="genehmigungsfreistellung.ergebnisBAB.0603">
            <ownedComment xmi:id="_16_5_4_940029b_1470126430634_300418_6328" body="&lt;para>Diese Nachricht unterrichtet die Bauaufsichtsbehörde über das Ergebnis der Prüfung, das dem Bauherrn von der Gemeinde übermittelt wurde.&lt;/para>" annotatedElement="_16_5_4_940029b_1470126430634_353642_6319"/>
            <generalization xmi:id="_16_5_4_940029b_1470126430634_800715_6321" isSubstitutable="true" general="_16_5_4_940029b_1461085723092_220631_5163"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126430634_266001_6322" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1470126430634_816367_6333" body="&lt;para>Bezug auf die Anzeige des Bauherrn gegenüber der Gemeinde. Nachricht 0600, die die Gemeinde erhalten hat.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470126430634_266001_6322"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126430634_228100_6334" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126430634_262515_6332" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470155702143_49172_6175" name="ergebnisDesVerfahrens" visibility="private" type="_16_5_4_940029b_1470154418625_431141_6144" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470155702143_761828_6178" body="&lt;para>Die Gemeinde trägt in dieses Element ein, welches Ergebnis der gemeindlichen Prüfung der Anzeige sie dem Bauherrn übermittelt hat.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470155702143_49172_6175"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470155702143_686918_6179" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470155702143_432787_6177" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1475787171501_129307_6064" name="Baulasten" clientDependency="_16_5_4_940029b_1475787171532_582012_6067">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787171532_553648_6066" name="baulasten.vorlageErklaerung.0700">
            <ownedComment xmi:id="_16_5_4_940029b_1475787171548_750236_6082" body="&lt;para>Diese Nachricht dient dazu, der Bauaufsichtsbehörde die Baulast-Erklärung sowie ergänzende Dokumentationen zuzustellen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1475787171532_553648_6066"/>
            <generalization xmi:id="_16_5_4_940029b_1475787171548_293734_6077" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476034193320_413197_7498" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1476034193320_486769_7501" body="&lt;para>Im Kontext einer nicht-selbständigen Baulasterklärung wird hier der Bezug zu einem laufenden Baugenehmigungsverfahren hergestellt. Im anderen Fall existiert noch keine Vorgangsnummer, so dass dieses Element nicht verwendet wird.&lt;/para>" annotatedElement="_16_5_4_940029b_1476034193320_413197_7498"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476037930924_657862_7803" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476037930924_45174_7802" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476034176681_146181_7491" name="beteiligtePersonen" visibility="private" type="_16_5_4_940029b_1476034342357_954336_7610" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476034176681_662564_7494" body="&lt;para>Die am Baulastverfahren beteiligten Pesonen sind unterhalb dieses Elements einzutragen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476034176681_146181_7491"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034176681_863088_7495" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034176681_451156_7493" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476034869674_250931_7672" name="beteiligteGrundstuecke" visibility="private" type="_16_5_4_940029b_1476034761055_276755_7650" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476034869674_313398_7675" body="&lt;para>Hier werden die für das Baulastverfahren relevanten Grundstücke eingetragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1476034869674_250931_7672"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034869674_297108_7676" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034869674_755940_7674" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035557766_218550_7740" name="erklaerung" visibility="private" type="_16_5_4_940029b_1476035195880_924265_7679" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476035557766_177073_7743" body="&lt;para>Der Zweck der angestrebten Baulast sowie der zu regelnde Sachverhalt werden hier beschrieben.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476035557766_218550_7740"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476035557766_450421_7744" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476035557766_402423_7742" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476034452204_375976_7643" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476034452204_918858_7646" body="&lt;para>Hier sind alle Pläne darzustellen, die für die Eindeutigkeit der Baulasterklärung relevant sind.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476034452204_375976_7643"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034452204_262687_7647" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034452204_83277_7645" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1475787171532_582012_6067" name="" supplier="_16_5_4_1d100e5_1384794877872_302539_331" client="_16_5_4_940029b_1475787171501_129307_6064"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787171532_608660_6069" name="baulasten.nachforderung.0701">
            <ownedComment xmi:id="_16_5_4_940029b_1475787171548_431360_6090" body="&lt;para>Diese Nachricht enthält die Befunde der Bauaufsichtsbehörde zu der eingereichten Baulasterklärung bzw. den beigefügten Unterlagen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787171532_608660_6069"/>
            <generalization xmi:id="_16_5_4_940029b_1475787171548_592090_6086" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_915891_6087" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_70672_6148" body="&lt;para>In diesem Element wird der Vorgang (Vorgangsnummer, unter der die Behörde die Baulasterklärung bearbeitet) genannt bzw. dem Antragsteller mitgeteilt  bzw. die Nachricht baulasten.vorlageErklaerung.0700 eingetragen, durch deren Eingang bei der Bauaufsichtsbehörde der Vorgang ausgelöst worden ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1475787171548_915891_6087"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_875996_6149" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_798044_6147" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_559022_6088" name="befundliste" visibility="private" type="_16_5_4_940029b_1467843232886_870322_5578" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_27124_6152" body="&lt;para>Hier sind die Ergebnisse der formellen Prüfung enthalten. Die Liste nennt die  Mängel, die bei der Prüfung der Baulast-Erklärung aufgefallen sind.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787171548_559022_6088"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_349182_6153" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_867276_6151" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787171532_426875_6070" name="baulasten.information.0702">
            <ownedComment xmi:id="_16_5_4_940029b_1475787171548_855341_6097" body="&lt;para>Die Akteure, die die Baulast-Erklärung vorgelegt haben, werden durch diese Nachricht über das Ergebnis der&#xA;Prüfung informiert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787171532_426875_6070"/>
            <generalization xmi:id="_16_5_4_940029b_1475787171548_507526_6092" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_545414_6093" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_791250_6162" body="&lt;para>In diesem Element wird der laufende Vorgang der Bearbeitung der Baulasterklärung genannt und die Nachricht baulasten.vorlageErklaerung.0700 genannt , durch deren Eingang bei der Bauaufsichtsbehörde der Vorgang ausgelöst worden ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1475787171548_545414_6093"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_972450_6163" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_343907_6161" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476036221822_871585_7757" name="sachverhalt" visibility="private" type="_16_5_4_940029b_1476036643713_810494_7775">
              <ownedComment xmi:id="_16_5_4_940029b_1476036221822_151735_7760" body="&lt;para>Dieses Element enthält die Ergebnisse der Prüfung der Baulasterklärung.&lt;/para>" annotatedElement="_16_5_4_940029b_1476036221822_871585_7757"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036221822_723550_7761" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036221822_795447_7759" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476036129706_61593_7750" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476036129706_626260_7753" body="&lt;para>Hier ist im Erfolgsfall die Dokumentation der vorgenommenen Eintragung ins BL-Verzeichnis enthalten.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476036129706_61593_7750"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476040546071_39424_7805" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476040546071_823235_7804" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787171532_583404_6072" name="baulasten.gebuehrenbescheid.0703">
            <ownedComment xmi:id="_16_5_4_940029b_1475787171548_4646_6109" body="&lt;para>Diese Nachricht enthält Informationen über die fälligen Gebühren, sowie die Aufforderung, diese auf&#xA;der Basis von Zahlungsinformationen zu entrichten.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787171532_583404_6072"/>
            <generalization xmi:id="_16_5_4_940029b_1475787171548_842025_6105" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_688751_6106" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_991110_6194" body="&lt;para>In diesem Element wird der laufende Vorgang der Bearbeitung der Baulasterklärung genannt und die Nachricht baulasten.vorlageErklaerung.0700 genannt , durch deren Eingang bei der Bauaufsichtsbehörde der Vorgang ausgelöst worden ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1475787171548_688751_6106"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_72846_6195" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_925501_6193" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_133831_6107" name="gebuehrenbescheid" visibility="private" type="_16_5_4_940029b_1467904417963_15998_6086" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_904759_6198" body="&lt;para>Unterhalb dieses Element finden sich die Angaben zur Gebührenberechnung und -begründung, sowie die Zahlungsdaten und weitere Informationen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787171548_133831_6107"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_813638_6199" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_103817_6197" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_533886_6108" name="frist" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_446176_6202" body="&lt;para>Dies ist die durch die Behörde gesetzte Zahlungsfrist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787171548_533886_6108"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_139044_6203" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_839258_6201" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1476034334212_405024_7609" name="Datentypen">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476034342357_954336_7610" name="Anonym_BeteiligteBaulast">
              <ownedComment xmi:id="_16_5_4_940029b_1476034342357_419551_7616" body="&lt;para>Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para>" annotatedElement="_16_5_4_940029b_1476034342357_954336_7610"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476034342357_750208_7612" name="baulastgeber" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
                <ownedComment xmi:id="_16_5_4_940029b_1476034342357_825845_7619" body="&lt;para>Hier sind die Daten des Baulastgebers einzutragen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476034342357_750208_7612"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034419713_39063_7642" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034419713_89494_7641" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476034342357_351348_7613" name="beguenstigter" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
                <ownedComment xmi:id="_16_5_4_940029b_1476034342357_893299_7623" body="&lt;para>Hier sind die Daten des Begünstigten (im Kontext eines Baugenehmigungsverfahrens ist dies der Bauherr) einzutragen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476034342357_351348_7613"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034342357_467936_7624" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034342357_805157_7622" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476034761055_276755_7650" name="Anonym_GrundstueckeBaulast">
              <ownedComment xmi:id="_16_5_4_940029b_1476034761055_395438_7653" body="&lt;para>Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para>" annotatedElement="_16_5_4_940029b_1476034761055_276755_7650"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476034761055_188910_7651" name="belastetesGrundstueck" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594">
                <ownedComment xmi:id="_16_5_4_940029b_1476034761055_796237_7656" body="&lt;para>Für jedes aufzuführende belastete Grundstück ist ein Element zu füllen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476034761055_188910_7651"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034834720_752043_7669" name="" value="*"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034834720_212848_7668" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476034761055_897066_7652" name="beguenstigtesGrundstueck" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594">
                <ownedComment xmi:id="_16_5_4_940029b_1476034761055_318880_7660" body="&lt;para>Für jedes aufzuführende begünstigte Grundstück  ist ein Element zu füllen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476034761055_897066_7652"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034840717_895118_7671" name="" value="*"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034840717_883475_7670" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476036643713_810494_7775" name="Anonym_Entscheidung">
              <ownedComment xmi:id="_16_5_4_940029b_1476036643713_646651_7779" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Bescheides, den die Bauaufsichtsbehörde nach Prüfung eines Antrags erlässt.&lt;/para>" annotatedElement="_16_5_4_940029b_1476036643713_810494_7775"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476036643713_549781_7776" name="baulastAkzeptiert" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1476036643713_439022_7782" body="&lt;para>Falls die Baulast akzeptiert und eingetragen wurde, ist hier 'true' zu übermitteln, anderenfalls 'false'.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476036643713_549781_7776"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036643713_115751_7783" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036643713_759531_7781" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476036643713_107737_7777" name="begruendung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
                <ownedComment xmi:id="_16_5_4_940029b_1476036643713_112608_7786" body="&lt;para>Falls die Baulast durch die Behörde nicht akzeptiert und eingetragen wurde, wird in diesem Element die Begründung für diese Entscheidung geliefert.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476036643713_107737_7777"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036732771_802106_7799" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036732771_166023_7798" name=""/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1475787797941_867272_6679" name="UeberwachungspflichtigeAnlagen" clientDependency="_16_5_4_940029b_1475787797957_970832_6682 _16_5_4_940029b_1476073869162_200619_6774">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787797941_348773_6681" name="ueberwachungspflichtigeAnlagen.pruefbescheinigung.0800">
            <ownedComment xmi:id="_16_5_4_940029b_1475787797957_323695_6691" body="&lt;para>Diese Nachricht dient zur Übermittlung der Prüfbescheinigung an die Bauaufsichtsbehörde. Sie enthält alle relevanten Informationen zur Bewertung der Wirksamkeit und Betriebssicherheit der überwachungspflichtigen Anlagen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787797941_348773_6681"/>
            <generalization xmi:id="_16_5_4_940029b_1475787797957_686967_6689" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476071161612_359923_6541" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1476071161612_423425_6544" body="&lt;para>In diesem Element wird die Vorgangsnummer bzw. das Aktenzeichen zur erteilten Baugenehmigung übermittelt, die der Errichtung des Gebäudes und der technischen Anlage(n) zu Grunde lag.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476071161612_359923_6541"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476071161612_722962_6545" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476071161612_861538_6543" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477926836011_430371_4781" name="gebaeude" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594">
              <ownedComment xmi:id="_16_5_4_940029b_1477926836058_899596_4784" body="&lt;para>Hier wird der Ort der Prüfung bezeichnet, nämlich Anschrift und Flurstück zum Gebäude, in dem die geprüfte technische Anlage (bzw. die geprüften technischen Anlagen)  installiert ist (sind).&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1477926836011_430371_4781"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477926836058_213416_4785" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477926836043_825815_4783" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476071641330_487967_6682" name="pruefgegenstand" visibility="private" type="_16_5_4_940029b_1476071320283_102133_6652">
              <ownedComment xmi:id="_16_5_4_940029b_1476071641330_200090_6685" body="&lt;para>Dieses Element bezeichnet den Gegenstand der Prüfung, eine bestimmte technische Anlage in dem lokalisierten Gebäude. Pro Element wird genau eine technische Anlage referenziert. Die Prüfung kann mehrere technische Anlagen in dem Gebäude zum Gegenstand haben.&lt;/para>" annotatedElement="_16_5_4_940029b_1476071641330_487967_6682"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477927172218_297343_4789" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477927172218_812720_4788" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476072133185_168795_6709" name="anlassDerPruefung" visibility="private" type="_16_5_4_940029b_1476071806236_935553_6689">
              <ownedComment xmi:id="_16_5_4_940029b_1476072133185_239755_6712" body="&lt;para>In diesem Element wird der Anlass der durchgeführten Prüfung genannt, über deren Ergebnis berichtet wird.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476072133185_168795_6709"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476072133185_372606_6713" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476072133185_405504_6711" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476072197571_935301_6716" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476072197571_990795_6719" body="&lt;para>Die Anlagen enthalten den Prüfbericht, der auch die Bewertung des Prüfergebnisses vornimmt und Konsequenzen empfiehlt. Der Inhalt des Prüfberichts ist in den Musterprüfgrundsätzen definiert (Anlage zur Musterprüfverordnung Ziffer 4). Der Betreiber der technischen Anlagen hat den Prüfbericht typischerweise als Papierdokument vom Prüfsachverständigen erhalten.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1476072197571_935301_6716"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476072197571_806625_6720" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476072197571_435460_6718" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1475787797957_970832_6682" name="" supplier="_16_5_4_1d100e5_1384794877872_302539_331" client="_16_5_4_940029b_1475787797941_867272_6679"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787797957_934854_6684" name="ueberwachungspflichtigeAnlagen.erinnerung.0801">
            <ownedComment xmi:id="_16_5_4_940029b_1475787797957_295334_6699" body="&lt;para>Diese Nachricht dient der Information des Betreibers, dass eine Prüfbescheinigung überfällig ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787797957_934854_6684"/>
            <generalization xmi:id="_16_5_4_940029b_1475787797957_357678_6695" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787797957_940393_6696" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475787797957_698472_6721" body="&lt;para>In diesem Element wird die Vorgangsnummer bzw. das Aktenzeichen zur erteilten Baugenehmigung übermittelt, die der Errichtung des Gebäudes und der technischen Anlage(n) zu Grunde lag.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475787797957_940393_6696"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787797957_497721_6722" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787797957_839365_6720" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476072284887_285728_6726" name="pruefgegenstand" visibility="private" type="_16_5_4_940029b_1476071320283_102133_6652">
              <ownedComment xmi:id="_16_5_4_940029b_1476072284887_79764_6729" body="&lt;para>Dieses Element bezeichnet den Gegenstand der Prüfung, eine bestimmte technische Anlage in dem lokalisierten Gebäude. Pro Element wird genau eine technische Anlage referenziert. Die Prüfung kann mehrere technische Anlagen in dem Gebäude zum Gegenstand haben.&lt;/para>" annotatedElement="_16_5_4_940029b_1476072284887_285728_6726"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476072284887_492927_6730" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476072284887_419850_6728" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476072309124_702843_6733" name="anlassDerPruefung" visibility="private" type="_16_5_4_940029b_1476071806236_935553_6689">
              <ownedComment xmi:id="_16_5_4_940029b_1476072309124_991195_6736" body="&lt;para>In diesem Element wird der Anlass der durchgeführten Prüfung genannt, über deren Ergebnis berichtet wird.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476072309124_702843_6733"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476072309124_602922_6737" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476072309124_705640_6735" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1476071227800_336263_6651" name="Datentypen">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476071320283_102133_6652" name="Anonym_Pruefgegenstand">
              <ownedComment xmi:id="_16_5_4_940029b_1476071320283_917862_6656" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Bescheides, den die Bauaufsichtsbehörde nach Prüfung eines Antrags erlässt.&lt;/para>" annotatedElement="_16_5_4_940029b_1476071320283_102133_6652"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476071352293_54581_6675" name="bezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
                <ownedComment xmi:id="_16_5_4_940029b_1476071352293_234807_6678" body="&lt;para>Hier wird die Bezeichnung des Prüfgegenstands eingetragen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476071352293_54581_6675"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476071352293_145371_6679" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476071352293_596218_6677" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476071320283_243150_6655" name="artDerTechnischenAnlage" visibility="private" type="_16_5_4_8a30247_1408528824829_316950_2466">
                <ownedComment xmi:id="_16_5_4_940029b_1476071320283_605640_6667" body="&lt;para>Dieses Element enthält Angaben zur Art der geprüften technischen Anlage.&lt;/para>" annotatedElement="_16_5_4_940029b_1476071320283_243150_6655"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476073163242_603300_6743" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476073163242_885705_6742" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476071806236_935553_6689" name="Anonym_Anlass">
              <ownedComment xmi:id="_16_5_4_940029b_1476071806237_778074_6692" body="" annotatedElement="_16_5_4_940029b_1476071806236_935553_6689"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476071806236_711433_6690" name="anlass" visibility="private" type="_16_5_4_43c01ae_1406133066375_719523_2502">
                <ownedComment xmi:id="_16_5_4_940029b_1476071806237_823395_6695" body="&lt;para>Dieses Element nennt den Anlass der durchgeführten Prüfung. Es deckt eine Reihe von Standardfällen ab.&lt;/para>" annotatedElement="_16_5_4_940029b_1476071806236_711433_6690"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477926362051_41711_4780" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477926362051_479160_4779" name=""/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476071806237_809464_6691" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467899960094_58945_5827">
                <ownedComment xmi:id="_16_5_4_940029b_1476071806238_541409_6699" body="&lt;para>Hier werden ggf. die Nebenbestimmungen der Baugenehmigung, insofern diese Prüfungen vorsehen, aufgeführt. Diese können ebenfalls Anlass einer durchgeführten Prüfung sein.&lt;/para>" annotatedElement="_16_5_4_940029b_1476071806237_809464_6691"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476071806238_821151_6700" name="" value="*"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476071806238_278261_6698" name=""/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1476073869162_200619_6774" name="" supplier="_16_5_4_5b501fb_1387625271062_845493_4821" client="_16_5_4_940029b_1475787797941_867272_6679"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1475788011145_184309_6775" name="Bauzustand" clientDependency="_16_5_4_940029b_1475788011145_686026_6778">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475788011145_680098_6777" name="bauzustand.anzeige.0920">
            <ownedComment xmi:id="_16_5_4_940029b_1475788011145_342408_6787" body="&lt;para>Mittels dieser Nachricht kündigt der  Bauherr der Bauaufsichtsbehörde den Zeitpunkt des Erreichens eines bestimmten Bauzustandes an.&lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1475788011145_680098_6777"/>
            <generalization xmi:id="_16_5_4_940029b_1475788011145_134420_6785" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475991889489_682821_6120" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475991889489_810325_6123" body="&lt;para>In diesem Elements werden Eintragungen vorgenommen, um auf die Baugenehmigung Bezug zu nehmen, die der aktuellen Baumaßnahmen zugrundliegen. Ggf. wird auf die entsprechende XBau-Nachricht referenziert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475991889489_682821_6120"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475991889489_421826_6124" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475991889489_79163_6122" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475991951293_941032_6127" name="sachverhalt" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1475991951293_870302_6130" body="&lt;para>In diesem Element wird der eingetretene Bauzustand erläutert, der anzuzeigen ist. Es wird auf entsprechende Termine hingewiesen.&lt;/para>" annotatedElement="_16_5_4_940029b_1475991951293_941032_6127"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475991951293_128106_6131" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475991951293_286538_6129" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1475788011145_686026_6778" name="" supplier="_16_5_4_1d100e5_1384794877872_302539_331" client="_16_5_4_940029b_1475788011145_184309_6775"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475788011145_785647_6780" name="bauzustand.befundliste.0921">
            <ownedComment xmi:id="_16_5_4_940029b_1475788011145_223457_6795" body="&lt;para>Diese Nachricht teilt dem Bauherrn festgestellte Ausführungsmangel mit, falls die Prüfung des Bauzustandes durch die Behörde ein negatives Ergebnis ergeben hat.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475788011145_785647_6780"/>
            <generalization xmi:id="_16_5_4_940029b_1475788011145_386082_6791" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475788011145_207234_6792" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475788011145_548148_6817" body="&lt;para>In diesem Elements wird auf die Vorgangsnummer der erteilten Baugenehmigung Bezug genommen, auf deren Basis gearbeitet wird, und auf die Nachricht 0900, mittels derer der geprüfte Bauzustand angezeigt worden ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1475788011145_207234_6792"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475788011145_86663_6818" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475788011145_952561_6816" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475788011145_461821_6793" name="pruefung" visibility="private" type="_16_5_4_940029b_1475992822008_751378_7400" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1475788011145_681393_6821" body="&lt;para>Dieses Element enthält die Informationen zur Prüfung und benennt die entsprechenden Mängel.&lt;/para>" annotatedElement="_16_5_4_940029b_1475788011145_461821_6793"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475788011145_562332_6822" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475788011145_896230_6820" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475788011145_98476_6781" name="bauzustand.freigabe.0922">
            <ownedComment xmi:id="_16_5_4_940029b_1475788011145_877784_6799" body="&lt;para>Mit dieser Nachricht erklärt die Bauaufsichtsbehörde dem Bauherrn ihre Zustimmung zur Fortführung der Bauarbeiten gemäß § 82 Abs. 1 Satz 2 MBO.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475788011145_98476_6781"/>
            <generalization xmi:id="_16_5_4_940029b_1475788011145_288798_6797" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475788011145_424082_6798" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475788011145_294844_6831" body="&lt;para>Dieses Element enthält die Vorgangsnummer der erteilten Baugenehmigung und referenziert auf die Nachricht 0900, mittels derer der geprüfte Bauzustand angezeigt worden ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1475788011145_424082_6798"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475788011145_319330_6832" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475788011145_327651_6830" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475993913239_980584_7445" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467899960094_58945_5827">
              <ownedComment xmi:id="_16_5_4_940029b_1475993913239_54456_7469" body="&lt;para>Hier können, falls notwendig, Nebenbestimmungen zur erteilten Zustimmung eingefügt werden.&lt;/para>" annotatedElement="_16_5_4_940029b_1475993913239_980584_7445"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475993913239_714050_7470" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475993913239_967228_7468" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1475992764255_817437_7399" name="Datentypen">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475992822008_751378_7400" name="Anonym_Pruefung">
              <ownedComment xmi:id="_16_5_4_940029b_1475992822008_355865_7404" body="&lt;para>Dieser Typ enthält die Informationen zur Prüfung auf der Baustelle mit den entsprechenden Befunden ab.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475992822008_751378_7400"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475992858647_974643_7417" name="datum" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1475993425597_453677_7437" body="&lt;para>Dieses Element enthält das Datum des Tages, an dem die Prüfung durchgeführt wurde.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475992858647_974643_7417"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475993149426_182774_7430" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475993149426_525020_7429" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475992874561_915923_7418" name="pruefer" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517">
                <ownedComment xmi:id="_16_5_4_940029b_1475993367682_458917_7436" body="&lt;para>Hier werden die Daten der Person genannt, die die Prüfung durchgeführt hat.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475992874561_915923_7418"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475993160753_857924_7432" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475993160753_407910_7431" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475993011743_207905_7420" name="ansprechpartnerBaustelle" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517">
                <ownedComment xmi:id="_16_5_4_940029b_1475993365019_755851_7435" body="&lt;para>Hier kann ggf. die Person angegeben werden, mit der auf der Baustelle im Kontext der durchgeführten Prüfung kommuniziert worden ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475993011743_207905_7420"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475993169300_867692_7434" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475993169300_799734_7433" name=""/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475992822008_914879_7403" name="befundliste" visibility="private" type="_16_5_4_940029b_1477928375350_829581_4792" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1475992822008_639476_7411" body="&lt;para>Dieses Element enthält die Mängelliste, die die Prüfung ergeben hat.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475992822008_914879_7403"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475992822008_808322_7412" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475992822008_701446_7410" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
        </packagedElement>
      </packagedElement>
      <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_5b501fb_1398421542326_660552_1933" name="" supplier="_16_5_4_5b501fb_1375258090807_886576_2132" client="_16_5_4_1d100e5_1384794823532_59933_328"/>
      <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_5b501fb_1400580960261_350236_1101" name="Codes" clientDependency="_16_5_4_940029b_1427804799647_414396_3790">
