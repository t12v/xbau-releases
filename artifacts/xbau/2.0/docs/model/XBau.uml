            <ownedComment xmi:id="_16_5_4_28e205cd_1296205701781_443099_1300" body="Dies ist der Typ für das Element 'hausnummer' im Typ Meldeanschrift." annotatedElement="_16_5_4_28e205cd_1296203840375_978526_898"/>
