                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364476447501_551128_1786" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364476447501_19657_1785" name="" value="1"/>
              </ownedAttribute>
