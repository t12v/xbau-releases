              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155848230_81330_5288" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461155848215_434363_5275" name="produkthersteller" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461155848230_65108_5293" body="&lt;para>In diesem Attribut ist der Name der Firma oder der Organisation einzutragen, die für das DV-Verfahren verantwortlich ist, mit dem diese Nachricht erstellt worden ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461155848215_434363_5275"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461155848230_809870_5294" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155848230_804289_5292" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461155848215_472209_5276" name="produktversion" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461155848230_845908_5297" body="&lt;para>In diesem Attribut sollen ergänzende Hinweise zu dem Produkt, mit dem diese Nachricht erstellt worden ist, eingetragen werden. Dies sind Angaben, die für eine möglichst präzise Identifikation im Fehlerfall hilfreich sind, wie zum Beispiel Version und Patchlevel.&lt;/para>" annotatedElement="_16_5_4_940029b_1461155848215_472209_5276"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461155848230_640346_5298" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155848230_580_5296" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461155848215_879601_5277" name="test" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461155848230_247899_5301" body="&lt;para>Dieses Attribut ist optional. Ist es vorhanden, so sagt dies aus, dass es sich um eine Nachricht handelt, die (aus Sicht des Senders der Nachricht) nicht im normalen Produktivbetrieb behandelt werden soll. Über den Inhalt des Attributes wird nichts weiter ausgesagt, dies kann bilateral zwischen den Kommunikationspartnern vereinbart werden.&lt;/para>" annotatedElement="_16_5_4_940029b_1461155848215_879601_5277"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461155848230_944988_5302" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155848230_668151_5300" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461156018749_393935_5433" name="nachrichtenkopf.G2privat" visibility="private" type="_16_5_4_940029b_1461155864757_385317_5310" aggregation="composite" association="_16_5_4_940029b_1461156018749_695913_5432">
              <ownedComment xmi:id="_16_5_4_940029b_1461164411761_161285_5903" body="&lt;para>Dieses Element enthält die  Kopfinformationen zu Nachrichten des vorliegenden Typs.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461156018749_393935_5433"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461156049362_124591_5448" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461156049362_540632_5447" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1461155864757_385317_5310" name="Nachrichtenkopf.G2privat">
            <ownedComment xmi:id="_16_5_4_940029b_1461160749352_660711_5866" body="&lt;para>Nachrichtenkopf für Nachrichten von Behörden an Private.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461155864757_385317_5310"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461155864757_509033_5312" name="identifikation.nachricht" visibility="private" type="_16_5_4_940029b_1461085771571_78551_5204" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461162241343_408925_5896" body="&lt;para>Hier werden die Identifkationsmerkmale zur vorliegenden Nachricht genannt.&lt;/para>" annotatedElement="_16_5_4_940029b_1461155864757_509033_5312"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461155864757_667170_5317" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155864757_525508_5316" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461155864757_897059_5313" name="leser" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461162287489_855669_5899" body="&lt;para>Hier wird die Fachbehörde bzw. Organisation genannt, für die die vorliegende Nachricht bestimmt ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1461155864757_897059_5313"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461155864757_198908_5320" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155864757_993984_5319" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461155864757_980935_5314" name="autor" visibility="private" type="_16_5_4_1eeb04c1_1364382738190_314891_1582" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461155864757_293845_5323" body="&lt;para>Hier wird die Fachbehörde bzw. Organisation genannt, die die vorliegende Nachricht erstellt hat.&lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1461155864757_980935_5314"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461155864757_266924_5324" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155864757_633015_5322" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1461156018749_695913_5432" name="" memberEnd="_16_5_4_940029b_1461156018749_130939_5434 _16_5_4_940029b_1461156018749_393935_5433">
            <ownedEnd xmi:id="_16_5_4_940029b_1461156018749_130939_5434" name="" visibility="private" type="_16_5_4_940029b_1461155848215_275954_5270" association="_16_5_4_940029b_1461156018749_695913_5432"/>
          </packagedElement>
          <packagedElement xmi:type="uml:InstanceSpecification" xmi:id="_16_5_4_940029b_1479075784545_748750_4846" name="">
            <classifier xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191702187_214129_966"/>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1461086907337_479976_5395" name="" supplier="_16_5_4_1eeb04c1_1364305973268_219502_1046" client="_16_5_4_1d100e5_1384794877872_302539_331"/>
        <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1461087400098_673231_5446" name="" supplier="_16_5_4_1eeb04c1_1364491177452_864851_1495" client="_16_5_4_1d100e5_1384794877872_302539_331"/>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1460555920890_762395_3824" name="DatentypenBauantrag">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460554558325_844345_3559" name="BeteiligteBauprojektInPlanung">
            <ownedComment xmi:id="_16_5_4_940029b_1461259199256_560810_5521" body="&lt;para>Typ für die an einem (sich in Planung befindlichen) Bauprojekt beteiligten Parteien (Personen und Organisationen).&lt;/para>" annotatedElement="_16_5_4_940029b_1460554558325_844345_3559"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460554744795_787519_3592" name="bauherr" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1461160825870_465236_5873" body="&lt;para>Hier ist der Akteur einzutragen, der am Verfahren als Bauherr beteiligt ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1460554744795_787519_3592"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460624268881_974516_4810" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460624268881_596196_4809" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460554867588_210126_3605" name="bevollmaechtigter" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517">
              <ownedComment xmi:id="_16_5_4_940029b_1461160828447_256555_5874" body="&lt;para>Hier ist ggf. eine Person einzutragen, die vom  Bauherrn als Bevollmächtigter benannt worden ist.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1460554867588_210126_3605"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460555330638_311860_3688" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460555330638_28448_3687" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460554868305_384954_3610" name="entwurfsverfasser" visibility="private" type="_16_5_4_8a30247_1408705895800_629557_4010">
              <ownedComment xmi:id="_16_5_4_940029b_1461160837694_864545_5875" body="&lt;para>Hier ist die Person einzutragen, die am Verfahren als Entwurfsverfasser beteiligt ist.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1460554868305_384954_3610"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460554868305_332567_3613" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460554868305_466540_3612" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465318842898_789664_5603" name="grundstueckseigentuemer" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1465318842914_635193_5606" body="&lt;para>Hier ist der Eigentümer des Baugrundstücks einzutragen, falls nicht der Bauherr Eigentümer ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465318842898_789664_5603"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465318996812_638972_5619" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465318996812_642718_5618" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460558980541_7300_3475" name="Anonym_Was">
            <ownedAttribute xmi:id="_16_5_4_940029b_1460558980541_29629_3476" name="artDerMassnahme" visibility="private" type="_16_5_4_8a30247_1408530590527_762740_2619">
              <ownedComment xmi:id="_16_5_4_940029b_1461160813890_302648_5870" body="&lt;para>In dieses Element ist einzutragen, von welcher grundsätzlichen Art (z. B. Errichtung oder Änderung) die  Maßnahmen im Rahmen des Bauvorhabens sind. &lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1460558980541_29629_3476"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460558980557_619579_3482" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460558980557_143966_3481" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460558980541_756691_3477" name="artDerBaulichenAnlage" visibility="private" type="_16_5_4_940029b_1475592596655_193877_6574">
              <ownedComment xmi:id="_16_5_4_940029b_1461160816719_662224_5871" body="&lt;para>Für den Gegenstand des Bauvorhabens wird hier die Art der baulichen Anlage näher spezifiziert. Außerdem werden technische Parameter des Vorhabens genannt.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1460558980541_756691_3477"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460559156638_60909_3560" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460559156638_687333_3559" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475593255419_293939_6943" name="bauvorhabenDatenblatt" visibility="private" type="_16_5_4_940029b_1476120195475_492410_6287">
              <ownedComment xmi:id="_16_5_4_940029b_1475593255419_119563_6946" body="&lt;para>Dieses Objekt bietet Felder für die Übermittlung von technischen Daten und Kennzahlen zum Bauvorhaben.&lt;/para>&#xA;&lt;para>Falls das Bauvorhaben eine Errichtung ist, beziehen sich alle aufgeführten Parameter des Datenblatts naturgemäß auf das projektierte Gesamtbauwerk.&lt;/para>&#xA;&lt;para>Falls das Bauvorhaben eine Änderung ist, ist abzuwägen, ob Daten in Bezug auf den Erweiterungsbau oder auf das Gesamtbauwerk anzugeben sind.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475593255419_293939_6943"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475593255419_798315_6947" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475593255419_639982_6945" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460559782420_922066_3743" name="Anonym_Wo">
            <ownedAttribute xmi:id="_16_5_4_940029b_1460559782420_968771_3744" name="baugrundstueck" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594">
              <ownedComment xmi:id="_16_5_4_940029b_1461160845396_901199_5877" body="&lt;para>In diesem Element sind Daten enthalten, die das Baugrundstück (ein Grundstück, auf dem das Vorhaben stattfinden soll bzw. auf dem es durchgeführt wurde) identifizieren. Ein Vorhaben kann mehrere Grundstücke betreffen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1460559782420_968771_3744"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460559858933_416512_3763" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460559858933_664444_3762" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460651189553_439942_3797" name="lageBauvorhaben" visibility="private" type="_16_5_4_940029b_1460651165974_293124_3777" aggregation="composite" association="_16_5_4_940029b_1460651189553_733771_3795">
              <ownedComment xmi:id="_16_5_4_940029b_1461160849283_962320_5878" body="&lt;para>In diesem Element sollen ergänzend georeferenzierte Informationen zur genaueren Lage des Bauvorhabens bzw. Gebäudes auf dem Baugrundstück abgebildet werden.&lt;/para>&#xA;&lt;para>Falls beispielsweise ein Umbau geplant ist und auf dem Grundstück mehrere Gebäude bestehen, muss aus diesen Angaben hervorgehen, was der Gegenstand des Anbaus ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1460651189553_439942_3797"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460651189553_994099_3800" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460651189553_356419_3799" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1460651189553_733771_3795" name="" memberEnd="_16_5_4_940029b_1460651189553_361952_3796 _16_5_4_940029b_1460651189553_439942_3797">
            <ownedEnd xmi:id="_16_5_4_940029b_1460651189553_361952_3796" name="" visibility="private" type="_16_5_4_940029b_1460559782420_922066_3743" association="_16_5_4_940029b_1460651189553_733771_3795"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460651165974_293124_3777" name="GeoreferenzierteLage">
            <ownedComment xmi:id="_16_5_4_940029b_1461160878182_666896_5884" body="&lt;para>In eine Instanz diesen Typs werden die Geodaten eines Vorhabens oder einer sonstigen Entität eintragen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1460651165974_293124_3777"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465269351210_845309_5051" name="flaeche" visibility="private" type="_16_5_4_940029b_1462299055656_708712_5047" aggregation="composite" association="_16_5_4_940029b_1465269351210_133361_5050">
              <ownedComment xmi:id="_16_5_4_940029b_1465270497478_461035_5532" body="&lt;para>In diesem Element lassen sich georeferenzierte Daten zu Bauvorhaben, Baulasten oder sonstigen Objekten übermitteln, also zu Gegenständen, die im Zusammenhang von XBau-Prozessen näher bestimmt werden sollen. Es  lassen sich hier z. B. die äußeren Kanten eines geplanten Gebäudes (Bauvorhaben) georeferenziert abbilden.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1465269351210_845309_5051"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465375574948_617106_5526" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465375574948_447007_5525" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460559782420_430828_3746" name="erlaeuterung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461160888499_448047_5886" body="&lt;para>Hier können ergänzend Erläuterungen zur Lage des Bauvorhabens (Vorhabens) auf dem Baugrundstück gegeben werden  (z. B. &quot;Anbau an Nordseite&quot;).&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1460559782420_430828_3746"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460560067276_69329_3775" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460560067276_796836_3774" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460560241523_867175_3826" name="Anlagen">
            <ownedComment xmi:id="_16_5_4_940029b_1461259171039_660685_5520" body="&lt;para>Dieser Typ dient dazu aufzunehmen: (a) in jedem Fall die Angaben (Metadaten) zu den Anlagen eines Antrags und (b) optional diese Anlagen (Primärdokumente) selbst. Anlagen zum Antrag sind in erster Linie Bauvorlagen, in vielen Fällen zusätzlich weitere Anlagen (wie Nachweise und ergänzende Dokumentationen).&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1460560241523_867175_3826"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460733760899_910997_4047" name="anlage" visibility="private" type="_16_5_4_8a30247_1408618910687_847379_2963" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461160810037_905663_5869" body="&lt;para>Jede Instanz dieses Elements steht für eine Anlage zum vorliegenden Antrag.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1460733760899_910997_4047"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460733760899_101516_4050" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460733760899_826458_4049" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1461084279278_496533_4827" name="Bauvorhaben">
            <ownedComment xmi:id="_16_5_4_940029b_1461160875809_931471_5883" body="&lt;para>Typ für die Daten eines Bauvorhabens, enthält Informationen zum Wer, Was und Wo des Bauvorhabens bzw. Vorhabens. Der Begriff 'Bauvorhaben' wird hier sehr weit gefasst, so dass auch Nutzungsänderungen ohne Baumaßnahmen abgedeckt sind. Der Typ wird in allen Nachrichten eingesetzt, in denen Eigenschaften eines Bauvorhabens (bzw. Vorhabens) anzugeben sind bzw. geprüft werden sollen. Er wird auch da eingesetzt, wo über ein Bauvorhaben (Vorhaben) oder über Maßnahmen im Zusammenhang eines Bauvorhabens (Vorhabens) zu informieren ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461084279278_496533_4827"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465272422051_162818_5562" name="bezeichnungDesBauvorhabens" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1465272422067_560947_5565" body="&lt;para>In dieses Element ist die Bezeichnung des Vorhabens einzutragen. Sie wird vom Bauherrn vergeben und später ggf. von der Bauaufsichtsbehörde geändert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465272422051_162818_5562"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465272422067_150034_5566" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465272422067_593755_5564" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461084360081_64878_4895" name="beteiligte" visibility="private" type="_16_5_4_940029b_1460554558325_844345_3559" aggregation="composite" association="_16_5_4_940029b_1461084360081_772823_4893">
              <ownedComment xmi:id="_16_5_4_940029b_1461160868556_215507_5882" body="&lt;para>Dieses Objekt steht für die am Bauvorhaben (Vorhaben) beteiligten Parteien (Personen und Organisationen).&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461084360081_64878_4895"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461084360081_356799_4898" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461084360081_977377_4897" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461084355950_986474_4887" name="gegenstand" visibility="private" type="_16_5_4_940029b_1460558980541_7300_3475" aggregation="composite" association="_16_5_4_940029b_1461084355950_158366_4885">
              <ownedComment xmi:id="_16_5_4_940029b_1461160865696_793817_5881" body="&lt;para>Dieser Abschnitt beschreibt, was der Gegenstand des Antrags ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461084355950_986474_4887"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461084355950_647401_4890" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461084355950_169353_4889" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461084352715_352666_4879" name="verortung" visibility="private" type="_16_5_4_940029b_1460559782420_922066_3743" aggregation="composite" association="_16_5_4_940029b_1461084352715_724467_4877">
              <ownedComment xmi:id="_16_5_4_940029b_1461160863411_495453_5880" body="&lt;para>Dieser Abschnitt beschäftigt sich mit der Lokalisierung des Vorhabens in relevanten Bezugssystemen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461084352715_352666_4879"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461084352715_174390_4882" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461084352715_15329_4881" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1461084360081_772823_4893" name="" memberEnd="_16_5_4_940029b_1461084360081_816834_4894 _16_5_4_940029b_1461084360081_64878_4895">
            <ownedEnd xmi:id="_16_5_4_940029b_1461084360081_816834_4894" name="" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" association="_16_5_4_940029b_1461084360081_772823_4893"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1461084352715_724467_4877" name="" memberEnd="_16_5_4_940029b_1461084352715_485776_4878 _16_5_4_940029b_1461084352715_352666_4879">
            <ownedEnd xmi:id="_16_5_4_940029b_1461084352715_485776_4878" name="" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" association="_16_5_4_940029b_1461084352715_724467_4877"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1461084355950_158366_4885" name="" memberEnd="_16_5_4_940029b_1461084355950_973076_4886 _16_5_4_940029b_1461084355950_986474_4887">
            <ownedEnd xmi:id="_16_5_4_940029b_1461084355950_973076_4886" name="" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" association="_16_5_4_940029b_1461084355950_158366_4885"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465269351210_133361_5050" name="" memberEnd="_16_5_4_940029b_1465269351210_590067_5052 _16_5_4_940029b_1465269351210_845309_5051">
            <ownedEnd xmi:id="_16_5_4_940029b_1465269351210_590067_5052" name="" visibility="private" type="_16_5_4_940029b_1460651165974_293124_3777" association="_16_5_4_940029b_1465269351210_133361_5050"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465319949338_111677_6242" name="Anonym_BerufNummer">
            <ownedComment xmi:id="_16_5_4_940029b_1465319949338_718197_6245" body="&#xA;" annotatedElement="_16_5_4_940029b_1465319949338_111677_6242"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465319467545_390342_6180" name="nummerEintragungsliste" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1465319467561_616051_6203" body="&lt;para>Hier ist die Nummer der Eintragungsliste der jeweiligen Kammer einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1465319467545_390342_6180"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483105030158_935680_5135" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483105030158_814261_5134" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465320233547_555419_6283" name="Anonym_Bauvorlageberechtigung">
            <ownedComment xmi:id="_16_5_4_940029b_1465320233563_422510_6288" body="" annotatedElement="_16_5_4_940029b_1465320233547_555419_6283"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465321337380_140631_6353" name="sachverhalt" visibility="private" type="_16_5_4_8a30247_1408526420047_574553_2278">
              <ownedComment xmi:id="_16_5_4_940029b_1465321337396_627951_6356" body="&lt;para>In diesem Element  ist zu kennzeichnen, aufgrund welchen Sachverhalts&#x9; der Entwurfsverfasser seine  Bauvorlageberechtigung innehat.&lt;/para>" annotatedElement="_16_5_4_940029b_1465321337380_140631_6353"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465321337396_370594_6357" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465321337396_127699_6355" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465320233547_302105_6285" name="kammer" visibility="private" type="_16_5_4_940029b_1465319949338_111677_6242">
              <ownedComment xmi:id="_16_5_4_940029b_1465320233563_384943_6291" body="&lt;para>Falls der Entwurfsverfasser seine Bauvorlageberechtigung als Architekt, Innenarchitekt oder Ingenieur innehat, ist dieses Element mit den Angaben aus der Zugehörigkeit zur entsprechenden Kammer zu füllen.&lt;/para>" annotatedElement="_16_5_4_940029b_1465320233547_302105_6285"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483105068731_999514_5138" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483105068731_47953_5137" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465368877212_444325_5428" name="Bezug">
            <ownedComment xmi:id="_16_5_4_940029b_1465369587050_970021_5510" body="&lt;para>Dieser Typ gestattet Eintragungen, um auf einen Vorgang (Geschäftsprozess) und ggf. auf eine Nachricht, die im Rahmen dieses Vorgangs gesendet worden ist, Bezug zu nehmen. &lt;/para>" annotatedElement="_16_5_4_940029b_1465368877212_444325_5428"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465369045932_696516_5487" name="vorgang" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1465369445636_190258_5508" body="&lt;para>Hier ist das Zeichen eines von der Bauaufsichtsbehörde geführten Vorgangs einzutragen, in dessen Kontext mit dieser Nachricht eine Aktion im Prozess durchgeführt wird. &lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465369045932_696516_5487"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465369058452_98569_5490" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465369058452_265785_5489" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465368962951_95865_5473" name="bezugNachricht" visibility="private" type="_16_5_4_940029b_1461085771571_78551_5204" aggregation="composite" association="_16_5_4_940029b_1465368962951_267124_5472">
              <ownedComment xmi:id="_16_5_4_940029b_1465369491950_429402_5509" body="&lt;para>Falls ein solcher Zusammenhang vorliegt, sind hier die Kennungen der Nachricht einzutragen, auf die sich diese Nachricht bezieht.&lt;/para>" annotatedElement="_16_5_4_940029b_1465368962951_95865_5473"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483344604197_502792_5298" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483344604197_808975_5297" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465368962951_267124_5472" name="" memberEnd="_16_5_4_940029b_1465368962951_915832_5474 _16_5_4_940029b_1465368962951_95865_5473">
            <ownedEnd xmi:id="_16_5_4_940029b_1465368962951_915832_5474" name="" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428" association="_16_5_4_940029b_1465368962951_267124_5472"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465389414760_979926_6071" name="BeteiligteBauprojektUmsetzung">
            <ownedComment xmi:id="_16_5_4_940029b_1465389414760_107104_6077" body="&lt;para>Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para>" annotatedElement="_16_5_4_940029b_1465389414760_979926_6071"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465389414760_258948_6073" name="bauherr" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1465389414760_844763_6080" body="&lt;para>Hier sind Angaben zur Person des  Bauherrn zu machen, falls diese nicht identisch ist mit dem Bauherrn, der den Bescheid zum Bauantrag erhalten hat.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465389414760_258948_6073"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465389573417_763503_6107" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465389573417_929380_6106" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465389414760_429445_6074" name="bauleiter" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1465389414760_699851_6084" body="&lt;para>Hier sind Angaben zur Person und ggf. Firma des Bauleiters zu machen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1465389414760_429445_6074"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465389541231_272512_6105" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465389541231_548859_6104" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465389414760_590_6075" name="bauunternehmer" visibility="private" type="_16_5_4_8a30247_1422977426041_172815_6757">
              <ownedComment xmi:id="_16_5_4_940029b_1465389414760_466876_6088" body="&lt;para>Als Bauunternehmer ist der Rohbau-Unternehmer einzutragen, benötigt wird die Firma mit Ansprechpartner.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1465389414760_590_6075"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465389414760_816775_6089" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465389414760_668981_6087" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465389414760_954276_6076" name="fachbauleiter" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1465389414760_194241_6092" body="&lt;para>Hier sind ggf. die Fachbauleiter zu nennen, die auf einzelnen Teilgebieten an die Stelle des Bauleiters treten.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1465389414760_954276_6076"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465389528640_404082_6103" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465389528640_341362_6102" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467842445378_570661_5400" name="Anonym_BefundFormell">
            <ownedComment xmi:id="_16_5_4_940029b_1467842445394_510974_5406" body="" annotatedElement="_16_5_4_940029b_1467842445378_570661_5400"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842445378_959445_5402" name="artDesBefundes" visibility="private" type="_16_5_4_940029b_1467878653841_502297_5169">
              <ownedComment xmi:id="_16_5_4_940029b_1467842445394_187112_5409" body="&lt;para>In diesem Element wird die Befundkategorie angegeben, der dieser Befund zugeordnet werden kann.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467842445378_959445_5402"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467879824604_329319_5562" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467879824604_405201_5561" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842445394_688125_5403" name="refAnlage" visibility="private" type="_16_5_4_940029b_1467842624105_925789_5453">
              <ownedComment xmi:id="_16_5_4_940029b_1467842445394_286618_5413" body="&lt;para>Für Befunde, die sich auf eine eingereichte Bauvorlage bzw. eine sonstige Anlage zum Antrag beziehen, wird in diesem Objekt der Bezug hergestellt.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1467842445394_688125_5403"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467842998545_132167_5559" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467842998545_917651_5558" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842977089_248652_5552" name="betroffeneAnlage" visibility="private" type="_16_5_4_8a30247_1408530241706_68973_2543" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467879267029_945752_5558" body="&lt;para>Für Befunde, die Mängel an einer eingereichten Bauvorlage oder das Fehlen einer Bauvorlage (einer bestimmten Art) betreffen, wird in diesem Element die Art dieser Bauvorlage angegeben (die den Mangel hat bzw. die nachzureichen ist).&lt;/para>" annotatedElement="_16_5_4_940029b_1467842977089_248652_5552"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467842989812_115219_5557" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467842989812_77180_5556" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467843013793_549083_5560" name="beschreibung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467843013793_631994_5563" body="&lt;para>Hier wird der Sachverhalt des Befundes beschrieben. Dieser Sachverhalt ist eine detialliertere Darstellung im Rahmen der parallel angegebenen Art des Befundes.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467843013793_549083_5560"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467843013793_784635_5564" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467843013793_252774_5562" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467842624105_925789_5453" name="RefAnlage">
            <ownedComment xmi:id="_16_5_4_940029b_1469955948657_527861_6074" body="&lt;para>Typ für die Bezugnahme auf Bestandteile eines Antrags oder eines Auftrags. Dieser Typ wird im Kontext einer formellen Prüfung eingesetzt.&lt;/para>" annotatedElement="_16_5_4_940029b_1467842624105_925789_5453"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842761727_594467_5522" name="art" visibility="private" type="_16_5_4_8a30247_1408530241706_68973_2543" aggregation="composite" association="_16_5_4_940029b_1467842761727_550967_5520">
              <ownedComment xmi:id="_16_5_4_940029b_1467879371270_198765_5559" body="&lt;para>Hier wird die Art der referenzierten  Bauvorlage oder sonstigen Anlage zum vorliegenden Antrag genannt.&lt;/para>" annotatedElement="_16_5_4_940029b_1467842761727_594467_5522"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467842761727_217530_5525" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467842761727_440391_5524" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842810328_89873_5526" name="bezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467842810328_81868_5529" body="&lt;para>Hier wird die Bezeichnung der referenziereten  Bauvorlage angegeben.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467842810328_89873_5526"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467842810328_997862_5530" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467842810328_297523_5528" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842875383_95114_5542" name="versionsnummer" visibility="private">
              <ownedComment xmi:id="_16_5_4_940029b_1467842875383_23903_5545" body="&lt;para>Hier ist die Versionsnummer der referenzierten Bauvorlage einzutragen. &lt;/para>" annotatedElement="_16_5_4_940029b_1467842875383_95114_5542"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469736063910_705855_5763" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469736063910_76784_5762" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1467842761727_550967_5520" name="" memberEnd="_16_5_4_940029b_1467842761727_876377_5521 _16_5_4_940029b_1467842761727_594467_5522">
            <ownedEnd xmi:id="_16_5_4_940029b_1467842761727_876377_5521" name="" visibility="private" type="_16_5_4_940029b_1467842624105_925789_5453" association="_16_5_4_940029b_1467842761727_550967_5520"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467843232886_870322_5578" name="BefundlisteFormell">
            <ownedComment xmi:id="_16_5_4_940029b_1468226410169_570540_5568" body="&lt;para>Dieser Typ beinhaltet die Befunde der formellen Prüfung eines Antrags oder einer Anfrage. Für jeden Befund sind die entsprechenden Parameter gefüllt, die Inhalt und Bezug des Befundes für den Antragsteller bzw. Anfragenden nachvollziehbar machen.&lt;/para>" annotatedElement="_16_5_4_940029b_1467843232886_870322_5578"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467843283923_737799_5635" name="befund" visibility="private" type="_16_5_4_940029b_1467842445378_570661_5400" aggregation="composite" association="_16_5_4_940029b_1467843283923_190241_5633">
              <ownedComment xmi:id="_16_5_4_940029b_1467879574842_759782_5560" body="&lt;para>Dieses Element stellt genau einen Befund der Befundliste dar.&lt;/para>" annotatedElement="_16_5_4_940029b_1467843283923_737799_5635"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467843315561_39694_5643" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467843315561_553642_5642" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1467843283923_190241_5633" name="" memberEnd="_16_5_4_940029b_1467843283923_268709_5634 _16_5_4_940029b_1467843283923_737799_5635">
            <ownedEnd xmi:id="_16_5_4_940029b_1467843283923_268709_5634" name="" visibility="private" type="_16_5_4_940029b_1467843232886_870322_5578" association="_16_5_4_940029b_1467843283923_190241_5633"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467880682692_826535_5579" name="Anonym_BelastenderVerwaltungsaktGrund">
            <ownedComment xmi:id="_16_5_4_940029b_1467881357405_42046_5676" body="" annotatedElement="_16_5_4_940029b_1467880682692_826535_5579"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467880682692_48585_5580" name="rechtsbereich" visibility="private" type="_16_5_4_940029b_1467881020760_671045_5646" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467880682692_666174_5586" body="&lt;para>Dieses Element nennt den  Rechtsbereich, innerhalb dessen der belastende Verwaltungsakt liegt. &lt;/para>" annotatedElement="_16_5_4_940029b_1467880682692_48585_5580"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467880682692_346347_5587" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467880682692_305102_5585" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467880682692_589206_5581" name="bezeichnungRegelverstoss" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467880682692_82739_5590" body="&lt;para>Hier wird die Bezeichnung des betreffenden Regelverstoßes genannt.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467880682692_589206_5581"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467880682692_430865_5591" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467880682692_683190_5589" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467880748142_983290_5609" name="begruendung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467880748142_338809_5612" body="&lt;para>Hier wird begründet, inwiefern es sich um einen Regelverstoß handelt.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467880748142_983290_5609"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467880748142_40326_5613" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467880748142_217668_5611" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467881984463_299931_5687" name="BefundlisteMateriell">
            <ownedComment xmi:id="_16_5_4_940029b_1468226644882_844054_5570" body="&lt;para>Eine Instanz diesen Typs steht für eine Befundliste der materiellen Prüfung eines Antrags. Jeder Befund beinhaltet die Parameter, die einen  belastenden Verwaltungsakt im Kontext eines Baugenehmigungsvorgangs definieren. &lt;/para>" annotatedElement="_16_5_4_940029b_1467881984463_299931_5687"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467881984463_587315_5688" name="befund" visibility="private" type="_16_5_4_940029b_1467880682692_826535_5579" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467881984463_458327_5691" body="&lt;para>Jedes Element steht für einen  belastenden Verwaltungsakt im Kontext des aktuellen Baugenehmigungsvorgang, zu dem der Adressat der Nachricht zu einer Stellungnahme aufgefordert ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1467881984463_587315_5688"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467881984463_448132_5692" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467881984463_739099_5690" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467883282532_109433_5716" name="StellungnahmeBelastenderVerwaltungsakt">
            <ownedComment xmi:id="_16_5_4_940029b_1467883282532_537740_5721" body="&lt;para>Dieser Typ nimmt die Parameter einer Stellungnahme auf, mit der sich ein Antragsteller zu einem  belastenden Verwaltungsakt äußert. &lt;/para>" annotatedElement="_16_5_4_940029b_1467883282532_109433_5716"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467883282532_133376_5719" name="bezeichnungRegelverstoss" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467883282532_906231_5728" body="&lt;para>Hier ist die Bezeichnung des betreffenden Regelverstoßes genannt.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467883282532_133376_5719"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467883282532_64852_5729" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467883282532_202732_5727" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467883282532_277358_5720" name="stellungnahme" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467883282532_265671_5732" body="&lt;para>Dieses Element enthält die Stellungnahme des Antragsstellers. Sie nimmt auf die Beanstandung Bezug.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467883282532_277358_5720"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467883282532_214318_5733" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467883282532_982774_5731" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467895898882_574009_5195" name="Text">
            <ownedComment xmi:id="_16_5_4_940029b_1467895898898_77167_5201" body="&lt;para>Diese Typ nimmt Absätze eines Textes auf. &lt;/para>" annotatedElement="_16_5_4_940029b_1467895898882_574009_5195"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467895898898_759179_5200" name="textabsatz" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467895898898_31456_5216" body="&lt;para>Pro Element wird Text im Umfang eines Absatzes (Freitext) festgehalten.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467895898898_759179_5200"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467895922892_21641_5227" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467895922892_177470_5226" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467896012971_615347_5228" name="Bescheid">
            <ownedComment xmi:id="_16_5_4_940029b_1467896012971_191572_5234" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Bescheides, den die Bauaufsichtsbehörde nach Prüfung eines Antrags erlässt.&lt;/para>" annotatedElement="_16_5_4_940029b_1467896012971_615347_5228"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467896012971_594522_5233" name="tenor" visibility="private" type="_16_5_4_940029b_1467896417302_199580_5413">
              <ownedComment xmi:id="_16_5_4_940029b_1467896012971_670740_5249" body="&lt;para>Hier wird der Bescheid formuliert. Es handelt sich entweder um eine Genehmigung oder um eine Ablehnung.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467896012971_594522_5233"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467896012971_939024_5250" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467896012971_801434_5248" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467896012971_435561_5230" name="begruendung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467896012971_530169_5237" body="&lt;para>Falls der Bescheid ablehnend ausgefallen ist, wird in diesem Element die entsprechende Begründung geliefert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467896012971_435561_5230"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467897591079_715941_5614" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467897591079_903715_5613" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467896136333_818342_5259" name="rechtshelfsbelehrung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467896136333_431643_5262" body="&lt;para>Hier werden die Rechtshelfsbelehrungen zum Bescheid gegeben.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467896136333_818342_5259"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467896136333_692886_5263" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467896136333_549461_5261" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467896136646_712173_5266" name="hinweise" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467896136646_733530_5269" body="&lt;para>Hier werden ggf. ergänzende Hinweise zum Bescheid gegeben.&lt;/para>" annotatedElement="_16_5_4_940029b_1467896136646_712173_5266"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899223525_211272_5766" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899223525_940531_5765" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467899754926_723683_5816" name="abweichung" visibility="private" type="_16_5_4_940029b_1467898745212_460254_5732">
              <ownedComment xmi:id="_16_5_4_940029b_1467899754926_689793_5819" body="&lt;para>Hier werden ggf. die Erläuterungen zur Genehmigung einer beantragten Abweichung eingetragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1467899754926_723683_5816"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899779273_568933_5824" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899779273_940020_5823" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467900508054_878418_5896" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467899960094_58945_5827">
              <ownedComment xmi:id="_16_5_4_940029b_1467900508054_419827_5899" body="&lt;para>Hier werden ggf. die Nebenbestimmungen zum Bescheid eingefügt.&lt;/para>" annotatedElement="_16_5_4_940029b_1467900508054_878418_5896"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467900508054_459410_5900" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467900508054_904728_5898" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467896417302_199580_5413" name="Anonym_Tenor">
            <ownedComment xmi:id="_16_5_4_940029b_1467896417302_79764_5416" body="&#xA;" annotatedElement="_16_5_4_940029b_1467896417302_199580_5413"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1483174208250_220105_4993" name="istGenehmigung" visibility="private" aggregation="composite" association="_16_5_4_940029b_1483174208250_292936_4991">
              <ownedComment xmi:id="_16_5_4_940029b_1483174208250_221227_4996" body="&lt;para>Falls der Tenor positiv  ist (Genehmigung), so ist in diesem Element &quot;true&quot; zu übermitteln, andernfalls (Ablehnung) &quot;false&quot;.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1483174208250_220105_4993"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483174208250_449384_4997" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483174208250_865470_4995" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1483173944143_754493_4933" name="kommentareFachrecht" visibility="private" type="_16_5_4_940029b_1467898080791_611578_5629" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1483173944143_103892_4936" body="&lt;para>Unterhalb dieses Elements sind - falls solche vorliegen - zur Information die Kommentare bzw. Bewertungen aus den beteiligten Stellen nach Fachrecht festgehalten. Sie sind im Verfahren der Bauaufsichtsbehörde berücksichtigt worden, das zum vorliegenden Bescheid geführt hat. &lt;/para>" annotatedElement="_16_5_4_940029b_1483173944143_754493_4933"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483173944143_191489_4937" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483173944143_168734_4935" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467898080791_611578_5629" name="Anonym_KommentierungFachrecht">
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898254675_357693_5716" name="kommentarFachrecht" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195" aggregation="composite" association="_16_5_4_940029b_1467898254675_471068_5714">
              <ownedComment xmi:id="_16_5_4_940029b_1467898465801_34247_5731" body="&lt;para>Pro Kommentar aus einem Fachbereich ist ein eigenes Element (welches mehrere Absätze Text enthalten kann) zu füllen. &lt;/para>" annotatedElement="_16_5_4_940029b_1467898254675_357693_5716"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483174387356_701124_5003" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483174387356_16671_5002" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1467898254675_471068_5714" name="" memberEnd="_16_5_4_940029b_1467898254675_242691_5715 _16_5_4_940029b_1467898254675_357693_5716">
            <ownedEnd xmi:id="_16_5_4_940029b_1467898254675_242691_5715" name="" visibility="private" type="_16_5_4_940029b_1467898080791_611578_5629" association="_16_5_4_940029b_1467898254675_471068_5714"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467898745212_460254_5732" name="AbweichungBearbeitet">
            <ownedComment xmi:id="_16_5_4_940029b_1467898745212_139877_5738" body="&lt;para>Falls die Abweichung eines Bauvorhabens von öffentlich-rechtlichen Bestimmungen bearbeitet (und damit zugelassen bzw. nicht zugelassen) wurde, dient dieser Typ im entsprechenden Kontext zur Übermittlung der relevanten Parameter.&lt;/para>" annotatedElement="_16_5_4_940029b_1467898745212_460254_5732"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477414923667_692142_4874" name="istZugelassen" visibility="private">
              <ownedComment xmi:id="_16_5_4_940029b_1477414923667_568641_4877" body="&lt;para>Falls die beantragte Abweichung zugelassen wurde, ist hier 'true' einzutragen, andernfalls 'false'.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1477414923667_692142_4874"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477414923667_762298_4878" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477414923667_925184_4876" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898745212_618349_5734" name="art" visibility="private" type="_16_5_4_940029b_1467899588074_956585_5786">
              <ownedComment xmi:id="_16_5_4_940029b_1467898745212_715109_5741" body="&lt;para>Hier ist einzutragen, als welche Art von Abweichung die beantragte Abweichung einzustufen ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467898745212_618349_5734"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467898745212_622775_5742" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467898745212_603681_5740" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898745212_176599_5736" name="vorschrift" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467898745212_771422_5749" body="&lt;para>Vorschrift der materiellen Anforderung: Hier sind Referenzen auf die Rechtsnormen einzutragen, auf die sich die bearbeitete Abweichung bezieht.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467898745212_176599_5736"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467898745212_805833_5750" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467898745212_422605_5748" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898745212_921510_5735" name="begruendung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467898745212_467326_5745" body="&lt;para>In diesem Element wird begründet, warum die Abweichung zugelassen bzw. nicht zugelassen wurde.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467898745212_921510_5735"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477413999548_8273_4858" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477413999548_483262_4857" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898745212_501005_5737" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467898745212_376704_5753" body="&lt;para>Hier werden für den Fall der Zulassung der beantragten Abweichungen ggf. Nebenbestimmungen formuliert, deren Einhaltung die Bauaufsichtsbehörde zur Bedingung für die Zulassung gemacht hat.&lt;/para>" annotatedElement="_16_5_4_940029b_1467898745212_501005_5737"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477414285029_975590_4862" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477414285029_329768_4861" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467899960094_58945_5827" name="Nebenbestimmung">
            <ownedComment xmi:id="_16_5_4_940029b_1467899960094_268144_5832" body="&lt;para>Dieser Typ beinhaltet die Parameter, die eine Nebenbestimmung definieren. &lt;/para>" annotatedElement="_16_5_4_940029b_1467899960094_58945_5827"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467899960094_859221_5830" name="art" visibility="private" type="_16_5_4_940029b_1467900180389_963351_5866">
              <ownedComment xmi:id="_16_5_4_940029b_1467899960094_37751_5839" body="&lt;para>Hier wird die Art genannt, von der die erlassene Nebenbestimmung ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467899960094_859221_5830"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899960094_379143_5840" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899960094_874529_5838" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467899960094_262689_5829" name="rechtsbereich" visibility="private" type="_16_5_4_940029b_1467881020760_671045_5646" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467899960094_429933_5835" body="&lt;para>Dieses Element nennt den  Rechtsbereich, innerhalb dessen die Nebenbestimmung erlassen ist. &lt;/para>" annotatedElement="_16_5_4_940029b_1467899960094_262689_5829"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899960094_314099_5836" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899960094_335460_5834" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467899960094_603922_5831" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1467899960094_68030_5843" body="&lt;para>Hier wird die Nebenbestimmung formuliert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1467899960094_603922_5831"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899960094_876462_5844" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899960094_676513_5842" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1468095951196_331249_5557" name="AbweichungBeantragt">
            <ownedComment xmi:id="_16_5_4_940029b_1468095951200_292499_5563" body="&lt;para>Dieser Typ beinhaltet die Parameter einer Abweichung von öffentlich-rechtlichen Bestimmungen, die der Bauaufsichtsbehörde zur Zulassung vorgelegt wird.&lt;/para>" annotatedElement="_16_5_4_940029b_1468095951196_331249_5557"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468095951196_464435_5559" name="art" visibility="private" type="_16_5_4_940029b_1467899588074_956585_5786">
              <ownedComment xmi:id="_16_5_4_940029b_1468095951200_502251_5566" body="&lt;para>Hier ist einzutragen, als welche Art von Abweichung die beantragte Abweichung einzustufen ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468095951196_464435_5559"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468095951200_970357_5567" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468095951200_711068_5565" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477414687178_700359_4863" name="vorschrift" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1477414687178_93340_4866" body="&lt;para>In diesem Element ist die Vorschrift der materiellen Anforderung zu bezeichnen: Es sind Referenzen auf die Rechtsnormen einzutragen, auf die sich die bearbeitete Abweichung bezieht.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1477414687178_700359_4863"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477414687178_372032_4867" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477414687178_842513_4865" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468095951196_511790_5560" name="beschreibung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1468095951200_497666_5570" body="&lt;para>In diesen Objekt ist der Abweichungsgegenstand im Detail zu erläutern.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468095951196_511790_5560"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468095951200_873398_5571" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468095951200_187319_5569" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468095951200_819943_5561" name="begruendung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1468095951200_681462_5574" body="&lt;para>In diesem Element ist zur beantragten Abweichung eine Erläuterung zu geben, warum die beantragte Zulassung aus Sicht des Antragstellers gerechtfertigt ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468095951200_819943_5561"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468095951200_177256_5575" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468095951200_590143_5573" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1468234354477_21931_5653" name="VorbescheidBeantragt">
            <ownedComment xmi:id="_16_5_4_940029b_1468234354477_785240_5658" body="&lt;para>Dieser Typ beinhaltet die Parameter einer Frage, die im Rahmen eines Vorbescheidantrags thematisiert wird. Insoweit diese Frage einen Abweichungsantrag bzw. eine beantragte Erleichterung betrifft, sind in einer Instanz des Typs Daten enthalten, die den entsprechenden Kontext verdeutlichen.&lt;/para>" annotatedElement="_16_5_4_940029b_1468234354477_21931_5653"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234354477_312707_5655" name="artDerFrage" visibility="private" type="_16_5_4_940029b_1468234098881_686844_5623">
              <ownedComment xmi:id="_16_5_4_940029b_1468234354477_17954_5661" body="&lt;para>Hier ist einzutragen, in welche Kategorie die im Rahmen des Vorbescheidantrags thematisierte Fragestellung einzuordnen ist. &lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468234354477_312707_5655"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468234354477_97916_5662" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468234354477_794779_5660" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468235962721_846336_5792" name="vorbescheidfrage" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1468235962721_637394_5797" body="&lt;para>Beschreibung der Fragestellung(en) im Rahmen eines Vorbescheids&lt;/para>" annotatedElement="_16_5_4_940029b_1468235962721_846336_5792"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469644175736_637697_5676" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469644175736_402589_5675" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234506946_62529_5679" name="beantragteAbweichung" visibility="private" type="_16_5_4_940029b_1468095951196_331249_5557" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1468234506962_947930_5682" body="&lt;para>Hier sind die Daten zu einer möglichen Abweichung eingefügt, falls die Vorbescheidfrage eine solche betrifft.&lt;/para>" annotatedElement="_16_5_4_940029b_1468234506946_62529_5679"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468236044140_731193_5814" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468236044140_711048_5813" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468235962721_471439_5794" name="angefragteErleichterung" visibility="private" type="_16_5_4_940029b_1468234557055_465841_5686" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1468235962721_72284_5805" body="&lt;para>Hier sind die Daten zu einer möglichen Erleichterung eingefügt, falls die Vorbescheidfrage eine solche betrifft.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1468235962721_471439_5794"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468235962721_248033_5806" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468235962721_24417_5804" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1468234557055_465841_5686" name="ErleichterungAngefragt">
            <ownedComment xmi:id="_16_5_4_940029b_1468234557055_443329_5691" body="&lt;para>Dieser Typ beinhaltet die Parameter einer beantragten Erleichterung, die der Bauaufsichtsbehörde zur Genehmigung vorgelegt werden soll.&lt;/para>" annotatedElement="_16_5_4_940029b_1468234557055_465841_5686"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234557055_894333_5688" name="gegenstand" visibility="private" type="_16_5_4_940029b_1483376802440_144041_4921">
              <ownedComment xmi:id="_16_5_4_940029b_1468234557055_701697_5694" body="&lt;para>Hier wird angezeigt, auf welchen Aspekt des Bauvorhabens sich die beantragte Erleichterung bezieht.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468234557055_894333_5688"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468234557055_986832_5695" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468234557055_396465_5693" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234557055_464140_5689" name="beschreibung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1468234557055_629887_5698" body="&lt;para>Hier ist der Erleichterungsgegenstand zu konkretisieren. Es wird im Detail verdeutlicht, worum es bei dem Anliegen geht).&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468234557055_464140_5689"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468234557055_661634_5699" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468234557055_7751_5697" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234557055_407548_5690" name="begruendung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1468234557055_556565_5702" body="&lt;para>In diesem Element wird ggf. eine Begründung zur beantragten Erleichterung gegeben, d.h. es wird erläutert, warum die beantragte Erleichterung benötigt wird bzw. gerechtfertigt ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1468234557055_407548_5690"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468235448925_329059_5764" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468235448925_27700_5763" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475588555524_74161_6543" name="Anonym_VorlageArt">
            <ownedComment xmi:id="_16_5_4_940029b_1475588555540_819428_6549" body="" annotatedElement="_16_5_4_940029b_1475588555524_74161_6543"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475588555524_228815_6545" name="vorlageBauvorhaben" visibility="private" type="_16_5_4_940029b_1475588088450_490142_6509">
              <ownedComment xmi:id="_16_5_4_940029b_1475588555540_512182_6552" body="&lt;para>Für Anlagen zu einem Antrag oder einer Anzeige, die zur Beurteilung des Bauvorhabens (Vorhabens) dienen, wird hier die Art der Vorlage (bzw. Anlage) genannt.&lt;/para>" annotatedElement="_16_5_4_940029b_1475588555524_228815_6545"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475588555540_909626_6553" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475588555540_475865_6551" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475588555540_640277_6546" name="vorlageBauantragBearbeitung" visibility="private" type="_16_5_4_8a30247_1408530241706_68973_2543">
              <ownedComment xmi:id="_16_5_4_940029b_1475588555540_467309_6556" body="&lt;para>Für sonstige Anlagen, die zur Bearbeitung des Bauantrags notwendig sind (sich also nicht auf das Bauvorhaben beziehen), wird hier die Art der Vorlage (bzw. Anlage) genannt.&lt;/para>" annotatedElement="_16_5_4_940029b_1475588555540_640277_6546"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475588555540_554659_6557" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475588555540_727705_6555" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475588555540_568318_6547" name="vorlageBauzustand" visibility="private" type="_16_5_4_940029b_1475159895898_998624_6483">
              <ownedComment xmi:id="_16_5_4_940029b_1475588555540_750002_6560" body="&lt;para>Für Bauvorlagen, deren Zweck ist,  die Anzeige eines Bauzustands zu belegen, wird hier die Art der Vorlage genannt.&lt;/para>" annotatedElement="_16_5_4_940029b_1475588555540_568318_6547"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475588555540_138725_6561" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475588555540_278164_6559" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475592596655_193877_6574" name="Anonym_ArtDerBaulichenAnlage">
            <ownedAttribute xmi:id="_16_5_4_940029b_1475592596655_291999_6576" name="artDesGebaeudes" visibility="private" type="_16_5_4_940029b_1475164426407_736819_6878">
              <ownedComment xmi:id="_16_5_4_940029b_1475592596655_383269_6585" body="&lt;para>Hier wird für bauliche Anlagen, die Gebäude sind, eine Klassifizierung vorgenommen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1475592596655_291999_6576"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475592596655_958121_6586" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475592596655_323750_6584" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475592596655_616097_6577" name="artDerSonstigenAnlage" visibility="private" type="_16_5_4_940029b_1478973756024_756938_5136">
              <ownedComment xmi:id="_16_5_4_940029b_1475592596655_601256_6589" body="&lt;para>Hier ist für sonstige bauliche Anlagen, also solche, die nicht Gebäude sind, eine Klassifizierung vorzunehmen.&lt;/para>" annotatedElement="_16_5_4_940029b_1475592596655_616097_6577"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475592596655_59344_6590" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475592596655_823356_6588" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477944131500_703757_4834" name="artNichtAufgefuehrt" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1477944131500_391176_4837" body="&lt;para>Falls die Codelisten der anderen Elemente die Art der baulichen Anlage des Vorhabens nicht kennzeichnen können (und nur dann), ist hier die Angabe als Freitext einzutragen. &lt;/para>" annotatedElement="_16_5_4_940029b_1477944131500_703757_4834"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483378041247_400288_4949" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483378041247_747258_4948" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1477928375350_829581_4792" name="BefundlistePruefungBauzustand">
            <ownedComment xmi:id="_16_5_4_940029b_1477928375379_528002_4795" body="&lt;para>Eine Instanz diesen Typs steht für eine Befundliste der materiellen Prüfung eines Antrags. Jeder Befund beinhaltet die Parameter, die einen  belastenden Verwaltungsakt im Kontext eines Baugenehmigungsvorgangs definieren. &lt;/para>" annotatedElement="_16_5_4_940029b_1477928375350_829581_4792"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477928375379_682741_4794" name="befund" visibility="private" type="_16_5_4_940029b_1477928417510_526532_4802" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1477928375379_488596_4798" body="&lt;para>Jedes Element steht für einen  belastenden Verwaltungsakt im Kontext des aktuellen Baugenehmigungsvorgang, zu dem der Adressat der Nachricht zu einer Stellungnahme aufgefordert ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1477928375379_682741_4794"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477928375379_4901_4799" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477928375379_134966_4797" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1477928417510_526532_4802" name="Anonym_BefundPruefungBauzustand">
            <ownedComment xmi:id="_16_5_4_940029b_1477928417510_98460_4806" body="" annotatedElement="_16_5_4_940029b_1477928417510_526532_4802"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477928417510_622788_4804" name="beschreibung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1477928417510_824193_4813" body="&lt;para>Hier wird der festgestellt Mangel beschrieben.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1477928417510_622788_4804"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477928417510_34072_4814" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477928417510_998881_4812" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477928417510_722577_4805" name="verweise" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
              <ownedComment xmi:id="_16_5_4_940029b_1477928417510_165732_4817" body="&lt;para>Hier kann ein Verweis auf eine Nebenbestimmung der Baugenehmigung eingefügt werden, oder auf z. B. den Prüfbericht Standsicherheit oder Brandschutz.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1477928417510_722577_4805"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477928647430_413581_4828" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477928647430_91777_4827" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477928417510_709191_4803" name="rechtsbereich" visibility="private" type="_16_5_4_940029b_1467881020760_671045_5646" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1477928417510_961772_4809" body="&lt;para>Dieses Element nennt (falls zutreffend) den  Rechtsbereich, innerhalb dessen die Bestimmung liegt, gegen die im Kontext des Befundes verstoßen wurde. &lt;/para>" annotatedElement="_16_5_4_940029b_1477928417510_709191_4803"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477928451695_986504_4826" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477928451695_571477_4825" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1483174208250_292936_4991" name="" memberEnd="_16_5_4_940029b_1483174208250_476558_4992 _16_5_4_940029b_1483174208250_220105_4993">
            <ownedEnd xmi:id="_16_5_4_940029b_1483174208250_476558_4992" name="" visibility="private" type="_16_5_4_940029b_1467896417302_199580_5413" association="_16_5_4_940029b_1483174208250_292936_4991"/>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1462266604624_778766_8289" name="" supplier="_16_5_4_5b501fb_1387625256714_228692_1513" client="_16_5_4_1d100e5_1384794877872_302539_331"/>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1462299055656_708712_5047" name="Anonym_Geometrie">
          <ownedAttribute xmi:id="_16_5_4_940029b_1465269124067_598733_5018" name="" visibility="private" type="_16_5_4_5b501fb_1387625256936_106257_2159" aggregation="composite" association="_16_5_4_940029b_1465269124036_718978_5016">
            <ownedComment xmi:id="_16_5_4_940029b_1465270668196_604854_5535" body="&lt;para>Das Element (globales Element gml:Polygon) enthält die GML-Darstellung einer Grundfläche (es können Außenkanten und Innenkanten dargestellt werden).&lt;/para>&#xA;&lt;para>Aus der GML-Dokumentation: &quot;A Polygon is a special surface that is defined by a single surface patch. The boundary of this patch is coplanar and the polygon uses planar interpolation in its interior. The elements exterior and interior describe the surface boundary of the polygon.&quot; Quelle: &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&quot;>http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&lt;/link>  &lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1465269124067_598733_5018"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465269124067_248877_5021" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465269124067_392495_5020" name="" value="1"/>
          </ownedAttribute>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465269124036_718978_5016" name="" memberEnd="_16_5_4_940029b_1465269124067_795564_5017 _16_5_4_940029b_1465269124067_598733_5018">
          <ownedComment xmi:id="_16_5_4_940029b_1465540439858_361794_5449" body="&lt;para>Doku an der Assoziation zum globalen Element Polygon.&lt;/para>" annotatedElement="_16_5_4_940029b_1465269124036_718978_5016"/>
          <ownedEnd xmi:id="_16_5_4_940029b_1465269124067_795564_5017" name="" visibility="private" type="_16_5_4_940029b_1462299055656_708712_5047" association="_16_5_4_940029b_1465269124036_718978_5016"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465320433717_376869_6328" name="" memberEnd="_16_5_4_940029b_1465320433717_718640_6329 _16_5_4_940029b_1465320433717_159041_6330">
          <ownedEnd xmi:id="_16_5_4_940029b_1465320433717_718640_6329" name="" visibility="private" type="_16_5_4_8a30247_1408705895800_629557_4010" association="_16_5_4_940029b_1465320433717_376869_6328"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1408703057450_27821_3423" name="Akteur">
          <ownedComment xmi:id="_16_5_4_8a30247_1408706838747_261394_4377" body="&lt;para>Durch den Typ Akteur wird eine Differenzierung zwischen  natürlichen Einzelpersonen, Personengruppen und juristischen Personen definiert.&lt;/para>&#xA;&lt;para>Im Namen einer Firma handelt eine natürliche Person als Vertreter. Bei mehreren Personen (z.B. Eigentümergemeinschaften) wird jede Person (juristisch oder nätürlich) als Akteur definiert. Eine Person dieser Gruppe kann als Vertreter definiert werden.&lt;/para>" annotatedElement="_16_5_4_8a30247_1408703057450_27821_3423"/>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1422977828419_207131_7447" name="organisation" visibility="private" type="_16_5_4_8a30247_1422977426041_172815_6757" aggregation="composite" association="_16_5_4_8a30247_1422977828419_100798_7445">
            <ownedComment xmi:id="_16_5_4_8a30247_1422977828419_864327_7450" body="[nd]" annotatedElement="_16_5_4_8a30247_1422977828419_207131_7447"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977828419_252084_7451" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977828419_180743_7449" name=""/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_940029b_1460622920874_103982_4471" name="natuerlichePerson" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517" aggregation="composite" association="_16_5_4_940029b_1460622920874_846896_4469">
            <ownedComment xmi:id="_16_5_4_940029b_1460622920874_478403_4474" body="[nd]" annotatedElement="_16_5_4_940029b_1460622920874_103982_4471"/>
