                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291321_471205_6117" body="Hier kann angegeben werden, welche Sprachen eine natürliche Person als Fremdsprache beherrscht." annotatedElement="_16_5_4_5b501fb_1387625291121_629376_5228"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291321_698076_6118" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_608193_5164" association="_16_5_4_5b501fb_1387625291121_629376_5228"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291121_573057_5229" name="" memberEnd="_16_5_4_5b501fb_1387625291321_220743_6121 _16_5_4_5b501fb_1387625291280_282115_5857">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291321_348395_6120" body="Die &quot;identifikation&quot; einer &quot;Organisation&quot; fasst alle Elemente zusammen, die eine Organisation in einem fachlichen Kontext eindeutig unter anderen Organisationen identifiziert. &#xA;&#xA;" annotatedElement="_16_5_4_5b501fb_1387625291121_573057_5229"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291321_220743_6121" name="" visibility="private" type="_16_5_4_5b501fb_1387625291114_133591_5178" association="_16_5_4_5b501fb_1387625291121_573057_5229"/>
