                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351737_49934_2632" body="Die Komponente &quot;geokodierung&quot; beinhaltet Information zur geografischen Bestimmung einer Anschrift." annotatedElement="_16_5_4_5b501fb_1389522351520_465199_1751"/>
