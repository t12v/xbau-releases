          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1431428108514_93970_3186" name="TeilbekanntesDatumMitUnbekannt">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1431429234421_76217_3261" body="&lt;para>Mit diesem Datentyp wird in der Regel ein teilbekanntes Datum übermittelt. Ist das Datum nicht einmal teilweise bekannt, wird stattdessen &lt;code>true&lt;/code> in dem Kindelement &lt;code>unbekannt&lt;/code> übermittelt.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1431428108514_93970_3186"/>
