                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351737_819882_2635" body="Hier werden Angaben zur Geburt einer natürlichen Person gemacht." annotatedElement="_16_5_4_5b501fb_1389522351520_891270_1752"/>
