          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1431428090168_137433_3166" name="TagesdatumMitUnbekannt">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1431429155434_254735_3260" body="&lt;para>Mit diesem Datentyp wird in der Regel ein vollständig bekanntes Datum übermittelt. Ist das Datum nicht bekannt, wird statt des Datums &lt;code>true&lt;/code> in dem Kindelement &lt;code>unbekannt&lt;/code> übermittelt.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1431428090168_137433_3166"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1431428166219_579512_3224" name="datum" visibility="private" type="_16_5_4_1eeb04c1_1431426558549_879342_2894">
