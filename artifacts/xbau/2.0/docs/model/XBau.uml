            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_1eeb04c1_1380019709066_319431_1643" name="" memberEnd="_16_5_4_1eeb04c1_1380019709066_960444_1645 _16_5_4_1eeb04c1_1380019709066_704288_1644">
            <ownedEnd xmi:id="_16_5_4_1eeb04c1_1380019709066_960444_1645" name="" visibility="private" type="_16_5_4_1eeb04c1_1380019660674_995526_1587" association="_16_5_4_1eeb04c1_1380019709066_319431_1643"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1380019783198_447885_1675" name="PostalischeInlandsanschrift.Gebaeudeanschrift" clientDependency="_16_5_4_1eeb04c1_1436452973247_953116_3869">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1380023551707_688434_1784" body="&lt;para>Dieser Datentyp beinhaltet die Angaben für die Adressierung im Inland, soweit es sich um eine Gebäudeanschrift (und nicht um eine Postfachanschrift) handelt.&lt;/para>&#xA;" annotatedElement="_16_5_4_1eeb04c1_1380019783198_447885_1675"/>
            <generalization xmi:id="_16_5_4_1ccb0481_1425469069739_861877_2296" isSubstitutable="true" general="_16_5_4_1ccb0481_1425468921949_760319_2133"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1380019824008_354867_1703" name="hausnummern.bis" visibility="private" type="_16_5_4_1eeb04c1_1377075001233_323278_1145">
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1380019838532_958154_1706" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1380019838532_922298_1705" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_1eeb04c1_1380019856051_376159_1711" name="" memberEnd="_16_5_4_1eeb04c1_1380019856051_185416_1713 _16_5_4_1eeb04c1_1380019856051_736962_1712">
            <ownedEnd xmi:id="_16_5_4_1eeb04c1_1380019856051_185416_1713" name="" visibility="private" type="_16_5_4_1eeb04c1_1380019660674_995526_1587" association="_16_5_4_1eeb04c1_1380019856051_376159_1711"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1ccb0481_1425468921949_760319_2133" name="PostalischeInlandsanschrift.Basis" clientDependency="_16_5_4_1eeb04c1_1436452978030_184911_3872">
            <ownedComment xmi:id="_16_5_4_1ccb0481_1425468921982_614975_2146" body="&lt;para>Dieser Datentyp bildet die Basis einer postalischen Gebäudeanschrift. Er basiert auf der Meldeanschrift, enthält aber nur die für die Adressierung erforderlichen Angaben. Die Angabe des Wohnort, der Postleitzahl und der Straße sind in diesem Datentyp verpflichtend.&lt;/para>&#xA;" annotatedElement="_16_5_4_1ccb0481_1425468921949_760319_2133"/>
            <generalization xmi:id="_16_5_4_1ccb0481_1425468928690_441786_2281" isSubstitutable="true" general="_16_5_4_b7102e0_1292420010055_54472_505"/>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921958_463262_2135" name="hausnummer" visibility="private" type="_16_5_4_28e205cd_1296203840375_978526_898">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468921990_233300_2150" body="&lt;para>Es sind nur die Ziffern einer Hausnummer anzugeben.&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921958_463262_2135"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468921990_921533_2151" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468921987_281712_2149" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921963_804553_2136" name="hausnummerBuchstabeZusatzziffer" visibility="private" type="_16_5_4_28e205cd_1296203866609_175384_921">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468921995_922338_2154" body="&lt;para>Es sind Buchstaben oder Zusatzziffern zur Hausnummer anzugeben.&lt;/para>&#xA;&lt;para>Beispiel: 124 &lt;emphasis role=&quot;underline&quot;>A&lt;/emphasis>, 109&lt;emphasis role=&quot;underline&quot;>.5&lt;/emphasis>&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921963_804553_2136"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468921996_311353_2155" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468921995_707779_2153" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921965_416213_2137" name="postleitzahl" visibility="private" type="_16_5_4_28e205cd_1296203901906_876602_944">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468921996_806964_2158" body="&lt;para>Es ist die Postleitzahl anzugeben.&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921965_416213_2137"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468959798_840171_2287" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468959798_668413_2286" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921966_747588_2138" name="stockwerkswohnungsnummer" visibility="private" type="_16_5_4_28e205cd_1296203985453_789100_986">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468921997_691524_2162" body="&lt;para>Es können Stockwerks- oder Wohnungsnummern angegeben werden, soweit sie für die Adressierung erforderlich sind. Beispiele: 7OG, 13OG, P für Parterre, HP für Hochparterre, St für Souterrain oder (Wohnung) 115.&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921966_747588_2138"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468921998_77870_2163" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468921997_185317_2161" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921968_226942_2139" name="strasse" visibility="private" type="_16_5_4_28e205cd_1296204045078_587048_1032">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468921998_26373_2166" body="&lt;para>Es ist die Bezeichnung der Straße anzugeben; eine sinnvoll gekürzte Straßenbezeichnung ist zulässig.&lt;/para>&#xA;&lt;para>Ist keine Straßenbezeichnung &amp;mdash; wohl aber eine Hausnummer &amp;mdash; vorhanden, so ist die Zeichenkette &lt;quote>Hausnummer&lt;/quote> anzugeben. Sind weder Straßenbezeichnung noch Hausnummer vorhanden, so ist die Zeichenkette &lt;quote>ohne Hausnummer&lt;/quote> anzugeben.&lt;/para>&#xA;&lt;para>&lt;/para>&#xA;&lt;para>Bei Überschreitung einer Länge von 25 Zeichen darf sinnvoll abgekürzt werden.&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921968_226942_2139"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468968484_528673_2289" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468968484_433434_2288" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921969_588692_2140" name="teilnummerDerHausnummer" visibility="private" type="_16_5_4_28e205cd_1296204065781_198512_1055">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468921999_95530_2170" body="&lt;para>Es sind Teilnummern zur Hausnummer anzugeben.&lt;/para>&#xA;&lt;para>Beispiel: 16 &lt;emphasis role=&quot;underline&quot;>1/7&lt;/emphasis>&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921969_588692_2140"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468921999_610589_2171" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468921999_28976_2169" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921971_420202_2141" name="wohnort" visibility="private" type="_16_5_4_28e205cd_1296204091359_810864_1078">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468922000_743619_2174" body="&lt;para>Es ist die postalische Wohnortsbezeichnung anzugeben.&lt;/para>&#xA;&lt;para>&lt;/para>&#xA;&lt;para>Bei Überschreitung einer Länge von 25 Zeichen darf sinnvoll abgekürzt werden.&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921971_420202_2141"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468981813_539662_2291" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468981812_168665_2290" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921977_262524_2142" name="wohnortFruehererGemeindename" visibility="private" type="_16_5_4_28e205cd_1296204107812_31054_1101">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468922000_945584_2178" body="&lt;para>Es ist der frühere Gemeindename anzugeben, der als Stadt- bzw. Ortsteilname dem jetzigen Gemeindenamen hinzugefügt werden kann.&lt;/para>&lt;para>Der frühere Gemeindename (jetziger Ortsteil- oder Stadtteilname) ist bei &lt;emphasis role=&quot;underline&quot;>Adressierungen&lt;/emphasis> unterhalb des Namens (oberhalb der Straßenbezeichnung) anzugeben.&lt;/para>&lt;para>Beispiel: Frau&lt;/para>&lt;para>               Rita Scholl&lt;/para>&lt;para>               Zuffenhausen&lt;/para>&lt;para>              Am Stadtpark 12&lt;/para>&lt;para>              70123 Stuttgart&lt;/para>&#xA;&lt;para>&lt;/para>&#xA;&lt;para>Bei Überschreitung einer Länge von 25 Zeichen darf sinnvoll abgekürzt werden.&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921977_262524_2142"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468922000_956181_2179" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468922000_120310_2177" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1ccb0481_1425468921978_680650_2143" name="wohnungsinhaber" visibility="private" type="_16_5_4_28e205cd_1296206834546_531647_1337">
              <ownedComment xmi:id="_16_5_4_1ccb0481_1425468922001_789270_2182" body="&lt;para>In diesem Element ist der Hauptmieter oder Eigentümer der Wohnung anzugeben, soweit dies für die Adressierung erforderlich ist. &lt;/para>&#xA;&lt;para>&lt;/para>&#xA;&lt;para>Bei Überschreitung einer Länge von 26 Zeichen darf sinnvoll abgekürzt werden.&lt;/para>" annotatedElement="_16_5_4_1ccb0481_1425468921978_680650_2143"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1ccb0481_1425468922001_131586_2183" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1ccb0481_1425468922001_516743_2181" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1436970640093_504463_3037" name="zusatzangaben" visibility="private" type="_16_5_4_28e205cd_1296204176046_185713_1147">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1436970640095_259161_3040" body="&lt;para>Es sind Zusatzangaben zur Anschrift anzugeben. Beispiele: Hinterhaus, Gartenhaus.&lt;/para>&#xA;&lt;para>&lt;/para>&#xA;&lt;para>Bei Überschreitung einer Länge von 21 Zeichen darf sinnvoll abgekürzt werden.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1436970640093_504463_3037"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1436970640095_854956_3041" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1436970640094_612731_3039" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_127f0398_1432802995142_406371_2417" name="" supplier="_16_5_4_5b501fb_1387625271062_845493_4821" client="_16_5_4_1eeb04c1_1375790911435_19752_1798"/>
