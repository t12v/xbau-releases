                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351736_478028_2617" body="Angaben zum Gültigkeitszeitraum für den Namen der Organisation." annotatedElement="_16_5_4_5b501fb_1389522351519_491990_1746"/>
                  <ownedEnd xmi:id="_16_5_4_5b501fb_1389522351737_799022_2618" name="" visibility="private" type="_16_5_4_5b501fb_1389522351511_324525_1700" association="_16_5_4_5b501fb_1389522351519_491990_1746"/>
                </packagedElement>
                <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1389522351519_781951_1747" name="" memberEnd="_16_5_4_5b501fb_1389522351737_181102_2621 _16_5_4_5b501fb_1389522351557_104244_1856">
                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351737_336985_2620" body="Behörde, die den Familienstand amtlich gemacht hat." annotatedElement="_16_5_4_5b501fb_1389522351519_781951_1747"/>
                  <ownedEnd xmi:id="_16_5_4_5b501fb_1389522351737_181102_2621" name="" visibility="private" type="_16_5_4_5b501fb_1389522351500_248015_1685" association="_16_5_4_5b501fb_1389522351519_781951_1747"/>
