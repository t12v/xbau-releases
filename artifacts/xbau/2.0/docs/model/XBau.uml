  <XOEVProfil:xoevABIE xmi:id="_vcDBXXCeEei-9cvzAL3INg" base_Class="_16_5_4_1eeb04c1_1364313776811_220119_9414"/>
  <XOEVProfil:xoevABIE xmi:id="_vcDBXnCeEei-9cvzAL3INg" base_Class="_16_5_4_1eeb04c1_1351595172450_828165_1636" Abweichung="Die Auslandsanschrift aus XInneres enthält das Druckbild einer Auslandsanschrift in unstrukturierter Form." MotivationDerAbweichung="Für die Übermittlung von  ausländischen Anschriften ist der strukturierte Ansatz der Kernkomponente nicht geeignet. Aus diesem Grund wurde in XInneres ein Datentyp für ausländische Anschriften konzipiert, der sich an dem Druckbild einer Anschrift und der entsprechenden DIN-Norm orientiert. "/>
  <XOEVProfil:xoevABIE xmi:id="_vcDBX3CeEei-9cvzAL3INg" base_Class="_16_5_4_b7102e0_1292420010055_54472_505" MotivationDerAbweichung="Die Klasse heißt Meldeanschrift und nicht Anschrift, weil sie zur Übermittlung von Anschriften vorgesehen ist, an denen Personen in der Meldebehörde gemeldet sein können."/>
  <XOEVProfil:xoevABIE xmi:id="_vcDBYHCeEei-9cvzAL3INg" base_Class="_16_5_4_1eeb04c1_1380019660674_995526_1587" MotivationDerAbweichung="Im Interesse der Wiederverwendung der Meldeanschrift wurde die postalische Inlandsanschrift als Choice zwischen Gebäude- und Postfachanschriften modelliert."/>
  <XOEVProfil:xoevABIE xmi:id="_vcDBYXCeEei-9cvzAL3INg" base_Class="_16_5_4_1ccb0481_1425468921949_760319_2133"/>
