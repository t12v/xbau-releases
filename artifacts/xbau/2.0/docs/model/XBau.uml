                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483129729635_631388_5168" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1483129800564_101573_5177" name="anzahlStunden" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1483129800564_952342_5180" body="&lt;para>Der voraussichtlich zu leistende Aufwand in h.&lt;/para>" annotatedElement="_16_5_4_940029b_1483129800564_101573_5177"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483129800564_91781_5181" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483129800564_12381_5179" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1483129867536_906657_5184" name="geschaetzteGebuehr" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1483129867536_847644_5187" body="&lt;para>Die sich auf der Basis von Stundensatz und voraussichtlich zu leistendem Aufwand ergebende Gebühr (in Eurocent).&lt;/para>" annotatedElement="_16_5_4_940029b_1483129867536_906657_5184"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
