                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351738_640742_2644" body="Die &quot;identifikation&quot; einer &quot;Organisation&quot; fasst alle Elemente zusammen, die eine Organisation in einem fachlichen Kontext eindeutig unter anderen Organisationen identifiziert. &#xA;&#xA;" annotatedElement="_16_5_4_5b501fb_1389522351520_99760_1755"/>
