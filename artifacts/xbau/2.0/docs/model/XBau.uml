                <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1389522351520_598067_1750" name="" memberEnd="_16_5_4_5b501fb_1389522351737_350118_2630 _16_5_4_5b501fb_1389522351720_699530_2468">
                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351737_783965_2629" body="Der Geburtsname ist der Nachname einer Person, der sich jeweils aus dem Geburtseintrag für diese Person ergibt. Der Geburtsname ist i.d.R. der Nachname, der vor der ersten Eheschließung oder Lebenspartnerschaft geführt wurde.&#xA;" annotatedElement="_16_5_4_5b501fb_1389522351520_598067_1750"/>
                  <ownedEnd xmi:id="_16_5_4_5b501fb_1389522351737_350118_2630" name="" visibility="private" type="_16_5_4_5b501fb_1389522351514_923302_1707" association="_16_5_4_5b501fb_1389522351520_598067_1750"/>
