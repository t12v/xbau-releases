          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_1eeb04c1_1436452978030_184911_3872" name="" supplier="_16_5_4_5b501fb_1387625291113_329233_5177" client="_16_5_4_1ccb0481_1425468921949_760319_2133"/>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_1eeb04c1_1436453387812_987059_3885" name="" supplier="_16_5_4_5b501fb_1387625291113_329233_5177" client="_16_5_4_1eeb04c1_1380019660674_995526_1587"/>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_1eeb04c1_1446713628391_441140_2844" name="" supplier="_16_5_4_5b501fb_1387625291268_905208_5817" client="_16_5_4_1eeb04c1_1380019732248_220724_1656"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_1eeb04c1_1380018580370_758888_1076" name="Entwurf">
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_1eeb04c1_1364479517685_144083_2787" name="Entwurf.Aenderungsart" clientDependency="_16_5_4_127f0398_1432803525825_857823_2785">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364476447497_743572_1773" name="Code.Aenderungsart">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364476447500_188380_1780" body="&lt;para>Diese Tabelle enthält die Art der Änderungen bei Mitteilungen und ermöglicht eine Unterscheidung zwischen Korrektur und Fortschreibung aufgrund eines veränderten Sachverhalts.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1364476447497_743572_1773"/>
              <generalization xmi:id="_16_5_4_1eeb04c1_1364476447498_836338_1775" isSubstitutable="true" general="_16_5_4_5b501fb_1387625280047_322339_5028"/>
              <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364476447498_455645_1776" name="code" visibility="private">
