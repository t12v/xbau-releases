                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351739_408598_2671" body="Der frühere Familienname ist der Nachname, den eine Person vor einer Nachnamensänderung geführt hat. &#xA;" annotatedElement="_16_5_4_5b501fb_1389522351521_198803_1764"/>
