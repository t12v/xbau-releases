            <ownedAttribute xmi:id="_16_5_4_940029b_1467903767415_763656_6076" name="summe" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467903767415_694530_6079" body="&lt;para>Hier ist Summe aller Positionen in Eurocent einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1467903767415_763656_6076"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
