                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351739_99841_2674" body="Angaben zum Zeitraum, in welchem der Familienstand einer natürlichen Person gültig ist. " annotatedElement="_16_5_4_5b501fb_1389522351521_143958_1765"/>
