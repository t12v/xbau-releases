                <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1389522351519_342080_1745" name="" memberEnd="_16_5_4_5b501fb_1389522351736_148106_2615 _16_5_4_5b501fb_1389522351721_370090_2470">
                  <ownedComment xmi:id="_16_5_4_5b501fb_1389522351736_238954_2614" body="Der Vorname ist der Name bzw. der Teil des Namens, der nicht die Zugehörigkeit zu einer Familie ausdrückt, sondern das Individuum innerhalb der Familie bezeichnet und dazu dient, es von anderen Familienmitgliedern zu unterscheiden. " annotatedElement="_16_5_4_5b501fb_1389522351519_342080_1745"/>
                  <ownedEnd xmi:id="_16_5_4_5b501fb_1389522351736_148106_2615" name="" visibility="private" type="_16_5_4_5b501fb_1389522351514_923302_1707" association="_16_5_4_5b501fb_1389522351519_342080_1745"/>
