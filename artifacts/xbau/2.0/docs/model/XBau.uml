  <XOEVProfil:xoevABIE xmi:id="_vcDBW3CeEei-9cvzAL3INg" base_Class="_16_5_4_1eeb04c1_1380019783198_447885_1675" MotivationDerAbweichung="Das zusätzliche Kindelement ist erforderlich, um Hausnummernbereich übermitteln zu können."/>
