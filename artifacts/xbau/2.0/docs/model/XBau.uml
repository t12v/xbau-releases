              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364478035871_632185_2704" name="listVersionID" visibility="private">
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191848984_108685_1498"/>
