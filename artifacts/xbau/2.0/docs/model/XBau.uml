                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291321_849723_6132" body="Hier werden Angaben zum Namen einer Behörde zusammengefasst." annotatedElement="_16_5_4_5b501fb_1387625291122_709828_5233"/>
