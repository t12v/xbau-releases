                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291322_68605_6150" body="Angaben zum Zeitraum, in welchem der Familienstand einer natürlichen Person gültig ist. " annotatedElement="_16_5_4_5b501fb_1387625291122_625053_5239"/>
