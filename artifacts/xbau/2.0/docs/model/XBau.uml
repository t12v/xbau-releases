              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291117_704173_5185" name="" memberEnd="_16_5_4_5b501fb_1387625291314_492558_5989 _16_5_4_5b501fb_1387625291295_81693_5913">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291314_752284_5988" body="Die verwaltungspolitische Zuständigkeit der Behörde beschreibt für welche verwaltungspolitische Einheit eine Behörde zuständig ist." annotatedElement="_16_5_4_5b501fb_1387625291117_704173_5185"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291314_492558_5989" name="" visibility="private" type="_16_5_4_5b501fb_1387625291115_477657_5180" association="_16_5_4_5b501fb_1387625291117_704173_5185"/>
