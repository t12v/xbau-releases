        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475159895898_998624_6483" name="Code.VorlagenBauzustand">
          <ownedComment xmi:id="_16_5_4_940029b_1475159895913_63649_6489" body="&lt;para>Diese Codeliste nennt Arten von Bauvorlagen, die als Anlagen zu Bauzustandsanzeigen dienen können. Quelle ist § 81 MBO in Verbindung mit MBauVorlV Teil IV. &lt;/para>&#xA;&lt;para>Diese Unterlagen sind keine Bauvorlagen zum Bauantrag gem. § 68 Abs. 2 MBO, sondern weitere Bauzustandsanzeigen zur Bauüberwachung gem. § 81 MBO.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475159895898_998624_6483"/>
