              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_100186_5200" name="" memberEnd="_16_5_4_5b501fb_1387625291317_153150_6034 _16_5_4_5b501fb_1387625291296_132817_5916">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291316_24883_6033" body="Die &quot;behoerdenidentifikation&quot; fasst alle Elemente zusammen, die eine Behörde eindeutig unter anderen Behörden identifiziert. &#xA;&#xA;" annotatedElement="_16_5_4_5b501fb_1387625291119_100186_5200"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291317_153150_6034" name="" visibility="private" type="_16_5_4_5b501fb_1387625291115_477657_5180" association="_16_5_4_5b501fb_1387625291119_100186_5200"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_524112_5201" name="" memberEnd="_16_5_4_5b501fb_1387625291317_703269_6037 _16_5_4_5b501fb_1387625291177_500937_5457">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291317_452115_6036" body="Hier werden Angaben zum Familienstand einer natürlichen Person gemacht." annotatedElement="_16_5_4_5b501fb_1387625291119_524112_5201"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291317_703269_6037" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_608193_5164" association="_16_5_4_5b501fb_1387625291119_524112_5201"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_477912_5202" name="" memberEnd="_16_5_4_5b501fb_1387625291317_609752_6040 _16_5_4_5b501fb_1387625291277_568643_5848">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291317_723374_6039" body="Unter &quot;kommunikation&quot; werden Angaben zur Erreichbarkeit einer Organisation über elektronische Kommunikationskanäle zusammengefasst. " annotatedElement="_16_5_4_5b501fb_1387625291119_477912_5202"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291317_609752_6040" name="" visibility="private" type="_16_5_4_5b501fb_1387625291114_133591_5178" association="_16_5_4_5b501fb_1387625291119_477912_5202"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_380574_5203" name="" memberEnd="_16_5_4_5b501fb_1387625291317_144410_6043 _16_5_4_5b501fb_1387625291233_12267_5681">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291317_618365_6042" body="Hier werden Angaben zum Sterbeort gemacht." annotatedElement="_16_5_4_5b501fb_1387625291119_380574_5203"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291317_144410_6043" name="" visibility="private" type="_16_5_4_5b501fb_1387625291109_633566_5172" association="_16_5_4_5b501fb_1387625291119_380574_5203"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_893985_5204" name="" memberEnd="_16_5_4_5b501fb_1387625291317_715585_6046 _16_5_4_5b501fb_1387625291138_770287_5303">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291317_967762_6045" body="Hier werden Angaben zum Zeitraum der Gültigkeit einer &quot;Registrierung&quot; gemacht. " annotatedElement="_16_5_4_5b501fb_1387625291119_893985_5204"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291317_715585_6046" name="" visibility="private" type="_16_5_4_5b501fb_1387625291098_653665_5158" association="_16_5_4_5b501fb_1387625291119_893985_5204"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_484844_5205" name="" memberEnd="_16_5_4_5b501fb_1387625291317_877486_6049 _16_5_4_5b501fb_1387625291178_231840_5459">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291317_981516_6048" body="Hier werden Angaben zur Anschrift einer natürlichen Person gemacht." annotatedElement="_16_5_4_5b501fb_1387625291119_484844_5205"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291317_877486_6049" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_608193_5164" association="_16_5_4_5b501fb_1387625291119_484844_5205"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_108209_5206" name="" memberEnd="_16_5_4_5b501fb_1387625291317_277333_6052 _16_5_4_5b501fb_1387625291182_745588_5471">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291317_527384_6051" body="Die &quot;staatsangehoerigkeit&quot; einer natürlichen Person gibt an, welchem Staat die Person angehört. Die Staatsangehörigkeit ist das rechtliche Band zwischen dem Staat und dem Staatsangehörigen und bestimmt Rechte wie Pflichten zwischen Staat und Staatsangehörigem." annotatedElement="_16_5_4_5b501fb_1387625291119_108209_5206"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291317_277333_6052" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_608193_5164" association="_16_5_4_5b501fb_1387625291119_108209_5206"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_149777_5207" name="" memberEnd="_16_5_4_5b501fb_1387625291318_992551_6055 _16_5_4_5b501fb_1387625291206_345713_5571">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291318_828867_6054" body="Zeitraum in dem das Ausweisdokument gültig ist. " annotatedElement="_16_5_4_5b501fb_1387625291119_149777_5207"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291318_992551_6055" name="" visibility="private" type="_16_5_4_5b501fb_1387625291106_495606_5168" association="_16_5_4_5b501fb_1387625291119_149777_5207"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_107876_5208" name="" memberEnd="_16_5_4_5b501fb_1387625291318_767861_6058 _16_5_4_5b501fb_1387625291132_169833_5277">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291318_5272_6057" body="Die Nation, der die Anschrift verwaltungspolitisch zugeordnet wird." annotatedElement="_16_5_4_5b501fb_1387625291119_107876_5208"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291318_767861_6058" name="" visibility="private" type="_16_5_4_5b501fb_1387625291097_935148_5157" association="_16_5_4_5b501fb_1387625291119_107876_5208"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_249794_5209" name="" memberEnd="_16_5_4_5b501fb_1387625291318_347425_6061 _16_5_4_5b501fb_1387625291279_609442_5854">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291318_349456_6060" body="Angaben zur Anschrift der Organisation, die über den Typ der Anschrift auf deren Verwendung als Postanschrift, Niederlassungsanschrift oder Gründungsanschrift verweist." annotatedElement="_16_5_4_5b501fb_1387625291119_249794_5209"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291318_347425_6061" name="" visibility="private" type="_16_5_4_5b501fb_1387625291114_133591_5178" association="_16_5_4_5b501fb_1387625291119_249794_5209"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291119_32073_5210" name="" memberEnd="_16_5_4_5b501fb_1387625291318_741291_6064 _16_5_4_5b501fb_1387625291303_209425_5941">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291318_461038_6063" body="Der Ehename ist der von beiden Ehegatten durch Erklärung bestimmte gemeinsame Familienname der Ehegatten. Zum Ehenamen kann der Geburtsname eines der Ehegatten oder der zur Zeit der Erklärung von einem Ehegatten geführte Name bestimmt werden." annotatedElement="_16_5_4_5b501fb_1387625291119_32073_5210"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291318_741291_6064" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291119_32073_5210"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_51531_5211" name="" memberEnd="_16_5_4_5b501fb_1387625291318_231666_6067 _16_5_4_5b501fb_1387625291265_139616_5810">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291318_131855_6066" body="Die &quot;verwaltungspolitischeKodierung&quot; beinhaltet Informationen, mit denen eine Anschrift verwaltungspolitisch eindeutig zugeordnet werden kann. " annotatedElement="_16_5_4_5b501fb_1387625291120_51531_5211"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291318_231666_6067" name="" visibility="private" type="_16_5_4_5b501fb_1387625291113_329233_5177" association="_16_5_4_5b501fb_1387625291120_51531_5211">
                  <ownedComment xmi:id="_16_5_4_5b501fb_1387625291435_756771_7308" body="…beinhaltet Informationen zur verwaltungspolitische eindeutigen Zuordnung einer Anschrift. " annotatedElement="_16_5_4_5b501fb_1387625291318_231666_6067"/>
                </ownedEnd>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_873375_5212" name="" memberEnd="_16_5_4_5b501fb_1387625291318_898085_6070 _16_5_4_5b501fb_1387625291265_906584_5809">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291318_650759_6069" body="Der Staat, dem die Anschrift postalisch zugeordnet wird." annotatedElement="_16_5_4_5b501fb_1387625291120_873375_5212"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291318_898085_6070" name="" visibility="private" type="_16_5_4_5b501fb_1387625291113_329233_5177" association="_16_5_4_5b501fb_1387625291120_873375_5212"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_127224_5213" name="" memberEnd="_16_5_4_5b501fb_1387625291319_25989_6073 _16_5_4_5b501fb_1387625291305_361159_5948">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291318_300395_6072" body="Der frühere Vorname ist der Vorname, der vor einer Vornamensänderung geführt wurde.&#xA;" annotatedElement="_16_5_4_5b501fb_1387625291120_127224_5213"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_25989_6073" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291120_127224_5213"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_795313_5214" name="" memberEnd="_16_5_4_5b501fb_1387625291319_925602_6076 _16_5_4_5b501fb_1387625291171_567642_5432">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_158394_6075" body="Hier werden Angaben zum Zeitraum gemacht, in dem eine natürliche Person einer Religionsgemeinschaft angehört." annotatedElement="_16_5_4_5b501fb_1387625291120_795313_5214"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_925602_6076" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_124392_5163" association="_16_5_4_5b501fb_1387625291120_795313_5214"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_136357_5215" name="" memberEnd="_16_5_4_5b501fb_1387625291319_290982_6079 _16_5_4_5b501fb_1387625291305_470274_5947">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_449638_6078" body="Der Rufname ist der im alltäglichen Gebrauch zu nutzende Vorname.&#xA;" annotatedElement="_16_5_4_5b501fb_1387625291120_136357_5215"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_290982_6079" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291120_136357_5215"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_932766_5216" name="" memberEnd="_16_5_4_5b501fb_1387625291319_893052_6082 _16_5_4_5b501fb_1387625291303_622764_5942">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_729162_6081" body="Der Familienname ist der aktuelle Nachname einer Person und Ausdruck einer bestimmten Familienzugehörigkeit dieser Person. &#xA;" annotatedElement="_16_5_4_5b501fb_1387625291120_932766_5216"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_893052_6082" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291120_932766_5216"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_964792_5217" name="" memberEnd="_16_5_4_5b501fb_1387625291319_121198_6085 _16_5_4_5b501fb_1387625291306_837649_5952">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_199736_6084" body="Die Komponente &quot;alternativeRepraesentation&quot; beinhaltet den Namen einer natürlichen Person in einer Form, die einer festgelegten Konvention folgt. Die in der Komponente  &quot;AlternativeRepraesentation&quot; übermittelten Informationen müssen redundant zu den anderen Elementen der Komponente &quot;NameNatuerlichePerson&quot; sein, sie dürfen diese nicht ersetzen. &#xA;" annotatedElement="_16_5_4_5b501fb_1387625291120_964792_5217"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_121198_6085" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291120_964792_5217"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_7333_5218" name="" memberEnd="_16_5_4_5b501fb_1387625291319_328253_6088 _16_5_4_5b501fb_1387625291296_677464_5915">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_77148_6087" body="Die Behördenkennung ist ein System zur eindeutigen Identifikation einer Behörde bspw. im DVDV.&#xA;" annotatedElement="_16_5_4_5b501fb_1387625291120_7333_5218"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_328253_6088" name="" visibility="private" type="_16_5_4_5b501fb_1387625291115_477657_5180" association="_16_5_4_5b501fb_1387625291120_7333_5218"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_610736_5219" name="" memberEnd="_16_5_4_5b501fb_1387625291319_12886_6091 _16_5_4_5b501fb_1387625291304_506286_5946">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_251390_6090" body="Der Vorname ist der Name bzw. der Teil des Namens, der nicht die Zugehörigkeit zu einer Familie ausdrückt, sondern das Individuum innerhalb der Familie bezeichnet und dazu dient, es von anderen Familienmitgliedern zu unterscheiden. " annotatedElement="_16_5_4_5b501fb_1387625291120_610736_5219"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_12886_6091" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291120_610736_5219"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_827601_5220" name="" memberEnd="_16_5_4_5b501fb_1387625291320_257455_6094 _16_5_4_5b501fb_1387625291245_202912_5734">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_523538_6093" body="Angaben zum Gültigkeitszeitraum für den Namen der Organisation." annotatedElement="_16_5_4_5b501fb_1387625291120_827601_5220"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291320_257455_6094" name="" visibility="private" type="_16_5_4_5b501fb_1387625291111_535429_5174" association="_16_5_4_5b501fb_1387625291120_827601_5220"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291121_679275_5221" name="" memberEnd="_16_5_4_5b501fb_1387625291320_143270_6097 _16_5_4_5b501fb_1387625291146_812125_5332">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_894398_6096" body="Behörde, die den Familienstand amtlich gemacht hat." annotatedElement="_16_5_4_5b501fb_1387625291121_679275_5221"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291320_143270_6097" name="" visibility="private" type="_16_5_4_5b501fb_1387625291098_333760_5159" association="_16_5_4_5b501fb_1387625291121_679275_5221"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291121_732691_5222" name="" memberEnd="_16_5_4_5b501fb_1387625291320_855901_6100 _16_5_4_5b501fb_1387625291307_702202_5955">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_646399_6099" body="Ein weiterer Name ist ein Name, der nicht Bestandteil des Vor- oder Nachnamens einer Person und weder Künstlername noch Ordensname ist. " annotatedElement="_16_5_4_5b501fb_1387625291121_732691_5222"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291320_855901_6100" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291121_732691_5222"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291121_533571_5223" name="" memberEnd="_16_5_4_5b501fb_1387625291320_995862_6103 _16_5_4_5b501fb_1387625291276_246924_5847">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_691153_6102" body="Angaben zur Unterorganisation dieser Organisation." annotatedElement="_16_5_4_5b501fb_1387625291121_533571_5223"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291320_995862_6103" name="" visibility="private" type="_16_5_4_5b501fb_1387625291114_133591_5178" association="_16_5_4_5b501fb_1387625291121_533571_5223"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291121_644578_5224" name="" memberEnd="_16_5_4_5b501fb_1387625291320_889940_6106 _16_5_4_5b501fb_1387625291304_240971_5944">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_977908_6105" body="Der Geburtsname ist der Nachname einer Person, der sich jeweils aus dem Geburtseintrag für diese Person ergibt. Der Geburtsname ist i.d.R. der Nachname, der vor der ersten Eheschließung oder Lebenspartnerschaft geführt wurde.&#xA;" annotatedElement="_16_5_4_5b501fb_1387625291121_644578_5224"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291320_889940_6106" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291121_644578_5224"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291121_208330_5225" name="" memberEnd="_16_5_4_5b501fb_1387625291320_11047_6109 _16_5_4_5b501fb_1387625291270_993760_5823">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_485635_6108" body="Die Komponente &quot;geokodierung&quot; beinhaltet Information zur geografischen Bestimmung einer Anschrift." annotatedElement="_16_5_4_5b501fb_1387625291121_208330_5225"/>
