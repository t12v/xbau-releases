            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196509903_464243_8738" name="" supplier="_16_5_4_5b501fb_1387625291226_923939_5653" client="_16_5_4_8a30247_1422894619924_583177_3381"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196516639_628708_8741" name="" supplier="_16_5_4_5b501fb_1387625291227_44637_5654" client="_16_5_4_8a30247_1422894619924_870277_3382"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196979970_783012_8890" name="" supplier="_16_5_4_5b501fb_1387625291104_134064_5166" client="_16_5_4_940029b_1422888807308_342425_3010"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427197248344_315701_9035" name="" supplier="_16_5_4_5b501fb_1387625291113_329233_5177" client="_16_5_4_8a30247_1422884384004_352244_4233"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427197289116_398332_9041" name="" supplier="_16_5_4_5b501fb_1387625291267_147247_5816" client="_16_5_4_8a30247_1422884384004_802917_4242"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427197297440_108061_9044" name="" supplier="_16_5_4_5b501fb_1387625291268_905208_5817" client="_16_5_4_8a30247_1422884384004_979617_4243"/>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1422890212649_362655_3330" name="fachuebergrBausteine">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1422888807308_342425_3010" name="Staat" clientDependency="_16_5_4_8ae0277_1427196979970_783012_8890">
            <ownedComment xmi:id="_16_5_4_940029b_1422888807323_361464_3013" body="&lt;para>Als Staat bezeichnet man eine politische Ordnung, die ein gemeinsames als Staatsgebiet abgegrenztes Territorium, ein dazugehöriges Staatsvolk und eine Machtausübung über dieses umfasst.&lt;/para>" annotatedElement="_16_5_4_940029b_1422888807308_342425_3010"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888807323_584813_3012" name="staat" visibility="private" type="_16_5_4_8a30247_1423043972175_271232_6283">
              <ownedComment xmi:id="_16_5_4_940029b_1422888807386_708822_3048" body="&lt;para>Dieses verwendet einen Schlüssel zur Identifikation eines Staates.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1422888807323_584813_3012"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1422888807386_299198_3049" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888807386_664297_3047" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1422888990355_651351_3077" name="Geokodierung">
            <ownedComment xmi:id="_16_5_4_940029b_1422888990355_414714_3085" body="&lt;para>Diese Komponente beinhaltet Informationen zur geografischen Bestimmung von Dingen.&lt;/para>" annotatedElement="_16_5_4_940029b_1422888990355_651351_3077"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888990355_159436_3082" name="flurnummer" visibility="private" clientDependency="_16_5_4_8ae0277_1427195192987_807482_7497" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1422888990387_346535_3137" body="&lt;para>Die Flur ist eine zusammenhängende, aus mehreren Flurstücken bestehende Fläche des Liegenschaftskatasters.&lt;/para> &#xA;&#xA;&lt;para>Eine Flurnummer ist ein Schlüssel zur Identifikation einer Flur.&lt;/para> " annotatedElement="_16_5_4_940029b_1422888990355_159436_3082"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_241020_3138" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_420216_3136" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888990355_12648_3083" name="flurstueck" visibility="private" clientDependency="_16_5_4_8ae0277_1427195183468_521989_7494" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1422888990387_813605_3141" body="&lt;para>Ein Flurstück ist die kleinste Buchungseinheit des Liegenschaftskatasters und stellt eine geometrisch eindeutigen Teil der Erdoberfläche dar.&lt;/para>  &#xA;&#xA;&lt;para>Das Flurstück wird mit einer Flurstücksnummer, die aus einer Zahl, einer Kombination von Zahl und Buchstabe oder einer Kombination von Zähler und Nenner besteht, bezeichnet.&lt;/para>" annotatedElement="_16_5_4_940029b_1422888990355_12648_3083"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_660567_3142" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_344631_3140" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888990355_381968_3084" name="gemarkung" visibility="private" clientDependency="_16_5_4_8ae0277_1427195151400_176266_7491" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1422888990387_344542_3145" body="&lt;para>Die Komponente &quot;gemarkung&quot; bezeichnet eine Fläche.&lt;/para>&#xA;&#xA;&lt;para>Eine Gemarkung ist eine zusammenhängende, aus mehreren Fluren bestehende Fläche des Liegenschaftskatasters. Sie wird nach ihrer Lage benannt.&lt;/para>" annotatedElement="_16_5_4_940029b_1422888990355_381968_3084"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_594563_3146" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_285412_3144" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422884384004_352244_4233" name="Anschrift" clientDependency="_16_5_4_8ae0277_1427197248344_315701_9035 _16_5_4_8ae0277_1427193531907_193244_6959">
            <ownedComment xmi:id="_16_5_4_8a30247_1422884384004_53636_4250" body="&lt;para>Eine Anschrift beschreibt einen Ort mit den klassischen Ordnungsbegriffen wie Orts- und Straßennamen sowie ergänzenden Informationen wie Ortsteil und Postfach.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422884384004_352244_4233"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_253575_4235" name="staat" visibility="private" type="_16_5_4_940029b_1422888807308_342425_3010" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_208972_4317" body="&lt;para>Der Staat, dem die Anschrift postalisch zugeordnet wird.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422884384004_253575_4235"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422884384082_809940_4318" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_29934_4316" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_806120_4239" name="strasse" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_250735_4333" body="&lt;para>Eine Straße ist ein planmäßig angelegter, im allgemeinen befestigter Verkehrsweg innerhalb eines Ortes.&lt;/para> &#xA;&#xA;&lt;para>Das Element strasse enthält den Namen (die Bezeichnung) einer Straße.&lt;/para>&#xA;" annotatedElement="_16_5_4_8a30247_1422884384004_806120_4239"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_34049_4334" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_323635_4332" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_451688_4240" name="hausnummer" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_264227_4337" body="&lt;para>Eine Hausnummer dient der genauen Lokalisierung eines Grundstücks, Gebäudes oder Gebäudeteils (Eingang) in einer Straße.&lt;/para> &#xA;&#xA;" annotatedElement="_16_5_4_8a30247_1422884384004_451688_4240"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_892535_4338" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_682001_4336" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_212723_4241" name="postfach" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_549186_4341" body="&lt;para>Ein Postfach (oft Postfachnummer) ist ein Schlüssel zur Identifikation eines Postfaches in einer Postfiliale.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422884384004_212723_4241"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_913439_4342" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_784010_4340" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_802917_4242" name="postleitzahl" visibility="private" clientDependency="_16_5_4_8ae0277_1427197289116_398332_9041" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_588674_4345" body="&lt;para>Eine Postleitzahl ist eine Angabe, um postalische Zustellgebiete unabhängig von Gebietskörperschaften (Gemeinde, Kreis) zu bezeichnen.&lt;/para>&#xA;" annotatedElement="_16_5_4_8a30247_1422884384004_802917_4242"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_224431_4346" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_467767_4344" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_979617_4243" name="ort" visibility="private" clientDependency="_16_5_4_8ae0277_1427197297440_108061_9044" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_612642_4349" body="&lt;para>Der &quot;ort&quot; enthält den Namen eines Ortes (Gemeinde, Ortschaft oder Stadt).&lt;/para>&#xA;" annotatedElement="_16_5_4_8a30247_1422884384004_979617_4243"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_775087_4350" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_46680_4348" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_337175_4246" name="wohnungsgeber" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_10646_4361" body="&lt;para>Die Komponente &quot;wohnungsgeber&quot; enthält Angaben (Name/Bezeichnung) zum Hauptmieter oder Eigentümer einer Immobilie.&lt;/para>&#xA;&#xA;&lt;para>Die Angabe eines Wohnungsgebers im Kontext der Anschrift dient der genaueren oder leichteren Adressierung. Sie darf nicht genutzt werden um Mietverhältnisse oder ähnliche rechtliche Beziehungen zwischen Personen auszudrücken.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: bei Meyer&lt;/para>" annotatedElement="_16_5_4_8a30247_1422884384004_337175_4246"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_381478_4362" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_415657_4360" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_320565_4247" name="zusatz" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_765934_4365" body="&lt;para>Ein Anschriftenzusatz beinhaltet ggf. erforderliche weitere Präzisierungen zu einer Anschrift.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: Hinterhof, 3. Aufgang, Haus A, 3. Stock, Appartement 25a,  3. Stock - Appartement 25 a, #325a, Raum 77&lt;/para>" annotatedElement="_16_5_4_8a30247_1422884384004_320565_4247"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_511194_4366" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_837226_4364" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422894619924_503273_3379" name="Kommunikation" clientDependency="_16_5_4_8ae0277_1427196503513_568354_8735 _16_5_4_8ae0277_1427193463099_815271_6947">
            <ownedComment xmi:id="_16_5_4_8a30247_1422894619924_612939_3385" body="&lt;para>&quot;Kommunikation&quot; fasst Angaben zur Erreichbarkeit über elektronische Kommunikationskanäle (z.B. Telefon, Fax, E-Mail) zusammen.&lt;/para>&#xA;" annotatedElement="_16_5_4_8a30247_1422894619924_503273_3379"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_583177_3381" name="kanal" visibility="private" clientDependency="_16_5_4_8ae0277_1427196509903_464243_8738" type="_16_5_4_8a30247_1423044922195_172323_6450">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_400513_3423" body="&lt;para>Der &quot;kanal&quot; gibt an, über welchen Kommunikationskanal eine Erreichbarkeit besteht (Telefon, E-Mail usw.).&lt;/para>  &#xA;&#xA;" annotatedElement="_16_5_4_8a30247_1422894619924_583177_3381"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_536564_3424" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_949595_3422" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_870277_3382" name="kennung" visibility="private" clientDependency="_16_5_4_8ae0277_1427196516639_628708_8741" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_381305_3427" body="&lt;para>Die &quot;kennung&quot; beinhaltet die konkreten Angaben zur Erreichbarkeit über einen Kommunikationskanal, d.h. die Telefonnummer, Faxnummer, E-Mail-Adresse oder dergleichen. Die Kennung soll strukturiert erfasst werden.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: +49 30 12345-67 (internationale Rufnummer nach DIN 5008)&#xA;&#xA;030 12345-67 ( nationale Rufnummern nach DIN 5008)&#xA;&#xA;+49 89 1234567 (internationale Rufnummer nach E.123)&#xA;&#xA;(089) 123456) (nationale Rufnummer nach E.123)&#xA;&#xA;tel:+49-30-1234567 (Uniform Resource Identifier nach RFC 3966)&lt;/para>&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_8a30247_1422894619924_870277_3382"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_970802_3428" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_907455_3426" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_202463_3383" name="istDienstlich" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_69296_3431" body="&lt;para>Mit der Komponente &quot;istDienstlich&quot; kann angegeben werden, ob es sich um dienstliche oder private Kommunikationsdaten handelt.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422894619924_202463_3383"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_150044_3432" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_691580_3430" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_228031_3384" name="zusatz" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_510860_3435" body="&lt;para>Im &quot;zusatz&quot; können zusätzliche freie Angaben zur Erreichbarkeit über einen Kommunikationskanal gemacht werden.&lt;/para> &#xA;&#xA;&lt;para>Beispiel: erreichbar tagsüber zwischen 9 und 16 Uhr&lt;/para>" annotatedElement="_16_5_4_8a30247_1422894619924_228031_3384"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619955_829010_3436" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_525294_3434" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422955073653_603895_5103" name="NameNatuerlichePerson" clientDependency="_16_5_4_8ae0277_1427196365903_938927_8698">
            <ownedComment xmi:id="_16_5_4_8a30247_1422955073653_702979_5120" body="&lt;para>Der Name einer Person ist eine Benennung dieser Person, die dazu dient, diese Person von anderen Personen zu unterscheiden.&lt;/para>&#xA;" annotatedElement="_16_5_4_8a30247_1422955073653_603895_5103"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_897530_5113" name="titel" visibility="private" clientDependency="_16_5_4_8ae0277_1427196387606_122294_8701" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_967723_5280" body="&lt;para>Ein Titel wird häufig im Zusammenhang mit Namen verwendet, ist aber  kein orginärer Bestandteil des Namens. Im Unterschied dazu gehören Adelstitel zum Familiennamen und sind daher in diesem Verständnis kein Titel. Zu den Titeln zählen beispielsweise akademische Grade, Dienst- und Amtsbezeichnungen oder militärische Ränge. Es können auch Titel übermittelt werden, die keine Titel im Sinne des Meldewesens sind.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: Dr.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422955073653_897530_5113"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422955073794_777288_5281" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955073794_566369_5279" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_433210_5114" name="anrede" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_891832_5284" body="&lt;para>Die Anrede ist der Namenszusatz (auch eine Anrede ohne Namen nur mit Titel ist eine Anrede) bei der Anrede (mündlich oder schriftlich) oder bei einem Anruf (fernmündlich) an eine Person oder Personengruppe.&lt;/para>&#xA;&#xA;&lt;para>Anmerkung: Die komplette Anrede einer Person kann in einem Feld übermittelt werden.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: Herr, Frau, Herr Staatssekretär, Frau Bundeskanzlerin, Herr Botschafter, Eure Eminenz&lt;/para>" annotatedElement="_16_5_4_8a30247_1422955073653_433210_5114"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621011095_18399_3911" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621011095_467363_3910" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_116526_5106" name="familienname" visibility="private" clientDependency="_16_5_4_8ae0277_1427196440753_243032_8707" type="_16_5_4_8a30247_1422955529766_893716_5914" aggregation="composite" association="_16_5_4_8ae0277_1427196276261_283770_8628">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_120326_5252" body="&lt;para>Der Familienname ist der aktuelle Nachname einer Person und Ausdruck einer bestimmten Familienzugehörigkeit dieser Person.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422955073653_116526_5106"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621123614_270154_3913" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621123614_669924_3912" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_701701_5110" name="vorname" visibility="private" clientDependency="_16_5_4_8ae0277_1427196421259_460285_8704" type="_16_5_4_8a30247_1422955529766_893716_5914" aggregation="composite" association="_16_5_4_8ae0277_1427196267171_513183_8533">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_942027_5268" body="&lt;para>Der Vorname ist der Name bzw. der Teil des Namens, der nicht die Zugehörigkeit zu einer Familie ausdrückt, sondern das Individuum innerhalb der Familie bezeichnet und dazu dient, es von anderen Familienmitgliedern zu unterscheiden.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422955073653_701701_5110"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621132576_234_3915" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621132576_435657_3914" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422955529766_893716_5914" name="AllgemeinerName">
            <ownedComment xmi:id="_16_5_4_8a30247_1422955529766_553979_5920" body="&lt;para>Der AllgemeineName dient der Darstellung von Vor- und Nachnamen und fasst deren  gemeinsame Eigenschaften zusammen.&lt;/para>&#xA;" annotatedElement="_16_5_4_8a30247_1422955529766_893716_5914"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955529766_536500_5916" name="name" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955529797_194605_5964" body="&lt;para>Die Komponente &quot;name&quot; ist der  Familien- oder Vorname als Zeichenkette.&lt;/para> &#xA;&lt;para>Nachnamen, z.B.  mit Adelstiteln bzw. ausländische Nachnamen werden als ein Name übermittelt und nicht in verschiedene Bestandteile aufgeteilt.&lt;/para> &#xA;&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_8a30247_1422955529766_536500_5916"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_737978_5965" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_512651_5963" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955529766_12705_5917" name="nichtVorhanden" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955529797_243429_5968" body="&lt;para>Diese Komponente beinhaltet eine Feststellung (wahr oder falsch), ob zu Recht kein Name angegeben wurde. Ueber das Setzen auf TRUE, wird angezeigt, dass zurecht kein Name angegeben wurde.&lt;/para> " annotatedElement="_16_5_4_8a30247_1422955529766_12705_5917"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422955529797_277543_5969" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_108430_5967" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422957254152_639975_8085" name="Organisationseinheit">
            <ownedComment xmi:id="_16_5_4_8a30247_1422957254152_410520_8090" body="&lt;para>Die Organisationseinheit fasst Angaben zur Darstellung der internen hierarchischen Organisationsstruktur einer Institution zusammen, z.B. zur Darstellung von Abteilungen oder Referaten.&lt;/para> " annotatedElement="_16_5_4_8a30247_1422957254152_639975_8085"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957254152_631909_8087" name="name" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957254183_537292_8127" body="&lt;para>Bezeichnung der Organisationseinheit.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422957254152_631909_8087"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957254183_868799_8128" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957254183_511440_8126" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957254152_920001_8088" name="hierarchieebene" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957254183_458854_8131" body="&lt;para>Kennzeichnung der Hierarchieebene der Organisationseinheit.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422957254152_920001_8088"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191803156_348252_1327"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957254199_654246_8132" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957254183_475168_8130" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957254152_542971_8089" name="hierarchiename" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957254199_404694_8135" body="&lt;para>Hier kann der Name einer Hierachieebene angegeben werden.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: Abteilung, Referat&lt;/para>" annotatedElement="_16_5_4_8a30247_1422957254152_542971_8089"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957254199_100104_8136" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957254199_627123_8134" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422957408723_400098_8364" name="NameOrganisation" clientDependency="_16_5_4_8ae0277_1427193489689_812796_6950">
            <ownedComment xmi:id="_16_5_4_8a30247_1422957408723_801794_8369" body="&lt;para>&quot;NameOrganisation&quot; fasst die Angaben zum Namen einer Organisation zusammen.&lt;/para> " annotatedElement="_16_5_4_8a30247_1422957408723_400098_8364"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957408723_631641_8366" name="name" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957408770_89516_8412" body="&lt;para>Offizieller Name einer Organisation. Entspricht bei registrierten Organisationen dem im Register eingetragenen Namen.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422957408723_631641_8366"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460623839986_120551_4727" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460623839986_414204_4726" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957408723_203762_8367" name="kurzbezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957408770_938031_8416" body="&lt;para>Kurzbezeichnung des Namen einer Organisation.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422957408723_203762_8367"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957408770_660999_8417" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957408770_737842_8415" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422977426041_172815_6757" name="Organisation" clientDependency="_16_5_4_8ae0277_1427193498410_184944_6953">
            <ownedComment xmi:id="_16_5_4_8a30247_1422977426056_688199_6771" body="&lt;para>Eine Organisation ist eine  Vereinigung mehrerer natürlicher oder juristischer Personen bzw. eine rechtsfähige Personengesellschaft zu einem gemeinsamen Zweck, z.B.  im wirtschaftlichen, gemeinnützigen,  religiösen, öffentlichen oder politischen Bereich.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_8a30247_1422977426041_172815_6757"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426041_317412_6762" name="id" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_320047_6869" body="&lt;para>Die &quot;id&quot; kann genutzt werden, um eine Instanz einer Organisation innerhalb einer Datenstruktur eindeutig zu identifizieren. Hierbei handelt es sich um eine technische ID.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422977426041_317412_6762"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191788187_847831_1270"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977426150_930056_6870" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977426150_649444_6868" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426041_309857_6763" name="rechtsform" visibility="private" type="_16_5_4_5b501fb_1387625280047_322339_5028">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_481936_6873" body="&lt;para>Die Rechtsform definiert die gesetzlichen Rahmenbedingungen der Organisation.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: GmbH, Stiftung, e.V.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422977426041_309857_6763"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977426150_734832_6874" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977426150_880416_6872" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426041_754458_6765" name="name" visibility="private" clientDependency="_16_5_4_8ae0277_1427193864249_936524_7178" type="_16_5_4_8a30247_1422957408723_400098_8364" aggregation="composite" association="_16_5_4_8ae0277_1427191914590_100076_5913">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_492509_6881" body="&lt;para>Angaben zum offiziellen Namen einer Organisation.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422977426041_754458_6765"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460623828363_231187_4725" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460623828363_397124_4724" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426056_110707_6767" name="anschrift" visibility="private" type="_16_5_4_8a30247_1422884384004_352244_4233" aggregation="composite" association="_16_5_4_8ae0277_1427192330303_284590_6843">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_843785_6889" body="&lt;para>Angaben zur Anschrift der Organisation, die über den Typ der Anschrift auf deren Verwendung als Postanschrift, Niederlassungsanschrift oder Gründungsanschrift verweist.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422977426056_110707_6767"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977426150_706309_6890" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977426150_462413_6888" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426041_568786_6761" name="kommunikation" visibility="private" type="_16_5_4_8a30247_1422894619924_503273_3379" aggregation="composite" association="_16_5_4_8ae0277_1427191961941_338157_6253">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_701628_6865" body="&lt;para>Unter &quot;kommunikation&quot; werden Angaben zur Erreichbarkeit einer Organisation über elektronische Kommunikationskanäle zusammengefasst.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422977426041_568786_6761"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977426150_271056_6866" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977426150_839361_6864" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460624135928_771822_4802" name="vertreter" visibility="private" type="_16_5_4_8a30247_1422955073653_603895_5103" association="_16_5_4_940029b_1460624135928_756920_4800">
              <ownedComment xmi:id="_16_5_4_940029b_1483458770760_264485_4562" body="&lt;para>Angaben zu einer Person, die autorisierrt ist, für die Organisation zu sprechen. &lt;/para>" annotatedElement="_16_5_4_940029b_1460624135928_771822_4802"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460624135928_219294_4805" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460624135928_538610_4804" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8ae0277_1427191914590_100076_5913" name="" memberEnd="_16_5_4_8ae0277_1427191914590_907334_5914 _16_5_4_8a30247_1422977426041_754458_6765">
            <ownedEnd xmi:id="_16_5_4_8ae0277_1427191914590_907334_5914" name="" visibility="private" type="_16_5_4_8a30247_1422977426041_172815_6757" association="_16_5_4_8ae0277_1427191914590_100076_5913"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8ae0277_1427191961941_338157_6253" name="" memberEnd="_16_5_4_8ae0277_1427191961941_158591_6254 _16_5_4_8a30247_1422977426041_568786_6761">
            <ownedEnd xmi:id="_16_5_4_8ae0277_1427191961941_158591_6254" name="" visibility="private" type="_16_5_4_8a30247_1422977426041_172815_6757" association="_16_5_4_8ae0277_1427191961941_338157_6253"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8ae0277_1427192330303_284590_6843" name="" memberEnd="_16_5_4_8ae0277_1427192330303_736203_6844 _16_5_4_8a30247_1422977426056_110707_6767">
            <ownedEnd xmi:id="_16_5_4_8ae0277_1427192330303_736203_6844" name="" visibility="private" type="_16_5_4_8a30247_1422977426041_172815_6757" association="_16_5_4_8ae0277_1427192330303_284590_6843"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8ae0277_1427196267171_513183_8533" name="" memberEnd="_16_5_4_8ae0277_1427196267171_732130_8534 _16_5_4_8a30247_1422955073653_701701_5110">
            <ownedEnd xmi:id="_16_5_4_8ae0277_1427196267171_732130_8534" name="" visibility="private" type="_16_5_4_8a30247_1422955073653_603895_5103" association="_16_5_4_8ae0277_1427196267171_513183_8533"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8ae0277_1427196276261_283770_8628" name="" memberEnd="_16_5_4_8ae0277_1427196276261_48657_8629 _16_5_4_8a30247_1422955073653_116526_5106">
            <ownedEnd xmi:id="_16_5_4_8ae0277_1427196276261_48657_8629" name="" visibility="private" type="_16_5_4_8a30247_1422955073653_603895_5103" association="_16_5_4_8ae0277_1427196276261_283770_8628"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1460624135928_756920_4800" name="" memberEnd="_16_5_4_940029b_1460624135928_202297_4801 _16_5_4_940029b_1460624135928_771822_4802">
            <ownedEnd xmi:id="_16_5_4_940029b_1460624135928_202297_4801" name="" visibility="private" type="_16_5_4_8a30247_1422977426041_172815_6757" association="_16_5_4_940029b_1460624135928_756920_4800"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1529068732076_398157_9585" name="VerwaltungspolitischeKodierung">
            <ownedComment xmi:id="_18_0_2_940029b_1529068737165_417775_9607" body="&lt;para>Die Komponente &quot;VerwaltungspolitischeKodierung&quot; beinhaltet Information, die eine verwaltungspolitisch eindeutige Zuordnung ermöglichen.&lt;/para> " annotatedElement="_18_0_2_940029b_1529068732076_398157_9585"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1529068737165_921805_9608" name="kreis" visibility="private" type="_16_5_4_5b501fb_1387625280047_322339_5028">
              <ownedComment xmi:id="_18_0_2_940029b_1529068737181_187370_9617" body="&lt;para>In Deutschland bezeichnet der Kreis eine bestimmt Region, einen Stadt- oder Landkreis.&lt;/para>&#xA;&#xA;&lt;para>Die Bezeichnung eines Kreises erfolgt durch die Angabe eines Schlüssels zur Identifikation des Kreises innerhalb des Landes.&lt;/para>&#xA;&#xA;" annotatedElement="_18_0_2_940029b_1529068737165_921805_9608"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_546155_9616" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_213344_9618" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1529068737181_464818_9609" name="bezirk" visibility="private" type="_16_5_4_5b501fb_1387625280047_322339_5028">
              <ownedComment xmi:id="_18_0_2_940029b_1529068737181_346783_9621" body="&lt;para>In Deutschland wird mit Bezirk eine bestimmte Region bezeichnet, die einem Regierungsbezirk, einem ehemaligen Regierungsbezirk oder einer anderen statistischen Einheit entspricht, die zwar mehrere Kreise umfasst, jedoch kleiner als ein Bundesland ist.&lt;/para>&#xA;&#xA;&lt;para>Die Bezeichnung eines Bezirks erfolgt durch die Angabe eines Schlüssels zur Identifikation des Bezirks innerhalb des Landes.&lt;/para>&#xA;&#xA;" annotatedElement="_18_0_2_940029b_1529068737181_464818_9609"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_724242_9620" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_238817_9622" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1529068737181_657835_9610" name="bundesland" visibility="private" type="_16_5_4_5b501fb_1387625280047_322339_5028">
              <ownedComment xmi:id="_18_0_2_940029b_1529068737181_79755_9625" body="&lt;para>In Deutschland bezeichnet ein Bundesland eine bestimmte Region und umfasst mehrere Kreise und Bezirke (Ausnahme bilden die sogenannten Stadtstaaten).&lt;/para>&#xA;&#xA;&lt;para>Die Bezeichnung eines Bundeslandes erfolgt durch die Angabe eines Schlüssels zur Identifikation des Bundeslandes innerhalb des Landes.&lt;/para>&#xA;&#xA;" annotatedElement="_18_0_2_940029b_1529068737181_657835_9610"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_871377_9624" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_289308_9626" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1529068737181_176827_9611" name="gemeindeschluessel" visibility="private" type="_16_5_4_5b501fb_1387625280047_322339_5028">
              <ownedComment xmi:id="_18_0_2_940029b_1529068737181_935824_9629" body="&lt;para>Ein Gemeindeschlüssel ist ein Schlüssel zur Identifikation einer Gemeinde oder sonstiger Gebietskörperschaften (Kreis, Bezirk, Bundesland).&lt;/para>&#xA;" annotatedElement="_18_0_2_940029b_1529068737181_176827_9611"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_155139_9628" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_959992_9630" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1529068737181_603085_9612" name="regionalschluessel" visibility="private" type="_16_5_4_5b501fb_1387625280047_322339_5028">
              <ownedComment xmi:id="_18_0_2_940029b_1529068737181_883932_9633" body="&lt;para>Ein Regionalschlüssel ist ein Schlüssel zur Identifikation einer Gemeinde oder sonstiger Gebietskörperschaften (Kreis, Bezirks, Bundesland).&lt;/para>&#xA;" annotatedElement="_18_0_2_940029b_1529068737181_603085_9612"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_832787_9632" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_822895_9634" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1529068737181_174272_9613" name="nation" visibility="private" type="_16_5_4_940029b_1422888807308_342425_3010" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1529068737181_182410_9637" body="&lt;para>Die Nation, der die Anschrift verwaltungspolitisch zugeordnet wird.&lt;/para>" annotatedElement="_18_0_2_940029b_1529068737181_174272_9613"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1529068737181_960905_9636" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1529068737181_134944_9638" name=""/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8a30247_1422977828419_100798_7445" name="" memberEnd="_16_5_4_8a30247_1422977828419_632855_7446 _16_5_4_8a30247_1422977828419_207131_7447">
          <ownedEnd xmi:id="_16_5_4_8a30247_1422977828419_632855_7446" name="" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423" association="_16_5_4_8a30247_1422977828419_100798_7445"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8ae0277_1427194978142_462923_7460" name="" memberEnd="_16_5_4_8ae0277_1427194978142_497560_7461 _16_5_4_8a30247_1422969627950_52913_6195">
          <ownedEnd xmi:id="_16_5_4_8ae0277_1427194978142_497560_7461" name="" visibility="private" type="_16_5_4_8a30247_1408964097602_950511_3483" association="_16_5_4_8ae0277_1427194978142_462923_7460"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1427804664853_997754_3783" name="" supplier="_16_5_4_5b501fb_1400580960261_350236_1101" client="_16_5_4_1d100e5_1384794877872_302539_331"/>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460619307903_831925_3517" name="AmBauBeteiligtePerson" clientDependency="_18_0_2_940029b_1513951637567_197418_9729">
          <ownedComment xmi:id="_16_5_4_940029b_1460619307918_202040_3525" body="&lt;para>Dieser Typ fasst die Merkmale zusammen, die typischerweise zu am Bau beteiligten natürlichen Personen genannt werden bzw. zu nennen sind. &lt;/para>" annotatedElement="_16_5_4_940029b_1460619307903_831925_3517"/>
          <ownedAttribute xmi:id="_16_5_4_940029b_1460619307918_202687_3519" name="name" visibility="private" type="_16_5_4_8a30247_1422955073653_603895_5103">
            <ownedComment xmi:id="_16_5_4_940029b_1460619307918_517815_3528" body="&lt;para>In dieses Element sind die Angaben zu den Namen der Person einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1460619307918_202687_3519"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621351010_693379_4052" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621351010_776728_4051" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_940029b_1460619307918_770102_3520" name="anschrift" visibility="private" type="_16_5_4_8a30247_1422884384004_352244_4233">
            <ownedComment xmi:id="_16_5_4_940029b_1460619307918_585177_3532" body="&lt;para>In dieses Objekt sind die Angaben zur Anschrift der Person einzutragen. Welche Anschrift dafür auszuwählen ist, ist nicht festgelegt. Wichtig ist, dass es eine zustellfähige Anschrift sein muss (für den Zweck der verbindlichen Zustellung).&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1460619307918_770102_3520"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460622442815_531805_4124" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460622442815_634129_4123" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_940029b_1460619307918_566376_3524" name="kommunikation" visibility="private" type="_16_5_4_8a30247_1422894619924_503273_3379">
            <ownedComment xmi:id="_16_5_4_940029b_1460619307918_756628_3548" body="&lt;para>In dieses Objekt sind Angaben einzutragen, die benötigt werden, um mit der Person zu kommunizieren (z. B. per Brief oder per Telefon). Diese Daten dienen der persönlichen Erreichbarkeit; die Unterscheidung, ob es sich um eine private oder eine geschäftliche E-Mail-Adresse handelt, ist nicht erheblich.).&lt;/para>" annotatedElement="_16_5_4_940029b_1460619307918_566376_3524"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460622475673_312080_4130" name="" value="*"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460622475673_81049_4129" name=""/>
          </ownedAttribute>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1460622920874_846896_4469" name="" memberEnd="_16_5_4_940029b_1460622920874_634152_4470 _16_5_4_940029b_1460622920874_103982_4471">
          <ownedEnd xmi:id="_16_5_4_940029b_1460622920874_634152_4470" name="" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423" association="_16_5_4_940029b_1460622920874_846896_4469"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1460625640639_113817_4874" name="" memberEnd="_16_5_4_940029b_1460625640639_342607_4875 _16_5_4_940029b_1460625640639_216405_4876">
          <ownedEnd xmi:id="_16_5_4_940029b_1460625640639_342607_4875" name="" visibility="private" type="_16_5_4_8a30247_1408705895800_629557_4010" association="_16_5_4_940029b_1460625640639_113817_4874"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460650473351_39062_3594" name="Baugrundstueck">
          <ownedComment xmi:id="_16_5_4_940029b_1460650473383_888268_3606" body="&lt;para>Das Baugrundstück ist der Ort der Baumaßnahme. Dieser kann aus mehreren Grundstücken im Sinne des Grundbuchs bestehen. Ein Grundstück kann aus mehreren Fluren bzw. Flurstücken bestehen.&lt;/para>" annotatedElement="_16_5_4_940029b_1460650473351_39062_3594"/>
          <ownedAttribute xmi:id="_16_5_4_940029b_1460650473383_619864_3605" name="anschrift" visibility="private" type="_16_5_4_940029b_1460721362807_804568_3502" aggregation="composite">
            <ownedComment xmi:id="_16_5_4_940029b_1460650473383_716868_3645" body="&lt;para>In diesem Element wird die Anschrift des Baugrundstücks eingetragen. Falls dem Baugrundstück von der Kommune (noch) keine Anschrift zugewiesen ist, wird dieses Element nicht erstellt.&lt;/para>" annotatedElement="_16_5_4_940029b_1460650473383_619864_3605"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468227176055_493655_5572" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468227176055_281969_5571" name=""/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_940029b_1460650473367_909263_3604" name="flurstueckkennzeichnung" visibility="private" type="_16_5_4_8a30247_1408964097602_950511_3483" aggregation="composite">
            <ownedComment xmi:id="_16_5_4_940029b_1460650473383_591441_3641" body="&lt;para>Hier sind in jedem Fall die Angaben zum Flurstück des Vorhabens einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1460650473367_909263_3604"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465375493186_630359_5524" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465375493186_185633_5523" name="" value="1"/>
          </ownedAttribute>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1460722635641_688840_4025" name="Anschrift">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460721362807_804568_3502" name="AnschriftBaugrundstueck" clientDependency="_18_0_2_940029b_1513949697553_223796_9263">
            <ownedComment xmi:id="_16_5_4_940029b_1461160791847_474447_5868" body="&lt;para>In diesem Typ sind die Angaben zusammengefasst, die für die Anschrift eines Baugrundstücks hinreichend sind.&lt;/para>" annotatedElement="_16_5_4_940029b_1460721362807_804568_3502"/>
            <generalization xmi:id="_16_5_4_940029b_1460721367712_332552_3522" isSubstitutable="true" general="_16_5_4_8a30247_1422884384004_352244_4233"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460721452812_475929_3534" name="strasse" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1460721452812_935873_3547" body="&lt;para>In dieses Element wird die Bezeichnung der Straße eingetragen, in der das Baugrundstück liegt..&lt;/para>&#xA;&lt;para>Es ist nach Möglichkeit der amtliche Straßenname aus einem offiziellen Straßenverzeichnis zu nutzen.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1460721452812_475929_3534"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460721452812_189169_3548" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460721452812_126515_3546" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460721452812_900465_3535" name="hausnummer" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1460721452812_956668_3551" body="&lt;para>Eine Hausnummer dient der genauen Lokalisierung eines Grundstücks, Gebäudes oder Gebäudeteils (Eingang) in einer Straße.&lt;/para> &#xA;&#xA;" annotatedElement="_16_5_4_940029b_1460721452812_900465_3535"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460721452812_396494_3552" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460721452812_631905_3550" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460721452812_823197_3537" name="postleitzahl" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1460721452812_355595_3559" body="&lt;para>Angabe der Postleitzahl des Baugrundstücks.&lt;/para>" annotatedElement="_16_5_4_940029b_1460721452812_823197_3537"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460721559089_968673_3599" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460721559089_935912_3598" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460721452812_631026_3538" name="ort" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1460721452812_265494_3563" body="&lt;para>Angabe der Ortsbezeichnung zum  Baugrundstück.&lt;/para>" annotatedElement="_16_5_4_940029b_1460721452812_631026_3538"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460721569653_45556_3601" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460721569653_474263_3600" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460721452812_264481_3540" name="zusatz" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1460721452812_283563_3571" body="&lt;para>Ein Anschriftenzusatz beinhaltet ggf. erforderliche weitere Präzisierungen zu der Anschrift.&lt;/para>&#xA;&lt;para>Beispiele: Hinterhof, 3. Aufgang, Haus A, 3. Stock, Appartement 25a,  3. Stock - Appartement 25 a, #325a, Raum 77&lt;/para>" annotatedElement="_16_5_4_940029b_1460721452812_264481_3540"/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460721452812_931762_3572" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460721452812_651078_3570" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_2_940029b_1513949697553_223796_9263" name="" supplier="_16_5_4_5b501fb_1387625291113_329233_5177" client="_16_5_4_940029b_1460721362807_804568_3502"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1461085536903_309557_5042" name="Nachrichtenkopf">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1461085723092_220631_5163" name="Nachricht.G2G">
            <ownedComment xmi:id="_16_5_4_940029b_1461160736823_266303_5862" body="&lt;para>Nachrichtenstruktur für die Kommunikation von Behörden mit anderen Behörden.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461085723092_220631_5163"/>
            <generalization xmi:id="_16_5_4_940029b_1461085868449_881846_5328" isSubstitutable="true" general="_16_5_4_1eeb04c1_1364308813094_424263_1603"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461085803478_900593_5223" name="standard" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461085803478_211779_5235" body="&lt;para>In diesem Attribut wird der Name des Standards übermittelt, aus dem die Nachricht stammt. Der Name des Standards wird durch den Fachstandard als fixed-Value auf Schemaebene festgelegt (z. B. &lt;emphasis>XPersonenstand&lt;/emphasis>).&lt;/para>" annotatedElement="_16_5_4_940029b_1461085803478_900593_5223"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461085803478_42479_5236" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461085803478_67980_5234" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461085803478_247496_5224" name="version" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461085803478_764045_5239" body="&lt;para>In diesem Attribut wird die Version des Standards übermittelt, aus dem die Nachricht stammt. Die Versionsbezeichnung wird durch den Fachstandard als fixed-Value auf Schemaebene festgelegt (z. B. &lt;emphasis>1.5.0&lt;/emphasis>).&lt;/para>" annotatedElement="_16_5_4_940029b_1461085803478_247496_5224"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461085803478_997437_5240" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461085803478_974164_5238" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461085803478_212359_5225" name="produkt" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461085803478_728817_5243" body="&lt;para>In diesem Attribut ist der Name des Produktes (der Software) einzutragen, mit dem diese Nachricht erstellt worden ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1461085803478_212359_5225"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461085803478_831177_5244" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461085803478_357711_5242" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461085803478_777731_5226" name="produkthersteller" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461085803478_257596_5247" body="&lt;para>In diesem Attribut ist der Name der Firma oder der Organisation einzutragen, die für das DV-Verfahren verantwortlich ist, mit dem diese Nachricht erstellt worden ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461085803478_777731_5226"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461085803478_759199_5248" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461085803478_758945_5246" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461085803478_638727_5227" name="produktversion" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461085803478_449349_5251" body="&lt;para>In diesem Attribut sollen ergänzende Hinweise zu dem Produkt, mit dem diese Nachricht erstellt worden ist, eingetragen werden. Dies sind Angaben, die für eine möglichst präzise Identifikation im Fehlerfall hilfreich sind, wie zum Beispiel Version und Patchlevel.&lt;/para>" annotatedElement="_16_5_4_940029b_1461085803478_638727_5227"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461085803478_541368_5252" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461085803478_3186_5250" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461085803478_960725_5228" name="test" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461085803494_197091_5255" body="&lt;para>Dieses Attribut ist optional. Ist es vorhanden, so sagt dies aus, dass es sich um eine Nachricht handelt, die (aus Sicht des Senders der Nachricht) nicht im normalen Produktivbetrieb behandelt werden soll. Über den Inhalt des Attributes wird nichts weiter ausgesagt, dies kann bilateral zwischen den Kommunikationspartnern vereinbart werden.&lt;/para>" annotatedElement="_16_5_4_940029b_1461085803478_960725_5228"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461085803494_824338_5256" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461085803478_233448_5254" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461086772758_675618_5352" name="nachrichtenkopf" visibility="private" type="_16_5_4_940029b_1461085754575_118769_5184" aggregation="composite" association="_16_5_4_940029b_1461086772758_223483_5351">
              <ownedComment xmi:id="_16_5_4_940029b_1461164407710_382238_5902" body="&lt;para>Dieses Element enthält die  Kopfinformationen zu Nachrichten des vorliegenden Typs.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1461086772758_675618_5352"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461086787424_432755_5363" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461086787424_84737_5362" name="" value="1"/>
