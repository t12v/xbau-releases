            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465470022975_209579_5291" name="Anonym_SachverhaltNutzungsaufnahme">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_723005_5385" body="&lt;para>Nur eine natürliche Person mit einer Bauvorlageberechtigung kann einen Baunatrag unterschreiben. Dieser Typ definiert die Angaben zum Nachweis der Bauvorlageberechtigung.&lt;/para>" annotatedElement="_16_5_4_940029b_1465470022975_209579_5291"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465477337577_720333_5854" name="geplanteNutzungsaufnahme" visibility="private" type="_16_5_4_940029b_1465388521993_510280_5790" aggregation="composite" association="_16_5_4_940029b_1465477337577_549003_5852">
                <ownedComment xmi:id="_16_5_4_940029b_1465477337577_995191_5857" body="&lt;para>Dieses Element dient dazu, den Zeitpunkt der geplanten Nutzungsaufnahme mitzuteilen.&lt;/para>" annotatedElement="_16_5_4_940029b_1465477337577_720333_5854"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465477337577_945292_5858" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465477337577_998310_5856" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465477337577_549003_5852" name="" memberEnd="_16_5_4_940029b_1465477337577_619829_5853 _16_5_4_940029b_1465477337577_720333_5854">
              <ownedEnd xmi:id="_16_5_4_940029b_1465477337577_619829_5853" name="" visibility="private" type="_16_5_4_940029b_1465470022975_209579_5291" association="_16_5_4_940029b_1465477337577_549003_5852"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465487002264_623886_6490" name="Untersagung">
              <ownedComment xmi:id="_16_5_4_940029b_1465488028984_608703_6506" body="&lt;para>Dieser Typ deckt alle Informationen ab, die zu einer verfügten Untersagung von Baubeginn bzw. Nutzungsaufnahme gehören können.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465487002264_623886_6490"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465487030846_227673_6491" name="anordnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1465487030846_362058_6494" body="&lt;para>Die Anordnung besteht aus einem Sachverhalt (Verstoß wird genannt, z.B. &quot;fehlende Absteckung&quot;), einer Begründung (die Rechtsnorm, die zur Untersagung führt) sowie einer Rechtsbehelfsbelehrung (Textbaustein, ggf. §-Referenz, ggf. als Anlage, z.B. pdf-Datei o.ä.).&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465487030846_227673_6491"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465487030846_340820_6495" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465487030846_888957_6493" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465487045647_613484_6498" name="fehlendeUnterlagen" visibility="private" type="_16_5_4_940029b_1465392561571_667791_6181" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1465487045662_798813_6501" body="&lt;para>Hinweise auf fehlende Voraussetzungen (Mängelliste) werden benannt. Es werden die Unterlagen genannt, deren Fehlen zur Untersagung geführt hat.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465487045647_613484_6498"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465487045662_923092_6502" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465487045662_29288_6500" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465389092557_873397_6026" name="" memberEnd="_16_5_4_940029b_1465389092557_343914_6027 _16_5_4_940029b_1465389092557_932726_6028">
            <ownedEnd xmi:id="_16_5_4_940029b_1465389092557_343914_6027" name="" visibility="private" type="_16_5_4_940029b_1465387558131_115019_5529" association="_16_5_4_940029b_1465389092557_873397_6026"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1465396791609_260643_6893" name="" supplier="_16_5_4_1d100e5_1384794877872_302539_331" client="_16_5_4_940029b_1465387558116_218898_5527"/>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465470022788_806914_5173" name="" memberEnd="_16_5_4_940029b_1465470022975_460290_5300 _16_5_4_940029b_1465470022788_771545_5180">
            <ownedEnd xmi:id="_16_5_4_940029b_1465470022975_460290_5300" name="" visibility="private" type="_16_5_4_940029b_1465470022788_57931_5169" association="_16_5_4_940029b_1465470022788_806914_5173"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465470022788_61936_5170" name="anzeige.nutzungsaufnahmeUntersagung.0911">
            <ownedComment xmi:id="_16_5_4_940029b_1465470022788_867472_5188" body="&lt;para>Die Nachricht enthält den Hinweis, dass die geplante Maßnahme die Voraussetzungen nicht erfüllt und benennt entsprechende Mängel. Sie fordert zur Nachbesserung auf.&lt;/para>" annotatedElement="_16_5_4_940029b_1465470022788_61936_5170"/>
            <generalization xmi:id="_16_5_4_940029b_1465470022788_149530_5184" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_895822_5186" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_22235_5329" body="&lt;para>Bezug auf Vorgang und Nachricht einer Nutzungsbeginnanzeige.&lt;/para>" annotatedElement="_16_5_4_940029b_1465470022788_895822_5186"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_570637_5330" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_704065_5328" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_794409_5185" name="untersagung" visibility="private" type="_16_5_4_940029b_1465487002264_623886_6490" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_415491_5325" body="&lt;para>Dieses Objekt enthält die nötigen Informationen zur verfügten Untersagung.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465470022788_794409_5185"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_631350_5326" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_844978_5324" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465470022788_57931_5169" name="anzeige.nutzungsaufnahme.0910">
            <ownedComment xmi:id="_16_5_4_940029b_1465470022788_336146_5182" body="&lt;para>Mit dieser Nachricht teilt der Bauherr der Bauaufsichtsbehörde mit, dass die Aufnahme der Nutzung des errichteten Gebäudes zu einem bestimmten Termin geplant ist. Mit dieser Anzeige werden (sofern eine Prüfung durch einen Prüfsachverständigen vorgesehen ist) die Bescheinigungen über die ordnungsgemäße Ausführung von Brandschutz und Standsicherheit mitvorgelegt.&lt;/para>" annotatedElement="_16_5_4_940029b_1465470022788_57931_5169"/>
            <generalization xmi:id="_16_5_4_940029b_1465470022788_143992_5177" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_80700_5179" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_793893_5311" body="&lt;para>Referenz auf einen Vorgang der Bauaufsichtsbehörde (ein durchlaufenes Baugenehmigungsverfahren) und ggf. auf eine Nachricht, die im Zusammenhang des Vorgangs verschickt worden ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1465470022788_80700_5179"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_173771_5312" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_611083_5310" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_771545_5180" name="sachverhalt" visibility="private" type="_16_5_4_940029b_1465470022975_209579_5291" aggregation="composite" association="_16_5_4_940029b_1465470022788_806914_5173">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_681168_5315" body="&lt;para>Hier ist der Sachverhalt der geplanten Nutzungsaufnahme angegeben.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465470022788_771545_5180"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_911414_5316" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_810670_5314" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_171924_5178" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_518674_5307" body="&lt;para>Hier sind die Anlagen bzw. Verweise auf solche Anlagen einzufügen. Das sind  insbesondere Bescheinigungen über die ordnungsgemäße Ausführung von Brandschutz und Standsicherheit und ggf. weitere Unterlagen, die für die Prüfung durch die Bauaufsichtsbehörde  benötigt werden.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1465470022788_171924_5178"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_841355_5308" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_683903_5306" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1469886407614_283581_5959" name="Informationsempfaenger" clientDependency="_16_5_4_940029b_1469886407739_45632_6005 _16_5_4_940029b_1469889118908_387477_6528">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469886407739_806875_6004" name="informationsempfaenger.benachrichtigung.0400">
            <ownedComment xmi:id="_16_5_4_940029b_1469886407739_657926_6033" body="&lt;para>Diese Nachricht transportiert Informationen über Stand bzw. Ergebnisse eines bauaufsichtlichen Vorgangs. Sie wird von der Bauaufsichtsbehörde an Dritte (Behörden und sonstige öffentliche Stellen) versendet, die diese Daten für ihre Aufgabenerfüllung benötigen. In einer gegebenen Nachricht sind diejenigen Daten des Vorgangs enthalten, die für diesen Informationsempfänger für seine Aufgabenerfüllung relevant sind.&lt;/para>" annotatedElement="_16_5_4_940029b_1469886407739_806875_6004"/>
            <generalization xmi:id="_16_5_4_940029b_1469886407739_236727_6026" isSubstitutable="true" general="_16_5_4_940029b_1461085723092_220631_5163"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469886407739_336431_6027" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469886407739_547222_6062" body="&lt;para>Dieses Element nennt den Vorgang der Bauaufsichtsbehörde, aus dem die Informationen entnommen sind. &lt;/para>&#xA;&lt;para>Eine Referenz auf eine Nachricht ist hier i.d.R. nicht einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1469886407739_336431_6027"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469886407739_459376_6063" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469886407739_702458_6061" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469886407739_215863_6028" name="anlass" visibility="private" type="_16_5_4_940029b_1469887076493_271076_6260" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469886407739_269424_6066" body="&lt;para>Hier wird der Anlass genannt: Welches bauaufsichtliche Ereignis hat zu dieser Benachrichtigung geführt?&lt;/para>" annotatedElement="_16_5_4_940029b_1469886407739_215863_6028"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469886407739_155068_6067" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469886407739_916434_6065" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469887840710_719342_6292" name="datenBescheid" visibility="private" type="_16_5_4_940029b_1469889566170_285621_6564" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469887840725_833143_6295" body="&lt;para>Hier werden Bescheiddaten übermittelt, soweit für den vorliegenden Anlass relevant. &lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469887840710_719342_6292"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469887840725_821642_6296" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469887840725_494176_6294" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469886407739_924777_6029" name="bauvorhaben" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469886407739_463631_6070" body="&lt;para>Hier werden Daten zum Bauvorhaben übermittelt, soweit für den vorliegenden Anlass relevant. &lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1469886407739_924777_6029"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469887462507_830874_6291" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469887462507_258314_6290" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469888121482_782568_6302" name="verortungAbbruch" visibility="private" type="_16_5_4_940029b_1460559782420_922066_3743" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469888121498_613562_6305" body="&lt;para>Hier werden Daten zum geplanten Abbruch eingetragen, soweit für den vorliegenden Anlass relevant. &lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1469888121482_782568_6302"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469888121498_175234_6306" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469888121498_134302_6304" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469888555259_827194_6462" name="verortungHausnummer" visibility="private" type="_16_5_4_940029b_1469888550138_987925_6442" aggregation="composite" association="_16_5_4_940029b_1469888555259_370946_6460">
              <ownedComment xmi:id="_16_5_4_940029b_1469894512991_354629_6650" body="&lt;para>Je Element sind Angaben zur georeferenzierten Lage einer  Hausnummer (Hauseingang) abgebildet.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469888555259_827194_6462"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469889438642_396939_6540" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469889438642_684932_6539" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469886407739_149305_6030" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469886407739_781024_6074" body="&lt;para>Hier werden relevante Anlagen eingefügt, soweit für den vorliegenden Anlass relevant. &lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1469886407739_149305_6030"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469886407739_635817_6075" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469886407739_31496_6073" name=""/>
            </ownedAttribute>
