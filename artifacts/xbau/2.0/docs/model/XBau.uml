          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364372067428_126125_9749" name="Code.Praefix">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1364372298604_449563_9789" body="&lt;para>Diese Codeliste enthält alle Präfixe, welche im DVDV zum Einsatz kommen. Diese Präfixe werden für die fachliche Adressierung über das DVDV verwendet.&lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_1eeb04c1_1364372067428_126125_9749"/>
            <generalization xmi:id="_16_5_4_1eeb04c1_1364372067428_396641_9750" isSubstitutable="true" general="_16_5_4_5b501fb_1387625280047_322339_5028"/>
