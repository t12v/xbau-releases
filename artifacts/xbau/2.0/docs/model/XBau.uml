            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1371546519804_685664_2271" name="weitergeleiteteNachricht" visibility="private">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1371555546066_665351_2601" body="&lt;para>In diesem Element wird die unveränderte fachliche Nachricht übermittelt, wie sie von der den Prozess auslösenden Behörde erstellt wurde.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1371546519804_685664_2271"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191711843_120906_985"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1371546531402_307396_2274" name="" value="1"/>
