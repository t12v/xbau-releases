              <ownedComment xmi:id="_16_5_4_1eeb04c1_1391428737089_152319_1270" body="&lt;para>In diesem Element wird die vollständige Liste der Behörden übermittelt, die im Laufe des Prozesses die fachliche Nachricht weitergeleitet haben.&lt;/para>&#xA;&lt;para>Diese Liste wird gebildet, indem die Behörde, die die Weiterleitungsnachricht erstellt, sich selbst an die (ggf. leere) Liste der &lt;code>weiterleitendeStellen&lt;/code> anhängt.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1391428737087_943181_1267"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1391428737089_135308_1271" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1391428737088_992849_1269" name="" value="1"/>
            </ownedAttribute>
