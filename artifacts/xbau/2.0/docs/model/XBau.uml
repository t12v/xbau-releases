            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364476550233_66087_2455" name="Code.SGS.Staatsangehoerigkeit">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364476550236_982543_2462" body="&lt;para>Diese Codeliste enthält alle Staatsangehörigkeiten im vollen politischen Sinne und entspricht dem &lt;quote>Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote> des Auswärtigen Amtes. Darüber hinaus enthält die Codeliste zusätzliche Einträge für ehemalige Staaten ab 1970 sowie Ersatzwerte (wie staatenlos, ungeklärt und ohne Angabe) sowie einen Eintrag für die Palästinensischen Gebiete.&lt;/para>&#xA;&lt;para>Die Bedeutung des übermittelten Schlüssels ergibt sich aus der Spalte &lt;quote>Staatsangehoerigkeit&lt;/quote> der veröffentlichten Genericcode-Datei.&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1364476550233_66087_2455"/>
              <generalization xmi:id="_16_5_4_1eeb04c1_1364476550234_365114_2457" isSubstitutable="true" general="_16_5_4_5b501fb_1387625280047_322339_5028"/>
              <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364476550234_384981_2458" name="code" visibility="private">
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
