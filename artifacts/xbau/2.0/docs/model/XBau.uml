            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364476536488_324647_2421" name="Code.SGS.Gebiet">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364476536491_887316_2428" body="&lt;para>Diese Codeliste für &lt;quote>Staatsgebiete und deren unselbständigen Teile&lt;/quote> umfasst Staatsgebiete sowie ggf. auch exterritoriale Teile mit eigenem ISO-Code. Sie entspricht den Einträgen im Länderverzeichnis des Auswärtigen Amtes und wird durch die Gebietsbezeichnung als Codename und durch numerische ID markiert. Enthält z.B. Einträge für Frankreich (Mutterland, das Hexagon), Französisch-Guayana (exterritoriales Übersee-Departement), Italien (Gebiet des Stiefels + Inseln), Vereinigtes Königreich (Mutterland: England, Schottland, Wales + Nordirland), britische Jungferninseln (Überseegebiet des Vereinigten Königreichs), Schottland.&lt;/para>&#xA;&lt;para>Die Bedeutung des übermittelten Schlüssels ergibt sich aus der Spalte &lt;quote>Gebietsbezeichnung_kurz&lt;/quote> der veröffentlichten Genericcode-Datei.&lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_1eeb04c1_1364476536488_324647_2421"/>
              <generalization xmi:id="_16_5_4_1eeb04c1_1364476536489_966484_2423" isSubstitutable="true" general="_16_5_4_5b501fb_1387625280047_322339_5028"/>
