            </packagedElement>
            <packagedElement xmi:type="uml:Enumeration" xmi:id="_16_5_4_1eeb04c1_1404904125483_524372_1741" name="Test"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_127f0398_1432803532642_6552_2787" name="" supplier="_16_5_4_5b501fb_1387625280030_115253_5005" client="_16_5_4_1eeb04c1_1364477284016_472414_2524"/>
