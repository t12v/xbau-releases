    <packagedElement xmi:type="uml:Model" xmi:id="_16_5_4_1d100e5_1384794823532_59933_328" name="XBau" clientDependency="_16_5_4_5b501fb_1398421542326_660552_1933 _16_5_4_940029b_1461254772677_52752_5374" viewpoint="">
      <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_1d100e5_1384794864912_344343_330" name="Basisdatentypen"/>
      <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_1d100e5_1384794877872_302539_331" name="Baukasten" clientDependency="_16_5_4_940029b_1461086907337_479976_5395 _16_5_4_940029b_1461087400098_673231_5446 _16_5_4_5b501fb_1398421954089_963191_2041 _16_5_4_5b501fb_1400581456272_172100_1655 _16_5_4_940029b_1427804664853_997754_3783 _16_5_4_940029b_1462266604624_778766_8289">
        <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_5b501fb_1398421954089_963191_2041" name="" supplier="_16_5_4_5b501fb_1387625271062_845493_4821" client="_16_5_4_1d100e5_1384794877872_302539_331"/>
        <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_5b501fb_1400581456272_172100_1655" name="" supplier="_16_5_4_5b501fb_1387625280030_115253_5005" client="_16_5_4_1d100e5_1384794877872_302539_331"/>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1408618910687_847379_2963" name="AnlageBauvorlage">
          <ownedComment xmi:id="_16_5_4_8a30247_1408618950539_93426_2982" body="&lt;para>Dieser Typ nimmt die Metadaten zu einer Bauvorlage bzw. sonstigen Anlage auf, die einem Antrag als Anlage beigefügt ist.&lt;/para>" annotatedElement="_16_5_4_8a30247_1408618910687_847379_2963"/>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1408619091277_368407_2990" name="bezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
            <ownedComment xmi:id="_16_5_4_8a30247_1408619147449_70100_2997" body="&lt;para>Hier ist eine deskriptive Bezeichnung der Bauvorlage bzw. sonstigen Anlage einzutragen, z. B. &quot;Grundriss 3. OG&quot;. &lt;/para>" annotatedElement="_16_5_4_8a30247_1408619091277_368407_2990"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465327555991_114782_6768" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465327555991_43377_6767" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1408619009086_730434_2983" name="versionsnummer" visibility="private">
            <ownedComment xmi:id="_16_5_4_8a30247_1408619185388_426657_2998" body="&lt;para>Hier ist eine Versionsnummer einzutragen. Sie dient dazu, (sequentiell eingereichte) Bauvorlagen (oder sonstige Anlagen) zu unterscheiden, die dieselbe Bezeichnung tragen.&lt;/para>" annotatedElement="_16_5_4_8a30247_1408619009086_730434_2983"/>
            <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465327561803_720905_6770" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465327561803_826132_6769" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1408619236437_124908_2999" name="datum" visibility="private">
            <ownedComment xmi:id="_16_5_4_8a30247_1408619298264_17580_3006" body="&lt;para>Hier ist das Datum der Erstellung bzw. der letzten Bearbeitung dieser Bauvorlage bzw. sonstigen Anlage einzutragen.&lt;/para>" annotatedElement="_16_5_4_8a30247_1408619236437_124908_2999"/>
            <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465327547253_461774_6766" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465327547253_448767_6765" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1408619391062_185340_3007" name="bauvorlageart" visibility="private" type="_16_5_4_940029b_1475588555524_74161_6543">
            <ownedComment xmi:id="_16_5_4_8a30247_1410188132361_100082_3209" body="&lt;para>Unterhalb dieses Elements wird die Art dieser Bauvorlage oder sonstigen Anlage näher spezifiziert.&lt;/para>" annotatedElement="_16_5_4_8a30247_1408619391062_185340_3007"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465327539581_806168_6764" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465327539581_813882_6763" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1408625590364_787747_3057" name="mimeType" visibility="private" type="_16_5_4_940029b_1483303261965_543138_5139">
            <ownedComment xmi:id="_16_5_4_8a30247_1410188137314_219406_3211" body="&lt;para>Dieses Element nennt - analog zur Übermittlung von E-Mail-Anlagen - den MIME-Typ (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot;&#xA;            xlink:href=&quot;https://de.wikipedia.org/wiki/Internet_Media_Type&quot;&#xA;            >https://de.wikipedia.org/wiki/Internet_Media_Type&lt;/link>) des enthaltenen Inhalts, sieht also Einträge wie text/xml, text/plain, application/gzip oder application/pdf vor. Mandatorisch, weil für den Empfänger wichtige Information zur Verarbeitung der Daten.&lt;/para>&#xA;&lt;para>Als Anlagen können u.a. auch IFC-Darstellungen (vgl. &lt;xref xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; linkend=&quot;spezifikation.einleitung&quot;/>) übermittelt werden. Entsprechende Kennzeichnungen des mimeTypes (ifc, ifcXML, fcZIP) sind dafür verfügbar.&lt;/para>" annotatedElement="_16_5_4_8a30247_1408625590364_787747_3057"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465326137115_498871_6762" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465326137115_73787_6761" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_940029b_1468231692531_923102_5585" name="primaerdokument" visibility="private">
            <ownedComment xmi:id="_16_5_4_940029b_1468231692531_181625_5588" body="&lt;para>Hier sind ggf. die Binärdaten der Anlage (Primärdokument) in base64-codierter Form einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1468231692531_923102_5585"/>
            <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191711843_120906_985"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468231692531_588599_5589" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468231692531_276583_5587" name=""/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_940029b_1465323422313_646977_6742" name="referenzPrimaerdokument" visibility="private">
            <ownedComment xmi:id="_16_5_4_940029b_1465323422313_390618_6745" body="&lt;para>Hier ist der Link auf das Primärdokument in einem Quellsystem einzutragen, der die Anlage (Datei) identifiziert bzw. als Ressource verfügbar macht.&lt;/para>" annotatedElement="_16_5_4_940029b_1465323422313_646977_6742"/>
            <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191702187_214129_966"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465323422313_778442_6746" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465323422313_849553_6744" name=""/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_940029b_1465323220009_117547_6735" name="dateinameAnhang" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
            <ownedComment xmi:id="_16_5_4_940029b_1465323220025_277318_6738" body="&lt;para>Hier ist der Name der Datei (Primärdokument) einzutragen, als die die Bauvorlage als Anlage zum Antrag übermittelt wird.&lt;/para>" annotatedElement="_16_5_4_940029b_1465323220009_117547_6735"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465323220025_978224_6739" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465323220025_553837_6737" name=""/>
          </ownedAttribute>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1408705895800_629557_4010" name="Entwurfsverfasser">
          <ownedComment xmi:id="_16_5_4_8a30247_1408705928504_523657_4029" body="&lt;para>Dieser Typ dient dazu, die Daten des  Entwurfsverfassers zu übermitteln, der verantwortlich an der Vorbereitung des  Bauprojekts mitwirkt bzw. mitgewirkt hat.&lt;/para>" annotatedElement="_16_5_4_8a30247_1408705895800_629557_4010"/>
          <ownedAttribute xmi:id="_16_5_4_940029b_1460625640639_216405_4876" name="personendaten" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517" aggregation="composite" association="_16_5_4_940029b_1460625640639_113817_4874">
            <ownedComment xmi:id="_16_5_4_940029b_1460625640639_676913_4879" body="&lt;para>Hier sind die Daten zur Person des  Entwurfsverfassers einzutragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1460625640639_216405_4876"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460625640639_579127_4880" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460625640639_757998_4878" name=""/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_940029b_1465320433717_159041_6330" name="bauvorlageberechtigung" visibility="private" type="_16_5_4_940029b_1465320233547_555419_6283" aggregation="composite" association="_16_5_4_940029b_1465320433717_376869_6328">
            <ownedComment xmi:id="_16_5_4_940029b_1465320433717_41803_6333" body="&lt;para>Hier sind die Daten einzutragen, die die Bauvorlageberechtigung des Entwurfsverfassers belegen.&lt;/para>" annotatedElement="_16_5_4_940029b_1465320433717_159041_6330"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465320433717_987034_6334" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465320433717_683269_6332" name=""/>
          </ownedAttribute>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1408964097602_950511_3483" name="FlurstueckKennzeichnung">
          <ownedComment xmi:id="_16_5_4_8a30247_1408964140406_260187_3502" body="&lt;para>Typ zur eindeutigen Identifikation eines Flurstücks.&lt;/para>&#xA;&lt;para>Ein Flurstück ist ein amtlich vermessener Teil der Erdoberfläche. Das Liegenschaftskataster ordnet jedem Flurstück des jeweiligen Nummerierungsbezirks (Flur oder Gemarkung) eine Flurstücksnummer zu.&#xA;&lt;/para>&#xA;&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_8a30247_1408964097602_950511_3483"/>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1408964599802_91559_3503" name="bundesland" visibility="private" clientDependency="_16_5_4_8ae0277_1427194878441_42353_7435" type="_16_5_4_8a30247_1423044461203_939066_6394">
            <ownedComment xmi:id="_16_5_4_8a30247_1410188461488_459574_3290" body="&lt;para>Hier wird das Bundesland genannt, in dem sich das Flurstück befindet.&lt;/para>" annotatedElement="_16_5_4_8a30247_1408964599802_91559_3503"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465375451399_21960_5522" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465375451399_94626_5521" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1422969627950_52913_6195" name="flurstueck" visibility="private" clientDependency="_16_5_4_8a30247_1422969825126_748524_6205" type="_16_5_4_940029b_1422888990355_651351_3077" association="_16_5_4_8ae0277_1427194978142_462923_7460">
            <ownedComment xmi:id="_16_5_4_940029b_1468227329223_484000_5573" body="&lt;para>Hier sind in jedem Fall die Angaben zum Flustück einzutragen, auf dem gemäß Antrag gebaut werden soll. Es sind die identifzierenden Angaben zum Flurstück einzutragen.&lt;/para>" annotatedElement="_16_5_4_8a30247_1422969627950_52913_6195"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465375445297_803876_5520" name="" value="1"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465375445297_154803_5519" name="" value="1"/>
          </ownedAttribute>
        </packagedElement>
