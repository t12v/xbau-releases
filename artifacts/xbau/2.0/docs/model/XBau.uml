        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1469909667809_817143_5940" name="BautechnischeNachweise" clientDependency="_16_5_4_940029b_1469909667809_816039_5943">
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1469909667809_816039_5943" name="" supplier="_16_5_4_1d100e5_1384794877872_302539_331" client="_16_5_4_940029b_1469909667809_817143_5940"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469909667809_97639_5945" name="bautechnischeNachweise.pruefauftrag.0500">
            <ownedComment xmi:id="_16_5_4_940029b_1469909667825_926851_5966" body="&lt;para>Diese Nachricht enthält alle Auftragsinformationen und die zu prüfenden Dokumente (die bautechnischen Nachweise zu Brandschutz und / oder zu Standsicherheit).&lt;/para>" annotatedElement="_16_5_4_940029b_1469909667809_97639_5945"/>
            <generalization xmi:id="_16_5_4_940029b_1469909667825_221799_5962" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469909667825_566467_5963" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469909667825_545414_6024" body="&lt;para>Hier trägt die Bauaufsichtsbehörde die Vorgangsnumme (Beauftragung und damit zusammenhängende Kommunikation) für künftige Referenzierung ein.&lt;/para>" annotatedElement="_16_5_4_940029b_1469909667825_566467_5963"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469909667825_365757_6025" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469909667825_809308_6023" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469949298512_323921_5732" name="bezugZuPruefauftrag" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469949298512_682160_5735" body="&lt;para>Dieses Element wird verwendet, falls eine Referenz auf einen vorhergehenden Prüfauftrag (bezogen auf ggf. dasselbe bzw. erweiterte Gebäude) übermittelt werden soll.&lt;/para>" annotatedElement="_16_5_4_940029b_1469949298512_323921_5732"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469949420439_532610_5740" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469949420439_456019_5739" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469950213207_886460_5775" name="pruefauftrag" visibility="private" type="_16_5_4_940029b_1469949980871_187287_5756">
              <ownedComment xmi:id="_16_5_4_940029b_1469950213207_611321_5778" body="&lt;para>In diesem Element wird ein Prüfauftrag abgebildet. Jeder Prüfauftrag bezieht sich auf genau einen bautechnischen Nachweis.&lt;/para>" annotatedElement="_16_5_4_940029b_1469950213207_886460_5775"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469950942264_711766_5798" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469950942264_943919_5797" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469952132793_164810_5956" name="rahmendatenGebuehrenberechnung" visibility="private" type="_16_5_4_940029b_1475680854021_621117_6026">
              <ownedComment xmi:id="_16_5_4_940029b_1469952132793_844701_5959" body="&lt;para>In diesem Element sind Rahmendaten zur Gebührenberechnung aus Sicht der Bauaufsichtsbehörde abgebildet, soweit sie auf den hier erteilten Auftrag anwendbar sind. Sie geben dem Auftragnehmer die Möglichkeit, die Komplexität des Bauvorhabens einzuschätzen, in dessen Kontext der Auftrag erteilt wird, und entsprechend Aufwand und Auftragswert des Prüfauftrags zu kalkulieren.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469952132793_164810_5956"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475680494588_259823_6025" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475680494588_632382_6024" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469949543928_251973_5741" name="bauvorhaben" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469949543928_189314_5744" body="&lt;para>Hier sind die Daten zum Bauvorhaben (Wer, Was, Wo) enthalten.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469949543928_251973_5741"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469949543928_35068_5745" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469949543928_612162_5743" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469949584052_908578_5748" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469949584052_187798_5751" body="&lt;para>Dieses Objekt enthält die Unterlagen (bzw. deren Metadaten), die für die Erfüllung des Prüfauftrags benötigt werden. Auch die zu prüfenden bautechnischen Nachweis gehören zu diesen Unterlagen.&lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1469949584052_908578_5748"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469949584052_322289_5752" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469949584052_917196_5750" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469909667809_758060_5948" name="bautechnischeNachweise.pruefauftragKorrektur.0503">
            <ownedComment xmi:id="_16_5_4_940029b_1469909667825_442747_5985" body="&lt;para>Diese Nachricht enthält geänderte oder ergänzte Daten des Prüfauftrags bzw. seiner Anlagen. Sie bezieht sich auf einen bereits erteilten Prüfauftrag und auf eine zu diesem&#xA;vorliegende Mängel- bzw. Befundliste.&lt;/para>" annotatedElement="_16_5_4_940029b_1469909667809_758060_5948"/>
            <generalization xmi:id="_16_5_4_940029b_1469909667825_706368_5981" isSubstitutable="true" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469909667825_813568_5982" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469909667825_986729_6070" body="&lt;para>Hier ist die Vorgangsnummer (Beauftragung) einzutragen (analog zu Nachricht 0500). Außerdem ist auf die Nachricht 0502 zu verweisen, auf deren Basis die Beauftragung angepasst worden ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469909667825_813568_5982"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469909667825_347932_6071" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469909667825_388247_6069" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469985012845_395835_5887" name="bezugZuPruefauftrag" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469985012849_708505_5894" body="&lt;para>Hier kann eine korrigierte Referenz auf einen vorhergehenden Prüfauftrag stehen.&lt;/para>" annotatedElement="_16_5_4_940029b_1469985012845_395835_5887"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469985012849_99987_5895" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469985012849_605190_5893" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469985012845_938861_5888" name="pruefauftrag" visibility="private" type="_16_5_4_940029b_1469949980871_187287_5756">
              <ownedComment xmi:id="_16_5_4_940029b_1469985012849_651205_5898" body="&lt;para>In diesem Element wird der ggf. angepasste Prüfauftrag übermittelt. &lt;/para>" annotatedElement="_16_5_4_940029b_1469985012845_938861_5888"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469985012849_614112_5899" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469985012849_126291_5897" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469985012849_153054_5889" name="rahmendatenGebuehrenberechnung" visibility="private" type="_16_5_4_940029b_1475680854021_621117_6026">
              <ownedComment xmi:id="_16_5_4_940029b_1469985012853_963345_5902" body="&lt;para>Hier können die ggf. korrigierten Rahmendaten zur Gebührenberechnung eingetragen werden.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469985012849_153054_5889"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469985012853_661082_5903" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469985012853_614707_5901" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469985012849_987517_5890" name="bauvorhaben" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469985012853_638702_5906" body="&lt;para>Hier werden angepasste Daten zum Bauvorhaben (Wer, Was, Wo) eingetragen, falls eine solche Anpassung in einem Bereich notwendig war (Bruttoprinzip).&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469985012849_987517_5890"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469985318946_86315_5923" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469985318946_166488_5922" name=""/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469985012849_74941_5891" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469985012853_104544_5910" body="&lt;para>Hier können korrigierte bzw. ergänzte Unterlagen, die für die Erfüllung des Prüfauftrags benötigt werden, eingetragen werden.&lt;/para>&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1469985012849_74941_5891"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469985326729_462485_5925" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469985326729_743800_5924" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469909667809_586604_5949" name="bautechnischeNachweise.formellePruefung.0502">
            <ownedComment xmi:id="_16_5_4_940029b_1469909667825_89392_5993" body="&lt;para>Diese Nachricht nennt Mängel bzw. Nachbesserungsbedarf zu einem erteilten Prüfauftrag.&lt;/para>" annotatedElement="_16_5_4_940029b_1469909667809_586604_5949"/>
            <generalization xmi:id="_16_5_4_940029b_1469909667825_115778_5987" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469909667825_536985_5988" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469909667825_291750_6084" body="&lt;para>Hier trägt der Auftragnehmer die Vorgangsnumme der Bauaufsichtsbehörde ein, die ihm mit der Beauftragung (Nachricht 0500) zugestellt wurde. Außerdem wird die Referenz auf die Nachricht 0500 eingetragen.&lt;/para>" annotatedElement="_16_5_4_940029b_1469909667825_536985_5988"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469909667825_133030_6085" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469909667825_721573_6083" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469954130145_707787_6026" name="befundliste" visibility="private" type="_16_5_4_940029b_1467843232886_870322_5578" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469954130145_268432_6029" body="&lt;para>Nach der Prüfiung des Auftrags durch den Auftragnehmer: Hier sind die Ergebnisse der formellen Prüfung als Befundliste enthalten. Für jeden Befund sind die entsprechenden Parameter gefüllt, die Inhalt und Bezug des Befundes nachvollziehbar machen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1469954130145_707787_6026"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469954130145_146807_6030" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469954130145_704820_6028" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469909667825_764937_5950" name="bautechnischeNachweise.pruefbericht.0506">
            <ownedComment xmi:id="_16_5_4_940029b_1469909667825_868541_6000" body="&lt;para>Diese Nachricht nennt die Ergebnisse der Prüfung der vorgelegten bautechnischen Nachweise.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1469909667825_764937_5950"/>
            <generalization xmi:id="_16_5_4_940029b_1469909667825_183802_5995" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469909667825_196036_5996" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469909667825_548327_6106" body="&lt;para>In diesem Element wird auf Vorgang und Prüfauftrag Bezug genommen. &lt;/para>" annotatedElement="_16_5_4_940029b_1469909667825_196036_5996"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469909667825_119089_6107" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469909667825_856146_6105" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469909667825_382413_5997" name="pruefbericht" visibility="private" type="_16_5_4_940029b_1470064704646_498940_5928" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469909667825_45665_6110" body="&lt;para>In diesem Element werden die Prüfergebnisse dargestellt und durch Nebensbestimmungen und weitere Anmerkungen ergänzt.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469909667825_382413_5997"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469909667825_284753_6111" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469909667825_124404_6109" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469909667825_636205_5999" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469909667825_293187_6118" body="&lt;para>Hier sind, soweit zutreffend, die  durch den Prüfingenieur überarbeiteten beziehungsweise kommentierten Bauvorlagen angefügt.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469909667825_636205_5999"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469909667825_483806_6119" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469909667825_588796_6117" name=""/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469910026518_152820_6186" name="bautechnischeNachweise.rechnung.0507">
            <ownedComment xmi:id="_16_5_4_940029b_1469910026518_886623_6193" body="&lt;para>Diese Nachricht enthält die Rechnung für die erbrachten Leistungen des Auftragnehmers.&lt;/para>&#xA;&#xA;&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1469910026518_152820_6186"/>
            <generalization xmi:id="_16_5_4_940029b_1469910026518_205840_6188" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469910026518_379308_6189" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469910026518_128293_6198" body="&lt;para>In diesem Element wird auf Vorgang und Prüfauftrag Bezug genommen. &lt;/para>" annotatedElement="_16_5_4_940029b_1469910026518_379308_6189"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469910026518_806626_6199" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469910026518_997932_6197" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470083850344_995328_6004" name="zeitaufwand" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470083850344_957967_6007" body="&lt;para>In dieses Element trägt der Auftragnehmer den Aufwand für die Leistungserbringung in Minuten ein.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470083850344_995328_6004"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470083850344_314425_6008" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470083850344_323677_6006" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470083755646_970279_5997" name="rahmendatenGebuehrenberechnung" visibility="private" type="_16_5_4_940029b_1475680854021_621117_6026">
              <ownedComment xmi:id="_16_5_4_940029b_1470083755646_710522_6000" body="&lt;para>In diesem Element sind Rahmendaten zur Gebührenberechnung aus Sicht des Auftragnehmers nach abgeschlossener Leistung abgebildet.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470083755646_970279_5997"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470083755646_892684_6001" name="" value="*"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470083755646_426010_5999" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469910063190_204364_6222" name="bautechnischeNachweise.auftragsbestaetigung.0501">
            <ownedComment xmi:id="_16_5_4_940029b_1469910063206_479498_6230" body="&lt;para>Der Prüfingenieur bestätigt mit dieser Nachricht, dass er den Auftrag erhalten und angenommen hat.&lt;/para>" annotatedElement="_16_5_4_940029b_1469910063190_204364_6222"/>
            <generalization xmi:id="_16_5_4_940029b_1469910063190_756788_6224" isSubstitutable="true" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469910063190_112133_6225" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469910063206_810644_6235" body="&lt;para>Dieses Elements stellt den Bezug zum erteilten Auftrag (Vorgangsnummer) und zur entsprechenden &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; linkend=&quot;XBau.Nachrichten.BautechnischeNachweise.bautechnischeNachweise.pruefauftrag.0500&quot;>Nachricht 0500&lt;/link> her. Dieser Auftrag wird mit dieser Nachricht bestätigt.&lt;/para>" annotatedElement="_16_5_4_940029b_1469910063190_112133_6225"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469910063206_820841_6236" name="" value="1"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469910063206_31290_6234" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1470041878031_671287_5926" name="Datentypen">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469949980871_187287_5756" name="AnonymPruefauftrag">
              <ownedComment xmi:id="_16_5_4_940029b_1469949980871_569522_5760" body="" annotatedElement="_16_5_4_940029b_1469949980871_187287_5756"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1469950793857_762635_5786" name="gegenstand" visibility="private" type="_16_5_4_8a30247_1408530429014_910874_2581">
                <ownedComment xmi:id="_16_5_4_940029b_1469950793861_576977_5789" body="&lt;para>Dieses Element bezeichnet die Art des zu prüfenden bautechnischen Nachweises.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469950793857_762635_5786"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469950917258_351397_5796" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469950917258_435396_5795" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1469949980871_1038_5759" name="auftrag" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195">
                <ownedComment xmi:id="_16_5_4_940029b_1469949980871_554082_5767" body="&lt;para>Dieses Element enthält die Formulierung des Prüfauftrags.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1469949980871_1038_5759"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469950855248_72251_5794" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469950855248_528164_5793" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470064704646_498940_5928" name="Anonym_Pruefbericht">
              <ownedComment xmi:id="_16_5_4_940029b_1470064704646_71591_5936" body="" annotatedElement="_16_5_4_940029b_1470064704646_498940_5928"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1470064704646_419203_5930" name="ergebnis" visibility="private" type="_16_5_4_940029b_1470064787705_550306_5973">
                <ownedComment xmi:id="_16_5_4_940029b_1470064704646_614007_5939" body="&lt;para>Hier wird das Prüfergebnis formuliert und erläutert.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470064704646_419203_5930"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470064704646_253384_5940" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470064704646_374333_5938" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1470064704646_630525_5934" name="abweichung" visibility="private" type="_16_5_4_940029b_1467898745212_460254_5732">
                <ownedComment xmi:id="_16_5_4_940029b_1470064704646_995070_5955" body="&lt;para>Hier können bei Bedarf Empfehlungen an die Bauaufsichtsbehörde zur Zulassung von Abweichungen eingetragen werden.&lt;/para>" annotatedElement="_16_5_4_940029b_1470064704646_630525_5934"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470064704646_812744_5956" name="" value="*"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470064704646_946007_5954" name=""/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1470064704646_660331_5935" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467899960094_58945_5827">
                <ownedComment xmi:id="_16_5_4_940029b_1470064704646_222598_5959" body="&lt;para>Hier sind die Nebenbestimmungen zum Prüfergebnis einzufügen (z. B. Auflagen, die einem positiven Prüfergebnis beigegeben werden), falls solche gemäß der Bewertung des Prüfingenieurs festgesetzt werden sollten. Diese Nebenbestimmungen haben dieselbe Struktur wie im Kontext eines Bescheides der Bauaufsichtsbehörde. Im Unterschied zu dort findet im vorliegenden Kontext aber nur der Rechtsbereich des Bauordnungsrechts Anwendung.&lt;/para>" annotatedElement="_16_5_4_940029b_1470064704646_660331_5935"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470064704646_356709_5960" name="" value="*"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470064704646_621382_5958" name=""/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470064787705_550306_5973" name="Anonym_Pruefergebnis">
              <ownedComment xmi:id="_16_5_4_940029b_1470064787705_739746_5977" body="&#xA;" annotatedElement="_16_5_4_940029b_1470064787705_550306_5973"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1470064787705_896522_5975" name="istOrdnungsgemaess" visibility="private" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1470064787705_565993_5980" body="&lt;para>Falls das Prüfergebnis positiv ist - also der Inhalt der vorgelegten Bauvorlagen den Vorschriften entspricht -, so ist in diesem Element 'true' zu übermitteln, andernfalls 'false'.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470064787705_896522_5975"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470064787705_927962_5981" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470064787705_471618_5979" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1470064787705_414844_5976" name="erlaeuterung" visibility="private" type="_16_5_4_940029b_1467895898882_574009_5195" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1470064787705_141659_5984" body="&lt;para>In diesen Textabschnitten wird aufgelistet, welche Gegenstände geprüft wurden, welche Methoden dabei angewendet wurden und zu welchen Ergebnissen der Prüfer gelangt ist.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1470064787705_414844_5976"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470064787705_669354_5985" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470064787705_149600_5983" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475680854021_621117_6026" name="RahmendatenGebuehrenberechnung">
              <ownedComment xmi:id="_16_5_4_940029b_1475680854021_190670_6031" body="&lt;para>Dieser Typ dient dazu, Rahmendaten zur Gebührenberechnung für einen erteilten Prüfauftrag an einen Prüfingenieur abzubilden. Sie geben dem Auftragnehmer die Möglichkeit, die Komplexität des Bauvorhabens einzuschätzen, in dessen Kontext der Auftrag erteilt wird, und entsprechend Aufwand und Auftragswert des Prüfauftrags zu kalkulieren. Der Typ stellt die alternativen Ansätze für die Gebührenberechnung dar, in der Anwendung des Typs ist genau eine dieser Alternativen anzuwenden.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475680854021_621117_6026"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475683800881_638539_6490" name="anrechenbareKosten" visibility="private" type="_16_5_4_940029b_1475683796926_830352_6470" association="_16_5_4_940029b_1475683800881_44205_6488">
                <ownedComment xmi:id="_16_5_4_940029b_1475683800881_693798_6493" body="&lt;para>Gebührenberechnung auf der Basis der anrechenbaren Kosten, orientiert an der Tabelle der anrechenbaren Bauwerte gemäß Anlage 1 zu § 27 Abs. 1 Satz 1 M-PPVO&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475683800881_638539_6490"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475683800881_80193_6494" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475683800881_191095_6492" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475680854021_570934_6030" name="herstellungskosten" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1475680854021_367293_6042" body="&lt;para>Gebührenberechnung nach Herstellungskosten: Prognostizierte Herstellungskosten des Bauvorhabens in Eurocent.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475680854021_570934_6030"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475680854021_956551_6043" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475680854021_509281_6041" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475680854021_217128_6028" name="aufwand" visibility="private" type="_16_5_4_940029b_1483129729635_585998_5155">
                <ownedComment xmi:id="_16_5_4_940029b_1475680854021_669681_6034" body="&lt;para>Gebührenberechnung nach Aufwand: Die Gebühr für die beauftragtenLeistungen wird nach Zeitaufwand in Rechnung zu stellen sein. In diesem Element ist der Stundensatz (netto) in Eurocent anzugeben, zu dem der Auftragnehmer seine Leistungen in Rechnung stellen darf.&lt;/para>&#xA;&lt;para>Diese Alternative wird angewendet, falls die Basiswerte nicht ermittelt werden können. Falls das Bauvorhaben in einem Umbau oder Anbau besteht, kann z. B. kein Bauvolumen ermittelt werden.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1475680854021_217128_6028"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475680854021_562624_6035" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475680854021_751859_6033" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1475683800881_44205_6488" name="" memberEnd="_16_5_4_940029b_1475683800881_585215_6489 _16_5_4_940029b_1475683800881_638539_6490">
              <ownedEnd xmi:id="_16_5_4_940029b_1475683800881_585215_6489" name="" visibility="private" type="_16_5_4_940029b_1475680854021_621117_6026" association="_16_5_4_940029b_1475683800881_44205_6488"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475683796926_830352_6470" name="Anonym_AnrechenbareKosten">
              <ownedAttribute xmi:id="_16_5_4_940029b_1475683822837_819392_6506" name="bauwerksklasse" visibility="private" type="_16_5_4_8a30247_1408376570428_985611_2905" aggregation="composite" association="_16_5_4_940029b_1475683822837_952656_6504">
                <ownedComment xmi:id="_16_5_4_940029b_1475684079513_809502_6511" body="&lt;para>Hier ist die Bauwerksklasse abgebildet, die dem Bauvorhaben zugeordnet werden kann.&lt;/para>" annotatedElement="_16_5_4_940029b_1475683822837_819392_6506"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475683822837_107017_6509" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475683822837_725213_6508" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475683808072_142355_6499" name="bauwert" visibility="private" type="_16_5_4_940029b_1475682117613_388096_6192" aggregation="composite" association="_16_5_4_940029b_1475683808072_257111_6497">
                <ownedComment xmi:id="_16_5_4_940029b_1475683808072_133847_6502" body="&lt;para>Hier wird der anrechenbare Bauwert des Bauvorhabens dargestellt. Pro Gebäudeart, die im Bauvorhaben vorgesehen ist, ist eine Position aufzuführen.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1475683808072_142355_6499"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475683808072_913122_6503" name="" value="*"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475683808072_390879_6501" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1483129067114_628366_5148" name="summeGesamt" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1483129067114_543035_5151" body="&lt;para>Summe über alle Positionen (in Eurocent). Der anrechenbare Bauuwert für das Bauvorhaben.&lt;/para>&#xA;&lt;para>&lt;emphasis role=&quot;rot&quot;>Bauwerksklasse streichen? Sie scheint nicht in die Berechnung dieser Summe einzufließen.&lt;/emphasis>&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1483129067114_628366_5148"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483129067114_897006_5152" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483129067114_977600_5150" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475682117613_388096_6192" name="Anonym_AnrechenbareBauwerte">
              <ownedAttribute xmi:id="_16_5_4_940029b_1483137464830_987979_5008" name="gebaeudeartBauwert" visibility="private" type="_16_5_4_940029b_1483136948155_787690_4951">
                <ownedComment xmi:id="_16_5_4_940029b_1483137464830_331617_5011" body="&lt;para>In diesem Element sind die Gebäudeart mit dem zugehörigem relativen Bauwert (Eurocent pro Kubikmeter) genannt. Sie sind bei der Berechnung der anrechenbaren Bauwerte zu berücksichtigen gemäß zutreffender Verordnung für die Prüfingenieure und Prüfsachverständige.&lt;/para>" annotatedElement="_16_5_4_940029b_1483137464830_987979_5008"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483137464830_445979_5012" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483137464830_975739_5010" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475683090953_235033_6414" name="zuschlaege" visibility="private" type="_16_5_4_940029b_1483136949034_455812_4978">
                <ownedComment xmi:id="_16_5_4_940029b_1475683388853_549099_6424" body="&lt;para>In diesem Element sind die Zuschläge zu nennen, die bei der Berechnung der anrechenbaren Bauwerte zu berücksichtigen sind, gemäß zutreffender Verordnung für die Prüfingenieure und Prüfsachverständige.&lt;/para>" annotatedElement="_16_5_4_940029b_1475683090953_235033_6414"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475683193723_459427_6422" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475683193723_148400_6421" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475683157980_292689_6416" name="bruttorauminhalt" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1475683395748_845592_6425" body="&lt;para>Bruttorauminhalt dieser Gebäudeart: Hier ist die Anzahl an m3 anzugeben, mit der diese Gebäudeart im Bauvorhaben repräsentiert ist.&lt;/para>" annotatedElement="_16_5_4_940029b_1475683157980_292689_6416"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475683185895_972404_6420" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475683185895_208856_6419" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1483128947245_533913_5140" name="summePosition" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1483128947245_452047_5143" body="&lt;para>Der anrechenbare Bauwert für diese Position (in Eurocent), also für diese Gebäudeart.&lt;/para>" annotatedElement="_16_5_4_940029b_1483128947245_533913_5140"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483128947245_268795_5144" name="" value="1"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483128947245_505965_5142" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1475683822837_952656_6504" name="" memberEnd="_16_5_4_940029b_1475683822837_380366_6505 _16_5_4_940029b_1475683822837_819392_6506">
              <ownedEnd xmi:id="_16_5_4_940029b_1475683822837_380366_6505" name="" visibility="private" type="_16_5_4_940029b_1475683796926_830352_6470" association="_16_5_4_940029b_1475683822837_952656_6504"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1475683808072_257111_6497" name="" memberEnd="_16_5_4_940029b_1475683808072_264354_6498 _16_5_4_940029b_1475683808072_142355_6499">
              <ownedEnd xmi:id="_16_5_4_940029b_1475683808072_264354_6498" name="" visibility="private" type="_16_5_4_940029b_1475683796926_830352_6470" association="_16_5_4_940029b_1475683808072_257111_6497"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1483129729635_585998_5155" name="Anonym_Aufwand">
              <ownedAttribute xmi:id="_16_5_4_940029b_1483129729635_774638_5158" name="stundensatz" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1483129729635_269139_5169" body="&lt;para>Der Stundensatz der der Berechnung des voraussitchtlichen Aufwands zugrundeliegt (in Eurocent).&lt;/para>" annotatedElement="_16_5_4_940029b_1483129729635_774638_5158"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
