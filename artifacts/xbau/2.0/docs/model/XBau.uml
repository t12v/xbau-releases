            <ownedComment xmi:id="_16_5_4_1eeb04c1_1392822315938_113951_3176" body="&lt;para>Dieser Typ realisiert die abstrakte Oberklasse für alle Fehlernachrichten .&lt;/para>" annotatedElement="_16_5_4_1eeb04c1_1392822315927_509689_3166"/>
            <generalization xmi:id="_16_5_4_1eeb04c1_1392822315929_12518_3168" isSubstitutable="true" general="_16_5_4_1eeb04c1_1364308813094_424263_1603"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1392822315929_859030_3169" name="standard" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" isReadOnly="true">
