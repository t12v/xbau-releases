          <ownedAttribute xmi:id="_16_5_4_940029b_1483136949050_721930_4983" name="listVersionID" visibility="private" isReadOnly="true">
            <ownedComment xmi:id="_16_5_4_940029b_1483136949050_694083_4997" body="&lt;para>Die Version der Codeliste, welche der Interpretation des übermittelten Schlüssels zu Grunde gelegt werden soll.&lt;/para>&#xA;&#xA;" annotatedElement="_16_5_4_940029b_1483136949050_721930_4983"/>
