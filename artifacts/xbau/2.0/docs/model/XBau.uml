            <ownedAttribute xmi:id="_16_5_4_940029b_1476117799500_729075_6124" name="baumassenzahl" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476117799500_538476_6127" body="&lt;para>Die Baumassenzahl (BMZ, BauNVO, § 21), gibt an, wie viel Kubikmeter Baumasse je Quadratmeter Fläche eines Baugrundstücks zulässig oder vorhanden sind.&lt;/para>&#xA;" annotatedElement="_16_5_4_940029b_1476117799500_729075_6124"/>
