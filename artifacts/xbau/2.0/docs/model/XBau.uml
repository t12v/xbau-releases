          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1453987450065_712239_3319" name="Code.DVDV.Behoerdenschluessel">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1453987450080_250722_3326" body="&lt;para>Diese Codeliste enthält die Behördenschlüssel zur Präfix dbs. Ein solcher Behördenschlüssel wird unter anderem für Bundes- und Landesbehörden von der Koordinierenden Stelle DVDV vergeben.&lt;/para>&#xA;" annotatedElement="_16_5_4_1eeb04c1_1453987450065_712239_3319"/>
