    <ownedAttribute xmi:id="_16_5_4_5b501fb_1287395686258_528623_346" name="Leistungserbringer" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1287396077285_450575_620" body="Mit dieser Eigenschaft kann der Leistungserbringer bezüglich des ausgewählten Dienstes angegeben werden. Diese Information wird momentan in der Übersichtstabelle zu den Diensten genutzt." annotatedElement="_16_5_4_5b501fb_1287395686258_528623_346"/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1287395782577_288791_614" name="" value="1"/>
      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1287395782554_408332_613" name=""/>
    </ownedAttribute>
    <ownedAttribute xmi:id="_16_5_4_5b501fb_1287395712310_824936_347" name="Hinweis" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1287396142749_717251_621" body="Mit dieser Eigenschaft können Hinweise zur produktiven Nutzung des Dienstes (z.B. bzgl. DVDV) gegeben werden. Sie werden momentan in der Übersichtstabelle zu den Diensten aufgeführt." annotatedElement="_16_5_4_5b501fb_1287395712310_824936_347"/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1287395844802_356062_616" name="" value="1"/>
      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1287395844802_419781_615" name=""/>
    </ownedAttribute>
    <ownedAttribute xmi:id="_16_5_4_5b501fb_1287395972027_726252_617" name="Nachrichtenbeschreibung" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1287396454388_485124_622" body="In der Übersichtstabelle zu den Diensten werden in der Spalte &quot;Nachrichten&quot; alle Nachrichten des Dienstes aufgeführt (Nachrichtennummern). Häufig macht ein ergänzender Kommentar zu den Nummern Sinn. Dieser kann mit der Eigenschaft &quot;NachrichtenBeschreibung&quot; vorgenommen werden.&#xA;&#xA;Falls die genannte Liste von Nachrichtennummern nicht herausgeschrieben werden soll, muss zu Beginn des Eintrags &quot;[nl]&quot; (no list) stehen. Darauf können beliebige Inhalte folgen." annotatedElement="_16_5_4_5b501fb_1287395972027_726252_617"/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1287396004877_249935_619" name="" value="1"/>
      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1287396004877_208102_618" name=""/>
    </ownedAttribute>
  </packagedElement>
