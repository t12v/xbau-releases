						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1592308467398_364415_14476' name='ansprechpartner' visibility='private' type='_19_0_3_136d03d4_1655652146888_346373_9674'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1592308467398_707031_14478' body='&lt;para&gt;Pro Instanz dieses Elements kann eine Angabe zu einer Person als operativer Ansprechpartner für die Organisation übermittelt werden.&lt;/para&gt;'>
