						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8a30247_1422977426056_110707_6767' name='anschrift' visibility='private' aggregation='composite' type='_16_5_4_8a30247_1422884384004_352244_4233' association='_16_5_4_8ae0277_1427192330303_284590_6843'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422977426150_843785_6889' body='&lt;para&gt;Angaben zur Anschrift der Organisation, die über den Typ der Anschrift auf deren Verwendung als Postanschrift, Niederlassungsanschrift oder Gründungsanschrift verweist.&lt;/para&gt;'>
