						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1622094358071_613420_9436' name='linie' visibility='private' aggregation='composite' type='_19_0_3_136d03d4_1622094389299_293379_9451'>
