	<XOEV_Profil:xoevCodeliste xmi:id='_19_0_3_136d03d4_1612313333075_139278_10233' base_Class='_19_0_3_136d03d4_1612313332051_551267_9598' beschreibung='Die Bundesrepublik Deutschland ist ein Zusammenschluss von Bundesländern. Die meisten Bundesländer umfassen mehrere Kreise und Bezirke bzw. Regierungsbezirke. Diese Codeliste stellt alle Bezirke nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS).' herausgebernameKurz='Destatis' herausgebernameLang='Statistisches Bundesamt, Wiesbaden' kennung='urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:bezirk' nameKurz='Destatis Bezirk' nameLang='Bezirke bzw. Regierungsbezirke der deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes' nameTechnisch='Bezirk'/>
	<xmi:Extension extender='MagicDraw UML 19.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
	<XOEV_Profil:xoevCodeliste xmi:id='_19_0_3_136d03d4_1612313333075_444275_10231' base_Class='_19_0_3_136d03d4_1612313332050_480442_9596' beschreibung='Diese Codeliste stellt alle Gemeinden Deutschlands durch den Amtlichen Regionalschlüssel (ARS) dar, wie im Gemeindeverzeichnis des Statistischen Bundesamtes enthalten. Darüber hinaus enthält die Codeliste für die Stadtstaaten Hamburg, Bremen und Berlin Einträge für Stadt-/Ortsteile bzw. Stadtbezirke. Diese Einträge sind mit einem entsprechenden Hinweis versehen.' herausgebernameKurz='Destatis' herausgebernameLang='Statistisches Bundesamt, Wiesbaden' kennung='urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:rs' nameKurz='Destatis ARS' nameLang='Gemeinden gemäß Amtlicher Regionalschlüssel (ARS)' nameTechnisch='rs'/>
	<xmi:Extension extender='MagicDraw UML 19.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
	<XOEV_Profil:xoevCodeliste xmi:id='_19_0_3_136d03d4_1612313333075_841872_10235' base_Class='_19_0_3_136d03d4_1612313332051_671210_9600' beschreibung='Enthält alle Registergerichte. Als Schlüssel für die Datenübermittlung ist die Spalte XJustiz_Id zu verwenden.' herausgebernameKurz='XGewerbeanzeige' herausgebernameLang='Betreiber XGewerbeanzeige (KoSIT und IT.NRW im Auftrag des Bundesministeriums für Wirtschaft und Energie)' kennung='urn:xoev-de:xgewerbeanzeige:codeliste:registergerichte' nameKurz='Registergerichte' nameLang='Registergerichte' nameTechnisch='registergerichte'/>
	<xmi:Extension extender='MagicDraw UML 19.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
	<XOEV_Profil:xoevCodeliste xmi:id='_19_0_3_136d03d4_1612313333075_262114_10232' base_Class='_19_0_3_136d03d4_1612313332050_732201_9597' beschreibung='Codeliste Staatsgebiete aus der Staats- und Gebietssystematik des Statistischen Bundesamtes.Sie basiert auf dem &lt;quote&gt;Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote&gt; des Auswärtigen Amtes.&#10;&#10;Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;&gt;www.xrepository.de&lt;/link&gt;) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.' herausgebernameKurz='Destatis' herausgebernameLang='Statistisches Bundesamt, Wiesbaden' kennung='urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:staatsgebiete' nameKurz='Destatis Staatsgebiete' nameLang='Staatsgebiete gemäß der Staats- und Gebietssystematik des Statistischen Bundesamts' nameTechnisch='staatsgebiete'/>
	<xmi:Extension extender='MagicDraw UML 19.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
	<XOEV_Profil:xoevCodeliste xmi:id='_19_0_3_136d03d4_1612313333075_246817_10234' base_Class='_19_0_3_136d03d4_1612313332051_117859_9599' beschreibung='Die Bundesrepublik Deutschland ist ein Zusammenschluss von Ländern. Die meisten Bundesländer umfassen mehrere Kreise und Bezirke. Diese Codeliste stellt die deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS).' herausgebernameKurz='Destatis' herausgebernameLang='Statistisches Bundesamt, Wiesbaden' kennung='urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:bundesland' nameKurz='Destatis Bundesland' nameLang='Länder der Bundesrepublik Deutschland' nameTechnisch='bundesland'/>
