	</xmi:Extension>
	<XOEV_Profil:xoevABIE xmi:id='_16_5_4_8a30247_1422884384004_318523_4234application1' base_Class='_16_5_4_8a30247_1422884384004_352244_4233' Abweichung='Enthält zusätzlich ein Element, in das Straße und Hausnummer als eine Zeichenfolge eingetragen werden.' MotivationDerAbweichung='Die eID führt gemäß BSI TR-03110 Advanced Security Mechanisms for Machine Readable Travel Documents and eIDAS token die Straße und Hausnummer in einem einzigen Feld „street“. Für die Übertragung von Anschriftsdaten nach Verwendung der eID-Funktion des neuen Personalausweises können Straße und Hausnummer nicht allgemeingültig getrennt werden. Für die Übernahme der Daten wird daher ein gemeinsames Feld benötigt. &#10;&#10;'/>
	<xmi:Extension extender='MagicDraw UML 19.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
