								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1617018517576_983893_9430' name='nachrichtenkopf' visibility='private' aggregation='composite' type='_19_0_3_136d03d4_1617016621104_44246_9389'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1617018517586_890521_9458' body='&lt;para&gt;Dieses Element enthält die  Kopfinformationen zu Nachrichten des vorliegenden Typs.&lt;/para&gt;&#10;'>
