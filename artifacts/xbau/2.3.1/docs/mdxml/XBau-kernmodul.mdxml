					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_8a30247_1422977426041_172815_6757' name='Organisation'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422977426056_688199_6771' body='&lt;para&gt;Eine Organisation ist eine  Vereinigung mehrerer natürlicher oder juristischer Personen bzw. eine rechtsfähige Personengesellschaft zu einem gemeinsamen Zweck.&lt;/para&gt;&#10;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_8a30247_1422977426041_172815_6757'/>
						</ownedComment>
