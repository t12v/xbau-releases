							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1594568645486_545150_14707' name='anschreiben' visibility='private' aggregation='composite' type='_18_0_2_940029b_1535727067041_864259_10734'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1594568645506_942495_14716' body='&lt;para&gt;In dieses Element ist der Anschreibentext der Nachricht einzutragen.&lt;/para&gt;&#10;'>
