						</ownedComment>
						<elementImport xmi:type='uml:ElementImport' xmi:id='_18_0_2_8c5027b_1531399846277_160508_10307'>
							<importedElement href='XML_Schema_Profile.mdzip#magicdraw_1046854034025_149241_159'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='XML Schema Profile::http://www.w3.org/2001/XMLSchema' referentType='Package'/>
								</xmi:Extension>
							</importedElement>
						</elementImport>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_8c5027b_1531399846277_292752_10309' name='show' visibility='private' aggregation='shared' type='_18_0_2_8c5027b_1531399846277_549411_10318'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_8c5027b_1531399846292_177474_10358' body='&#10;        The &#39;show&#39; attribute is used to communicate the desired presentation &#10;        of the ending resource on traversal from the starting resource; it&#39;s &#10;        value should be treated as follows: &#10;        new - load ending resource in a new window, frame, pane, or other &#10;              presentation context&#10;        replace - load the resource in the same window, frame, pane, or &#10;                  other presentation context&#10;        embed - load ending resource in place of the presentation of the &#10;                starting resource&#10;        other - behavior is unconstrained; examine other markup in the &#10;                link for hints &#10;        none - behavior is unconstrained &#10;      '>
								<annotatedElement xmi:idref='_18_0_2_8c5027b_1531399846277_292752_10309'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_8c5027b_1531399846277_763279_10310' name='actuate' visibility='private' aggregation='shared' type='_18_0_2_8c5027b_1531399846277_756733_10319'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_8c5027b_1531399846292_540514_10360' body='&#10;        The &#39;actuate&#39; attribute is used to communicate the desired timing &#10;        of traversal from the starting resource to the ending resource; &#10;        it&#39;s value should be treated as follows:&#10;        onLoad - traverse to the ending resource immediately on loading &#10;                 the starting resource &#10;        onRequest - traverse from the starting resource to the ending &#10;                    resource only on a post-loading event triggered for &#10;                    this purpose &#10;        other - behavior is unconstrained; examine other markup in link &#10;                for hints &#10;        none - behavior is unconstrained&#10;      '>
								<annotatedElement xmi:idref='_18_0_2_8c5027b_1531399846277_763279_10310'/>
							</ownedComment>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_8c5027b_1531399846277_133313_10311' name='href' visibility='private' aggregation='shared'>
