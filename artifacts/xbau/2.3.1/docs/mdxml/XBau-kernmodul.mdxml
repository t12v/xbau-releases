	</xmi:Extension>
	<XOEV_Profil:xoevVersionStandard xmi:id='_16_5_4_1d100e5_1384795021953_565292_401application2' base_Model='_16_5_4_1d100e5_1384794823532_59933_328' version='1.2' nameModellierungswerkzeug='MagicDraw' versionModellierungswerkzeug='19.0' versionXGenerator='3.0.1' versionXOEVHandbuch='2.3' beschreibung='Für diese Version wurden die Datentypen zu den am Bauvorhaben Beteiligten ergänzt und differenziert (Vertreter von Personengruppen). Es wurde eine eigene ID für jede Person im Rahmen der Bearbeitung des Vorgangs eingeführt. Es wurden erweiterte Möglichkeiten geschaffen, um Ansprechpartner für Organisationen zu benennen. Für die Anbindung der IT-Verfahren der Fachbehörden an OZG-Portale und Kollaborationsplattformen sind jetzt erweiterte Mechanismen definiert. Außerdem sind jetzt die Datentypen zur Übertragung von Primärdokumenten und zur Darstellung von formatiertem Text mit weiterer Funktionalität ausgestattet. - Alle Änderungen und Erweiterungen sind in der Versionshistorie des Spezifikationsdokuments dokumentiert.'/>
	<xmi:Extension extender='MagicDraw UML 19.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
	<XOEV_Profil:xoevStandard xmi:id='_16_5_4_1d100e5_1384795021953_565292_401application3' base_Model='_16_5_4_1d100e5_1384794823532_59933_328' kennung='urn:xoev-de:bmk:standard:xbau-kernmodul' nameTechnisch='xbau-kernmodul' nameKurz='XBau-Kernmodul' nameLang='XBau-Kernmodul' beschreibung='Das XBau-Kernmodul umfasst die von den XBau-Fachmodulen gemeinsam verwendeten Daten- und Nachrichtentypen.'/>
	<xmi:Extension extender='MagicDraw UML 19.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
