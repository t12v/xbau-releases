					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_136d03d4_1611781889004_410228_10088' name='Anonym_Link'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1611781889005_455806_10089'>
							<annotatedElement xmi:idref='_19_0_3_136d03d4_1611781889004_410228_10088'/>
						</ownedComment>
