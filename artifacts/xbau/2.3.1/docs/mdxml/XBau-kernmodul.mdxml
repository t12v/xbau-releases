						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1655652255505_600320_9677' name='funktion' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_18_0_6_5b501fb_1565874046564_914647_6619'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN SPEC 91379::2019-03::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1655654488729_831208_9691' body='&lt;para&gt;Hier kann über eine Funktionsangabe die Zuständigkeit des Ansprechpartners bezeichnet werden.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_136d03d4_1655652255505_600320_9677'/>
