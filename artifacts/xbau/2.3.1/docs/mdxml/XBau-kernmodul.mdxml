								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743652_473661_12260' body='&lt;para&gt;Dieses Element enthält den Namen des Ortes (Gemeinde, Ortschaft oder Stadt), zu der die Anschrift gehört.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743624_940876_12234'/>
