	<XOEV_Profil:xoevABIE xmi:id='_16_5_4_8a30247_1422977426041_170800_6759application1' base_Class='_16_5_4_8a30247_1422977426041_172815_6757' Abweichung='Reihenfolge der Attribute wurde geändert: anschrift steht jetzt vor kommunikation.' MotivationDerAbweichung='Einheitlichkeit herstellen. Andere Objekte des Baukastens (KK-Vorlage NatuerlichePerson; Klasse des Baukastens AmBauBeteiligtePerson) verwendet die Reihenfolge Name - Anschrift - Kommunikation. Deswegen sollte diese Reihenfolge auch in Bezug auf die Klasse Organisation eingehalten werde.'/>
	<xmi:Extension extender='MagicDraw UML 19.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
