							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1611781889007_996082_10097' body='&lt;para&gt;Hier ist die zur URL passende Beschreibung der Webseite oder Ressource einzutragen. &lt;/para&gt;&#10;'>
