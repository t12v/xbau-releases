							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1622232188108_112752_9507' name='ablageort' visibility='private' aggregation='composite' type='_19_0_3_136d03d4_1629826627962_517090_9457'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1622232188109_210575_9509' body='&lt;para&gt;Mit diesem Element kann ein Ablageort innerhalb der jeweiligen Struktur des Portals bzw. der Plattform für das Dokument angegeben werden.&lt;/para&gt;&#10;'>
