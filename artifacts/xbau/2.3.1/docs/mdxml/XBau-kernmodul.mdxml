						<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1541262170416_617292_11908' body='&lt;para&gt;Mit diesem Element wird der Fehler einer gegebenenen Nachricht benannt, der zu der vorliegenden Rückweisung geführt hat.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_18_0_2_940029b_1541262088385_220444_11846'/>
