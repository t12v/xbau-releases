    <packagedElement xmi:type="uml:Extension" xmi:id="_10_0EAPbeta2_be00301_1123763368170_851654_899" name="" visibility="public" memberEnd="_10_0EAPbeta2_be00301_1123763368170_975889_900 _10_0EAPbeta2_be00301_1123763368170_287875_901" navigableOwnedEnd="_10_0EAPbeta2_be00301_1123763368170_287875_901">
