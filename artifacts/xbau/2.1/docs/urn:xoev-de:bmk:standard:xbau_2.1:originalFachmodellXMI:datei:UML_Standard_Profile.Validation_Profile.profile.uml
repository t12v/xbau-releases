        <ownedRule xmi:id="_12_0_8f90291_1163122599062_7981_388" name="Not Abstract Classifier">
          <eAnnotations xmi:id="_3znSM1U7Eem76qy_rce7yg" source="MagicDraw">
            <details xmi:id="_3znSNFU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163122599062_7981_388"/>
          </eAnnotations>
          <ownedComment xmi:id="_12_0_8f90291_1163122660390_153460_390" annotatedElement="_12_0_8f90291_1163122599062_7981_388" body="If at least one operation is abstract implies that classifier is abstract">
            <eAnnotations xmi:id="_3znSNVU7Eem76qy_rce7yg" source="MagicDraw">
              <details xmi:id="_3znSNlU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163122660390_153460_390"/>
            </eAnnotations>
          </ownedComment>
          <constrainedElement xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#BehavioralFeature"/>
          <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163122630109_431704_389" name="">
            <eAnnotations xmi:id="_3znSN1U7Eem76qy_rce7yg" source="MagicDraw">
              <details xmi:id="_3znSOFU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163122630109_431704_389"/>
            </eAnnotations>
            <language>OCL2.0</language>
            <body>isAbstract implies owner.oclAsType(Classifier).isAbstract</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:id="_12_0_8f90291_1163188975562_203783_287" name="Not Public Interface Feature">
          <eAnnotations xmi:id="_3znSOVU7Eem76qy_rce7yg" source="MagicDraw">
            <details xmi:id="_3znSOlU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163188975562_203783_287"/>
          </eAnnotations>
          <ownedComment xmi:id="_12_0_8f90291_1163189140796_541803_292" annotatedElement="_12_0_8f90291_1163188975562_203783_287" body="All the features in the interface should be public">
            <eAnnotations xmi:id="_3znSO1U7Eem76qy_rce7yg" source="MagicDraw">
              <details xmi:id="_3znSPFU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163189140796_541803_292"/>
