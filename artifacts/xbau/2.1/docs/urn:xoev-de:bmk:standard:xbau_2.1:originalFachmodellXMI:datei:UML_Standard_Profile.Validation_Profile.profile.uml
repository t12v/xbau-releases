        <ownedComment xmi:id="_15_5_8f90291_1219661439435_488772_649" annotatedElement="_15_5_8f90291_1219661439435_75305_647" body="Stereotype must have meta class">
          <eAnnotations xmi:id="_3znRkVU7Eem76qy_rce7yg" source="MagicDraw">
            <details xmi:id="_3znRklU7Eem76qy_rce7yg" key="md_id" value="_15_5_8f90291_1219661439435_488772_649"/>
          </eAnnotations>
        </ownedComment>
        <constrainedElement xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Stereotype"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_15_5_8f90291_1219661439435_51280_650" name="">
          <eAnnotations xmi:id="_3znRk1U7Eem76qy_rce7yg" source="MagicDraw">
