        <eAnnotations xmi:id="_3znRz1U7Eem76qy_rce7yg" source="MagicDraw">
          <details xmi:id="_3znR0FU7Eem76qy_rce7yg" key="md_id" value="_16_5beta2_641020e_1236170876667_839583_420"/>
