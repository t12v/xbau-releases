          <eAnnotations xmi:id="_3znRV1U7Eem76qy_rce7yg" source="MagicDraw">
            <details xmi:id="_3znRWFU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163301831843_10377_344"/>
          </eAnnotations>
          <language>OCL2.0</language>
          <body>(not self.oclIsKindOf(EnumerationLiteral)) implies classifier->notEmpty()</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163459124796_403964_572" name="No Association Multiplicity">
        <eAnnotations xmi:id="_3znRWVU7Eem76qy_rce7yg" source="MagicDraw">
          <details xmi:id="_3znRWlU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163459124796_403964_572"/>
        </eAnnotations>
        <ownedComment xmi:id="_12_0_8f90291_1163460010828_397902_581" annotatedElement="_12_0_8f90291_1163459124796_403964_572" body="Specify multiplicity">
          <eAnnotations xmi:id="_3znRW1U7Eem76qy_rce7yg" source="MagicDraw">
            <details xmi:id="_3znRXFU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163460010828_397902_581"/>
          </eAnnotations>
        </ownedComment>
        <constrainedElement xmi:type="uml:Class" href="pathmap://UML_METAMODELS/UML.metamodel.uml#Association"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163459368859_47007_576" name="">
          <eAnnotations xmi:id="_3znRXVU7Eem76qy_rce7yg" source="MagicDraw">
            <details xmi:id="_3znRXlU7Eem76qy_rce7yg" key="md_id" value="_12_0_8f90291_1163459368859_47007_576"/>
          </eAnnotations>
          <language>OCL2.0</language>
          <body>self.memberEnd ->forAll ( n | (not n.lowerValue.oclIsUndefined()) or (not n.upperValue.oclIsUndefined()))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163463318250_346504_600" name="Nameless Class">
        <eAnnotations xmi:id="_3znRX1U7Eem76qy_rce7yg" source="MagicDraw">
