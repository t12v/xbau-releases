            <details xmi:id="_3znSJlU7Eem76qy_rce7yg" key="md_id" value="_17_0_5beta_903028d_1373622738070_948780_3315"/>
          </eAnnotations>
        </specification>
      </ownedRule>
    </packagedElement>
