				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1442751673366_72365_3503' name='Quittung'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1442754664850_43584_5257' body='&lt;para&gt;Dieser Datentyp umfasst alle Informationen, die zur Quittung eines Sachverhalts erforderlich sind.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1442751673366_72365_3503'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1442739072330_739607_5665' name='ursprungsereignis' visibility='private' type='_16_5_4_1eeb04c1_1371478525209_839263_1505'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1442739175383_771249_6177' body='&lt;para&gt;Mit diesem Element werden die Informationen übermittelt, mit denen der Einzelfall in der ursprünglichen Nachricht bzw. Sammelnachricht eindeutig identifiziert werden kann.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_5b501fb_1442739072330_739607_5665'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
