					<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1eeb04c1_1364372067428_396641_9750'>
						<general href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625280047_322339_5028'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
