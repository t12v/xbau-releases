							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1380019856051_736962_1712' name='gebaeude' visibility='private' aggregation='composite' type='_16_5_4_1eeb04c1_1380019783198_447885_1675' association='_16_5_4_1eeb04c1_1380019856051_376159_1711'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1380024053064_888631_1792' body='&lt;para&gt;Angaben für die Übermittlung einer Gebäudeanschrift.&lt;/para&gt;&#10;'>
