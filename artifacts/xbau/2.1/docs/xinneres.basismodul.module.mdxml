				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364382738190_314891_1582' name='Behoerde.Erreichbar'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364382738190_4513_1591' body='&lt;para&gt;Dieser Typ enthält Angaben über den Namen und die Erreichbarkeit einer Behörde. Eine Behörde  im Sinne des Verwaltungsverfahrensgesetzes ist jede Stelle, die Aufgaben der öffentlichen Verwaltung wahrnimmt.&lt;/para&gt;&#10;&lt;para&gt;Anders als in dem Typ &lt;emphasis&gt;Behoerde&lt;/emphasis&gt; sind in diesem Typen alle Angaben zur Kontaktaufnahme mit der übermittelten Behörde Pflichtelemente.&lt;/para&gt;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364382738190_314891_1582'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1eeb04c1_1364383015751_507230_2065' general='_16_5_4_1eeb04c1_1364313722451_850604_9366'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364382738190_624767_1584' name='behoerdenname' visibility='private'>
						<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1430905108746_786153_1911' body='&lt;para&gt;Es ist der Name der Behörde zu übermitteln.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364382738190_624767_1584'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364382738190_524282_1593' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1364382738190_20264_1594' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364382738190_866140_1586' name='behoerdenkennung' visibility='private' aggregation='composite' type='_16_5_4_1eeb04c1_1364313732581_658593_9386' association='_16_5_4_1eeb04c1_1364382997291_816964_2044'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364382738190_551655_1600' body='&lt;para&gt;Es wird die eindeutige Behördenkennung angegeben, über die die Behörde im DVDV ermittelt werden kann. Diese hier übermittelte Behördenkennung muss es dem Leser einer Nachricht ermöglichen, den Autor einer Nachricht im DVDV zu ermitteln um diesem ggf. erforderliche elektronische Mitteilungen senden zu können (bspw. Quittungen oder Fehlernachrichten). &lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364382738190_866140_1586'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364383065581_866294_2070' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1364383065581_135377_2071' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364382738190_722321_1588' name='erreichbarkeit' visibility='private' aggregation='composite' type='_16_5_4_1eeb04c1_1364313776811_220119_9414' association='_16_5_4_1eeb04c1_1364382995951_487358_2025'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364382738190_873732_1608' body='&lt;para&gt;Angaben zur Erreichbarkeit dieser Behörde per Telefon, Telefax, E-Mail etc.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364382738190_722321_1588'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364383115241_607703_2076' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1364383115241_313759_2077' value='*'/>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1386157306690_724066_1150' name='anschrift' visibility='private' aggregation='composite' type='_16_5_4_1eeb04c1_1380019660674_995526_1587' association='_16_5_4_1eeb04c1_1386157306690_834841_1148'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1386157306691_326638_1153' body='&lt;para&gt;Die Anschrift dieser Behörde (für persönliches Erscheinen oder die Zusendung von Dokumenten per Briefpost an die Behörde).&lt;/para&gt;&#10;&#10;&lt;!---&#10;&lt;para&gt;Der in der Anschrift hinterlegte Gemeindeschlüssel ist nicht zur Ermittlung einer Meldebehörde im DVDV vorgesehen. Hierfür ist ausschließlich die Behördenkennung (&lt;emphasis role=&quot;codebf&quot;&gt;behoerdenkennung&lt;/emphasis&gt;) zu verwenden.&lt;/para&gt;&#10;&#10;&lt;para&gt;&lt;emphasis role=&quot;rot&quot;&gt;*** Frage 1 ***&lt;/emphasis&gt;: Ist die Übermittlung einer postalischen Anschrift im Kontext des Nachrichtenkopfes erforderlich?&lt;/para&gt;&#10;--&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1386157306690_724066_1150'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1386157306691_988041_1152' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1386157306692_107413_1154' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364313722451_850604_9366' name='Behoerde'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364371684488_105835_9714' body='&lt;para&gt;Dieser Typ enthält Angaben über den Namen und die Erreichbarkeit einer Behörde. Eine Behörde  im Sinne des Verwaltungsverfahrensgesetzes ist jede Stelle, die Aufgaben der öffentlichen Verwaltung wahrnimmt.&lt;/para&gt;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364313722451_850604_9366'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364313743191_46553_9404' name='behoerdenname' visibility='private'>
						<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1d100e5_1384262798576_654159_1882' body='&lt;para&gt;Es ist der Name der Behörde zu übermitteln. &lt;/para&gt;&#10;&lt;para&gt;Er dient auch dazu, eine ggfs. erforderliche manuelle Klärung zu beschleunigen, indem bspw. der Autor einer Nachricht im Klartext übermittelt, an welche Behörde er die Nachricht schicken wollte.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364313743191_46553_9404'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364313751351_193740_9406' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1364313751351_747531_9407' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364313913401_902665_9449' name='behoerdenkennung' visibility='private' aggregation='composite' type='_16_5_4_1eeb04c1_1364313732581_658593_9386' association='_16_5_4_1eeb04c1_1364313913401_124412_9448'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364314552692_222453_9698' body='&lt;para&gt;Es wird die eindeutige Behördenkennung angegeben, über die die Behörde im DVDV ermittelt werden kann. Diese hier übermittelte Behördenkennung muss es dem Leser einer Nachricht ermöglichen, den Autor einer Nachricht im DVDV zu ermitteln um diesem ggf. erforderliche elektronische Mitteilungen senden zu können (bspw. Quittungen oder Fehlernachrichten). &lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364313913401_902665_9449'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364401014459_342103_2263' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1364401014459_781178_2264' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364314023501_443069_9518' name='erreichbarkeit' visibility='private' aggregation='composite' type='_16_5_4_1eeb04c1_1364313776811_220119_9414' association='_16_5_4_1eeb04c1_1364314023501_170081_9517'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364314889752_481140_9699' body='&lt;para&gt;Angaben zur Erreichbarkeit dieser Behörde per Telefon, Telefax, E-Mail etc.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364314023501_443069_9518'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364314034251_354533_9528'/>
						<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1364314034251_753500_9529' value='*'/>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1386157300162_861825_1139' name='anschrift' visibility='private' aggregation='composite' type='_16_5_4_1eeb04c1_1380019660674_995526_1587' association='_16_5_4_1eeb04c1_1386157300156_98235_1137'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1386157300163_492642_1142' body='&lt;para&gt;Die Anschrift dieser Behörde (für persönliches Erscheinen oder die Zusendung von Dokumenten per Briefpost an die Behörde).&lt;/para&gt;&#10;&lt;!---&#10;&lt;para&gt;Der in der Anschrift hinterlegte Gemeindeschlüssel ist nicht zur Ermittlung einer Meldebehörde im DVDV vorgesehen. Hierfür ist ausschließlich die Behördenkennung (&lt;emphasis role=&quot;codebf&quot;&gt;behoerdenkennung&lt;/emphasis&gt;) zu verwenden.&lt;/para&gt;&#10;&#10;&lt;para&gt;&lt;emphasis role=&quot;rot&quot;&gt;*** Frage 1 ***&lt;/emphasis&gt;: Ist die Übermittlung einer postalischen Anschrift im Kontext des Nachrichtenkopfes erforderlich?&lt;/para&gt;&#10;--&gt; '>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1386157300162_861825_1139'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1386157300163_123219_1141'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1386157300166_445204_1143' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364313732581_658593_9386' name='Behoerdenkennung'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364383264641_604199_2080' body='&lt;para&gt;Die &lt;emphasis role=&quot;codebf&quot;&gt;Behoerdenkennung&lt;/emphasis&gt; fasst die Elemente zusammen, unter denen eine Behörde als Anbieter elektronischer Services im DVDV verzeichnet ist. Sie besteht aus einem Präfix und der eigentlichen Kennung. Grundsätzlich gibt es zu jedem Präfix eine entsprechende Schlüsseltabelle für die Kennung.&lt;/para&gt;&#10;&#10;&lt;para&gt;Zum Beispiel werden Standesämter über das Präfix &lt;emphasis role=&quot;codebf&quot;&gt;psw&lt;/emphasis&gt; und die Standesamtsnummer adressiert.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364313732581_658593_9386'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364372151465_159655_9779' name='praefix' visibility='private' type='_16_5_4_1eeb04c1_1364372067428_126125_9749'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364372188687_205724_9787' body='&lt;para&gt;Klasse für Behördenkennungen.&lt;/para&gt;&#10;&#10;&lt;para&gt;Die Liste der Präfixe für Behördenkennungen wird durch das Bundesverwaltungsamt (BVA) als koordinierende Stelle für das DVDV verwaltet.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364372151465_159655_9779'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364372167190_845048_9781' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1364372167190_864270_9782' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364372167190_911035_9783' name='kennung' visibility='private' type='_16_5_4_1eeb04c1_1364378060427_980996_1230'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364372211322_658216_9788' body='&lt;para&gt;Dieses Element kennzeichnet eine Behörde innerhalb der durch den Präfix bezeichneten Klasse eindeutig.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364372167190_911035_9783'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1364372176690_807506_9785' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1364372176690_521977_9786' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1364378060427_980996_1230' name='Code.Behoerdenkennung'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1364378060442_693479_1237' body='&lt;para&gt;Die zu verwendende Schlüsseltabelle ergibt sich aus dem Nachrichtenkontext. Zum Beispiel ist bei der Datenübermittlung an ein Standesamt die Schlüsseltabelle der Standesamtsnummern und somit eine Standesamtsnummer als Behördenkennung zu verwenden.&lt;/para&gt;&#10;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1364378060427_980996_1230'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1eeb04c1_1364378060427_23672_1232'>
						<general href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625280047_322339_5028'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Code::1.0::Code' referentType='Class'/>
							</xmi:Extension>
						</general>
					</generalization>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1364378060427_93271_1233' name='code' visibility='private'>
