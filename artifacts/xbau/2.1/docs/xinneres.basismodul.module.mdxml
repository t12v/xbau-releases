							</xmi:Extension>
						</general>
					</generalization>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1431426978137_49471_2985' name='JahrMonat'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_5_44f60732_1469716751218_712121_8089' body='&lt;para&gt;Mit diesem Datentyp wird ein teilweise bekanntes Datum übermittelt. Vom Datum sind nur Jahr und Monat bekannt.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1431426978137_49471_2985'/>
