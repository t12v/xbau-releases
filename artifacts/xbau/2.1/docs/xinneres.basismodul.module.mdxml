								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1431428269651_222330_3236' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1431428269651_160367_3237' value='1'/>
							</modelExtension>
						</xmi:Extension>
