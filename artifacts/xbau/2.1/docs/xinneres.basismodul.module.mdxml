				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1392818604581_267765_2502' name='Rueckweisung.GrundSpezifisch'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1392820815251_923577_2578' body='&lt;para&gt;In diesem Datentyp wird ein Grund für die Rückweisung der Nachricht in Form eines beliebigen kontextspezifischen Fehlercodes (bspw. aus dem BZSt-Fehlerkatalog) oder einer Fehlerbeschreibung genauer spezifiziert.&lt;/para&gt;&#10;&lt;para&gt;Sofern in einem (fachlichen) Prozess kontextspezifische Fehlercodes verwendet werden, ist dies durch das &amp;xinneres-fachmodul; in der Prozessbeschreibung vorzugeben und die zu verwendende Schlüsseltabelle festzulegen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1392818604581_267765_2502'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1392818644854_89310_2520' name='fehlercode' visibility='private' type='_16_5_4_1eeb04c1_1392817805435_868120_2437'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1392820470402_604960_2571' body='&lt;para&gt;In diesem Element wird ein Fehlercode übermittelt. Die zugrundeliegende Schlüsseltabelle muss mit der &lt;code&gt;listURI&lt;/code&gt; (bspw. &lt;code&gt;urn:de:bund:bzst:schluessel:rts.fehlercodes&lt;/code&gt;) und &lt;code&gt;listVersionID&lt;/code&gt; (bspw. &lt;code&gt;2016-01-19&lt;/code&gt;) identifiziert werden.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1392818644854_89310_2520'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1392818684157_451078_2522'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1392818684157_501891_2523' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1392818684194_715020_2524' name='fehlerbeschreibung' visibility='private'>
						<type href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1387625271095_781237_4845'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1::String.Latin' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1392820758658_784713_2576' body='&lt;para&gt;Alternativ oder ergänzend zu dem übermittelten Fehlercode können hier weitere Hinweise übermittelt werden, die der Klärung des Sachverhalts dienen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1392818684194_715020_2524'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1392818735351_334415_2526'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1392818735351_982573_2527' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
