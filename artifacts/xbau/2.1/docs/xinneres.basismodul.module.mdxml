				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1443592725572_105539_3086' name='quittungVonSachverhalten.erinnerung.0021'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1443592725585_557748_3093' body='&lt;para&gt;Mit dieser Nachricht kann der Autor einer Ursprungsnachricht dem Leser mitteilen, dass in der Ursprungsnachricht quittungsrelevante Inhalte vorlagen, eine entsprechende Quittung (bzw. eine Rückweisung) bisher jedoch ausgeblieben ist. Darüber hinaus wird dem Leser der spezifische quittungsrelevante Sachverhalt mitgeteilt, für den eine Quittung erwartet wird.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1443592725572_105539_3086'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_5b501fb_1443592725578_635905_3088' general='_16_5_4_5b501fb_1442737845138_973807_4361'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1443592725578_316484_3089' name='ursprungsnachricht' visibility='private' type='_16_5_4_1eeb04c1_1431419041792_262655_2295'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1443592725587_13372_3098' body='&lt;para&gt;Mit diesem Element wird die Ursprungsnachricht referenziert, die quittungsrelevante Inhalte enthielt.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_5b501fb_1443592725578_316484_3089'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1443592725586_34692_3097' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1443592725587_753689_3099' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1443592725582_875444_3091' name='quittung' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1442751673366_72365_3503' association='_16_5_4_5b501fb_1443594548232_744663_3677'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1443592725589_54207_3106' body='&lt;para&gt;Mit diesem Element werden die Informationen zum quittungsrelevanten Sachverhalt übermittelt, dessen Quittung erwartet wird.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_5b501fb_1443592725582_875444_3091'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1454408438351_479296_3779' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1454408438354_418936_3780' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1443594568026_527298_3696' name='erinnerungsstufe' visibility='private'>
						<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191841406_826039_1460'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='XOEV-Profil::W3C Data Types::nonNegativeInteger' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1443595011036_886256_3765' body='&lt;para&gt;Mit diesem Element wird die Anzahl der übermittelten Erinnerungsnachrichten zur selben Ursprungsnachricht und demselben Sachverhalt übermittelt. In die erste Erinnerungsnachricht wird dementsprechend der Wert &lt;quote&gt;1&lt;/quote&gt; eingetragen. Bei weiteren Erinnerungen wird der Wert jeweils um &lt;quote&gt;1&lt;/quote&gt; hochgezählt.&lt;/para&gt;&#10;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_5b501fb_1443594568026_527298_3696'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1454350888938_586402_4809' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1454350888938_503987_4810' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
