						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1d100e5_1384263208000_712297_1887' body='[nd]'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1380019743090_739110_1660'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1380019753199_91244_1662'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1380019753199_638159_1663' value='1'/>
