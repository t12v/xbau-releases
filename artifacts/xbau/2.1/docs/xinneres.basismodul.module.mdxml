				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1431426558549_879342_2894' name='Tagesdatum'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1431427428706_45152_3053' body='&lt;para&gt;Mit diesem Datentyp wird ein vollständig bekanntes Datum übermittelt. Anders als in &lt;code&gt;xs:date&lt;/code&gt; ist hier die Angabe einer Zeitzone jedoch nicht möglich.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1431426558549_879342_2894'/>
					</ownedComment>
