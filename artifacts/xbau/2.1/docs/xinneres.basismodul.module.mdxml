							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1391427749385_415608_1213' name='zeitpunkt' visibility='private'>
						<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191729703_367727_1061'>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<referenceExtension referentPath='XOEV-Profil::W3C Data Types::dateTime' referentType='Class'/>
							</xmi:Extension>
						</type>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1391428547376_66832_1224' body='&lt;para&gt;Hier wird das Datum und die Zeit übermittelt, an dem die im Kindelement &lt;code&gt;stelle&lt;/code&gt; bezeichnete Stelle die Nachricht weitergeleitet hat. Der hier übermittelte Zeitpunkt entspricht dabei dem &lt;code&gt;erstellungszeitpunkt&lt;/code&gt; der Weiterleitungsnachricht, mit der die Stelle die Weiterleitung vorgenommen hat.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1391427749385_415608_1213'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1391427921055_135912_1215' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1391427921055_186400_1216' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
