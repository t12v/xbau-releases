				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1391427646335_481996_1191' name='WeiterleitendeStelle'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1391427993004_57821_1217' body='&lt;para&gt;Dieser Datentyp enthält Informationen zu einer Stelle, die eine Nachricht weitergeleitet hat.&lt;/para&gt;&#10;&lt;para&gt;Sollte eine Nachricht über mehrere Stellen weitergeleitet worden sein, kann anhand des Zeitpunktes der Weiterleitung die Reihenfolge bestimmt werden.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1391427646335_481996_1191'/>
					</ownedComment>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1391427731591_996504_1209' name='stelle' visibility='private' type='_16_5_4_1eeb04c1_1364382738190_314891_1582'>
