					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1442752849249_192708_4428' name='sachverhalt' visibility='private' type='_16_5_4_5b501fb_1442755991175_400493_5292'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1442755119956_405745_5262' body='&lt;para&gt;Mit diesem Element wird der quittungsrelevante Sachverhalt in der Form eines Codes übermittelt.&lt;/para&gt;'>
