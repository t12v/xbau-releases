				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1380019686134_103237_1614' name='PostalischeInlandsanschrift.Postfachanschrift'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1380023806047_442626_1786' body='&lt;para&gt;Dieser Datentyp beinhaltet die Angaben für die Adressierung im Inland, soweit es sich um eine Postfachanschrift (und nicht um eine Gebäudeanschrift) handelt.&lt;/para&gt;'>
