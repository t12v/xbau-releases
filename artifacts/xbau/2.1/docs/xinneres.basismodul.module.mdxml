				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1442755991175_400493_5292' name='Code.QuittungsrelevanterSachverhalt'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1443350862275_69420_3583' body='&lt;para&gt;In den verschiedenen Datenübermittlungskontexten treten verschiedene quittungsrelevante Sachverhalte auf, die mit diesem Code-Datentyp übermittelt werden können.&lt;/para&gt;'>
