				<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_1eeb04c1_1380019709066_319431_1643'>
					<memberEnd xmi:idref='_16_5_4_1eeb04c1_1380019709066_704288_1644'/>
					<memberEnd xmi:idref='_16_5_4_1eeb04c1_1380019709066_960444_1645'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1380019709066_960444_1645' visibility='private' type='_16_5_4_1eeb04c1_1380019660674_995526_1587' association='_16_5_4_1eeb04c1_1380019709066_319431_1643'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1eeb04c1_1380019783198_447885_1675' name='PostalischeInlandsanschrift.Gebaeudeanschrift'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1380023551707_688434_1784' body='&lt;para&gt;Dieser Datentyp beinhaltet die Angaben für die Adressierung im Inland, soweit es sich um eine Gebäudeanschrift (und nicht um eine Postfachanschrift) handelt.&lt;/para&gt;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1380019783198_447885_1675'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1ccb0481_1425469069739_861877_2296' general='_16_5_4_1ccb0481_1425468921949_760319_2133'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1380019824008_354867_1703' name='hausnummern.bis' visibility='private' type='_16_5_4_1eeb04c1_1377075001233_323278_1145'>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1380019838532_922298_1705'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1380019838532_958154_1706' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
				<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_1eeb04c1_1380019856051_376159_1711'>
					<memberEnd xmi:idref='_16_5_4_1eeb04c1_1380019856051_736962_1712'/>
					<memberEnd xmi:idref='_16_5_4_1eeb04c1_1380019856051_185416_1713'/>
					<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1380019856051_185416_1713' visibility='private' type='_16_5_4_1eeb04c1_1380019660674_995526_1587' association='_16_5_4_1eeb04c1_1380019856051_376159_1711'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_1ccb0481_1425468921949_760319_2133' name='PostalischeInlandsanschrift.Basis'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468921982_614975_2146' body='&lt;para&gt;Dieser Datentyp bildet die Basis einer postalischen Gebäudeanschrift. Er basiert auf der Meldeanschrift, enthält aber nur die für die Adressierung erforderlichen Angaben. Die Angabe des Wohnort, der Postleitzahl und der Straße sind in diesem Datentyp verpflichtend.&lt;/para&gt;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921949_760319_2133'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_1ccb0481_1425468928690_441786_2281' general='_16_5_4_b7102e0_1292420010055_54472_505'/>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921958_463262_2135' name='hausnummer' visibility='private' type='_16_5_4_28e205cd_1296203840375_978526_898'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468921990_233300_2150' body='&lt;para&gt;Es sind nur die Ziffern einer Hausnummer anzugeben.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921958_463262_2135'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468921987_281712_2149'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468921990_921533_2151' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921963_804553_2136' name='hausnummerBuchstabeZusatzziffer' visibility='private' type='_16_5_4_28e205cd_1296203866609_175384_921'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468921995_922338_2154' body='&lt;para&gt;Es sind Buchstaben oder Zusatzziffern zur Hausnummer anzugeben.&lt;/para&gt;&#10;&lt;para&gt;Beispiel: 124 &lt;emphasis role=&quot;underline&quot;&gt;A&lt;/emphasis&gt;, 109&lt;emphasis role=&quot;underline&quot;&gt;.5&lt;/emphasis&gt;&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921963_804553_2136'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468921995_707779_2153'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468921996_311353_2155' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921965_416213_2137' name='postleitzahl' visibility='private' type='_16_5_4_28e205cd_1296203901906_876602_944'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468921996_806964_2158' body='&lt;para&gt;Es ist die Postleitzahl anzugeben.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921965_416213_2137'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468959798_668413_2286' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468959798_840171_2287' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921966_747588_2138' name='stockwerkswohnungsnummer' visibility='private' type='_16_5_4_28e205cd_1296203985453_789100_986'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468921997_691524_2162' body='&lt;para&gt;Es können Stockwerks- oder Wohnungsnummern angegeben werden, soweit sie für die Adressierung erforderlich sind. Beispiele: 7OG, 13OG, P für Parterre, HP für Hochparterre, St für Souterrain oder (Wohnung) 115.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921966_747588_2138'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468921997_185317_2161'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468921998_77870_2163' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921968_226942_2139' name='strasse' visibility='private' type='_16_5_4_28e205cd_1296204045078_587048_1032'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468921998_26373_2166' body='&lt;para&gt;Es ist die Bezeichnung der Straße in der amtlichen Schreibweise anzugeben.&lt;/para&gt;&#10;&lt;para&gt;Die Feldlänge ist auf 55 Zeichen beschränkt.&lt;/para&gt;&#10;&lt;para&gt;Ist keine Straßenbezeichnung &amp;ndash; wohl aber eine Hausnummer &amp;ndash; vorhanden, so ist die Zeichenkette &lt;quote&gt;Hausnummer&lt;/quote&gt; anzugeben. Sind weder Straßenbezeichnung noch Hausnummer vorhanden, so ist die Zeichenkette &lt;quote&gt;ohne Hausnummer&lt;/quote&gt; anzugeben.&lt;/para&gt;&#10;&lt;para&gt;Zusätze, die nicht der Straßenbezeichnung dienen, sind nicht zulässig. Soweit Angaben wie z. B. &lt;quote&gt;Weg A 2 und 12&lt;/quote&gt; oder &lt;quote&gt;Weg B&lt;/quote&gt; zur Adressierung benötigt werden, sind diese im Element &lt;emphasis role=&quot;codebf&quot;&gt;zusatzangaben&lt;/emphasis&gt; zu übermitteln.&lt;/para&gt;&#10;&lt;para&gt;Siehe DSMeld-Blatt 1205.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921968_226942_2139'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468968484_433434_2288' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468968484_528673_2289' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921969_588692_2140' name='teilnummerDerHausnummer' visibility='private' type='_16_5_4_28e205cd_1296204065781_198512_1055'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468921999_95530_2170' body='&lt;para&gt;Es sind Teilnummern zur Hausnummer anzugeben.&lt;/para&gt;&#10;&lt;para&gt;Beispiel: 16 &lt;emphasis role=&quot;underline&quot;&gt;1/7&lt;/emphasis&gt;&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921969_588692_2140'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468921999_28976_2169'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468921999_610589_2171' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921971_420202_2141' name='wohnort' visibility='private' type='_16_5_4_28e205cd_1296204091359_810864_1078'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468922000_743619_2174' body='&lt;para&gt;Es ist die postalische Wohnortsbezeichnung anzugeben.&lt;/para&gt;&#10;&lt;para&gt;&lt;/para&gt;&#10;&lt;para&gt;Die Feldlänge ist auf 40 Zeichen beschränkt.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921971_420202_2141'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468981812_168665_2290' value='1'/>
							</modelExtension>
						</xmi:Extension>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468981813_539662_2291' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921977_262524_2142' name='wohnortFruehererGemeindename' visibility='private' type='_16_5_4_28e205cd_1296204107812_31054_1101'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468922000_945584_2178' body='&lt;para&gt;Es ist der frühere Gemeindename anzugeben, der als Stadt- bzw. Ortsteilname dem jetzigen Gemeindenamen hinzugefügt werden kann.&lt;/para&gt;&lt;para&gt;Der frühere Gemeindename (jetziger Ortsteil- oder Stadtteilname) ist bei &lt;emphasis role=&quot;underline&quot;&gt;Adressierungen&lt;/emphasis&gt; unterhalb des Namens (oberhalb der Straßenbezeichnung) anzugeben.&lt;/para&gt;&lt;para&gt;Beispiel: Frau&lt;/para&gt;&lt;para&gt;               Rita Scholl&lt;/para&gt;&lt;para&gt;               Zuffenhausen&lt;/para&gt;&lt;para&gt;              Am Stadtpark 12&lt;/para&gt;&lt;para&gt;              70123 Stuttgart&lt;/para&gt;&#10;&lt;para&gt;&lt;/para&gt;&#10;&lt;para&gt;Die Feldlänge ist auf 40 Zeichen beschränkt.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921977_262524_2142'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468922000_120310_2177'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468922000_956181_2179' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1ccb0481_1425468921978_680650_2143' name='wohnungsinhaber' visibility='private' type='_16_5_4_28e205cd_1296206834546_531647_1337'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1ccb0481_1425468922001_789270_2182' body='&lt;para&gt;In diesem Element ist der Hauptmieter oder Eigentümer der Wohnung anzugeben, soweit dies für die Adressierung erforderlich ist. &lt;/para&gt;&#10;&lt;para&gt;&lt;/para&gt;&#10;&lt;para&gt;Bei Überschreitung einer Länge von 26 Zeichen darf sinnvoll abgekürzt werden.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1ccb0481_1425468921978_680650_2143'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1ccb0481_1425468922001_516743_2181'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1ccb0481_1425468922001_131586_2183' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
					<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_1eeb04c1_1436970640093_504463_3037' name='zusatzangaben' visibility='private' type='_16_5_4_28e205cd_1296204176046_185713_1147'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_1eeb04c1_1436970640095_259161_3040' body='&lt;para&gt;Es sind Zusatzangaben zur Anschrift anzugeben. Beispiele: Hinterhaus, Gartenhaus.&lt;/para&gt;&#10;&lt;para&gt;&lt;/para&gt;&#10;&lt;para&gt;Bei Überschreitung einer Länge von 21 Zeichen darf sinnvoll abgekürzt werden.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_1eeb04c1_1436970640093_504463_3037'/>
						</ownedComment>
						<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_1eeb04c1_1436970640094_612731_3039'/>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<modelExtension>
								<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_1eeb04c1_1436970640095_854956_3041' value='1'/>
							</modelExtension>
						</xmi:Extension>
					</ownedAttribute>
				</packagedElement>
