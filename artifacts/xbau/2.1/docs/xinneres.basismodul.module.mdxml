				<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1442737174431_543030_2940' name='quittungVonSachverhalten.quittung.0020'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1442737606657_382795_4258' body='&lt;para&gt;Mit dieser Nachricht kann der Leser einer Ursprungsnachricht dem Autor, als Reaktion auf die fachliche Verarbeitung der Inhalte dieser Ursprungsnachricht, diesen quittungsrelevanten Sachverhalt quittieren.&lt;/para&gt;'>
