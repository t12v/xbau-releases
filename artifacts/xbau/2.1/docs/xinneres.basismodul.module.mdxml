							<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Lateinische Zeichen in Unicode::1.1.1' referentType='Package'/>
						</xmi:Extension>
					</supplier>
				</packagedElement>
			</packagedElement>
