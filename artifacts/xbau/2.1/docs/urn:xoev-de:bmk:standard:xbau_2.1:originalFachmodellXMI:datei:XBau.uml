        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1476089545293_858396_5697" name="DatentypenBaulast" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476035195880_924265_7679" name="BaulastErklaerung">
            <ownedComment xmi:id="_16_5_4_940029b_1476035195884_184657_7687" annotatedElement="_16_5_4_940029b_1476035195880_924265_7679" body="&lt;para>Dieser Typ beinhaltet die Daten zu Anlass und Inhalt einer Baulasterklärung.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035195884_93646_7682" name="anlass" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1476035195884_547703_7694" annotatedElement="_16_5_4_940029b_1476035195884_93646_7682" body="&lt;para>Hier wird die öffentlich-rechtliche Verpflichtung bezeichnet, die mit der einzutragenden Baulast einhergeht. Es wird der  Zweck bzw. das Ziel der einzurichtenden Baulast angegeben.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036632490_9679_7773" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036632490_879678_7774" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035195884_669763_7683" name="beschreibung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1476035195884_693195_7698" annotatedElement="_16_5_4_940029b_1476035195884_669763_7683" body="&lt;para>Hier ist Text einzutragen, der die Baulast mit Bezugnahme auf die in der Nachricht aufgeführten Grundstücke definiert.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476035195884_69497_7697" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476035195884_641727_7699" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476036535283_837924_7764" name="sachverhalt" visibility="private" type="_16_5_4_940029b_1476035380312_138234_7724">
              <ownedComment xmi:id="_16_5_4_940029b_1476036535283_843961_7767" annotatedElement="_16_5_4_940029b_1476036535283_837924_7764" body="&lt;para>Hier wird eine Beschreibung der Verpflichtung im Detail gegeben. Dies geschieht, indem georeferenziert auf die Gegenstände der Baulast Bezug genommen wird. Pro Element wird ein Baulast-Gegenstand genannt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036621928_4894_7771" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036621928_797043_7772" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476035380312_138234_7724" name="Anonym_Gegenstand">
            <ownedComment xmi:id="_16_5_4_940029b_1476035380312_721443_7727" annotatedElement="_16_5_4_940029b_1476035380312_138234_7724" body="&lt;para>Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035380312_805281_7725" name="baulastgegenstand" visibility="private" type="_16_5_4_940029b_1460651165974_293124_3777">
              <ownedComment xmi:id="_16_5_4_940029b_1476035380312_6317_7730" annotatedElement="_16_5_4_940029b_1476035380312_805281_7725" body="&lt;para>In diesem Element wird ein Baulast-Gegenstand georeferenziert definiert. z.B. eine Baulastfläche (Abstandsfläche, die von der Bebauung freizuhalten ist) oder eine gemeinsame Brandwand (die nicht verändert werden darf in einem Bauvorhaben).&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476035380312_10838_7729" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476035380312_220881_7731" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035380312_970392_7726" name="beschreibung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1476035380312_299863_7734" annotatedElement="_16_5_4_940029b_1476035380312_970392_7726" body="&lt;para>Zum georeferenzierten Baulast-Gegenstand werden hier Erläuterungen eingefügt.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476035380312_505582_7733" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476035380312_269185_7735" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
