                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291323_21262_6156" annotatedElement="_16_5_4_5b501fb_1387625291122_805111_5241" body="Hier kann angegeben werden, welche Sprachen eine natürliche Person als Muttersprache beherrscht."/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291323_742988_6157" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_608193_5164" association="_16_5_4_5b501fb_1387625291122_805111_5241"/>
