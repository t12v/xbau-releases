            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196365903_938927_8698" name="" client="_16_5_4_8a30247_1422955073653_603895_5103" supplier="_16_5_4_5b501fb_1387625291116_769920_5181"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196387606_122294_8701" name="" client="_16_5_4_8a30247_1422955073653_897530_5113" supplier="_16_5_4_5b501fb_1387625291305_307436_5949"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196421259_460285_8704" name="" client="_16_5_4_8a30247_1422955073653_701701_5110" supplier="_16_5_4_5b501fb_1387625291304_506286_5946"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196440753_243032_8707" name="" client="_16_5_4_8a30247_1422955073653_116526_5106" supplier="_16_5_4_5b501fb_1387625291303_622764_5942"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196503513_568354_8735" name="" client="_16_5_4_8a30247_1422894619924_503273_3379" supplier="_16_5_4_5b501fb_1387625291108_35213_5171"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196509903_464243_8738" name="" client="_16_5_4_8a30247_1422894619924_583177_3381" supplier="_16_5_4_5b501fb_1387625291226_923939_5653"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196516639_628708_8741" name="" client="_16_5_4_8a30247_1422894619924_870277_3382" supplier="_16_5_4_5b501fb_1387625291227_44637_5654"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427196979970_783012_8890" name="" client="_16_5_4_940029b_1422888807308_342425_3010" supplier="_16_5_4_5b501fb_1387625291104_134064_5166"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427197248344_315701_9035" name="" client="_16_5_4_8a30247_1422884384004_352244_4233" supplier="_16_5_4_5b501fb_1387625291113_329233_5177"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427197289116_398332_9041" name="" client="_16_5_4_8a30247_1422884384004_802917_4242" supplier="_16_5_4_5b501fb_1387625291267_147247_5816"/>
            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_8ae0277_1427197297440_108061_9044" name="" client="_16_5_4_8a30247_1422884384004_979617_4243" supplier="_16_5_4_5b501fb_1387625291268_905208_5817"/>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1422890212649_362655_3330" name="fachuebergrBausteine" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1422888807308_342425_3010" clientDependency="_16_5_4_8ae0277_1427196979970_783012_8890" name="Staat">
            <ownedComment xmi:id="_16_5_4_940029b_1422888807323_361464_3013" annotatedElement="_16_5_4_940029b_1422888807308_342425_3010" body="&lt;para>Als Staat bezeichnet man eine politische Ordnung, die ein gemeinsames als Staatsgebiet abgegrenztes Territorium, ein dazugehöriges Staatsvolk und eine Machtausübung über dieses umfasst.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888807323_584813_3012" name="staat" visibility="private" type="_16_5_4_8a30247_1423043972175_271232_6283">
              <ownedComment xmi:id="_16_5_4_940029b_1422888807386_708822_3048" annotatedElement="_16_5_4_940029b_1422888807323_584813_3012" body="&lt;para>Dieses verwendet einen Schlüssel zur Identifikation eines Staates.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888807386_664297_3047" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1422888807386_299198_3049" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1422888990355_651351_3077" name="Geokodierung">
            <ownedComment xmi:id="_16_5_4_940029b_1422888990355_414714_3085" annotatedElement="_16_5_4_940029b_1422888990355_651351_3077" body="&lt;para>Diese Komponente beinhaltet Informationen zur geografischen Bestimmung von Dingen.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888990355_159436_3082" clientDependency="_16_5_4_8ae0277_1427195192987_807482_7497" name="flurnummer" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1422888990387_346535_3137" annotatedElement="_16_5_4_940029b_1422888990355_159436_3082" body="&lt;para>Die Flur ist eine zusammenhängende, aus mehreren Flurstücken bestehende Fläche des Liegenschaftskatasters.&lt;/para> &#xA;&#xA;&lt;para>Eine Flurnummer ist ein Schlüssel zur Identifikation einer Flur.&lt;/para> "/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_420216_3136" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_241020_3138" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888990355_12648_3083" clientDependency="_16_5_4_8ae0277_1427195183468_521989_7494" name="flurstueck" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1422888990387_813605_3141" annotatedElement="_16_5_4_940029b_1422888990355_12648_3083" body="&lt;para>Ein Flurstück ist die kleinste Buchungseinheit des Liegenschaftskatasters und stellt eine geometrisch eindeutigen Teil der Erdoberfläche dar.&lt;/para>  &#xA;&#xA;&lt;para>Das Flurstück wird mit einer Flurstücksnummer, die aus einer Zahl, einer Kombination von Zahl und Buchstabe oder einer Kombination von Zähler und Nenner besteht, bezeichnet.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_344631_3140" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_660567_3142" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888990355_381968_3084" clientDependency="_16_5_4_8ae0277_1427195151400_176266_7491" name="gemarkung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1422888990387_344542_3145" annotatedElement="_16_5_4_940029b_1422888990355_381968_3084" body="&lt;para>Die Komponente &quot;gemarkung&quot; bezeichnet eine Fläche.&lt;/para>&#xA;&#xA;&lt;para>Eine Gemarkung ist eine zusammenhängende, aus mehreren Fluren bestehende Fläche des Liegenschaftskatasters. Sie wird nach ihrer Lage benannt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_285412_3144" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888990387_594563_3146" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422884384004_352244_4233" clientDependency="_16_5_4_8ae0277_1427193531907_193244_6959 _16_5_4_8ae0277_1427197248344_315701_9035" name="Anschrift">
            <ownedComment xmi:id="_16_5_4_8a30247_1422884384004_53636_4250" annotatedElement="_16_5_4_8a30247_1422884384004_352244_4233" body="&lt;para>Eine Anschrift beschreibt einen Ort mit den klassischen Ordnungsbegriffen wie Orts- und Straßennamen sowie ergänzenden Informationen wie Ortsteil und Postfach.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_253575_4235" name="staat" visibility="private" type="_16_5_4_940029b_1422888807308_342425_3010" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_208972_4317" annotatedElement="_16_5_4_8a30247_1422884384004_253575_4235" body="&lt;para>Der Staat, dem die Anschrift postalisch zugeordnet wird.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_29934_4316" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422884384082_809940_4318" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_806120_4239" name="strasse" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_250735_4333" annotatedElement="_16_5_4_8a30247_1422884384004_806120_4239" body="&lt;para>Eine Straße ist ein planmäßig angelegter, im allgemeinen befestigter Verkehrsweg innerhalb eines Ortes.&lt;/para> &#xA;&#xA;&lt;para>Das Element strasse enthält den Namen (die Bezeichnung) einer Straße.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_323635_4332" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_34049_4334" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_451688_4240" name="hausnummer" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_264227_4337" annotatedElement="_16_5_4_8a30247_1422884384004_451688_4240" body="&lt;para>Eine Hausnummer dient der genauen Lokalisierung eines Grundstücks, Gebäudes oder Gebäudeteils (Eingang) in einer Straße.&lt;/para> &#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_682001_4336" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_892535_4338" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_212723_4241" name="postfach" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_549186_4341" annotatedElement="_16_5_4_8a30247_1422884384004_212723_4241" body="&lt;para>Ein Postfach (oft Postfachnummer) ist ein Schlüssel zur Identifikation eines Postfaches in einer Postfiliale.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_784010_4340" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_913439_4342" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_802917_4242" clientDependency="_16_5_4_8ae0277_1427197289116_398332_9041" name="postleitzahl" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_588674_4345" annotatedElement="_16_5_4_8a30247_1422884384004_802917_4242" body="&lt;para>Eine Postleitzahl ist eine Angabe, um postalische Zustellgebiete unabhängig von Gebietskörperschaften (Gemeinde, Kreis) zu bezeichnen.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_467767_4344" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_224431_4346" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_979617_4243" clientDependency="_16_5_4_8ae0277_1427197297440_108061_9044" name="ort" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_612642_4349" annotatedElement="_16_5_4_8a30247_1422884384004_979617_4243" body="&lt;para>Der &quot;ort&quot; enthält den Namen eines Ortes (Gemeinde, Ortschaft oder Stadt).&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_46680_4348" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_775087_4350" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_337175_4246" name="wohnungsgeber" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_10646_4361" annotatedElement="_16_5_4_8a30247_1422884384004_337175_4246" body="&lt;para>Die Komponente &quot;wohnungsgeber&quot; enthält Angaben (Name/Bezeichnung) zum Hauptmieter oder Eigentümer einer Immobilie.&lt;/para>&#xA;&#xA;&lt;para>Die Angabe eines Wohnungsgebers im Kontext der Anschrift dient der genaueren oder leichteren Adressierung. Sie darf nicht genutzt werden um Mietverhältnisse oder ähnliche rechtliche Beziehungen zwischen Personen auszudrücken.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: bei Meyer&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_415657_4360" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_381478_4362" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422884384004_320565_4247" name="zusatz" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422884384082_765934_4365" annotatedElement="_16_5_4_8a30247_1422884384004_320565_4247" body="&lt;para>Ein Anschriftenzusatz beinhaltet ggf. erforderliche weitere Präzisierungen zu einer Anschrift.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: Hinterhof, 3. Aufgang, Haus A, 3. Stock, Appartement 25a,  3. Stock - Appartement 25 a, #325a, Raum 77&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_837226_4364" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422884384082_511194_4366" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422894619924_503273_3379" clientDependency="_16_5_4_8ae0277_1427196503513_568354_8735 _16_5_4_8ae0277_1427193463099_815271_6947" name="Kommunikation">
            <ownedComment xmi:id="_16_5_4_8a30247_1422894619924_612939_3385" annotatedElement="_16_5_4_8a30247_1422894619924_503273_3379" body="&lt;para>&quot;Kommunikation&quot; fasst Angaben zur Erreichbarkeit über elektronische Kommunikationskanäle (z.B. Telefon, Fax, E-Mail) zusammen.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_583177_3381" clientDependency="_16_5_4_8ae0277_1427196509903_464243_8738" name="kanal" visibility="private" type="_16_5_4_8a30247_1423044922195_172323_6450">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_400513_3423" annotatedElement="_16_5_4_8a30247_1422894619924_583177_3381" body="&lt;para>Der &quot;kanal&quot; gibt an, über welchen Kommunikationskanal eine Erreichbarkeit besteht (Telefon, E-Mail usw.).&lt;/para>  &#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_949595_3422" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_536564_3424" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_870277_3382" clientDependency="_16_5_4_8ae0277_1427196516639_628708_8741" name="kennung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_381305_3427" annotatedElement="_16_5_4_8a30247_1422894619924_870277_3382" body="&lt;para>Die &quot;kennung&quot; beinhaltet die konkreten Angaben zur Erreichbarkeit über einen Kommunikationskanal, d.h. die Telefonnummer, Faxnummer, E-Mail-Adresse oder dergleichen. Die Kennung soll strukturiert erfasst werden.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: +49 30 12345-67 (internationale Rufnummer nach DIN 5008)&#xA;&#xA;030 12345-67 ( nationale Rufnummern nach DIN 5008)&#xA;&#xA;+49 89 1234567 (internationale Rufnummer nach E.123)&#xA;&#xA;(089) 123456) (nationale Rufnummer nach E.123)&#xA;&#xA;tel:+49-30-1234567 (Uniform Resource Identifier nach RFC 3966)&lt;/para>&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_907455_3426" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_970802_3428" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_202463_3383" name="istDienstlich" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_69296_3431" annotatedElement="_16_5_4_8a30247_1422894619924_202463_3383" body="&lt;para>Mit der Komponente &quot;istDienstlich&quot; kann angegeben werden, ob es sich um dienstliche oder private Kommunikationsdaten handelt.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_691580_3430" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_150044_3432" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_228031_3384" name="zusatz" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_510860_3435" annotatedElement="_16_5_4_8a30247_1422894619924_228031_3384" body="&lt;para>Im &quot;zusatz&quot; können zusätzliche freie Angaben zur Erreichbarkeit über einen Kommunikationskanal gemacht werden.&lt;/para> &#xA;&#xA;&lt;para>Beispiel: erreichbar tagsüber zwischen 9 und 16 Uhr&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_525294_3434" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619955_829010_3436" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422955073653_603895_5103" clientDependency="_16_5_4_8ae0277_1427196365903_938927_8698" name="NameNatuerlichePerson">
            <ownedComment xmi:id="_16_5_4_8a30247_1422955073653_702979_5120" annotatedElement="_16_5_4_8a30247_1422955073653_603895_5103" body="&lt;para>Der Name einer Person ist eine Benennung dieser Person, die dazu dient, diese Person von anderen Personen zu unterscheiden.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_897530_5113" clientDependency="_16_5_4_8ae0277_1427196387606_122294_8701" name="titel" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_967723_5280" annotatedElement="_16_5_4_8a30247_1422955073653_897530_5113" body="&lt;para>Ein Titel wird häufig im Zusammenhang mit Namen verwendet, ist aber  kein orginärer Bestandteil des Namens. Im Unterschied dazu gehören Adelstitel zum Familiennamen und sind daher in diesem Verständnis kein Titel. Zu den Titeln zählen beispielsweise akademische Grade, Dienst- und Amtsbezeichnungen oder militärische Ränge. Es können auch Titel übermittelt werden, die keine Titel im Sinne des Meldewesens sind.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: Dr.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955073794_566369_5279" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422955073794_777288_5281" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_433210_5114" name="anrede" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_891832_5284" annotatedElement="_16_5_4_8a30247_1422955073653_433210_5114" body="&lt;para>Die Anrede ist der Namenszusatz (auch eine Anrede ohne Namen nur mit Titel ist eine Anrede) bei der Anrede (mündlich oder schriftlich) oder bei einem Anruf (fernmündlich) an eine Person oder Personengruppe.&lt;/para>&#xA;&#xA;&lt;para>Anmerkung: Die komplette Anrede einer Person kann in einem Feld übermittelt werden.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: Herr, Frau, Herr Staatssekretär, Frau Bundeskanzlerin, Herr Botschafter, Eure Eminenz&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621011095_467363_3910" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621011095_18399_3911" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_116526_5106" clientDependency="_16_5_4_8ae0277_1427196440753_243032_8707" name="familienname" visibility="private" type="_16_5_4_8a30247_1422955529766_893716_5914" aggregation="composite" association="_16_5_4_8ae0277_1427196276261_283770_8628">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_120326_5252" annotatedElement="_16_5_4_8a30247_1422955073653_116526_5106" body="&lt;para>Der Familienname ist der aktuelle Nachname einer Person und Ausdruck einer bestimmten Familienzugehörigkeit dieser Person.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621123614_669924_3912" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621123614_270154_3913" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_701701_5110" clientDependency="_16_5_4_8ae0277_1427196421259_460285_8704" name="vorname" visibility="private" type="_16_5_4_8a30247_1422955529766_893716_5914" aggregation="composite" association="_16_5_4_8ae0277_1427196267171_513183_8533">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_942027_5268" annotatedElement="_16_5_4_8a30247_1422955073653_701701_5110" body="&lt;para>Der Vorname ist der Name bzw. der Teil des Namens, der nicht die Zugehörigkeit zu einer Familie ausdrückt, sondern das Individuum innerhalb der Familie bezeichnet und dazu dient, es von anderen Familienmitgliedern zu unterscheiden.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621132576_435657_3914" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621132576_234_3915" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422955529766_893716_5914" name="AllgemeinerName">
            <ownedComment xmi:id="_16_5_4_8a30247_1422955529766_553979_5920" annotatedElement="_16_5_4_8a30247_1422955529766_893716_5914" body="&lt;para>Der AllgemeineName dient der Darstellung von Vor- und Nachnamen und fasst deren  gemeinsame Eigenschaften zusammen.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955529766_536500_5916" name="name" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955529797_194605_5964" annotatedElement="_16_5_4_8a30247_1422955529766_536500_5916" body="&lt;para>Die Komponente &quot;name&quot; ist der  Familien- oder Vorname als Zeichenkette.&lt;/para> &#xA;&lt;para>Nachnamen, z.B.  mit Adelstiteln bzw. ausländische Nachnamen werden als ein Name übermittelt und nicht in verschiedene Bestandteile aufgeteilt.&lt;/para> &#xA;&#xA;&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_512651_5963" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_737978_5965" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955529766_12705_5917" name="nichtVorhanden" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955529797_243429_5968" annotatedElement="_16_5_4_8a30247_1422955529766_12705_5917" body="&lt;para>Diese Komponente beinhaltet eine Feststellung (wahr oder falsch), ob zu Recht kein Name angegeben wurde. Ueber das Setzen auf TRUE, wird angezeigt, dass zurecht kein Name angegeben wurde.&lt;/para> "/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_108430_5967" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422955529797_277543_5969" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422957254152_639975_8085" name="Organisationseinheit">
            <ownedComment xmi:id="_16_5_4_8a30247_1422957254152_410520_8090" annotatedElement="_16_5_4_8a30247_1422957254152_639975_8085" body="&lt;para>Die Organisationseinheit fasst Angaben zur Darstellung der internen hierarchischen Organisationsstruktur einer Institution zusammen, z.B. zur Darstellung von Abteilungen oder Referaten.&lt;/para> "/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957254152_631909_8087" name="name" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957254183_537292_8127" annotatedElement="_16_5_4_8a30247_1422957254152_631909_8087" body="&lt;para>Bezeichnung der Organisationseinheit.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957254183_511440_8126" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957254183_868799_8128" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957254152_920001_8088" name="hierarchieebene" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957254183_458854_8131" annotatedElement="_16_5_4_8a30247_1422957254152_920001_8088" body="&lt;para>Kennzeichnung der Hierarchieebene der Organisationseinheit.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191803156_348252_1327"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957254183_475168_8130" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957254199_654246_8132" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957254152_542971_8089" name="hierarchiename" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957254199_404694_8135" annotatedElement="_16_5_4_8a30247_1422957254152_542971_8089" body="&lt;para>Hier kann der Name einer Hierachieebene angegeben werden.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: Abteilung, Referat&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957254199_627123_8134" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957254199_100104_8136" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422957408723_400098_8364" clientDependency="_16_5_4_8ae0277_1427193489689_812796_6950" name="NameOrganisation">
            <ownedComment xmi:id="_16_5_4_8a30247_1422957408723_801794_8369" annotatedElement="_16_5_4_8a30247_1422957408723_400098_8364" body="&lt;para>&quot;NameOrganisation&quot; fasst die Angaben zum Namen einer Organisation zusammen.&lt;/para> "/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957408723_631641_8366" name="name" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957408770_89516_8412" annotatedElement="_16_5_4_8a30247_1422957408723_631641_8366" body="&lt;para>Offizieller Name einer Organisation. Entspricht bei registrierten Organisationen dem im Register eingetragenen Namen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460623839986_414204_4726" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460623839986_120551_4727" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957408723_203762_8367" name="kurzbezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957408770_938031_8416" annotatedElement="_16_5_4_8a30247_1422957408723_203762_8367" body="&lt;para>Kurzbezeichnung des Namen einer Organisation.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957408770_737842_8415" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957408770_660999_8417" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422977426041_172815_6757" clientDependency="_16_5_4_8ae0277_1427193498410_184944_6953" name="Organisation">
            <ownedComment xmi:id="_16_5_4_8a30247_1422977426056_688199_6771" annotatedElement="_16_5_4_8a30247_1422977426041_172815_6757" body="&lt;para>Eine Organisation ist eine  Vereinigung mehrerer natürlicher oder juristischer Personen bzw. eine rechtsfähige Personengesellschaft zu einem gemeinsamen Zweck, z.B.  im wirtschaftlichen, gemeinnützigen, religiösen, öffentlichen oder politischen Bereich.&lt;/para>&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426041_754458_6765" clientDependency="_16_5_4_8ae0277_1427193864249_936524_7178" name="name" visibility="private" type="_16_5_4_8a30247_1422957408723_400098_8364" aggregation="composite" association="_16_5_4_8ae0277_1427191914590_100076_5913">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_492509_6881" annotatedElement="_16_5_4_8a30247_1422977426041_754458_6765" body="&lt;para>Angaben zum offiziellen Namen der Organisation.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460623828363_397124_4724" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460623828363_231187_4725" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426056_110707_6767" name="anschrift" visibility="private" type="_16_5_4_8a30247_1422884384004_352244_4233" aggregation="composite" association="_16_5_4_8ae0277_1427192330303_284590_6843">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_843785_6889" annotatedElement="_16_5_4_8a30247_1422977426056_110707_6767" body="&lt;para>Angaben zur Anschrift der Organisation, die über den Typ der Anschrift auf deren Verwendung als Postanschrift, Niederlassungsanschrift oder Gründungsanschrift verweist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977426150_462413_6888" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977426150_706309_6890" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426041_568786_6761" name="kommunikation" visibility="private" type="_16_5_4_8a30247_1422894619924_503273_3379" aggregation="composite" association="_16_5_4_8ae0277_1427191961941_338157_6253">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_701628_6865" annotatedElement="_16_5_4_8a30247_1422977426041_568786_6761" body="&lt;para>Unter &quot;kommunikation&quot; werden Angaben zur Erreichbarkeit einer Organisation über elektronische Kommunikationskanäle zusammengefasst.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977426150_839361_6864" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977426150_271056_6866" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460624135928_771822_4802" name="vertreter" visibility="private" type="_16_5_4_8a30247_1422955073653_603895_5103" association="_16_5_4_940029b_1460624135928_756920_4800">
              <ownedComment xmi:id="_16_5_4_940029b_1483458770760_264485_4562" annotatedElement="_16_5_4_940029b_1460624135928_771822_4802" body="&lt;para>Angaben zu einer Person, die autorisierrt ist, für die Organisation zu sprechen. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460624135928_538610_4804" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460624135928_219294_4805" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
