            </node>
            <node xmi:type="uml:CallBehaviorAction" xmi:id="_16_5_4_940029b_1478883858583_987323_4710" name="Befundliste erstellen" visibility="public" inPartition="_16_5_4_940029b_1478883858568_812138_4700" outgoing="_16_5_4_940029b_1478883858568_847198_4663" incoming="_16_5_4_940029b_1478883858568_285524_4664">
