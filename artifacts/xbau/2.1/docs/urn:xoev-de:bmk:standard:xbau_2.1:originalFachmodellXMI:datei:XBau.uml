                  <ownedComment xmi:id="_16_5_4_5b501fb_1406633287288_502131_6461" annotatedElement="_16_5_4_5b501fb_1406633287107_768044_5562" body="Die verwaltungspolitische Zuständigkeit der Behörde beschreibt für welche verwaltungspolitische Einheit eine Behörde zuständig ist."/>
                  <ownedEnd xmi:id="_16_5_4_5b501fb_1406633287288_224276_6462" name="" visibility="private" type="_16_5_4_5b501fb_1406633287056_222507_5361" association="_16_5_4_5b501fb_1406633287107_768044_5562"/>
