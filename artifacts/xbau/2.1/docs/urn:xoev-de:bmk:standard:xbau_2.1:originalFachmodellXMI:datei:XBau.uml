  <XOEVProfil:xoevABIE xmi:id="_3whgWlU7Eem76qy_rce7yg" base_Class="_16_5_4_1eeb04c1_1380019783198_447885_1675" MotivationDerAbweichung="Das zusätzliche Kindelement ist erforderlich, um Hausnummernbereich übermitteln zu können."/>
  <XOEVProfil:xoevABIE xmi:id="_3whgW1U7Eem76qy_rce7yg" base_Class="_16_5_4_1eeb04c1_1364313722451_850604_9366"/>
