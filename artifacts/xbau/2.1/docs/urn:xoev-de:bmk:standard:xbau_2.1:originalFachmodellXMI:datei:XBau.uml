            <ownedAttribute xmi:id="_16_5_4_940029b_1461155864757_980935_5314" name="autor" visibility="private" type="_16_5_4_1eeb04c1_1364382738190_314891_1582" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461155864757_293845_5323" annotatedElement="_16_5_4_940029b_1461155864757_980935_5314" body="&lt;para>Hier wird die Fachbehörde bzw. Organisation genannt, die die vorliegende Nachricht erstellt hat.&lt;/para>&#xA;&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155864757_633015_5322" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461155864757_266924_5324" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1461156018749_695913_5432" name="" memberEnd="_16_5_4_940029b_1461156018749_393935_5433 _16_5_4_940029b_1461156018749_130939_5434">
            <ownedEnd xmi:id="_16_5_4_940029b_1461156018749_130939_5434" name="" visibility="private" type="_16_5_4_940029b_1461155848215_275954_5270" association="_16_5_4_940029b_1461156018749_695913_5432"/>
          </packagedElement>
          <packagedElement xmi:type="uml:InstanceSpecification" xmi:id="_16_5_4_940029b_1479075784545_748750_4846" name="">
            <classifier xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191702187_214129_966"/>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1461086907337_479976_5395" name="" client="_16_5_4_1d100e5_1384794877872_302539_331" supplier="_16_5_4_1eeb04c1_1364305973268_219502_1046"/>
        <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1461087400098_673231_5446" name="" client="_16_5_4_1d100e5_1384794877872_302539_331" supplier="_16_5_4_1eeb04c1_1364491177452_864851_1495"/>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1460555920890_762395_3824" name="DatentypenBauantrag" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460554558325_844345_3559" name="BeteiligteBauprojektInPlanung">
            <ownedComment xmi:id="_16_5_4_940029b_1461259199256_560810_5521" annotatedElement="_16_5_4_940029b_1460554558325_844345_3559" body="&lt;para>Typ für die an einem (sich in Planung befindlichen) Bauprojekt beteiligten Parteien (Personen und Organisationen).&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460554744795_787519_3592" name="bauherr" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1461160825870_465236_5873" annotatedElement="_16_5_4_940029b_1460554744795_787519_3592" body="&lt;para>Hier ist der Akteur einzutragen, der am Verfahren als Bauherr beteiligt ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460624268881_596196_4809" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460624268881_974516_4810" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460554867588_210126_3605" name="bevollmaechtigter" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517">
              <ownedComment xmi:id="_16_5_4_940029b_1461160828447_256555_5874" annotatedElement="_16_5_4_940029b_1460554867588_210126_3605" body="&lt;para>Hier ist ggf. eine Person einzutragen, die vom  Bauherrn als Bevollmächtigter benannt worden ist.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460555330638_28448_3687" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460555330638_311860_3688" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460554868305_384954_3610" name="entwurfsverfasser" visibility="private" type="_16_5_4_8a30247_1408705895800_629557_4010">
              <ownedComment xmi:id="_16_5_4_940029b_1461160837694_864545_5875" annotatedElement="_16_5_4_940029b_1460554868305_384954_3610" body="&lt;para>Hier ist die Person einzutragen, die am Verfahren als Entwurfsverfasser beteiligt ist. Falls kein Entwurfsverfasser für das Bauvorhaben benötigt wird, kann dieses Element entfallen.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460554868305_466540_3612" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460554868305_332567_3613" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465318842898_789664_5603" name="grundstueckseigentuemer" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1465318842914_635193_5606" annotatedElement="_16_5_4_940029b_1465318842898_789664_5603" body="&lt;para>Hier ist der Eigentümer des Baugrundstücks einzutragen, falls nicht der Bauherr Eigentümer ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465318996812_642718_5618" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465318996812_638972_5619" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460558980541_7300_3475" name="Anonym_Was">
            <ownedAttribute xmi:id="_16_5_4_940029b_1460558980541_29629_3476" name="artDerMassnahme" visibility="private" type="_16_5_4_8a30247_1408530590527_762740_2619">
              <ownedComment xmi:id="_16_5_4_940029b_1461160813890_302648_5870" annotatedElement="_16_5_4_940029b_1460558980541_29629_3476" body="&lt;para>In dieses Element ist einzutragen, von welcher grundsätzlichen Art (z. B. Errichtung oder Änderung) die  Maßnahmen im Rahmen des Bauvorhabens sind. &lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460558980557_143966_3481" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460558980557_619579_3482" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460558980541_756691_3477" name="artDerBaulichenAnlage" visibility="private" type="_16_5_4_940029b_1475592596655_193877_6574">
              <ownedComment xmi:id="_16_5_4_940029b_1461160816719_662224_5871" annotatedElement="_16_5_4_940029b_1460558980541_756691_3477" body="&lt;para>Für den Gegenstand des Bauvorhabens wird hier die Art der baulichen Anlage näher spezifiziert. Außerdem werden technische Parameter des Vorhabens genannt.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460559156638_687333_3559" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460559156638_60909_3560" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475593255419_293939_6943" name="bauvorhabenDatenblatt" visibility="private" type="_16_5_4_940029b_1476120195475_492410_6287">
              <ownedComment xmi:id="_16_5_4_940029b_1475593255419_119563_6946" annotatedElement="_16_5_4_940029b_1475593255419_293939_6943" body="&lt;para>Dieses Objekt bietet Felder für die Übermittlung von technischen Daten und Kennzahlen zum Bauvorhaben.&lt;/para>&#xA;&lt;para>Falls das Bauvorhaben eine Errichtung ist, beziehen sich alle aufgeführten Parameter des Datenblatts naturgemäß auf das projektierte Gesamtbauwerk.&lt;/para>&#xA;&lt;para>Falls das Bauvorhaben eine Änderung ist, ist abzuwägen, ob Daten in Bezug auf den Erweiterungsbau oder auf das Gesamtbauwerk anzugeben sind.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475593255419_639982_6945" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475593255419_798315_6947" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460559782420_922066_3743" name="Anonym_Wo">
            <ownedAttribute xmi:id="_16_5_4_940029b_1460559782420_968771_3744" name="baugrundstueck" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594">
              <ownedComment xmi:id="_16_5_4_940029b_1461160845396_901199_5877" annotatedElement="_16_5_4_940029b_1460559782420_968771_3744" body="&lt;para>In diesem Element sind Daten enthalten, die das Baugrundstück (ein Grundstück, auf dem das Vorhaben stattfinden soll bzw. auf dem es durchgeführt wurde) identifizieren. Ein Vorhaben kann mehrere Grundstücke betreffen.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460559858933_664444_3762" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460559858933_416512_3763" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460651189553_439942_3797" name="lageBauvorhaben" visibility="private" type="_16_5_4_940029b_1460651165974_293124_3777" aggregation="composite" association="_16_5_4_940029b_1460651189553_733771_3795">
              <ownedComment xmi:id="_16_5_4_940029b_1461160849283_962320_5878" annotatedElement="_16_5_4_940029b_1460651189553_439942_3797" body="&lt;para>In diesem Element sollen ergänzend georeferenzierte Informationen zur genaueren Lage des Bauvorhabens bzw. Gebäudes auf dem Baugrundstück abgebildet werden.&lt;/para>&#xA;&lt;para>Falls beispielsweise ein Umbau geplant ist und auf dem Grundstück mehrere Gebäude bestehen, muss aus diesen Angaben hervorgehen, was der Gegenstand des Anbaus ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460651189553_356419_3799" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460651189553_994099_3800" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1460651189553_733771_3795" name="" memberEnd="_16_5_4_940029b_1460651189553_439942_3797 _16_5_4_940029b_1460651189553_361952_3796">
            <ownedEnd xmi:id="_16_5_4_940029b_1460651189553_361952_3796" name="" visibility="private" type="_16_5_4_940029b_1460559782420_922066_3743" association="_16_5_4_940029b_1460651189553_733771_3795"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460651165974_293124_3777" name="GeoreferenzierteLage">
            <ownedComment xmi:id="_16_5_4_940029b_1461160878182_666896_5884" annotatedElement="_16_5_4_940029b_1460651165974_293124_3777" body="&lt;para>In eine Instanz diesen Typs werden die Geodaten eines Vorhabens oder einer sonstigen Entität eintragen.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465269351210_845309_5051" name="flaeche" visibility="private" type="_16_5_4_940029b_1462299055656_708712_5047" aggregation="composite" association="_16_5_4_940029b_1465269351210_133361_5050">
              <ownedComment xmi:id="_16_5_4_940029b_1465270497478_461035_5532" annotatedElement="_16_5_4_940029b_1465269351210_845309_5051" body="&lt;para>In diesem Element lassen sich georeferenzierte Daten zu Bauvorhaben, Baulasten oder sonstigen Objekten übermitteln, also zu Gegenständen, die im Zusammenhang von XBau-Prozessen näher bestimmt werden sollen. Es  lassen sich hier z. B. die äußeren Kanten eines geplanten Gebäudes (Bauvorhaben) georeferenziert abbilden.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465375574948_447007_5525" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465375574948_617106_5526" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460559782420_430828_3746" name="erlaeuterung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1461160888499_448047_5886" annotatedElement="_16_5_4_940029b_1460559782420_430828_3746" body="&lt;para>Hier können ergänzend Erläuterungen zur Lage des Bauvorhabens (Vorhabens) auf dem Baugrundstück gegeben werden  (z. B. &quot;Anbau an Nordseite&quot;).&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460560067276_796836_3774" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460560067276_69329_3775" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460560241523_867175_3826" name="Anlagen">
            <ownedComment xmi:id="_16_5_4_940029b_1461259171039_660685_5520" annotatedElement="_16_5_4_940029b_1460560241523_867175_3826" body="&lt;para>Dieser Typ dient dazu aufzunehmen: (a) in jedem Fall die Angaben (Metadaten) zu den Anlagen eines Antrags und (b) optional diese Anlagen (Primärdokumente) selbst. Anlagen zum Antrag sind in erster Linie Bauvorlagen, in vielen Fällen zusätzlich weitere Anlagen (wie Nachweise und ergänzende Dokumentationen).&lt;/para>&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460733760899_910997_4047" name="anlage" visibility="private" type="_16_5_4_8a30247_1408618910687_847379_2963" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461160810037_905663_5869" annotatedElement="_16_5_4_940029b_1460733760899_910997_4047" body="&lt;para>Jede Instanz dieses Elements steht für eine Anlage zum vorliegenden Antrag.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460733760899_826458_4049" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460733760899_101516_4050" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1461084279278_496533_4827" name="Bauvorhaben">
            <ownedComment xmi:id="_16_5_4_940029b_1461160875809_931471_5883" annotatedElement="_16_5_4_940029b_1461084279278_496533_4827" body="&lt;para>Typ für die Daten eines Bauvorhabens, enthält Informationen zum Wer, Was und Wo des Bauvorhabens bzw. Vorhabens. Der Begriff 'Bauvorhaben' wird hier sehr weit gefasst, so dass auch Nutzungsänderungen ohne Baumaßnahmen abgedeckt sind. Der Typ wird in allen Nachrichten eingesetzt, in denen Eigenschaften eines Bauvorhabens (bzw. Vorhabens) anzugeben sind bzw. geprüft werden sollen. Er wird auch da eingesetzt, wo über ein Bauvorhaben (Vorhaben) oder über Maßnahmen im Zusammenhang eines Bauvorhabens (Vorhabens) zu informieren ist.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465272422051_162818_5562" name="bezeichnungDesBauvorhabens" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1465272422067_560947_5565" annotatedElement="_16_5_4_940029b_1465272422051_162818_5562" body="&lt;para>In dieses Element ist die Bezeichnung des Vorhabens einzutragen. Sie wird vom Bauherrn vergeben und später ggf. von der Bauaufsichtsbehörde geändert.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465272422067_593755_5564" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465272422067_150034_5566" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461084360081_64878_4895" name="beteiligte" visibility="private" type="_16_5_4_940029b_1460554558325_844345_3559" aggregation="composite" association="_16_5_4_940029b_1461084360081_772823_4893">
              <ownedComment xmi:id="_16_5_4_940029b_1461160868556_215507_5882" annotatedElement="_16_5_4_940029b_1461084360081_64878_4895" body="&lt;para>Dieses Objekt steht für die am Bauvorhaben (Vorhaben) beteiligten Parteien (Personen und Organisationen).&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461084360081_977377_4897" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461084360081_356799_4898" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461084355950_986474_4887" name="gegenstand" visibility="private" type="_16_5_4_940029b_1460558980541_7300_3475" aggregation="composite" association="_16_5_4_940029b_1461084355950_158366_4885">
              <ownedComment xmi:id="_16_5_4_940029b_1461160865696_793817_5881" annotatedElement="_16_5_4_940029b_1461084355950_986474_4887" body="&lt;para>Dieser Abschnitt beschreibt, was der Gegenstand des Antrags ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461084355950_169353_4889" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461084355950_647401_4890" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461084352715_352666_4879" name="verortung" visibility="private" type="_16_5_4_940029b_1460559782420_922066_3743" aggregation="composite" association="_16_5_4_940029b_1461084352715_724467_4877">
              <ownedComment xmi:id="_16_5_4_940029b_1461160863411_495453_5880" annotatedElement="_16_5_4_940029b_1461084352715_352666_4879" body="&lt;para>Dieser Abschnitt beschäftigt sich mit der Lokalisierung des Vorhabens in relevanten Bezugssystemen.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461084352715_15329_4881" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461084352715_174390_4882" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1461084360081_772823_4893" name="" memberEnd="_16_5_4_940029b_1461084360081_64878_4895 _16_5_4_940029b_1461084360081_816834_4894">
            <ownedEnd xmi:id="_16_5_4_940029b_1461084360081_816834_4894" name="" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" association="_16_5_4_940029b_1461084360081_772823_4893"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1461084352715_724467_4877" name="" memberEnd="_16_5_4_940029b_1461084352715_352666_4879 _16_5_4_940029b_1461084352715_485776_4878">
            <ownedEnd xmi:id="_16_5_4_940029b_1461084352715_485776_4878" name="" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" association="_16_5_4_940029b_1461084352715_724467_4877"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1461084355950_158366_4885" name="" memberEnd="_16_5_4_940029b_1461084355950_986474_4887 _16_5_4_940029b_1461084355950_973076_4886">
            <ownedEnd xmi:id="_16_5_4_940029b_1461084355950_973076_4886" name="" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" association="_16_5_4_940029b_1461084355950_158366_4885"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465269351210_133361_5050" name="" memberEnd="_16_5_4_940029b_1465269351210_845309_5051 _16_5_4_940029b_1465269351210_590067_5052">
            <ownedEnd xmi:id="_16_5_4_940029b_1465269351210_590067_5052" name="" visibility="private" type="_16_5_4_940029b_1460651165974_293124_3777" association="_16_5_4_940029b_1465269351210_133361_5050"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465319949338_111677_6242" name="Anonym_BerufNummer">
            <ownedComment xmi:id="_16_5_4_940029b_1465319949338_718197_6245" annotatedElement="_16_5_4_940029b_1465319949338_111677_6242" body="&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465319467545_390342_6180" name="nummerEintragungsliste" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1465319467561_616051_6203" annotatedElement="_16_5_4_940029b_1465319467545_390342_6180" body="&lt;para>Hier ist die Nummer der Eintragungsliste der jeweiligen Kammer einzutragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483105030158_814261_5134" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483105030158_935680_5135" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465320233547_555419_6283" name="Anonym_Bauvorlageberechtigung">
            <ownedComment xmi:id="_16_5_4_940029b_1465320233563_422510_6288" annotatedElement="_16_5_4_940029b_1465320233547_555419_6283" body=""/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465321337380_140631_6353" name="sachverhalt" visibility="private" type="_16_5_4_8a30247_1408526420047_574553_2278">
              <ownedComment xmi:id="_16_5_4_940029b_1465321337396_627951_6356" annotatedElement="_16_5_4_940029b_1465321337380_140631_6353" body="&lt;para>In diesem Element  ist zu kennzeichnen, aufgrund welchen Sachverhalts&#x9; der Entwurfsverfasser seine  Bauvorlageberechtigung innehat.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465321337396_127699_6355" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465321337396_370594_6357" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465320233547_302105_6285" name="kammer" visibility="private" type="_16_5_4_940029b_1465319949338_111677_6242">
              <ownedComment xmi:id="_16_5_4_940029b_1465320233563_384943_6291" annotatedElement="_16_5_4_940029b_1465320233547_302105_6285" body="&lt;para>Falls der Entwurfsverfasser seine Bauvorlageberechtigung als Architekt, Innenarchitekt oder Ingenieur innehat, ist dieses Element mit den Angaben aus der Zugehörigkeit zur entsprechenden Kammer zu füllen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483105068731_47953_5137" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483105068731_999514_5138" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465389414760_979926_6071" name="BeteiligteBauprojektUmsetzung">
            <ownedComment xmi:id="_16_5_4_940029b_1465389414760_107104_6077" annotatedElement="_16_5_4_940029b_1465389414760_979926_6071" body="&lt;para>Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465389414760_258948_6073" name="bauherr" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1465389414760_844763_6080" annotatedElement="_16_5_4_940029b_1465389414760_258948_6073" body="&lt;para>Hier sind Angaben zur Person des  Bauherrn zu machen, falls diese nicht identisch ist mit dem Bauherrn, der den Bescheid zum Bauantrag erhalten hat.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465389573417_929380_6106" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465389573417_763503_6107" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465389414760_429445_6074" name="bauleiter" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1465389414760_699851_6084" annotatedElement="_16_5_4_940029b_1465389414760_429445_6074" body="&lt;para>Hier sind Angaben zur Person und ggf. Firma des Bauleiters zu machen.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465389541231_548859_6104" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465389541231_272512_6105" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465389414760_590_6075" name="bauunternehmer" visibility="private" type="_16_5_4_8a30247_1422977426041_172815_6757">
              <ownedComment xmi:id="_16_5_4_940029b_1465389414760_466876_6088" annotatedElement="_16_5_4_940029b_1465389414760_590_6075" body="&lt;para>Als Bauunternehmer ist der Rohbau-Unternehmer einzutragen, benötigt wird die Firma mit Ansprechpartner.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465389414760_668981_6087" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465389414760_816775_6089" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465389414760_954276_6076" name="fachbauleiter" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
              <ownedComment xmi:id="_16_5_4_940029b_1465389414760_194241_6092" annotatedElement="_16_5_4_940029b_1465389414760_954276_6076" body="&lt;para>Hier sind ggf. die Fachbauleiter zu nennen, die auf einzelnen Teilgebieten an die Stelle des Bauleiters treten.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465389528640_341362_6102" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465389528640_404082_6103" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467842445378_570661_5400" name="Anonym_BefundAntragFormell">
            <ownedComment xmi:id="_16_5_4_940029b_1467842445394_510974_5406" annotatedElement="_16_5_4_940029b_1467842445378_570661_5400" body=""/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842445378_959445_5402" name="artDesBefundes" visibility="private" type="_16_5_4_940029b_1467878653841_502297_5169">
              <ownedComment xmi:id="_16_5_4_940029b_1467842445394_187112_5409" annotatedElement="_16_5_4_940029b_1467842445378_959445_5402" body="&lt;para>In diesem Element wird die Befundkategorie angegeben, der dieser Befund zugeordnet werden kann.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467879824604_405201_5561" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467879824604_329319_5562" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842445394_688125_5403" name="refAnlage" visibility="private" type="_16_5_4_940029b_1467842624105_925789_5453">
              <ownedComment xmi:id="_16_5_4_940029b_1467842445394_286618_5413" annotatedElement="_16_5_4_940029b_1467842445394_688125_5403" body="&lt;para>Für Befunde, die sich auf eine eingereichte Bauvorlage bzw. eine sonstige Anlage zum Antrag beziehen, wird in diesem Objekt der Bezug hergestellt.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467842998545_917651_5558" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467842998545_132167_5559" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842977089_248652_5552" name="betroffeneAnlage" visibility="private" type="_16_5_4_8a30247_1408530241706_68973_2543" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467879267029_945752_5558" annotatedElement="_16_5_4_940029b_1467842977089_248652_5552" body="&lt;para>Für Befunde, die Mängel an einer eingereichten Bauvorlage oder das Fehlen einer Bauvorlage (einer bestimmten Art) betreffen, wird in diesem Element die Art dieser Bauvorlage angegeben (die den Mangel hat bzw. die nachzureichen ist).&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467842989812_77180_5556" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467842989812_115219_5557" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467843013793_549083_5560" name="beschreibung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1467843013793_631994_5563" annotatedElement="_16_5_4_940029b_1467843013793_549083_5560" body="&lt;para>Hier wird der Sachverhalt des Befundes beschrieben. Dieser Sachverhalt ist eine detailliertere Darstellung im Rahmen der parallel angegebenen Art des Befundes.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467843013793_252774_5562" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467843013793_784635_5564" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467842624105_925789_5453" name="RefAnlage">
            <ownedComment xmi:id="_16_5_4_940029b_1469955948657_527861_6074" annotatedElement="_16_5_4_940029b_1467842624105_925789_5453" body="&lt;para>Typ für die Bezugnahme auf Bestandteile eines Antrags oder eines Auftrags. Dieser Typ wird im Kontext einer formellen Prüfung eingesetzt.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842761727_594467_5522" name="art" visibility="private" type="_16_5_4_8a30247_1408530241706_68973_2543" aggregation="composite" association="_16_5_4_940029b_1467842761727_550967_5520">
              <ownedComment xmi:id="_16_5_4_940029b_1467879371270_198765_5559" annotatedElement="_16_5_4_940029b_1467842761727_594467_5522" body="&lt;para>Hier wird die Art der referenzierten  Bauvorlage oder sonstigen Anlage zum vorliegenden Antrag genannt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467842761727_440391_5524" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467842761727_217530_5525" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842810328_89873_5526" name="bezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467842810328_81868_5529" annotatedElement="_16_5_4_940029b_1467842810328_89873_5526" body="&lt;para>Hier wird die Bezeichnung der referenziereten  Bauvorlage angegeben.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467842810328_297523_5528" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467842810328_997862_5530" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467842875383_95114_5542" name="versionsnummer" visibility="private">
              <ownedComment xmi:id="_16_5_4_940029b_1467842875383_23903_5545" annotatedElement="_16_5_4_940029b_1467842875383_95114_5542" body="&lt;para>Hier ist die Versionsnummer der referenzierten Bauvorlage einzutragen. &lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469736063910_76784_5762" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469736063910_705855_5763" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1467842761727_550967_5520" name="" memberEnd="_16_5_4_940029b_1467842761727_594467_5522 _16_5_4_940029b_1467842761727_876377_5521">
            <ownedEnd xmi:id="_16_5_4_940029b_1467842761727_876377_5521" name="" visibility="private" type="_16_5_4_940029b_1467842624105_925789_5453" association="_16_5_4_940029b_1467842761727_550967_5520"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467843232886_870322_5578" name="BefundlisteAntragFormell">
            <ownedComment xmi:id="_16_5_4_940029b_1468226410169_570540_5568" annotatedElement="_16_5_4_940029b_1467843232886_870322_5578" body="&lt;para>Dieser Typ beinhaltet die Befunde der formellen Prüfung eines Antrags oder einer Anfrage. Für jeden Befund sind die entsprechenden Parameter gefüllt, die Inhalt und Bezug des Befundes für den Antragsteller bzw. Anfragenden nachvollziehbar machen.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467843283923_737799_5635" name="befund" visibility="private" type="_16_5_4_940029b_1467842445378_570661_5400" aggregation="composite" association="_16_5_4_940029b_1467843283923_190241_5633">
              <ownedComment xmi:id="_16_5_4_940029b_1467879574842_759782_5560" annotatedElement="_16_5_4_940029b_1467843283923_737799_5635" body="&lt;para>Dieses Element stellt genau einen Befund der Befundliste dar.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467843315561_553642_5642" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467843315561_39694_5643" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1467843283923_190241_5633" name="" memberEnd="_16_5_4_940029b_1467843283923_737799_5635 _16_5_4_940029b_1467843283923_268709_5634">
            <ownedEnd xmi:id="_16_5_4_940029b_1467843283923_268709_5634" name="" visibility="private" type="_16_5_4_940029b_1467843232886_870322_5578" association="_16_5_4_940029b_1467843283923_190241_5633"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467880682692_826535_5579" name="Anonym_BelastenderVerwaltungsaktGrund">
            <ownedComment xmi:id="_16_5_4_940029b_1467881357405_42046_5676" annotatedElement="_16_5_4_940029b_1467880682692_826535_5579" body=""/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467880682692_48585_5580" name="rechtsbereich" visibility="private" type="_16_5_4_940029b_1467881020760_671045_5646" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467880682692_666174_5586" annotatedElement="_16_5_4_940029b_1467880682692_48585_5580" body="&lt;para>Dieses Element nennt den  Rechtsbereich, innerhalb dessen der belastende Verwaltungsakt liegt. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467880682692_305102_5585" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467880682692_346347_5587" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467880682692_589206_5581" name="bezeichnungRegelverstoss" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467880682692_82739_5590" annotatedElement="_16_5_4_940029b_1467880682692_589206_5581" body="&lt;para>Hier wird die Bezeichnung des betreffenden Regelverstoßes genannt.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467880682692_683190_5589" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467880682692_430865_5591" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467880748142_983290_5609" name="begruendung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467880748142_338809_5612" annotatedElement="_16_5_4_940029b_1467880748142_983290_5609" body="&lt;para>Hier wird begründet, inwiefern es sich um einen Regelverstoß handelt.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467880748142_217668_5611" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467880748142_40326_5613" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467881984463_299931_5687" name="BefundlisteMateriell">
            <ownedComment xmi:id="_16_5_4_940029b_1468226644882_844054_5570" annotatedElement="_16_5_4_940029b_1467881984463_299931_5687" body="&lt;para>Eine Instanz diesen Typs steht für eine Befundliste der materiellen Prüfung eines Antrags. Jeder Befund beinhaltet die Parameter, die einen  belastenden Verwaltungsakt im Kontext eines Baugenehmigungsvorgangs definieren. &lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467881984463_587315_5688" name="befund" visibility="private" type="_16_5_4_940029b_1467880682692_826535_5579" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467881984463_458327_5691" annotatedElement="_16_5_4_940029b_1467881984463_587315_5688" body="&lt;para>Jedes Element steht für einen  belastenden Verwaltungsakt im Kontext des aktuellen Baugenehmigungsvorgang, zu dem der Adressat der Nachricht zu einer Stellungnahme aufgefordert ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467881984463_739099_5690" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467881984463_448132_5692" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467883282532_109433_5716" name="StellungnahmeBelastenderVerwaltungsakt">
            <ownedComment xmi:id="_16_5_4_940029b_1467883282532_537740_5721" annotatedElement="_16_5_4_940029b_1467883282532_109433_5716" body="&lt;para>Dieser Typ nimmt die Parameter einer Stellungnahme auf, mit der sich ein Antragsteller zu einem  belastenden Verwaltungsakt äußert. &lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467883282532_133376_5719" name="bezeichnungRegelverstoss" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467883282532_906231_5728" annotatedElement="_16_5_4_940029b_1467883282532_133376_5719" body="&lt;para>Hier ist die Bezeichnung des betreffenden Regelverstoßes genannt.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467883282532_202732_5727" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467883282532_64852_5729" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467883282532_277358_5720" name="stellungnahme" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_16_5_4_940029b_1467883282532_265671_5732" annotatedElement="_16_5_4_940029b_1467883282532_277358_5720" body="&lt;para>Dieses Element enthält die Stellungnahme des Antragsstellers. Sie nimmt auf die Beanstandung Bezug.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467883282532_982774_5731" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467883282532_214318_5733" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467896012971_615347_5228" name="StellungnahmeStrukturiert">
            <ownedComment xmi:id="_16_5_4_940029b_1467896012971_191572_5234" annotatedElement="_16_5_4_940029b_1467896012971_615347_5228" body="&lt;para>Dieser Typ beinhaltet die Parameter einer strukturierten Stellungname, den die beteiligte Behörde für die Zustellung ihrer Stellungnahme verwenden kann.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467896012971_594522_5233" name="tenor" visibility="private" type="_18_0_2_940029b_1528208046488_660356_9591">
              <ownedComment xmi:id="_16_5_4_940029b_1467896012971_670740_5249" annotatedElement="_16_5_4_940029b_1467896012971_594522_5233" body="&lt;para>Hier wird der Tenor der Stellungnahme formuliert. Handelt es sich um eine Zustimmung, kann diese mit oder ohne Nebenbestimmung zugestellt werden. Falls eine Abweichungsentscheidung in diesem Fall vorliegt, kann diese positiv oder negativ ausfallen.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467896012971_801434_5248" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467896012971_939024_5250" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_8c5027b_1516030904633_681670_9453" name="rechtsbereich" visibility="private" type="_16_5_4_940029b_1467881020760_671045_5646">
              <ownedComment xmi:id="_18_0_2_8c5027b_1516893822803_219520_9686" annotatedElement="_18_0_2_8c5027b_1516030904633_681670_9453" body="&lt;para>Dieses Element nennt den Rechtsbereich, innerhalb dessen die Stellungnahme zugestellt wird.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1516030956814_410512_9455" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_8c5027b_1516030956814_313039_9456" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467899754926_723683_5816" name="abweichung" visibility="private" type="_16_5_4_940029b_1467898745212_460254_5732">
              <ownedComment xmi:id="_16_5_4_940029b_1467899754926_689793_5819" annotatedElement="_16_5_4_940029b_1467899754926_723683_5816" body="&lt;para>Hier werden ggf. die Erläuterungen zur Stellungnahme geliefert, die eine beantragte Abweichung betreffen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899779273_940020_5823" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899779273_568933_5824" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467900508054_878418_5896" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467899960094_58945_5827">
              <ownedComment xmi:id="_16_5_4_940029b_1467900508054_419827_5899" annotatedElement="_16_5_4_940029b_1467900508054_878418_5896" body="&lt;para>Hier werden ggf. Nebenbestimmungen zur Stellungnahme eingefügt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467900508054_904728_5898" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467900508054_459410_5900" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467896012971_435561_5230" name="begruendung" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_16_5_4_940029b_1467896012971_530169_5237" annotatedElement="_16_5_4_940029b_1467896012971_435561_5230" body="&lt;para>Falls die Stellungnahme nicht zustimmend ausgefallen ist, wird in diesem Element die entsprechende Begründung geliefert.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467897591079_903715_5613" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467897591079_715941_5614" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_8c5027b_1516031282383_682826_9459" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826">
              <ownedComment xmi:id="_18_0_2_8c5027b_1516893752973_201694_9623" annotatedElement="_18_0_2_8c5027b_1516031282383_682826_9459" body="&lt;para>Die für das Verständnis der Stellungnahme notwendigen Bauvorlagen werden in diesem Objekt eingefügt. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1516031312798_634031_9461" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_8c5027b_1516031312798_161663_9462" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467896417302_199580_5413" name="Anonym_TenorBescheid">
            <ownedComment xmi:id="_16_5_4_940029b_1467896417302_79764_5416" annotatedElement="_16_5_4_940029b_1467896417302_199580_5413" body="&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1483174208250_220105_4993" name="istGenehmigung" visibility="private" aggregation="composite" association="_16_5_4_940029b_1483174208250_292936_4991">
              <ownedComment xmi:id="_16_5_4_940029b_1483174208250_221227_4996" annotatedElement="_16_5_4_940029b_1483174208250_220105_4993" body="&lt;para>Falls der Tenor positiv  ist (Genehmigung), so ist in diesem Element &quot;true&quot; zu übermitteln, andernfalls (Ablehnung) &quot;false&quot;.&lt;/para>&#xA;&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483174208250_865470_4995" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483174208250_449384_4997" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1483173944143_754493_4933" name="kommentareFachrecht" visibility="private" type="_16_5_4_940029b_1467898080791_611578_5629" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1483173944143_103892_4936" annotatedElement="_16_5_4_940029b_1483173944143_754493_4933" body="&lt;para>Unterhalb dieses Elements sind - falls solche vorliegen - zur Information die Kommentare bzw. Bewertungen aus den beteiligten Stellen nach Fachrecht festgehalten. Sie sind im Verfahren der Bauaufsichtsbehörde berücksichtigt worden, das zum vorliegenden Bescheid geführt hat. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483173944143_168734_4935" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483173944143_191489_4937" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467898080791_611578_5629" name="Anonym_KommentierungFachrecht">
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898254675_357693_5716" name="kommentarFachrecht" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734" aggregation="composite" association="_16_5_4_940029b_1467898254675_471068_5714">
              <ownedComment xmi:id="_16_5_4_940029b_1467898465801_34247_5731" annotatedElement="_16_5_4_940029b_1467898254675_357693_5716" body="&lt;para>Pro Kommentar aus einem Fachbereich ist ein eigenes Element (welches mehrere Absätze Text enthalten kann) zu füllen. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483174387356_16671_5002" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483174387356_701124_5003" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1467898254675_471068_5714" name="" memberEnd="_16_5_4_940029b_1467898254675_357693_5716 _16_5_4_940029b_1467898254675_242691_5715">
            <ownedEnd xmi:id="_16_5_4_940029b_1467898254675_242691_5715" name="" visibility="private" type="_16_5_4_940029b_1467898080791_611578_5629" association="_16_5_4_940029b_1467898254675_471068_5714"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467898745212_460254_5732" name="AbweichungBearbeitet">
            <ownedComment xmi:id="_16_5_4_940029b_1467898745212_139877_5738" annotatedElement="_16_5_4_940029b_1467898745212_460254_5732" body="&lt;para>Falls die Abweichung eines Bauvorhabens von öffentlich-rechtlichen Bestimmungen bearbeitet (und damit zugelassen bzw. nicht zugelassen) wurde, dient dieser Typ im entsprechenden Kontext zur Übermittlung der relevanten Parameter.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477414923667_692142_4874" name="istZugelassen" visibility="private">
              <ownedComment xmi:id="_16_5_4_940029b_1477414923667_568641_4877" annotatedElement="_16_5_4_940029b_1477414923667_692142_4874" body="&lt;para>Falls die beantragte Abweichung zugelassen wurde, ist hier 'true' einzutragen, andernfalls 'false'.&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477414923667_925184_4876" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477414923667_762298_4878" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898745212_618349_5734" name="art" visibility="private" type="_16_5_4_940029b_1467899588074_956585_5786">
              <ownedComment xmi:id="_16_5_4_940029b_1467898745212_715109_5741" annotatedElement="_16_5_4_940029b_1467898745212_618349_5734" body="&lt;para>Hier ist einzutragen, als welche Art von Abweichung die beantragte Abweichung einzustufen ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467898745212_603681_5740" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467898745212_622775_5742" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898745212_176599_5736" name="vorschrift" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_16_5_4_940029b_1467898745212_771422_5749" annotatedElement="_16_5_4_940029b_1467898745212_176599_5736" body="&lt;para>Vorschrift der materiellen Anforderung: Hier sind Referenzen auf die Rechtsnormen einzutragen, auf die sich die bearbeitete Abweichung bezieht.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467898745212_422605_5748" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467898745212_805833_5750" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898745212_921510_5735" name="begruendung" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_16_5_4_940029b_1467898745212_467326_5745" annotatedElement="_16_5_4_940029b_1467898745212_921510_5735" body="&lt;para>In diesem Element wird begründet, warum die Abweichung zugelassen bzw. nicht zugelassen wurde.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477413999548_483262_4857" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477413999548_8273_4858" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467898745212_501005_5737" name="nebenbestimmung" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_16_5_4_940029b_1467898745212_376704_5753" annotatedElement="_16_5_4_940029b_1467898745212_501005_5737" body="&lt;para>Hier werden für den Fall der Zulassung der beantragten Abweichungen ggf. Nebenbestimmungen formuliert, deren Einhaltung die Bauaufsichtsbehörde zur Bedingung für die Zulassung gemacht hat.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477414285029_329768_4861" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477414285029_975590_4862" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467899960094_58945_5827" name="Nebenbestimmung">
            <ownedComment xmi:id="_16_5_4_940029b_1467899960094_268144_5832" annotatedElement="_16_5_4_940029b_1467899960094_58945_5827" body="&lt;para>Dieser Typ beinhaltet die Parameter, die eine Nebenbestimmung definieren. &lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467899960094_859221_5830" name="art" visibility="private" type="_16_5_4_940029b_1467900180389_963351_5866">
              <ownedComment xmi:id="_16_5_4_940029b_1467899960094_37751_5839" annotatedElement="_16_5_4_940029b_1467899960094_859221_5830" body="&lt;para>Hier wird die Art genannt, von der die erlassene Nebenbestimmung ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899960094_874529_5838" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899960094_379143_5840" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467899960094_262689_5829" name="rechtsbereich" visibility="private" type="_16_5_4_940029b_1467881020760_671045_5646" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1467899960094_429933_5835" annotatedElement="_16_5_4_940029b_1467899960094_262689_5829" body="&lt;para>Dieses Element nennt den  Rechtsbereich, innerhalb dessen die Nebenbestimmung erlassen ist. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899960094_335460_5834" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899960094_314099_5836" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467899960094_603922_5831" name="nebenbestimmung" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_16_5_4_940029b_1467899960094_68030_5843" annotatedElement="_16_5_4_940029b_1467899960094_603922_5831" body="&lt;para>Hier wird die Nebenbestimmung formuliert.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467899960094_676513_5842" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467899960094_876462_5844" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1468095951196_331249_5557" name="AbweichungBeantragt">
            <ownedComment xmi:id="_16_5_4_940029b_1468095951200_292499_5563" annotatedElement="_16_5_4_940029b_1468095951196_331249_5557" body="&lt;para>Dieser Typ beinhaltet die Parameter einer Abweichung von öffentlich-rechtlichen Bestimmungen, die der Bauaufsichtsbehörde zur Zulassung vorgelegt wird.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468095951196_464435_5559" name="art" visibility="private" type="_16_5_4_940029b_1467899588074_956585_5786">
              <ownedComment xmi:id="_16_5_4_940029b_1468095951200_502251_5566" annotatedElement="_16_5_4_940029b_1468095951196_464435_5559" body="&lt;para>Hier ist einzutragen, als welche Art von Abweichung die beantragte Abweichung einzustufen ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468095951200_711068_5565" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468095951200_970357_5567" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477414687178_700359_4863" name="vorschrift" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1477414687178_93340_4866" annotatedElement="_16_5_4_940029b_1477414687178_700359_4863" body="&lt;para>In diesem Element ist die Vorschrift der materiellen Anforderung zu bezeichnen: Es sind Referenzen auf die Rechtsnormen einzutragen, auf die sich die bearbeitete Abweichung bezieht.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477414687178_842513_4865" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477414687178_372032_4867" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468095951196_511790_5560" name="beschreibung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1468095951200_497666_5570" annotatedElement="_16_5_4_940029b_1468095951196_511790_5560" body="&lt;para>In diesen Objekt ist der Abweichungsgegenstand im Detail zu erläutern.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468095951200_187319_5569" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468095951200_873398_5571" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468095951200_819943_5561" name="begruendung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1468095951200_681462_5574" annotatedElement="_16_5_4_940029b_1468095951200_819943_5561" body="&lt;para>In diesem Element ist zur beantragten Abweichung eine Erläuterung zu geben, warum die beantragte Zulassung aus Sicht des Antragstellers gerechtfertigt ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468095951200_590143_5573" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468095951200_177256_5575" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1468234354477_21931_5653" name="VorbescheidBeantragt">
            <ownedComment xmi:id="_16_5_4_940029b_1468234354477_785240_5658" annotatedElement="_16_5_4_940029b_1468234354477_21931_5653" body="&lt;para>Dieser Typ beinhaltet die Parameter einer Frage, die im Rahmen eines Vorbescheidantrags thematisiert wird. Insoweit diese Frage einen Abweichungsantrag bzw. eine beantragte Erleichterung betrifft, sind in einer Instanz des Typs Daten enthalten, die den entsprechenden Kontext verdeutlichen.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234354477_312707_5655" name="artDerFrage" visibility="private" type="_16_5_4_940029b_1468234098881_686844_5623">
              <ownedComment xmi:id="_16_5_4_940029b_1468234354477_17954_5661" annotatedElement="_16_5_4_940029b_1468234354477_312707_5655" body="&lt;para>Hier ist einzutragen, in welche Kategorie die im Rahmen des Vorbescheidantrags thematisierte Fragestellung einzuordnen ist. &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468234354477_794779_5660" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468234354477_97916_5662" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468235962721_846336_5792" name="vorbescheidfrage" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1468235962721_637394_5797" annotatedElement="_16_5_4_940029b_1468235962721_846336_5792" body="&lt;para>Beschreibung der Fragestellung(en) im Rahmen eines Vorbescheids&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469644175736_402589_5675" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469644175736_637697_5676" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234506946_62529_5679" name="beantragteAbweichung" visibility="private" type="_16_5_4_940029b_1468095951196_331249_5557" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1468234506962_947930_5682" annotatedElement="_16_5_4_940029b_1468234506946_62529_5679" body="&lt;para>Hier sind die Daten zu einer möglichen Abweichung eingefügt, falls die Vorbescheidfrage eine solche betrifft.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468236044140_711048_5813" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468236044140_731193_5814" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468235962721_471439_5794" name="angefragteErleichterung" visibility="private" type="_16_5_4_940029b_1468234557055_465841_5686" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1468235962721_72284_5805" annotatedElement="_16_5_4_940029b_1468235962721_471439_5794" body="&lt;para>Hier sind die Daten zu einer möglichen Erleichterung eingefügt, falls die Vorbescheidfrage eine solche betrifft.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468235962721_24417_5804" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468235962721_248033_5806" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1468234557055_465841_5686" name="ErleichterungAngefragt">
            <ownedComment xmi:id="_16_5_4_940029b_1468234557055_443329_5691" annotatedElement="_16_5_4_940029b_1468234557055_465841_5686" body="&lt;para>Dieser Typ beinhaltet die Parameter einer beantragten Erleichterung, die der Bauaufsichtsbehörde zur Genehmigung vorgelegt werden soll.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234557055_894333_5688" name="gegenstand" visibility="private" type="_16_5_4_940029b_1483376802440_144041_4921">
              <ownedComment xmi:id="_16_5_4_940029b_1468234557055_701697_5694" annotatedElement="_16_5_4_940029b_1468234557055_894333_5688" body="&lt;para>Hier wird angezeigt, auf welchen Aspekt des Bauvorhabens sich die beantragte Erleichterung bezieht.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468234557055_396465_5693" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468234557055_986832_5695" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234557055_464140_5689" name="beschreibung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1468234557055_629887_5698" annotatedElement="_16_5_4_940029b_1468234557055_464140_5689" body="&lt;para>Hier ist der Erleichterungsgegenstand zu konkretisieren. Es wird im Detail verdeutlicht, worum es bei dem Anliegen geht).&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468234557055_7751_5697" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468234557055_661634_5699" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1468234557055_407548_5690" name="begruendung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1468234557055_556565_5702" annotatedElement="_16_5_4_940029b_1468234557055_407548_5690" body="&lt;para>In diesem Element wird ggf. eine Begründung zur beantragten Erleichterung gegeben, d.h. es wird erläutert, warum die beantragte Erleichterung benötigt wird bzw. gerechtfertigt ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1468235448925_27700_5763" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1468235448925_329059_5764" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475588555524_74161_6543" name="Anonym_VorlageArt">
            <ownedComment xmi:id="_16_5_4_940029b_1475588555540_819428_6549" annotatedElement="_16_5_4_940029b_1475588555524_74161_6543" body=""/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475588555524_228815_6545" name="vorlageBauvorhaben" visibility="private" type="_16_5_4_940029b_1475588088450_490142_6509">
              <ownedComment xmi:id="_16_5_4_940029b_1475588555540_512182_6552" annotatedElement="_16_5_4_940029b_1475588555524_228815_6545" body="&lt;para>Für Anlagen zu einem Antrag oder einer Anzeige, die zur Beurteilung des Bauvorhabens (Vorhabens) dienen, wird hier die Art der Vorlage (bzw. Anlage) genannt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475588555540_475865_6551" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475588555540_909626_6553" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475588555540_640277_6546" name="vorlageBauantragBearbeitung" visibility="private" type="_16_5_4_8a30247_1408530241706_68973_2543">
              <ownedComment xmi:id="_16_5_4_940029b_1475588555540_467309_6556" annotatedElement="_16_5_4_940029b_1475588555540_640277_6546" body="&lt;para>Für sonstige Anlagen, die zur Bearbeitung des Bauantrags notwendig sind (sich also nicht auf das Bauvorhaben beziehen), wird hier die Art der Vorlage (bzw. Anlage) genannt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475588555540_727705_6555" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475588555540_554659_6557" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475588555540_568318_6547" name="vorlageBauzustand" visibility="private" type="_16_5_4_940029b_1475159895898_998624_6483">
              <ownedComment xmi:id="_16_5_4_940029b_1475588555540_750002_6560" annotatedElement="_16_5_4_940029b_1475588555540_568318_6547" body="&lt;para>Für Bauvorlagen, deren Zweck ist,  die Anzeige eines Bauzustands zu belegen, wird hier die Art der Vorlage genannt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475588555540_278164_6559" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475588555540_138725_6561" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475592596655_193877_6574" name="Anonym_ArtDerBaulichenAnlage">
            <ownedAttribute xmi:id="_16_5_4_940029b_1475592596655_291999_6576" name="artDesGebaeudes" visibility="private" type="_16_5_4_940029b_1475164426407_736819_6878">
              <ownedComment xmi:id="_16_5_4_940029b_1475592596655_383269_6585" annotatedElement="_16_5_4_940029b_1475592596655_291999_6576" body="&lt;para>Hier wird für bauliche Anlagen, die Gebäude sind, eine Klassifizierung vorgenommen.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475592596655_323750_6584" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475592596655_958121_6586" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475592596655_616097_6577" name="artDerSonstigenAnlage" visibility="private" type="_16_5_4_940029b_1478973756024_756938_5136">
              <ownedComment xmi:id="_16_5_4_940029b_1475592596655_601256_6589" annotatedElement="_16_5_4_940029b_1475592596655_616097_6577" body="&lt;para>Hier ist für sonstige bauliche Anlagen, also solche, die nicht Gebäude sind, eine Klassifizierung vorzunehmen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475592596655_823356_6588" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475592596655_59344_6590" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477944131500_703757_4834" name="artNichtAufgefuehrt" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1477944131500_391176_4837" annotatedElement="_16_5_4_940029b_1477944131500_703757_4834" body="&lt;para>Falls die Codelisten der anderen Elemente die Art der baulichen Anlage des Vorhabens nicht kennzeichnen können (und nur dann), ist hier die Angabe als Freitext einzutragen. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483378041247_747258_4948" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1483378041247_400288_4949" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1477928375350_829581_4792" name="BefundlistePruefungBauzustand">
            <ownedComment xmi:id="_16_5_4_940029b_1477928375379_528002_4795" annotatedElement="_16_5_4_940029b_1477928375350_829581_4792" body="&lt;para>Eine Instanz diesen Typs steht für eine Befundliste der materiellen Prüfung eines Antrags. Jeder Befund beinhaltet die Parameter, die einen  belastenden Verwaltungsakt im Kontext eines Baugenehmigungsvorgangs definieren. &lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477928375379_682741_4794" name="befund" visibility="private" type="_16_5_4_940029b_1477928417510_526532_4802" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1477928375379_488596_4798" annotatedElement="_16_5_4_940029b_1477928375379_682741_4794" body="&lt;para>Jedes Element steht für einen  belastenden Verwaltungsakt im Kontext des aktuellen Baugenehmigungsvorgang, zu dem der Adressat der Nachricht zu einer Stellungnahme aufgefordert ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477928375379_134966_4797" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477928375379_4901_4799" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1477928417510_526532_4802" name="Anonym_BefundPruefungBauzustand">
            <ownedComment xmi:id="_16_5_4_940029b_1477928417510_98460_4806" annotatedElement="_16_5_4_940029b_1477928417510_526532_4802" body=""/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477928417510_622788_4804" name="beschreibung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1477928417510_824193_4813" annotatedElement="_16_5_4_940029b_1477928417510_622788_4804" body="&lt;para>Hier wird der festgestellt Mangel beschrieben.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477928417510_998881_4812" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477928417510_34072_4814" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477928417510_722577_4805" name="verweise" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1477928417510_165732_4817" annotatedElement="_16_5_4_940029b_1477928417510_722577_4805" body="&lt;para>Hier kann ein Verweis auf eine Nebenbestimmung der Baugenehmigung eingefügt werden, oder auf z. B. den Prüfbericht Standsicherheit oder Brandschutz.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477928647430_91777_4827" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477928647430_413581_4828" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477928417510_709191_4803" name="rechtsbereich" visibility="private" type="_16_5_4_940029b_1467881020760_671045_5646" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1477928417510_961772_4809" annotatedElement="_16_5_4_940029b_1477928417510_709191_4803" body="&lt;para>Dieses Element nennt (falls zutreffend) den  Rechtsbereich, innerhalb dessen die Bestimmung liegt, gegen die im Kontext des Befundes verstoßen wurde. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477928451695_571477_4825" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477928451695_986504_4826" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1483174208250_292936_4991" name="" memberEnd="_16_5_4_940029b_1483174208250_220105_4993 _16_5_4_940029b_1483174208250_476558_4992">
            <ownedEnd xmi:id="_16_5_4_940029b_1483174208250_476558_4992" name="" visibility="private" type="_16_5_4_940029b_1467896417302_199580_5413" association="_16_5_4_940029b_1483174208250_292936_4991"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_8c5027b_1527777801950_350739_9451" name="Bescheid">
            <ownedComment xmi:id="_18_0_2_8c5027b_1527777801950_641169_9452" annotatedElement="_18_0_2_8c5027b_1527777801950_350739_9451" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Bescheides, den die Bauaufsichtsbehörde nach Prüfung eines Antrags erlässt.&lt;/para>"/>
            <ownedAttribute xmi:id="_18_0_2_8c5027b_1527777801950_33412_9453" name="tenor" visibility="private" type="_16_5_4_940029b_1467896417302_199580_5413">
              <ownedComment xmi:id="_18_0_2_8c5027b_1527777801950_169172_9461" annotatedElement="_18_0_2_8c5027b_1527777801950_33412_9453" body="&lt;para>Hier wird der Bescheid formuliert. Es handelt sich entweder um eine Genehmigung oder um eine Ablehnung.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1527777801950_228533_9462" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_8c5027b_1527777801950_351299_9460" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_8c5027b_1527777801950_83563_9454" name="begruendung" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_18_0_2_8c5027b_1527777801950_610829_9465" annotatedElement="_18_0_2_8c5027b_1527777801950_83563_9454" body="&lt;para>Falls der Bescheid ablehnend ausgefallen ist, wird in diesem Element die entsprechende Begründung geliefert.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1527777801950_702081_9466" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_8c5027b_1527777801950_214032_9464" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_8c5027b_1527777801950_853954_9455" name="rechtshelfsbelehrung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_18_0_2_8c5027b_1527777801950_268093_9469" annotatedElement="_18_0_2_8c5027b_1527777801950_853954_9455" body="&lt;para>Hier werden die Rechtshelfsbelehrungen zum Bescheid gegeben.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1527777801950_805984_9470" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_8c5027b_1527777801950_712635_9468" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_8c5027b_1527777801950_123347_9456" name="hinweise" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_18_0_2_8c5027b_1527777801950_452175_9473" annotatedElement="_18_0_2_8c5027b_1527777801950_123347_9456" body="&lt;para>Hier werden ggf. ergänzende Hinweise zum Bescheid gegeben.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1527777801950_954429_9474" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_8c5027b_1527777801950_686125_9472" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_8c5027b_1527777801950_316267_9457" name="abweichung" visibility="private" type="_16_5_4_940029b_1467898745212_460254_5732">
              <ownedComment xmi:id="_18_0_2_8c5027b_1527777801950_516013_9477" annotatedElement="_18_0_2_8c5027b_1527777801950_316267_9457" body="&lt;para>Hier werden ggf. die Erläuterungen zur Genehmigung einer beantragten Abweichung eingetragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1527777801950_910226_9478" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_8c5027b_1527777801950_139659_9476" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_8c5027b_1527777801950_738867_9458" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467899960094_58945_5827">
              <ownedComment xmi:id="_18_0_2_8c5027b_1527777801950_925456_9481" annotatedElement="_18_0_2_8c5027b_1527777801950_738867_9458" body="&lt;para>Hier werden ggf. die Nebenbestimmungen zum Bescheid eingefügt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1527777801950_681981_9482" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_8c5027b_1527777801950_98705_9480" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1528208046488_660356_9591" name="Anonym_TenorStellungnahme">
            <ownedComment xmi:id="_18_0_2_940029b_1528208046488_630896_9592" annotatedElement="_18_0_2_940029b_1528208046488_660356_9591" body="&#xA;"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1528208046488_270134_9593" name="istZustimmung" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1528208046488_248980_9596" annotatedElement="_18_0_2_940029b_1528208046488_270134_9593" body="&lt;para>Falls die Stellungnahme positiv  ausgefallen ist (Zustimmung), so wird in diesem Element &quot;true&quot; übermittelt, andernfalls &quot;false&quot;.&lt;/para>&#xA;&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1528208046488_820074_9597" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1528208046488_830242_9595" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1462299055656_708712_5047" name="Anonym_Geometrie">
          <ownedAttribute xmi:id="_16_5_4_940029b_1465269124067_598733_5018" name="polygon" visibility="private" type="_18_0_2_8c5027b_1530287031672_844520_12582" aggregation="composite" association="_16_5_4_940029b_1465269124036_718978_5016">
            <ownedComment xmi:id="_16_5_4_940029b_1465270668196_604854_5535" annotatedElement="_16_5_4_940029b_1465269124067_598733_5018" body="&lt;para>Das Element (globales Element gml:Polygon) enthält die GML-Darstellung einer Grundfläche (es können Außenkanten und Innenkanten dargestellt werden).&lt;/para>&#xA;&lt;para>Aus der GML-Dokumentation: &quot;A Polygon is a special surface that is defined by a single surface patch. The boundary of this patch is coplanar and the polygon uses planar interpolation in its interior. The elements exterior and interior describe the surface boundary of the polygon.&quot; Quelle: &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&quot;>http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&lt;/link>  &lt;/para>&#xA;"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465269124067_392495_5020" name="" value="1"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465269124067_248877_5021" name="" value="1"/>
          </ownedAttribute>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465269124036_718978_5016" name="" memberEnd="_16_5_4_940029b_1465269124067_598733_5018 _16_5_4_940029b_1465269124067_795564_5017">
          <ownedComment xmi:id="_16_5_4_940029b_1465540439858_361794_5449" annotatedElement="_16_5_4_940029b_1465269124036_718978_5016" body="&lt;para>Doku an der Assoziation zum globalen Element Polygon.&lt;/para>"/>
          <ownedEnd xmi:id="_16_5_4_940029b_1465269124067_795564_5017" name="" visibility="private" type="_16_5_4_940029b_1462299055656_708712_5047" association="_16_5_4_940029b_1465269124036_718978_5016"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465320433717_376869_6328" name="" memberEnd="_16_5_4_940029b_1465320433717_159041_6330 _16_5_4_940029b_1465320433717_718640_6329">
          <ownedEnd xmi:id="_16_5_4_940029b_1465320433717_718640_6329" name="" visibility="private" type="_16_5_4_8a30247_1408705895800_629557_4010" association="_16_5_4_940029b_1465320433717_376869_6328"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1408703057450_27821_3423" name="Akteur">
          <ownedComment xmi:id="_16_5_4_8a30247_1408706838747_261394_4377" annotatedElement="_16_5_4_8a30247_1408703057450_27821_3423" body="&lt;para>Durch den Typ Akteur wird eine Differenzierung zwischen  natürlichen Einzelpersonen, Personengruppen und juristischen Personen definiert.&lt;/para>&#xA;&lt;para>Im Namen einer Firma handelt eine natürliche Person als Vertreter. Bei mehreren Personen (z.B. Eigentümergemeinschaften) wird jede Person (juristisch oder nätürlich) als Akteur definiert. Eine Person dieser Gruppe kann als Vertreter definiert werden.&lt;/para>"/>
          <ownedAttribute xmi:id="_16_5_4_8a30247_1422977828419_207131_7447" name="organisation" visibility="private" type="_16_5_4_8a30247_1422977426041_172815_6757" aggregation="composite" association="_16_5_4_8a30247_1422977828419_100798_7445">
