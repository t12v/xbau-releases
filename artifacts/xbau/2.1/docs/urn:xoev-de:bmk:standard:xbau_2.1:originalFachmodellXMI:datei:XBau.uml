        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_1eeb04c1_1364491558900_214019_1634" clientDependency="_16_5_4_127f0398_1432802773775_107719_2263 _16_5_4_127f0398_1432803575169_748537_2845" name="Kommunikation" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364313776811_220119_9414" name="Kommunikation">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1364378030865_908892_1229" annotatedElement="_16_5_4_1eeb04c1_1364313776811_220119_9414" body="&lt;para>Angaben zur Erreichbarkeit einer Behörde oder einer Person (Telefon, Fax, E-Mail, etc.).&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1415191695956_934970_2565" name="kanal" visibility="private" type="_16_5_4_1eeb04c1_1415191648150_782509_2421">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1415191695958_269496_2568" annotatedElement="_16_5_4_1eeb04c1_1415191695956_934970_2565" body="&lt;para>Es wird angegeben, über welches Kommunikationsmedium (z. B. Telefon, E-Mail) die Erreichbarkeit gegeben ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1415191695958_54583_2567" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1415191695959_176851_2569" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364313820971_336352_9436" name="kennung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1367854162356_72121_1360" annotatedElement="_16_5_4_1eeb04c1_1364313820971_336352_9436" body="&lt;para>Je nach Kommunikationsmedium (siehe Art) werden nähere Angaben gemacht.&lt;/para>&#xA;&lt;para>In der Regel werden hier Adressangaben eingetragen, etwa die Telefonnummer oder die E-Mail-Adresse.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364313831651_540196_9438" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364313831651_580247_9439" name="" value="1"/>
            </ownedAttribute>
