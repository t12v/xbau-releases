            <node xmi:type="uml:CallBehaviorAction" xmi:id="_16_5_4_940029b_1462359357898_743019_7173" name="Befundliste erstellen" visibility="public" inPartition="_16_5_4_940029b_1462359357898_828047_7164" outgoing="_16_5_4_940029b_1462359357898_235060_7145" incoming="_16_5_4_940029b_1462359357898_303225_7147">
