            <node xmi:type="uml:CallBehaviorAction" xmi:id="_16_5_4_940029b_1478883858583_64587_4712" name="materielle Prüfung durchführen" visibility="public" inPartition="_16_5_4_940029b_1478883858568_812138_4700" outgoing="_16_5_4_940029b_1478883858568_368926_4692" incoming="_16_5_4_940029b_1478883858568_827301_4691">
