              <ownedComment xmi:id="_16_5_4_940029b_1467902983357_270168_5954" annotatedElement="_16_5_4_940029b_1467902983357_724954_5947" body="&lt;para>IBAN des Kontos, auf das die Gebühr einzuzahlen ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467903173393_508250_5983" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467903173393_222641_5984" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467902983357_991281_5949" name="bic" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467902983357_14526_5962" annotatedElement="_16_5_4_940029b_1467902983357_991281_5949" body="&lt;para>Angabe zur Bank (BIC), bei der das Konto eingerichtet ist, auf das die Gebühr einzuzahlen ist. Für Überweisungen des Anwenders aus dem Ausland.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467902983357_999013_5961" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467902983357_103822_5963" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467903020454_231000_5976" name="verwendungszweck" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467903020454_476250_5979" annotatedElement="_16_5_4_940029b_1467903020454_231000_5976" body="&lt;para>Hier ist das Kassenzeichen einzutragen, unter dem die Sollstellung durch die Baubehörde bei der lokalen Finanzverwaltung veranlasst wurde. Ist vom Bauherrn bei der Zahlung im Überweisungsformular in das Feld &quot;Verwendungszweck&quot; einzutragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467903180941_133981_5985" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467903180941_558067_5986" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
