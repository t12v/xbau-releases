    <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1462348527108_909791_4858" name="Akteure &amp; Use Cases" URI="">
      <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1462348527123_535584_4859" name="Akteure" URI="">
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527545_39080_4882" name="Bauaufsichtsbehörde">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_785374_4959" annotatedElement="_16_5_4_940029b_1462348527545_39080_4882" body="&lt;para>Die Bauaufsichtsbehörde (BAB) prüft die Einhaltung der öffentlich-rechtlichen Vorschriften (vgl. §58 Abs.2 MBO).&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527545_777321_4883" name="Bauherr">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_379588_4960" annotatedElement="_16_5_4_940029b_1462348527545_777321_4883" body="&lt;para>Natürliche oder juristische  Person mit Bauvorhaben oder Bauprojekt. Verantwortlich für das Stellen von Anträgen., Anzeigen und Nachweisen. Bestellung der am Bau Beteiligten. (vgl. §53 MBO)&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527545_424508_4884" name="Prüfsachverständiger">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_919257_4961" annotatedElement="_16_5_4_940029b_1462348527545_424508_4884" body="&lt;para>Prüft im Auftrag des Bauherrn an Stelle der Bauaufsichtsbehörde. Verantwortlich für die Prufung von bautechnischen Nachweisen unter Beachtung der Schutzziele.&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527561_393609_4885" name="Entwurfsverfasser">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_871954_4962" annotatedElement="_16_5_4_940029b_1462348527561_393609_4885" body="&lt;para>Vom Bauherrn mit der fachlichen Betreuung des Bauvorhabens beauftragt. Kann ein Architekt sein / kann ein  Ingenieur sein.&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527561_375727_4886" name="Fachbehörde">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_699060_4963" annotatedElement="_16_5_4_940029b_1462348527561_375727_4886" body="&lt;para>Behörde mit Expertise für ein Fachgebiet. Nimmt im Beteiligungsverfahren Stellung zu entsprechenden Sach- und Fachfragen.&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527561_853870_4887" name="Fachplaner">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_99710_4964" annotatedElement="_16_5_4_940029b_1462348527561_853870_4887" body="&lt;para>Arbeitet im Auftrag des Entwurfsverfassers. Hat Sachkunde auf speziellen Gebieten.&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527561_560883_4888" name="Prüfingenieur">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_903431_4965" annotatedElement="_16_5_4_940029b_1462348527561_560883_4888" body="&lt;para>Prüft im Auftrag der Bauaufsichtsbehörde als beliehener Unternehmer. Verantwortlich für die Prufung von bautechnischen Nachweisen unter Beachtung der Schutzziele.&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527561_509484_4889" name="zuständige Behörde">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_635062_4966" annotatedElement="_16_5_4_940029b_1462348527561_509484_4889" body="&lt;para>Diese Behörde prüft, ob die öffentlich-rechtlichen Vorschriften ihres Zuständigkeitsbereichs eingehalten sind.&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527561_384987_4890" name="Informationsempfänger">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_787302_4967" annotatedElement="_16_5_4_940029b_1462348527561_384987_4890" body="&lt;para>Datenempfänger im Rahmen eines Informationsverfahrens.&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527561_281394_4891" name="Nachbar">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_670384_4968" annotatedElement="_16_5_4_940029b_1462348527561_281394_4891" body="&lt;para>Eigentümer eines benachbarten (nach SEVESO III betroffenen) Grundstücks (vgl. §70 Abs. 1). / &lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Actor" xmi:id="_16_5_4_940029b_1462348527561_753421_4892" name="Gemeinde">
          <ownedComment xmi:id="_16_5_4_940029b_1462348527561_854320_4969" annotatedElement="_16_5_4_940029b_1462348527561_753421_4892" body="&lt;para>Gemeinde, in der das Bauvorhaben gelegen ist. Sie ist Trägerin der kommunalen Planungshoheit.&lt;/para>"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1478121976053_839247_4754" name="" memberEnd="_16_5_4_940029b_1478121976053_195483_4755 _16_5_4_940029b_1478121976053_491921_4756" navigableOwnedEnd="_16_5_4_940029b_1478121976053_195483_4755 _16_5_4_940029b_1478121976053_491921_4756">
