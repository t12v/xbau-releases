                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_449638_6078" annotatedElement="_16_5_4_5b501fb_1387625291120_136357_5215" body="Der Rufname ist der im alltäglichen Gebrauch zu nutzende Vorname.&#xA;"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_290982_6079" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291120_136357_5215"/>
