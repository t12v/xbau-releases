            </node>
            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1478883858583_605599_4704" name="Angepasster &#xA;Prüfauftrag&#xA;Nachricht 0503" visibility="public" outgoing="_16_5_4_940029b_1478883858568_40193_4682" incoming="_16_5_4_940029b_1478883858568_126708_4672">
