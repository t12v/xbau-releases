            </node>
            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1462359358764_159431_7466" name="Ergebnis der Prüfung&#xA;Nachricht 0602" visibility="public" outgoing="_16_5_4_940029b_1462359358764_499825_7438" incoming="_16_5_4_940029b_1462359358764_334052_7430">
              <ownedComment xmi:id="_16_5_4_940029b_1462359360091_692676_8114" annotatedElement="_16_5_4_940029b_1462359358764_159431_7466" body="&lt;para>Die zuständige Behörde / Dienstelle versendet die Nachricht 'Nachforderung', um die ausstehenden Unterlagen zu erhalten.&lt;/para>"/>
            </node>
            <node xmi:type="uml:CallBehaviorAction" xmi:id="_16_5_4_940029b_1462359358764_832653_7467" name="Unterlagen zusammenstellen" visibility="public" inPartition="_16_5_4_940029b_1462359358764_193733_7459" outgoing="_16_5_4_940029b_1462359358764_480476_7429" incoming="_16_5_4_940029b_1462359358764_615742_7431">
