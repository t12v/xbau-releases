                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291322_930598_6144" annotatedElement="_16_5_4_5b501fb_1387625291122_480846_5237" body="Hier werden Angaben zur Religionszugehörigkeit einer natürlichen Person gemacht."/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291322_199035_6145" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_608193_5164" association="_16_5_4_5b501fb_1387625291122_480846_5237"/>
