            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1540998120907_538579_11241" name="DatenAnlass">
              <ownedComment xmi:id="_18_0_2_940029b_1540998120907_19395_11242" annotatedElement="_18_0_2_940029b_1540998120907_538579_11241" body="&lt;para>Dieser Typ enthält die Daten, die zum Anlass 'Baufertigstellung' gehören. &lt;/para>"/>
