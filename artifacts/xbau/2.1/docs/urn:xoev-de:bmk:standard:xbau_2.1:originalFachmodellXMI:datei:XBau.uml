              <ownedComment xmi:id="_18_0_2_8c5027b_1516030764456_456575_9445" annotatedElement="_18_0_2_8c5027b_1516030611157_996742_9438" body="&lt;para>Hier werden die Rechtshelfsbelehrungen zur Stellungnahme gegeben.&lt;/para>"/>
