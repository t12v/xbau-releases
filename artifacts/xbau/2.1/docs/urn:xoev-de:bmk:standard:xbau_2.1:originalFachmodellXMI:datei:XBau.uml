              <ownedComment xmi:id="_16_5_4_940029b_1461162244107_557189_5897" annotatedElement="_16_5_4_940029b_1461154163204_775260_4979" body="&lt;para>Hier werden die Identifkationsmerkmale zur vorliegenden Nachricht genannt.&lt;/para>"/>
