<xmi:XMI xmi:version="20110701" xmlns:xmi="http://www.omg.org/spec/XMI/20110701" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:KoSITCodelistenProfil="http:///schemas/KoSITCodelistenProfil/_3bzMQFU7Eem76qy_rce7yg/0" xmlns:KoSITDokumentationsProfil="http:///schemas/KoSITDokumentationsProfil/_3b8WMVU7Eem76qy_rce7yg/0" xmlns:KoSITMagicDrawProfil="http:///schemas/KoSITMagicDrawProfil/_3b8WMFU7Eem76qy_rce7yg/0" xmlns:MagicDrawProfile="http://www.omg.org/spec/UML/20131001/MagicDrawProfile" xmlns:OSCITransportProfil="http:///schemas/OSCITransportProfil/_3ZHEoFU7Eem76qy_rce7yg/0" xmlns:XMLSchemaProfile="http:///schemas/XMLSchemaProfile/_3cZCIFU7Eem76qy_rce7yg/0" xmlns:XOEVProfil="http:///schemas/XOEVProfil/_3cGHMFU7Eem76qy_rce7yg/0" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" xmlns:uml="http://www.eclipse.org/uml2/4.0.0/UML" xsi:schemaLocation="http:///schemas/KoSITCodelistenProfil/_3bzMQFU7Eem76qy_rce7yg/0 KoSIT-Codelisten-Profil.profile.uml#_3sjsF1U7Eem76qy_rce7yg http:///schemas/KoSITDokumentationsProfil/_3b8WMVU7Eem76qy_rce7yg/0 KoSIT-Dokumentations-Profil.profile.uml#_3sQqIlU7Eem76qy_rce7yg http:///schemas/KoSITMagicDrawProfil/_3b8WMFU7Eem76qy_rce7yg/0 KoSIT-MagicDraw-Profil.profile.uml#_3saXy1U7Eem76qy_rce7yg http://www.omg.org/spec/UML/20131001/MagicDrawProfile UML_Standard_Profile.MagicDraw_Profile.profile.uml#_3sjvdVU7Eem76qy_rce7yg http:///schemas/OSCITransportProfil/_3ZHEoFU7Eem76qy_rce7yg/0 OSCI-Transport-Profil.profile.uml#_3sQ0ZlU7Eem76qy_rce7yg http:///schemas/XMLSchemaProfile/_3cZCIFU7Eem76qy_rce7yg/0 XML_Schema_Profile.profile.uml#_3sQs1lU7Eem76qy_rce7yg http:///schemas/XOEVProfil/_3cGHMFU7Eem76qy_rce7yg/0 XOEV-Profil.profile.uml#_3sjmJlU7Eem76qy_rce7yg">
