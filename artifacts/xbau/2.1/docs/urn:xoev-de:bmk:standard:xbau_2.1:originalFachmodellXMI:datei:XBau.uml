            </node>
            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1462359357898_76092_7168" name="Ergebnis der formellen Prüfung&#xA;Nachricht 0301" visibility="public" outgoing="_16_5_4_940029b_1462359357898_904563_7155" incoming="_16_5_4_940029b_1462359357898_235060_7145">
