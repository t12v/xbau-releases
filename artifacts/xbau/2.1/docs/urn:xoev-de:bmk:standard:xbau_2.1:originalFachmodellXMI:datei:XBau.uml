        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1423043972175_271232_6283" name="Code.Staat">
          <ownedComment xmi:id="_16_5_4_8a30247_1423043972191_96309_6289" annotatedElement="_16_5_4_8a30247_1423043972175_271232_6283" body="&lt;para>Codeliste Staatsgebiete aus der Staats- und Gebietssystematik des Statistischen Bundesamtes.Sie basiert auf dem &lt;quote>Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote> des Auswärtigen Amtes. &lt;/para>&#xA;&#xA;&lt;para>Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;"/>
          <generalization xmi:id="_16_5_4_8a30247_1423043972191_589442_6285" general="_16_5_4_5b501fb_1387625280047_322339_5028"/>
