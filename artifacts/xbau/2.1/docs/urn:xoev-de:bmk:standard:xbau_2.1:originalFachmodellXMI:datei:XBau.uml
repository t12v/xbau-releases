            </node>
            <node xmi:type="uml:CallBehaviorAction" xmi:id="_16_5_4_940029b_1462359358764_76855_7470" name="Erklärung vorbereiten" visibility="public" inPartition="_16_5_4_940029b_1462359358764_319731_7462" outgoing="_16_5_4_940029b_1462359358764_334052_7430" incoming="_16_5_4_940029b_1462359358764_137939_7452">
