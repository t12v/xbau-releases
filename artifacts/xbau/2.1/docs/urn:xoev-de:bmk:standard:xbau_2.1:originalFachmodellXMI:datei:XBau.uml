                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_158394_6075" annotatedElement="_16_5_4_5b501fb_1387625291120_795313_5214" body="Hier werden Angaben zum Zeitraum gemacht, in dem eine natürliche Person einer Religionsgemeinschaft angehört."/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_925602_6076" name="" visibility="private" type="_16_5_4_5b501fb_1387625291102_124392_5163" association="_16_5_4_5b501fb_1387625291120_795313_5214"/>
