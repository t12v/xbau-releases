              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_964792_5217" name="" memberEnd="_16_5_4_5b501fb_1387625291306_837649_5952 _16_5_4_5b501fb_1387625291319_121198_6085">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_199736_6084" annotatedElement="_16_5_4_5b501fb_1387625291120_964792_5217" body="Die Komponente &quot;alternativeRepraesentation&quot; beinhaltet den Namen einer natürlichen Person in einer Form, die einer festgelegten Konvention folgt. Die in der Komponente  &quot;AlternativeRepraesentation&quot; übermittelten Informationen müssen redundant zu den anderen Elementen der Komponente &quot;NameNatuerlichePerson&quot; sein, sie dürfen diese nicht ersetzen. &#xA;"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291319_121198_6085" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291120_964792_5217"/>
              </packagedElement>
