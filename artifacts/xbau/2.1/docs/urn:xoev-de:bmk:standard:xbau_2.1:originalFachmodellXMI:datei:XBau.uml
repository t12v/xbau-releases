  <XOEVProfil:xoevCodeliste xmi:id="_3wrQkFU7Eem76qy_rce7yg" base_Enumeration="_18_0_2_8ae0277_1550653190309_213432_16354" nameLang="XBau Fehlerkennzahlen" nameKurz="XBau Fehlerkennzahlen" nameTechnisch="xbau-fehlerkennzahlen" kennung="urn:xoev-de:xbau:codeliste:xbau-fehlerkennzahlen" beschreibung="Codeliste der Fehlerkennzahlen für die Klassifikation von Fehlern, die in XBau-Nachrichteninstanzen angetroffen werden. Die Einträge bestehen aus Fehlerkennzahl und der Angabe deren Bedeutung. Gruppen von Codes: X - formales Problem mit XML oder mit (Inhalten von) Codelisten, V - Versionsproblem, S - nicht spezifikationskonform, A - Problem mit Anlagen zur empfangenen Nachricht." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQkVU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_940029b_1476116440129_865713_5899" nameLang="MBO Garagentypen" nameKurz="MBO Garagentypen" nameTechnisch="mbogaragentyp" kennung="urn:xoev-de:xbau:codeliste:mbogaragentyp" beschreibung="Garagen nach § 2 Abs. 7 MBO, konkretisiert in § 1 Abs. 8 MGarV" herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQklU7Eem76qy_rce7yg" base_Enumeration="_18_0_2_8ae0277_1550651525214_531686_16266" nameLang="Destatis Staatsgebiete" nameKurz="Destatis Staatsgebiete" nameTechnisch="Staatsgebiete" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:staatsgebiete" beschreibung="Codeliste Staatsgebiete aus der Staats- und Gebietssystematik des Statistischen Bundesamtes.Sie basiert auf dem &lt;quote>Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote> des Auswärtigen Amtes.&#xA;&#xA;Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&#xA;" herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQk1U7Eem76qy_rce7yg" base_Enumeration="_16_5_4_940029b_1476114435825_831058_5789" nameLang="MBO Typen von Sonderbauten" nameKurz="MBO Typen von Sonderbauten" nameTechnisch="mbosonderbauten" kennung="urn:xoev-de:xbau:codeliste:mbosonderbauten" beschreibung="Liste der Typen von Sonderbauten. Sonderbauten sind Anlagen und Räume besonderer Art oder Nutzung, die die Tatbestände nach § 2 Abs. 4 MBO erfüllen." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQlFU7Eem76qy_rce7yg" base_Enumeration="_18_0_2_940029b_1540999092759_252416_11376" nameLang="Statistikmeldung Anlass" nameKurz="Statistikmeldung Anlass" nameTechnisch="statistikmeldunganlass" kennung="urn:xoev-de:xbau:codeliste:statistikmeldunganlass" beschreibung="Diese Codeliste enthält die Anlässe für Datenlieferungen an die amtliche Statistik." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQlVU7Eem76qy_rce7yg" base_Enumeration="_18_0_2_8ae0277_1550516469334_25205_14314" nameLang="Gemeinden gemäß Amtlicher Gemeindeschlüssel (AGS)" nameKurz="AGS" nameTechnisch="ags" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:ags" beschreibung="Diese Codeliste stellt alle Gemeinden Deutschlands durch den Amtlichen Gemeindeschlüssel (AGS) dar, wie im Gemeindeverzeichnis des Statistischen Bundesamtes enthalten." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQllU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_940029b_1468415744304_712086_5550" nameLang="Beteiligung Rolle" nameKurz="Beteiligung Rolle" nameTechnisch="beteiligungrolle" kennung="urn:xoev-de:xbau:codeliste:beteiligungrolle" beschreibung="Benennung der Rolle einer zu beteiligenden Behörde oder Stelle als Träger öffentlicher Belange in einem Beteiligungsverfahren." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQl1U7Eem76qy_rce7yg" base_Enumeration="_16_5_4_43c01ae_1406132625880_538762_2473" nameLang="MPPVO Anlass Prüfung technische Anlage" nameKurz="MPPVO Anlass Prüfung technische Anlage" nameTechnisch="mppvopruefungtechnischeanlageanlass" kennung="urn:xoev-de:xbau:codeliste:mppvopruefungtechnischeanlageanlass" beschreibung="Anlass der Prüfung einer überwachungspflilchtigen Anlage gemäß Musterprüfverordnung §2 Abs. 2" herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQmFU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_940029b_1475159529718_208599_6281" nameLang="Vorlagen zur Bauzustandsanzeige" nameKurz="Vorlagen zur Bauzustandsanzeige" nameTechnisch="vorlagenbauzustand" kennung="urn:xoev-de:xbau:codeliste:vorlagenbauzustand" beschreibung="Diese Codeliste nennt Arten von Bauvorlagen, die als Anlagen zu Bauzustandsanzeigen dienen können. Quelle ist § 81 MBO in Verbindung mit MBauVorlV Teil IV. &#xA;Diese Unterlagen sind keine Bauvorlagen zum Bauantrag gem. § 68 Abs. 2 MBO, sondern weitere Bauzustandsanzeigen zur Bauüberwachung gem. § 81 MBO." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQmVU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_940029b_1475586524021_550350_6357" nameLang="Vorlagen zur Bearbeitung des Bauantrags" nameKurz="Vorlagen zur Bearbeitung des Bauantrags" nameTechnisch="vorlagenbauantragbearbeitung" kennung="urn:xoev-de:xbau:codeliste:vorlagenbauantragbearbeitung" beschreibung="Diese Codeliste nennt Arten von Bauvorlagen, die einem Bauantrag als Anlagen beigefügt sein können und die zur Bearbeitung des Bauantrags benötigt werden.  Quelle ist § 68 Abs. 2 MBO in Verbindung mit MBauVorlVO Teil II+III." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQmlU7Eem76qy_rce7yg" base_Enumeration="_18_0_2_8ae0277_1550601663157_390259_15280" nameLang="Länder der Bundesrepublik Deutschland" nameKurz="Bundesland" nameTechnisch="bundesland" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:bundesland" beschreibung="Die Bundesrepublik Deutschland ist ein Zusammenschluss von Ländern. Die meisten Bundesländer umfassen mehrere Kreise und Bezirke. Diese Codeliste stellt die deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS)." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQm1U7Eem76qy_rce7yg" base_Enumeration="_18_0_2_8ae0277_1550602605898_824662_15378" nameLang="Erreichbarkeit" nameKurz="Erreichbarkeit" nameTechnisch="erreichbarkeit" kennung="urn:de:xoev:codeliste:erreichbarkeit" beschreibung="Eine Liste der Kommunikationsmedien und -kanäle, über die man eine Person oder Institution erreichen kann." herausgebernameKurz="KoSIT"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQnFU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_8a30247_1408100467415_956350_2922" nameLang="Bautechnischer Nachweis Art" nameKurz="Bautechnischer Nachweis Art" nameTechnisch="bautechnischernachweisart" kennung="urn:xoev-de:xbau:codeliste:bautechnischernachweisart" beschreibung="Art eines bautechnischen Nachweises, der zu den Planungsunterlagen eines Bauvorhabens nach § 66 MBO gehören kann." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQnVU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_8a30247_1408095722858_893266_2236" nameLang="MPPVO Bauwerksklassen" nameKurz="MPPVO Bauwerksklassen" nameTechnisch="mppvobauwerksklasse" kennung="urn:xoev-de:xbau:codeliste:mppvobauwerksklasse" beschreibung="Bauwerksklassen gemäß Anlage 2 zu § 27 Abs. 4 M-PPVO." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQnlU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_940029b_1467878416682_738588_5139" nameLang="Befunde formelle Prüfung Antrag" nameKurz="Befunde formelle Prüfung Antrag" nameTechnisch="formellebefundeantragart" kennung="urn:xoev-de:xbau:codeliste:formellebefundeantragart" beschreibung="In dieser Codeliste sind Kategorien von Befunden einer formellen Prüfung notiert. Es geht hier um Befundlisten, die das Ergebnis der formellen Prüfung eines Bauantrags, Abweichungsantrags, Vorbescheidsantrags, Prüfauftrags (bautechnische Nachweise) oder einer vorgelegten Baulasterklärung sind." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQn1U7Eem76qy_rce7yg" base_Enumeration="_16_5_4_940029b_1470154222863_758686_6129" nameLang="Genehmigungsfreistellungsverfahren Ergebnis" nameKurz="Genehmigungsfreistellungsverfahren Ergebnis" nameTechnisch="genehmigungsfreistellung" kennung="urn:xoev-de:xbau:codeliste:genehmigungsfreistellung" beschreibung="Genehmigungsfreistellungsverfahren:  Definition der möglichen Ergebnisse eines Vorgangs mit entsprechendem Bescheid an den Bauherrn." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQoFU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_940029b_1467899502316_321798_5771" nameLang="Abweichung Art" nameKurz="Abweichung Art" nameTechnisch="abweichungart" kennung="urn:xoev-de:xbau:codeliste:abweichungart" beschreibung="Definition der Arten von beantragten oder genehmigten Abweichungen eines Bauvorhabens von den Rechtsnormen." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQoVU7Eem76qy_rce7yg" base_Enumeration="_18_0_2_940029b_1547045446018_746057_11869" nameLang="MPPVO Nachprüfung Grund" nameKurz="MPPVO Nachprüfung Grund" nameTechnisch="mppvonachpruefunggrund" kennung="urn:xoev-de:xbau:codeliste:mppvonachpruefunggrund" beschreibung="Prüfung einer überwachungspflichtigen Anlage: Mögliche Gründe dafür, dass eine Nachprüfung erforderlich ist." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQolU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_8a30247_1408106036477_930856_2954" nameLang="Baumaßnahme Art" nameKurz="Baumaßnahme Art" nameTechnisch="baumassnahme" kennung="urn:xoev-de:xbau:codeliste:baumassnahme" beschreibung="Diese Codeliste enthält die Einteilung, von welcher grundsätzlichen Art die  Maßnahmen im Rahmen eines Bauvorhabens sein können." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevStandard xmi:id="_3wrQo1U7Eem76qy_rce7yg" base_Model="_16_5_4_b7102e0_1292419822540_950613_464" nameLang="XInneres-Basismodul" nameKurz="XInneres-Basismodul" nameTechnisch="xinneres.basismodul" kennung="urn:xoev-de:kosit:standard:xinneres.basismodul" beschreibung="Im Auftrag des AK I hat die PG Standard bisher unter anderem die fachlichen Vorgaben und die Struktur der Meldeanschrift für die Bereiche Ausländer-, Melde- und Personenstandswesen harmonisiert. Der vorliegende Standard XInneres bildet auf technischer Ebene eine Klammer vor den Standards der Innenverwaltung. An dieser Stelle können gemeinsam genutzte Komponenten definiert werden. In der ersten Version von XInneres definiert der Standard die Datentypen für die Darstellung der Meldeanschrift."/>
  <XOEVProfil:xoevStandard xmi:id="_3wrQpFU7Eem76qy_rce7yg" base_Model="_16_5_4_1d100e5_1384794823532_59933_328" nameLang="XBau - Standard für die Datenkommunikation der Bauaufsichtsbehörde" nameKurz="XBau" nameTechnisch="xbau" kennung="urn:xoev-de:bmk:standard:xbau" beschreibung="XBau ist der XÖV-Standard für den Datenaustausch der Bauaufsichtsbehörden mit ihren Kommunikationspartnern (Bauherren, Architektenbüros, Behörden zahlreicher Rechtsbereiche)."/>
