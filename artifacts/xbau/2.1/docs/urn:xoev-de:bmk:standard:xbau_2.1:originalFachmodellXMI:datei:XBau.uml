                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291319_729162_6081" annotatedElement="_16_5_4_5b501fb_1387625291120_932766_5216" body="Der Familienname ist der aktuelle Nachname einer Person und Ausdruck einer bestimmten Familienzugehörigkeit dieser Person. &#xA;"/>
