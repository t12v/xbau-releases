            </node>
            <node xmi:type="uml:CallBehaviorAction" xmi:id="_16_5_4_940029b_1462359358764_468459_7469" name="Freistellung&#xA;wird bestätigt" visibility="public" inPartition="_16_5_4_940029b_1462359358764_319731_7462" outgoing="_16_5_4_940029b_1462359358764_671802_7435" incoming="_16_5_4_940029b_1462359358764_530674_7450">
