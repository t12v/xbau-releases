  <XOEVProfil:xoevVersionStandard xmi:id="_3wrQv1U7Eem76qy_rce7yg" base_Model="_16_5_4_b7102e0_1292419822540_950613_464" version="7" versionXOEVHandbuch="2.1" versionXGenerator="3.0.1" versionModellierungswerkzeug="18.0 SP6"/>
  <XOEVProfil:xoevVersionStandard xmi:id="_3wrQwFU7Eem76qy_rce7yg" base_Model="_16_5_4_1d100e5_1384794823532_59933_328" version="2.1" beschreibung="In vielen Teilen überarbeitete und erweiterte produktionsreife Fassung des Standards XBau. Auf der Basis des Baurechts des Bundes und der Länder und eng am Bedarf der Praxis der Behörden entwickelt. Erweiterungen und Verbesserungen befinden sich in der Planung auch für die Zukunft. " versionXOEVHandbuch="2.1.0" versionXGenerator="2.6.1" versionModellierungswerkzeug="18.0&#xA;"/>
  <XOEVProfil:xoevBibliothek xmi:id="_3wrQwVU7Eem76qy_rce7yg" nameLang="XÖV-Bibliothek: Spezifikation der XÖV-Bausteine" nameKurz="XÖV-Bibliothek" nameTechnisch="XOEV-Bibliothek" kennung="urn:xoev-de:kosit:xoev:bibliothek:xoevbibliothek" beschreibung="Die XÖV-Bibliothek ist seit der Version 2.0 des XÖV-Handbuchs der zentrale Ort zur Verwaltung und Bereitstellung aller XÖV-spezifischer, zur Wiederverwendung vorgesehener Datentypen, Kernkomponenten und (zukünftiger) Prozessmuster, so genannter XÖV-Bausteine." herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT" externeWebsite="http://www.xoev.de/de/bibliothek" statusVerwendung="AKTUELL" base_Model="_16_5_4_5b501fb_1375258090807_886576_2132"/>
  <XOEVProfil:xoevVersionBibliothek xmi:id="_3wrQwlU7Eem76qy_rce7yg" version="2017-08-01" statusVerwendung="AKTUELL" lizenz="Creative Commons Namensnennung - Keine Bearbeitung 4.0 International" bezugsort="http://www.xoev.de/de/bibliothek" aenderungZurVorversion="Die Metadaten der XÖV-Datentypen, -Kernkomponenten und -Bibliothek sowie ihrer Versionen wurden im UML-Modell der XÖV-Bibliothek mittels der im XÖV-Profil dafür vorgesehenen Stereotypen dokumentiert. In diesem Rahmen wurde die Bibliothek auf das neue XÖV-Profil in der Version 1.5.0 aktualisiert. Die Metadaten zu XÖV-Datentypen, -Kernkomponenten und der Bibliothek wurden in das Spezifikationsdokument zur Bibliothek aufgenommen. Der Abschnitt &quot;Identifikation der XÖV-Kernkomponenten&quot; wurde entfernt, da eine Kernkomponente zukünftig anhand ihrer Kennung und Version identifiziert werden kann und die Namen der Eigenschaften einer Kernkomponente im Kontext der jeweiligen Kernkomponente eindeutig sind." base_Model="_16_5_4_5b501fb_1375258090807_886576_2132"/>
  <XOEVProfil:xoevVersionDatentyp xmi:id="_3wrQw1U7Eem76qy_rce7yg" version="1.0" statusVerwendung="AKTUELL" lizenz="Creative Commons Namensnennung - Keine Bearbeitung 4.0 International" bezugsort="http://www.xoev.de/de/bibliothek" base_Class="_16_5_4_5b501fb_1387625280047_322339_5028"/>
  <XOEVProfil:xoevVersionDatentyp xmi:id="_3wrQxFU7Eem76qy_rce7yg" version="1.1.1" statusVerwendung="AKTUELL" lizenz="Creative Commons Namensnennung - Keine Bearbeitung 4.0 International" bezugsort="http://www.xoev.de/de/bibliothek" aenderungZurVorversion="Die Versionshistorie des XÖV-Datentyps String.Latin kann in der Dokumentation des zugrundeliegenden Standards eingesehen werden (Lateinische Zeichen in Unicode, http://www.xoev.de/de/einheitlicherzeichensatz)." base_Class="_16_5_4_5b501fb_1387625271095_781237_4845"/>
