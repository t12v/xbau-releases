        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467878653841_502297_5169" name="Code.FormelleBefundeAntragArt">
          <ownedComment xmi:id="_16_5_4_940029b_1467878653841_564739_5175" annotatedElement="_16_5_4_940029b_1467878653841_502297_5169" body="&lt;para>In dieser Codeliste sind Kategorien von Befunden einer formellen Prüfung notiert. Es geht hier um Befundlisten, die das Ergebnis der formellen Prüfung eines Bauantrags, Abweichungsantrags, Vorbescheidsantrags, Prüfauftrags (bautechnische Nachweise) oder einer vorgelegten Baulasterklärung sind. &lt;/para>"/>
          <generalization xmi:id="_16_5_4_940029b_1467878653841_960588_5171" general="_16_5_4_5b501fb_1387625280047_322339_5028"/>
