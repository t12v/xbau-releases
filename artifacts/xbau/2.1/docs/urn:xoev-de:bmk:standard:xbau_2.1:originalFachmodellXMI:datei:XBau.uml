            <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_127f0398_1432803532642_6552_2787" name="" client="_16_5_4_1eeb04c1_1364477284016_472414_2524" supplier="_16_5_4_5b501fb_1387625280030_115253_5005"/>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_1eeb04c1_1364491177452_864851_1495" clientDependency="_16_5_4_1eeb04c1_1375791352756_190471_1913 _16_5_4_1eeb04c1_1364491783196_389715_1863 _16_5_4_127f0398_1432802770764_866589_2261 _16_5_4_127f0398_1432803508836_477761_2777" name="Behoerde" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364382738190_314891_1582" name="Behoerde.Erreichbar">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1364382738190_4513_1591" annotatedElement="_16_5_4_1eeb04c1_1364382738190_314891_1582" body="&lt;para>Dieser Typ enthält Angaben über den Namen und die Erreichbarkeit einer Behörde. Eine Behörde  im Sinne des Verwaltungsverfahrensgesetzes ist jede Stelle, die Aufgaben der öffentlichen Verwaltung wahrnimmt.&lt;/para>&#xA;&lt;para>Anders als in dem Typ &lt;emphasis>Behoerde&lt;/emphasis> sind in diesem Typen alle Angaben zur Kontaktaufnahme mit der übermittelten Behörde Pflichtelemente.&lt;/para>&#xA;"/>
            <generalization xmi:id="_16_5_4_1eeb04c1_1364383015751_507230_2065" general="_16_5_4_1eeb04c1_1364313722451_850604_9366"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364382738190_624767_1584" name="behoerdenname" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1430905108746_786153_1911" annotatedElement="_16_5_4_1eeb04c1_1364382738190_624767_1584" body="&lt;para>Es ist der Name der Behörde zu übermitteln.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364382738190_524282_1593" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364382738190_20264_1594" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364382738190_866140_1586" name="behoerdenkennung" visibility="private" type="_16_5_4_1eeb04c1_1364313732581_658593_9386" aggregation="composite" association="_16_5_4_1eeb04c1_1364382997291_816964_2044">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364382738190_551655_1600" annotatedElement="_16_5_4_1eeb04c1_1364382738190_866140_1586" body="&lt;para>Es wird die eindeutige Behördenkennung angegeben, über die die Behörde im DVDV ermittelt werden kann. Diese hier übermittelte Behördenkennung muss es dem Leser einer Nachricht ermöglichen, den Autor einer Nachricht im DVDV zu ermitteln um diesem ggf. erforderliche elektronische Mitteilungen senden zu können (bspw. Quittungen oder Fehlernachrichten). &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364383065581_866294_2070" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364383065581_135377_2071" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364382738190_722321_1588" name="erreichbarkeit" visibility="private" type="_16_5_4_1eeb04c1_1364313776811_220119_9414" aggregation="composite" association="_16_5_4_1eeb04c1_1364382995951_487358_2025">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364382738190_873732_1608" annotatedElement="_16_5_4_1eeb04c1_1364382738190_722321_1588" body="&lt;para>Angaben zur Erreichbarkeit dieser Behörde per Telefon, Telefax, E-Mail etc.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364383115241_607703_2076" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364383115241_313759_2077" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1386157306690_724066_1150" name="anschrift" visibility="private" type="_16_5_4_1eeb04c1_1380019660674_995526_1587" aggregation="composite" association="_16_5_4_1eeb04c1_1386157306690_834841_1148">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1386157306691_326638_1153" annotatedElement="_16_5_4_1eeb04c1_1386157306690_724066_1150" body="&lt;para>Die Anschrift dieser Behörde (für persönliches Erscheinen oder die Zusendung von Dokumenten per Briefpost an die Behörde).&lt;/para>&#xA;&#xA;&lt;!---&#xA;&lt;para>Der in der Anschrift hinterlegte Gemeindeschlüssel ist nicht zur Ermittlung einer Meldebehörde im DVDV vorgesehen. Hierfür ist ausschließlich die Behördenkennung (&lt;emphasis role=&quot;codebf&quot;>behoerdenkennung&lt;/emphasis>) zu verwenden.&lt;/para>&#xA;&#xA;&lt;para>&lt;emphasis role=&quot;rot&quot;>*** Frage 1 ***&lt;/emphasis>: Ist die Übermittlung einer postalischen Anschrift im Kontext des Nachrichtenkopfes erforderlich?&lt;/para>&#xA;-->"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1386157306691_988041_1152" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1386157306692_107413_1154" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364313722451_850604_9366" name="Behoerde">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1364371684488_105835_9714" annotatedElement="_16_5_4_1eeb04c1_1364313722451_850604_9366" body="&lt;para>Dieser Typ enthält Angaben über den Namen und die Erreichbarkeit einer Behörde. Eine Behörde  im Sinne des Verwaltungsverfahrensgesetzes ist jede Stelle, die Aufgaben der öffentlichen Verwaltung wahrnimmt.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364313743191_46553_9404" name="behoerdenname" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_1d100e5_1384262798576_654159_1882" annotatedElement="_16_5_4_1eeb04c1_1364313743191_46553_9404" body="&lt;para>Es ist der Name der Behörde zu übermitteln. &lt;/para>&#xA;&lt;para>Er dient auch dazu, eine ggfs. erforderliche manuelle Klärung zu beschleunigen, indem bspw. der Autor einer Nachricht im Klartext übermittelt, an welche Behörde er die Nachricht schicken wollte.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364313751351_193740_9406" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364313751351_747531_9407" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364313913401_902665_9449" name="behoerdenkennung" visibility="private" type="_16_5_4_1eeb04c1_1364313732581_658593_9386" aggregation="composite" association="_16_5_4_1eeb04c1_1364313913401_124412_9448">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364314552692_222453_9698" annotatedElement="_16_5_4_1eeb04c1_1364313913401_902665_9449" body="&lt;para>Es wird die eindeutige Behördenkennung angegeben, über die die Behörde im DVDV ermittelt werden kann. Diese hier übermittelte Behördenkennung muss es dem Leser einer Nachricht ermöglichen, den Autor einer Nachricht im DVDV zu ermitteln um diesem ggf. erforderliche elektronische Mitteilungen senden zu können (bspw. Quittungen oder Fehlernachrichten). &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364401014459_342103_2263" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364401014459_781178_2264" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364314023501_443069_9518" clientDependency="_16_5_4_1eeb04c1_1436454636875_793674_3930" name="erreichbarkeit" visibility="private" type="_16_5_4_1eeb04c1_1364313776811_220119_9414" aggregation="composite" association="_16_5_4_1eeb04c1_1364314023501_170081_9517">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364314889752_481140_9699" annotatedElement="_16_5_4_1eeb04c1_1364314023501_443069_9518" body="&lt;para>Angaben zur Erreichbarkeit dieser Behörde per Telefon, Telefax, E-Mail etc.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364314034251_354533_9528" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364314034251_753500_9529" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1386157300162_861825_1139" name="anschrift" visibility="private" type="_16_5_4_1eeb04c1_1380019660674_995526_1587" aggregation="composite" association="_16_5_4_1eeb04c1_1386157300156_98235_1137">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1386157300163_492642_1142" annotatedElement="_16_5_4_1eeb04c1_1386157300162_861825_1139" body="&lt;para>Die Anschrift dieser Behörde (für persönliches Erscheinen oder die Zusendung von Dokumenten per Briefpost an die Behörde).&lt;/para>&#xA;&lt;!---&#xA;&lt;para>Der in der Anschrift hinterlegte Gemeindeschlüssel ist nicht zur Ermittlung einer Meldebehörde im DVDV vorgesehen. Hierfür ist ausschließlich die Behördenkennung (&lt;emphasis role=&quot;codebf&quot;>behoerdenkennung&lt;/emphasis>) zu verwenden.&lt;/para>&#xA;&#xA;&lt;para>&lt;emphasis role=&quot;rot&quot;>*** Frage 1 ***&lt;/emphasis>: Ist die Übermittlung einer postalischen Anschrift im Kontext des Nachrichtenkopfes erforderlich?&lt;/para>&#xA;--> "/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1386157300163_123219_1141" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1386157300166_445204_1143" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364313732581_658593_9386" name="Behoerdenkennung">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1364383264641_604199_2080" annotatedElement="_16_5_4_1eeb04c1_1364313732581_658593_9386" body="&lt;para>Die &lt;emphasis role=&quot;codebf&quot;>Behoerdenkennung&lt;/emphasis> fasst die Elemente zusammen, unter denen eine Behörde als Anbieter elektronischer Services im DVDV verzeichnet ist. Sie besteht aus einem Präfix und der eigentlichen Kennung. Grundsätzlich gibt es zu jedem Präfix eine entsprechende Schlüsseltabelle für die Kennung.&lt;/para>&#xA;&#xA;&lt;para>Zum Beispiel werden Standesämter über das Präfix &lt;emphasis role=&quot;codebf&quot;>psw&lt;/emphasis> und die Standesamtsnummer adressiert.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364372151465_159655_9779" name="praefix" visibility="private" type="_16_5_4_1eeb04c1_1364372067428_126125_9749">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364372188687_205724_9787" annotatedElement="_16_5_4_1eeb04c1_1364372151465_159655_9779" body="&lt;para>Klasse für Behördenkennungen.&lt;/para>&#xA;&#xA;&lt;para>Die Liste der Präfixe für Behördenkennungen wird durch das Bundesverwaltungsamt (BVA) als koordinierende Stelle für das DVDV verwaltet.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364372167190_845048_9781" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364372167190_864270_9782" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364372167190_911035_9783" name="kennung" visibility="private" type="_16_5_4_1eeb04c1_1364378060427_980996_1230">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1364372211322_658216_9788" annotatedElement="_16_5_4_1eeb04c1_1364372167190_911035_9783" body="&lt;para>Dieses Element kennzeichnet eine Behörde innerhalb der durch den Präfix bezeichneten Klasse eindeutig.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364372176690_807506_9785" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364372176690_521977_9786" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1364378060427_980996_1230" name="Code.Behoerdenkennung">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1364378060442_693479_1237" annotatedElement="_16_5_4_1eeb04c1_1364378060427_980996_1230" body="&lt;para>Die zu verwendende Schlüsseltabelle ergibt sich aus dem Nachrichtenkontext. Zum Beispiel ist bei der Datenübermittlung an ein Standesamt die Schlüsseltabelle der Standesamtsnummern und somit eine Standesamtsnummer als Behördenkennung zu verwenden.&lt;/para>&#xA;&#xA;"/>
            <generalization xmi:id="_16_5_4_1eeb04c1_1364378060427_23672_1232" general="_16_5_4_5b501fb_1387625280047_322339_5028"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1364378060427_93271_1233" name="code" visibility="private">
