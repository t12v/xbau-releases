  <XOEVProfil:xoevCodeliste xmi:id="_3wrQiVU7Eem76qy_rce7yg" base_Enumeration="_18_0_2_8ae0277_1550560369227_120051_14508" nameLang="BMK Bauwerkszuordnungskatalog" nameKurz="BMK Bauwerkszuordnungskatalog" nameTechnisch="bauwerkszuordnungskatalog" kennung="urn:xoev-de:bmk:codeliste:bauwerkszuordnungskatalog" beschreibung="Diese Codeliste stellt die Klassifikation von Gebäuden gemäß Bauwerkszuordnungskatalog dar. Der Bauwerkszuordnungskatalog  beschreibt die Art eines Gebäudes, indem die Art seiner Nutzung angegeben wird." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQilU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_8a30247_1408100123057_922371_2857" nameLang="Vorlagen zur Beurteilung des Bauvorhabens" nameKurz="Vorlagen zur Beurteilung des Bauvorhabens" nameTechnisch="vorlagenbauantragbauvorhaben" kennung="urn:xoev-de:xbau:codeliste:vorlagenbauantragbauvorhaben" beschreibung="Diese Codeliste nennt Arten von Bauvorlagen, die einem Bauantrag als Anlagen beigefügt sein können und die zur Beurteilung des Bauvorhabens notwendig sind. Quelle ist § 68 Abs. 2 MBO in Verbindung mit MBauVorlVO Teil II+III." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQi1U7Eem76qy_rce7yg" base_Enumeration="_16_5_4_8a30247_1408098313778_299755_2612" nameLang="Bauvorlageberechtigung Sachverhalt" nameKurz="Bauvorlageberechtigung Sachverhalt" nameTechnisch="bauvorlageberechtigungsachverhalt" kennung="urn:xoev-de:xbau:codeliste:bauvorlageberechtigungsachverhalt" beschreibung="Diese Codeliste nennt die gemäß § 65 Abs. 2 MBO definierten Sachverhalte, aufgrund derer eine Person bauvorlageberechtigt sein kann." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
