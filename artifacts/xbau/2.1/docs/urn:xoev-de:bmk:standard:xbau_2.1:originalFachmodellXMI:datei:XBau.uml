          <packagedElement xmi:type="uml:Enumeration" xmi:id="_16_5_4_940029b_1476113938361_712577_5705" name="Codelist.MboGebaeudeklasse">
            <ownedLiteral xmi:id="_16_5_4_940029b_1476113938361_512743_5707" name="1">
              <ownedComment xmi:id="_16_5_4_940029b_1476114053032_751850_5727" annotatedElement="_16_5_4_940029b_1476113938361_512743_5707" body="&lt;para>Freistehende Gebäude mit einer Höhe bis zu 7 m und nicht mehr als zwei Nutzungseinheiten von insgesamt nicht mehr als 400 m² und freistehende land- oder forstwirtschaftlich genutzte Gebäude&lt;/para>"/>
            </ownedLiteral>
            <ownedLiteral xmi:id="_16_5_4_940029b_1476113938361_615031_5708" name="2">
              <ownedComment xmi:id="_16_5_4_940029b_1476114056727_404279_5728" annotatedElement="_16_5_4_940029b_1476113938361_615031_5708" body="&lt;para>Gebäude mit einer Höhe bis zu 7 m und nicht mehr als zwei Nutzungseinheiten von insgesamt nicht mehr als 400 m²&lt;/para>"/>
            </ownedLiteral>
            <ownedLiteral xmi:id="_16_5_4_940029b_1476113938361_180254_5709" name="3">
              <ownedComment xmi:id="_16_5_4_940029b_1476114059442_684667_5729" annotatedElement="_16_5_4_940029b_1476113938361_180254_5709" body="&lt;para>Sonstige Gebäude mit einer Höhe bis zu 7 m&lt;/para>"/>
            </ownedLiteral>
            <ownedLiteral xmi:id="_16_5_4_940029b_1476113938361_855793_5710" name="4">
              <ownedComment xmi:id="_16_5_4_940029b_1476114061958_936457_5730" annotatedElement="_16_5_4_940029b_1476113938361_855793_5710" body="&lt;para>Gebäude mit einer Höhe bis zu 13 m und Nutzungseinheiten mit jeweils nicht mehr als 400 m²&lt;/para>"/>
            </ownedLiteral>
            <ownedLiteral xmi:id="_16_5_4_940029b_1476113938361_472749_5711" name="5">
              <ownedComment xmi:id="_16_5_4_940029b_1476114071937_38743_5731" annotatedElement="_16_5_4_940029b_1476113938361_472749_5711" body="&lt;para>Sonstige Gebäude einschließlich unterirdischer Gebäude&lt;/para>"/>
            </ownedLiteral>
          </packagedElement>
