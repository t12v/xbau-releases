              <ownedEnd xmi:id="_16_5_4_940029b_1465388627157_237474_5819" name="" visibility="private" type="_16_5_4_940029b_1465388336485_502829_5716" association="_16_5_4_940029b_1465388627157_986790_5817"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465388662917_85317_5832" name="" memberEnd="_16_5_4_940029b_1465388662917_766335_5833 _16_5_4_940029b_1465388662917_460174_5834">
              <ownedEnd xmi:id="_16_5_4_940029b_1465388662917_460174_5834" name="" visibility="private" type="_16_5_4_940029b_1465388336485_502829_5716" association="_16_5_4_940029b_1465388662917_85317_5832"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465388698765_786178_5845" name="Anonym_B">
              <ownedAttribute xmi:id="_16_5_4_940029b_1465388757695_649115_5902" name="datum" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1465390183440_905147_6118" annotatedElement="_16_5_4_940029b_1465388757695_649115_5902" body="&lt;para>Hier ist das Datum einzutragen, zu dem die angegebene Aktivität geplant ist.&lt;/para>"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465388757695_573041_5904" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465388757695_554899_5905" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465388794460_692128_5907" name="bezeichnungBauabschnitt" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1465388794460_419650_5910" annotatedElement="_16_5_4_940029b_1465388794460_692128_5907" body="&lt;para>Hier ist die Bezeichnung des Bauabschnitts einzutragen, dessen Arbeiten mittels der Nachricht angezeigt werden soll.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465388794460_382144_5909" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465388794460_418057_5911" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465388714024_490230_5867" name="" memberEnd="_16_5_4_940029b_1465388714024_39250_5868 _16_5_4_940029b_1465388714024_268825_5869">
              <ownedEnd xmi:id="_16_5_4_940029b_1465388714024_268825_5869" name="" visibility="private" type="_16_5_4_940029b_1465388336485_502829_5716" association="_16_5_4_940029b_1465388714024_490230_5867"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465392411967_447891_6136" name="Anonym_Unterlage">
              <ownedAttribute xmi:id="_16_5_4_940029b_1465392411967_987713_6138" name="erlaeuterung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1465392411967_811044_6145" annotatedElement="_16_5_4_940029b_1465392411967_987713_6138" body="&lt;para>Hier ist ggf. eine Erläuterung zur fehlenden Unterlage zu geben.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465393935119_814666_6280" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465393935119_471680_6281" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465392458377_31723_6151" name="bezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1465392458377_984674_6154" annotatedElement="_16_5_4_940029b_1465392458377_31723_6151" body="&lt;para>Hier ist die Bezeichnung der Unterlage einzutragen.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465392458377_683708_6153" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465392458377_618097_6155" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465392561571_667791_6181" name="FehlendeUnterlagen">
              <ownedAttribute xmi:id="_16_5_4_940029b_1465392600678_508690_6224" name="unterlage" visibility="private" type="_16_5_4_940029b_1465392411967_447891_6136" aggregation="composite" association="_16_5_4_940029b_1465392600678_154632_6223">
                <ownedComment xmi:id="_16_5_4_940029b_1465393881878_339250_6279" annotatedElement="_16_5_4_940029b_1465392600678_508690_6224" body="&lt;para>Dieses Element steht für eine Unterlage, auf deren Fehlen hingewiesen wird. &lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465392646339_610194_6271" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465392646339_512323_6272" name="" value="*"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465392600678_154632_6223" name="" memberEnd="_16_5_4_940029b_1465392600678_508690_6224 _16_5_4_940029b_1465392600678_741025_6225">
              <ownedEnd xmi:id="_16_5_4_940029b_1465392600678_741025_6225" name="" visibility="private" type="_16_5_4_940029b_1465392561571_667791_6181" association="_16_5_4_940029b_1465392600678_154632_6223"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465470022975_209579_5291" name="Anonym_SachverhaltNutzungsaufnahme">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_723005_5385" annotatedElement="_16_5_4_940029b_1465470022975_209579_5291" body="&lt;para>Nur eine natürliche Person mit einer Bauvorlageberechtigung kann einen Baunatrag unterschreiben. Dieser Typ definiert die Angaben zum Nachweis der Bauvorlageberechtigung.&lt;/para>"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465477337577_720333_5854" name="geplanteNutzungsaufnahme" visibility="private" type="_16_5_4_940029b_1465388521993_510280_5790" aggregation="composite" association="_16_5_4_940029b_1465477337577_549003_5852">
                <ownedComment xmi:id="_16_5_4_940029b_1465477337577_995191_5857" annotatedElement="_16_5_4_940029b_1465477337577_720333_5854" body="&lt;para>Dieses Element dient dazu, den Zeitpunkt der geplanten Nutzungsaufnahme mitzuteilen.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465477337577_998310_5856" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465477337577_945292_5858" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465477337577_549003_5852" name="" memberEnd="_16_5_4_940029b_1465477337577_720333_5854 _16_5_4_940029b_1465477337577_619829_5853">
              <ownedEnd xmi:id="_16_5_4_940029b_1465477337577_619829_5853" name="" visibility="private" type="_16_5_4_940029b_1465470022975_209579_5291" association="_16_5_4_940029b_1465477337577_549003_5852"/>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465487002264_623886_6490" name="Untersagung">
              <ownedComment xmi:id="_16_5_4_940029b_1465488028984_608703_6506" annotatedElement="_16_5_4_940029b_1465487002264_623886_6490" body="&lt;para>Dieser Typ deckt alle Informationen ab, die zu einer verfügten Untersagung als Reaktion auf eine Anzeige gehören können.&lt;/para>&#xA;"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465487030846_227673_6491" name="anordnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1465487030846_362058_6494" annotatedElement="_16_5_4_940029b_1465487030846_227673_6491" body="&lt;para>Die Anordnung besteht aus einem Sachverhalt (Verstoß wird genannt, z.B. &quot;fehlende Absteckung&quot;), einer Begründung (die Rechtsnorm, die zur Untersagung führt) sowie einer Rechtsbehelfsbelehrung (Textbaustein, ggf. §-Referenz, ggf. als Anlage, z.B. pdf-Datei o.ä.).&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465487030846_888957_6493" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465487030846_340820_6495" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1465487045647_613484_6498" name="fehlendeUnterlagen" visibility="private" type="_16_5_4_940029b_1465392561571_667791_6181" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1465487045662_798813_6501" annotatedElement="_16_5_4_940029b_1465487045647_613484_6498" body="&lt;para>Hinweise auf fehlende Voraussetzungen (Mängelliste) werden benannt. Es werden die Unterlagen genannt, deren Fehlen zur Untersagung geführt hat.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465487045662_29288_6500" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465487045662_923092_6502" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1547214928041_579854_13079" name="Anonym_SachverhaltBeseitigung">
              <ownedComment xmi:id="_18_0_2_940029b_1547214928041_629925_13080" annotatedElement="_18_0_2_940029b_1547214928041_579854_13079" body="&lt;para>Nur eine natürliche Person mit einer Bauvorlageberechtigung kann einen Baunatrag unterschreiben. Dieser Typ definiert die Angaben zum Nachweis der Bauvorlageberechtigung.&lt;/para>"/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547228073013_119261_13164" name="artDerBaulichenAnlage" visibility="private" type="_16_5_4_940029b_1476113874140_767343_5675" aggregation="composite">
                <ownedComment xmi:id="_18_0_2_940029b_1547228073021_729786_13166" annotatedElement="_18_0_2_940029b_1547228073013_119261_13164" body="&lt;para>In diesem Element wird die Art des Gebäudes übernmittelt, das beseitigt werden soll. Es wird die Einteilung in Gebäudeklassen gemäß MBO verwendet.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547228073021_162899_13167" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547228073019_500657_13165" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547228073213_313524_13171" name="grundstueck" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594" aggregation="composite">
                <ownedComment xmi:id="_18_0_2_940029b_1547228073213_63256_13173" annotatedElement="_18_0_2_940029b_1547228073213_313524_13171" body="&lt;para>In diesem Element wird das Grundstück und die Anschrift des Gebäudes übernmittelt, das beseitigt werden soll..&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547228073213_565041_13174" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547228073213_419718_13172" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547228073400_590050_13178" name="istFreistehend" visibility="private" aggregation="composite">
                <ownedComment xmi:id="_18_0_2_940029b_1547228073400_666508_13180" annotatedElement="_18_0_2_940029b_1547228073400_590050_13178" body="&lt;para>Falls das betreffende Gebäude freistehend ist, wird hier &quot;true&quot; eingetragen, andernfalls &quot;false&quot;.&lt;/para>&#xA;"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547228073400_872545_13181" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547228073400_641510_13179" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547228073806_378900_13192" name="hoeheDerBaulichenAnlage" visibility="private" aggregation="composite">
                <ownedComment xmi:id="_18_0_2_940029b_1547228073806_142568_13194" annotatedElement="_18_0_2_940029b_1547228073806_378900_13192" body="&lt;para>Falls die bauliche Anlage eine Höhe von mehr als 10 m hat, ist dieses Element zu übermitteln. Es ist die Höhe in Metern einzutragen (ohne Nachkommastellen). &lt;/para>"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547228073806_357584_13195" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547228073806_458889_13193" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465389092557_873397_6026" name="" memberEnd="_16_5_4_940029b_1465389092557_932726_6028 _16_5_4_940029b_1465389092557_343914_6027">
            <ownedEnd xmi:id="_16_5_4_940029b_1465389092557_343914_6027" name="" visibility="private" type="_16_5_4_940029b_1465387558131_115019_5529" association="_16_5_4_940029b_1465389092557_873397_6026"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1465396791609_260643_6893" name="" client="_16_5_4_940029b_1465387558116_218898_5527" supplier="_16_5_4_1d100e5_1384794877872_302539_331"/>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465470022788_806914_5173" name="" memberEnd="_16_5_4_940029b_1465470022788_771545_5180 _16_5_4_940029b_1465470022975_460290_5300">
            <ownedEnd xmi:id="_16_5_4_940029b_1465470022975_460290_5300" name="" visibility="private" type="_16_5_4_940029b_1465470022788_57931_5169" association="_16_5_4_940029b_1465470022788_806914_5173"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465470022788_61936_5170" name="anzeige.nutzungsaufnahmeUntersagung.0911">
            <ownedComment xmi:id="_16_5_4_940029b_1465470022788_867472_5188" annotatedElement="_16_5_4_940029b_1465470022788_61936_5170" body="&lt;para>Die Nachricht enthält den Hinweis, dass die geplante Maßnahme die Voraussetzungen nicht erfüllt und benennt entsprechende Mängel. Sie fordert zur Nachbesserung auf.&lt;/para>"/>
            <generalization xmi:id="_16_5_4_940029b_1465470022788_149530_5184" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_895822_5186" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_22235_5329" annotatedElement="_16_5_4_940029b_1465470022788_895822_5186" body="&lt;para>Bezug auf Vorgang und Nachricht einer Nutzungsbeginnanzeige.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_704065_5328" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_570637_5330" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_794409_5185" name="untersagung" visibility="private" type="_16_5_4_940029b_1465487002264_623886_6490" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_415491_5325" annotatedElement="_16_5_4_940029b_1465470022788_794409_5185" body="&lt;para>Dieses Objekt enthält die nötigen Informationen zur verfügten Untersagung.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_844978_5324" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_631350_5326" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465470022788_57931_5169" name="anzeige.nutzungsaufnahme.0910">
            <ownedComment xmi:id="_16_5_4_940029b_1465470022788_336146_5182" annotatedElement="_16_5_4_940029b_1465470022788_57931_5169" body="&lt;para>Mit dieser Nachricht teilt der Bauherr der Bauaufsichtsbehörde mit, dass die Aufnahme der Nutzung des errichteten Gebäudes zu einem bestimmten Termin geplant ist. Mit dieser Anzeige werden (sofern eine Prüfung durch einen Prüfsachverständigen vorgesehen ist) die Bescheinigungen über die ordnungsgemäße Ausführung von Brandschutz und Standsicherheit mitvorgelegt.&lt;/para>"/>
            <generalization xmi:id="_16_5_4_940029b_1465470022788_143992_5177" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_80700_5179" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_793893_5311" annotatedElement="_16_5_4_940029b_1465470022788_80700_5179" body="&lt;para>Referenz auf einen Vorgang der Bauaufsichtsbehörde (ein durchlaufenes Baugenehmigungsverfahren) und ggf. auf eine Nachricht, die im Zusammenhang des Vorgangs verschickt worden ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_611083_5310" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_173771_5312" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_771545_5180" name="sachverhalt" visibility="private" type="_16_5_4_940029b_1465470022975_209579_5291" aggregation="composite" association="_16_5_4_940029b_1465470022788_806914_5173">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_681168_5315" annotatedElement="_16_5_4_940029b_1465470022788_771545_5180" body="&lt;para>Hier ist der Sachverhalt der geplanten Nutzungsaufnahme angegeben.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_810670_5314" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_911414_5316" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465470022788_171924_5178" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1465470022975_518674_5307" annotatedElement="_16_5_4_940029b_1465470022788_171924_5178" body="&lt;para>Hier sind die Anlagen bzw. Verweise auf solche Anlagen einzufügen. Das sind  insbesondere Bescheinigungen über die ordnungsgemäße Ausführung von Brandschutz und Standsicherheit und ggf. weitere Unterlagen, die für die Prüfung durch die Bauaufsichtsbehörde  benötigt werden.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465470022975_683903_5306" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465470022975_841355_5308" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1547214671130_756522_13052" name="anzeige.beseitigungAbsicht.0950">
            <ownedComment xmi:id="_18_0_2_940029b_1547214671146_331031_13053" annotatedElement="_18_0_2_940029b_1547214671130_756522_13052" body="&lt;para>Mit dieser Nachricht teilt der Bauherr der Bauaufsichtsbehörde mit, dass die Beseitigung einer baulichen Anlage geplant ist.&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1547214671146_978026_13057" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1547228930190_567452_13199" name="referenzAnzeigender" visibility="private" type="_18_0_2_940029b_1546716878558_771130_12819">
              <ownedComment xmi:id="_18_0_2_940029b_1547228930190_162007_13201" annotatedElement="_18_0_2_940029b_1547228930190_567452_13199" body="&lt;para>In dieses Element sind Daten einzutragen, durch die sich die Anzeige (im Unterschied zur Nachrichteninstanz, durch die die Anzeige übermittelt wird) für spätere Referenzierung identifiziert. &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547228930190_938784_13202" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547228930190_480410_13200" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1547214671146_541473_13055" name="sachverhalt" visibility="private" type="_18_0_2_940029b_1547214928041_579854_13079" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1547214671161_812598_13064" annotatedElement="_18_0_2_940029b_1547214671146_541473_13055" body="&lt;para>Hier sind Eckdaten zum Sachverhalt der geplanten Beseitigung anzugeben.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547214671161_647258_13065" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547214671161_766472_13063" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1547214671146_124787_13056" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1547214671161_534267_13068" annotatedElement="_18_0_2_940029b_1547214671146_124787_13056" body="&lt;para>Hier sind die Anlagen bzw. Verweise auf solche Anlagen einzufügen. Dies sind die Unterlagen, die für die Bearbeitung der Anzeige durch die adressierte Bauaufsichtsbehörde benötigt werden.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547214671161_243608_13069" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547214671161_382788_13067" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1547229096440_304762_13282" name="anzeige.beseitigungUntersagung.0953">
            <ownedComment xmi:id="_18_0_2_940029b_1547229096440_761214_13283" annotatedElement="_18_0_2_940029b_1547229096440_304762_13282" body="&lt;para>Diese Nachricht enthält den Hinweis, dass die geplante Maßnahme die Voraussetzungen nicht erfüllt und benennt entsprechende Mängel. Die Bauaufsichtsbehörde fordert zur Nachbesserung auf und untersagt vorläufig die geplante Beseitigung.&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1547229096455_790527_13286" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1547229096440_288662_13284" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_18_0_2_940029b_1547229096455_103664_13289" annotatedElement="_18_0_2_940029b_1547229096440_288662_13284" body="&lt;para>Bezug auf Vorgang und Nachricht einer Anzeige Beseitigung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547229096455_289419_13290" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547229096455_557651_13288" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1547229096440_132099_13285" name="untersagung" visibility="private" type="_16_5_4_940029b_1465487002264_623886_6490" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1547229096455_843725_13293" annotatedElement="_18_0_2_940029b_1547229096440_132099_13285" body="&lt;para>Dieses Objekt enthält die nötigen Informationen zur verfügten Untersagung.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547229096455_665457_13294" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547229096455_218279_13292" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1547231768064_703279_13707" name="anzeige.beseitigungBestaetigung.0955">
            <ownedComment xmi:id="_18_0_2_940029b_1547231768064_354244_13708" annotatedElement="_18_0_2_940029b_1547231768064_703279_13707" body="&lt;para>Mit dieser Nachricht bestätigt die Baubehörde, dass für die geplante Beseitigung kein Genehmigungsverfahren durchgeführt werden muss.&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1547231768064_37713_13711" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1547231768064_881402_13709" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_18_0_2_940029b_1547231768064_128111_13714" annotatedElement="_18_0_2_940029b_1547231768064_881402_13709" body="&lt;para>Bezug auf Vorgang und Nachricht einer Anzeige Beseitigung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547231768064_503795_13715" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547231768064_18068_13713" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1552125171261_391374_14610" name="anzeige.beseitigungGeaendert.0952">
            <ownedComment xmi:id="_18_0_2_940029b_1552125171262_489876_14611" annotatedElement="_18_0_2_940029b_1552125171261_391374_14610" body="&lt;para>Diese Nachricht enthält geänderte oder ergänzte Daten zur angezeigten Absicht der Beseitigung einer baulichen Anlage. Sie bezieht sich auf eine bereits übermittelte Anzeige.&lt;/para>&#xA;&#xA;&lt;para>Entweder  ist sie eine Reaktion auf eine vorliegende Mängelliste der Bauaufsichtsbehörde. Oder es wird eine modifizierte Planung aus Gründen des Anzeigenden nachgereicht.&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1552125171265_6805_14615" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552125924961_109698_14637" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_18_0_2_940029b_1552125924962_723185_14639" annotatedElement="_18_0_2_940029b_1552125924961_109698_14637" body="&lt;para>Bezug auf Vorgang und Nachricht einer Anzeige Beseitigung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552125924962_538282_14640" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552125924961_779015_14638" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552125171264_728181_14613" name="sachverhalt" visibility="private" type="_18_0_2_940029b_1547214928041_579854_13079" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1552125171265_584705_14622" annotatedElement="_18_0_2_940029b_1552125171264_728181_14613" body="&lt;para>Hier sind (geänderte) Eckdaten zum Sachverhalt der geplanten Beseitigung anzugeben.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552125171266_823136_14623" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552125171265_150138_14621" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552125171265_571103_14614" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1552125171266_861449_14626" annotatedElement="_18_0_2_940029b_1552125171265_571103_14614" body="&lt;para>Hier sind die Anlagen bzw. Verweise auf solche Anlagen einzufügen. Es können im Rahmen der vorliegenden Nachricht geänderte oder vervollständigte Unterlagen sein. &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552125171266_873789_14627" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552125171266_241529_14625" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1469886407614_283581_5959" clientDependency="_18_0_2_940029b_1541255332450_111454_11427 _16_5_4_940029b_1469886407739_45632_6005 _18_0_2_8c5027b_1531483729905_661752_10895" name="Informationsempfaenger" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469886407739_806875_6004" name="informationsempfaenger.benachrichtigung.0400">
            <ownedComment xmi:id="_16_5_4_940029b_1469886407739_657926_6033" annotatedElement="_16_5_4_940029b_1469886407739_806875_6004" body="&lt;para>Diese Nachricht transportiert Informationen über Stand bzw. Ergebnisse eines bauaufsichtlichen Vorgangs. Sie wird von der Bauaufsichtsbehörde an Dritte (Behörden und sonstige öffentliche Stellen) versendet, die diese Daten für ihre Aufgabenerfüllung benötigen. In einer gegebenen Nachricht sind diejenigen Daten des Vorgangs enthalten, die für diesen Informationsempfänger für seine Aufgabenerfüllung relevant sind.&lt;/para>"/>
            <generalization xmi:id="_16_5_4_940029b_1469886407739_236727_6026" general="_16_5_4_940029b_1461085723092_220631_5163"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469886407739_336431_6027" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1469886407739_547222_6062" annotatedElement="_16_5_4_940029b_1469886407739_336431_6027" body="&lt;para>Dieses Element nennt den Vorgang der Bauaufsichtsbehörde, aus dem die Informationen entnommen sind. &lt;/para>&#xA;&lt;para>Eine Referenz auf eine Nachricht ist hier i.d.R. nicht einzutragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469886407739_702458_6061" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469886407739_459376_6063" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469886407739_215863_6028" name="anlass" visibility="private" type="_18_0_2_940029b_1552071235498_314274_14667" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469886407739_269424_6066" annotatedElement="_16_5_4_940029b_1469886407739_215863_6028" body="&lt;para>Hier wird der Anlass genannt: Welches bauaufsichtliche Ereignis hat zu dieser Benachrichtigung geführt?&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469886407739_916434_6065" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469886407739_155068_6067" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469887840710_719342_6292" name="datenBescheid" visibility="private" type="_16_5_4_940029b_1469889566170_285621_6564" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469887840725_833143_6295" annotatedElement="_16_5_4_940029b_1469887840710_719342_6292" body="&lt;para>Hier werden Bescheiddaten übermittelt, soweit für den vorliegenden Anlass relevant. &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469887840725_494176_6294" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469887840725_821642_6296" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469886407739_924777_6029" name="bauvorhaben" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469886407739_463631_6070" annotatedElement="_16_5_4_940029b_1469886407739_924777_6029" body="&lt;para>Hier werden Daten zum Bauvorhaben übermittelt, soweit für den vorliegenden Anlass relevant. &lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469887462507_258314_6290" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469887462507_830874_6291" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469888121482_782568_6302" name="verortungAbbruch" visibility="private" type="_16_5_4_940029b_1460559782420_922066_3743" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469888121498_613562_6305" annotatedElement="_16_5_4_940029b_1469888121482_782568_6302" body="&lt;para>Hier werden Daten zum geplanten Abbruch eingetragen, soweit für den vorliegenden Anlass relevant. &lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469888121498_134302_6304" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469888121498_175234_6306" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469888555259_827194_6462" name="verortungHausnummer" visibility="private" type="_16_5_4_940029b_1469888550138_987925_6442" aggregation="composite" association="_16_5_4_940029b_1469888555259_370946_6460">
              <ownedComment xmi:id="_16_5_4_940029b_1469894512991_354629_6650" annotatedElement="_16_5_4_940029b_1469888555259_827194_6462" body="&lt;para>Je Element sind Angaben zur georeferenzierten Lage einer  Hausnummer (Hauseingang) abgebildet.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469889438642_684932_6539" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469889438642_396939_6540" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1469886407739_149305_6030" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1469886407739_781024_6074" annotatedElement="_16_5_4_940029b_1469886407739_149305_6030" body="&lt;para>Hier werden relevante Anlagen eingefügt, soweit für den vorliegenden Anlass relevant. &lt;/para>&#xA;&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1469886407739_31496_6073" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1469886407739_635817_6075" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1469886407739_45632_6005" name="" client="_16_5_4_940029b_1469886407614_283581_5959" supplier="_16_5_4_1d100e5_1384794877872_302539_331"/>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1469888555259_370946_6460" name="" memberEnd="_16_5_4_940029b_1469888555259_827194_6462 _16_5_4_940029b_1469888555259_477912_6461">
            <ownedEnd xmi:id="_16_5_4_940029b_1469888555259_477912_6461" name="" visibility="private" type="_16_5_4_940029b_1469886407739_806875_6004" association="_16_5_4_940029b_1469888555259_370946_6460"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1470042030766_672738_5927" name="Datentypen" URI="">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1469888550138_987925_6442" name="Anonym_VerortungHausnummer">
              <ownedAttribute xmi:id="_16_5_4_940029b_1469888707373_227948_6481" name="point" visibility="private" type="_18_0_2_8c5027b_1530287031641_147665_12539" aggregation="composite" association="_16_5_4_940029b_1469888707373_557780_6480">
                <ownedComment xmi:id="_16_5_4_940029b_1469893677014_419387_6649" annotatedElement="_16_5_4_940029b_1469888707373_227948_6481" body="&lt;para>Das Element (globales Element gml:Point) enthält die GML-Darstellung eines Punktes auf der Erdoberfläche.&lt;/para>&#xA;&#xA;&lt;para>Aus der GML-Dokumentation: &quot;A Point is defined by a single coordinate tuple. The direct position of a point is specified by the pos element which is of type DirectPositionType.&quot; Quelle: &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&quot;>http://www.datypic.com/sc/niem21/e-gml32_Point.html&lt;/link>  &lt;/para>&#xA;"/>
              </ownedAttribute>
            </packagedElement>
