                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291322_947229_6133" name="" visibility="private" type="_16_5_4_5b501fb_1387625291115_477657_5180" association="_16_5_4_5b501fb_1387625291122_709828_5233"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291122_90165_5234" name="" memberEnd="_16_5_4_5b501fb_1387625291252_520896_5759 _16_5_4_5b501fb_1387625291322_64_6136">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291322_273783_6135" annotatedElement="_16_5_4_5b501fb_1387625291122_90165_5234" body="Die &quot;gueltigkeit&quot; gibt mit  Beginn- und/oder Endzeitpunkt den Zeitraum an, in dem ein Lebewesen ein bestimmtes Geschlecht hat."/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291322_64_6136" name="" visibility="private" type="_16_5_4_5b501fb_1387625291111_654189_5175" association="_16_5_4_5b501fb_1387625291122_90165_5234"/>
