              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1364313892881_275671_9442" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1364313892881_211494_9443" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
