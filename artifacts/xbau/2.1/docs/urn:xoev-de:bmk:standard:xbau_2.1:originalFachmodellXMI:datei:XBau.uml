            </node>
            <node xmi:type="uml:CallBehaviorAction" xmi:id="_16_5_4_940029b_1462359358764_229721_7468" name="Anzeige vorbereiten" visibility="public" inPartition="_16_5_4_940029b_1462359358764_193733_7459" outgoing="_16_5_4_940029b_1462359358764_615742_7431" incoming="_16_5_4_940029b_1462359358764_604737_7433">
