          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1478886262978_841475_5524" name="bautechnischeNachweise.anforderungNachbesserung.0504">
            <ownedComment xmi:id="_16_5_4_940029b_1478886262978_466020_5529" annotatedElement="_16_5_4_940029b_1478886262978_841475_5524" body="&lt;para>Diese Nachricht nennt Mängel bzw. Nachbesserungsbedarf zu einem erteilten Prüfauftrag.&lt;/para>"/>
            <generalization xmi:id="_16_5_4_940029b_1478886262978_730709_5526" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886262978_407424_5527" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1478886262978_756016_5534" annotatedElement="_16_5_4_940029b_1478886262978_407424_5527" body="&lt;para>Hier trägt der Auftragnehmer die Vorgangsnumme der Bauaufsichtsbehörde ein, die ihm mit der Beauftragung (Nachricht 0500) zugestellt wurde. Außerdem wird die Referenz auf die Nachricht 0500 eingetragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886262978_797144_5533" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886262978_49214_5535" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886594514_888914_5596" name="aufforderungZurStellungnahme" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1478886594514_957013_5600" annotatedElement="_16_5_4_940029b_1478886594514_888914_5596" body="&lt;para>Hier ist die Aufforderung zu Stellungnahme bzw. Kommentar formuliert.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886594514_913068_5599" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886594514_173915_5601" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886262978_174180_5528" name="befundliste" visibility="private" type="_16_5_4_940029b_1467881984463_299931_5687" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1478886262978_631871_5538" annotatedElement="_16_5_4_940029b_1478886262978_174180_5528" body="&lt;para>Nach der Prüfiung des Auftrags durch den Auftragnehmer: Hier sind die Ergebnisse der Prüfung als Befundliste enthalten. Jeder Befund wird mit den nötigen Details erläutert.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886262978_337123_5537" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886262978_703763_5539" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1478886366456_622274_5546" name="bautechnischeNachweise.nachbesserung.0505">
            <ownedComment xmi:id="_16_5_4_940029b_1478886366471_729317_5555" annotatedElement="_16_5_4_940029b_1478886366456_622274_5546" body="&lt;para>Diese Nachricht enthält nachgebesserte Unterlagen zum Prüfauftrags. Sie bezieht sich auf den erteilten Prüfauftrag und auf eine Mängelliste, die bei Prüfung der technischen Planungsdokumente erarbeitet wurde.&lt;/para>"/>
            <generalization xmi:id="_16_5_4_940029b_1478886366456_177784_5548" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886366456_575439_5549" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1478886366471_3810_5560" annotatedElement="_16_5_4_940029b_1478886366456_575439_5549" body="&lt;para>Hier ist die Vorgangsnummer (Beauftragung) einzutragen (analog zu Nachricht 0500). Außerdem ist auf die Nachricht 0504 zu verweisen, auf die mit dieser Nachricht geantwortet wird.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886366471_449902_5559" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886366471_321921_5561" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1478886366471_970658_5554" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1478886366471_523871_5580" annotatedElement="_16_5_4_940029b_1478886366471_970658_5554" body="&lt;para>Hier sind ggf. die korrigierten Unterlagen eingetragen.&lt;/para>&#xA;&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478886366471_359384_5579" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1478886366471_376437_5581" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1470126244519_424350_6023" clientDependency="_16_5_4_940029b_1470126244519_302796_6026" name="Genehmigungsfreistellung" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470126244519_807784_6025" name="genehmigungsfreistellung.anzeige.0600">
            <ownedComment xmi:id="_16_5_4_940029b_1470126244535_724494_6041" annotatedElement="_16_5_4_940029b_1470126244519_807784_6025" body="&lt;para>Mit dieser Nachricht zeigt der Bauherr der Gemeinde wg. möglicher Freistellung von der Genehmigungspflicht sein Vorhaben an. Die Nachricht enthält die einschlägigen Daten zum Vorhaben, ergänzend dokumentiert durch Unterlagen, die Bauvorlagen entsprechen sowie sonstige Unterlagen.&lt;/para>&#xA;&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1470126244519_873499_6036" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126244519_969163_6037" name="bauvorhaben" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" aggregation="composite" association="_16_5_4_940029b_1470126244519_988083_6027">
              <ownedComment xmi:id="_16_5_4_940029b_1470126244535_700970_6089" annotatedElement="_16_5_4_940029b_1470126244519_969163_6037" body="&lt;para>Dies ist die Dokumentation zum Bauvorhaben, für das der Bauherr die Genehmigungsfreistellung anzeigt. Die nötigen Daten (Wer, Was, Wo) sind enthalten.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126244535_740423_6088" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126244535_789584_6090" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126244535_149627_6040" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470126244535_798415_6101" annotatedElement="_16_5_4_940029b_1470126244535_149627_6040" body="&lt;para>Die für die Planung des Vorhabens notwendigen Unterlagen sind hier als Anlage beigefügt (MBO, MBauVorlV). In diesem Element sind die nötigen Metadaten und ggf. auch das Primärdokument enthalten. &lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126244535_323235_6100" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126244535_173472_6102" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126244535_848763_6039" name="alsBauantragWeiterzufuehren" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470126244535_233251_6097" annotatedElement="_16_5_4_940029b_1470126244535_848763_6039" body="&lt;para>Hier kann der Bauherr kennzeichnen (&quot;true&quot;, andernfalls &quot;false&quot;), dass der Vorgang bei abschlägiger Entscheidung in ein Baugenehmigungsverfahren übergehen soll und die eingereichten Unterlagen dann als Bauvorlagen verwendet werden sollen.&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470160712671_862962_6182" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470160712671_184452_6183" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1470126244519_302796_6026" name="" client="_16_5_4_940029b_1470126244519_424350_6023" supplier="_16_5_4_1d100e5_1384794877872_302539_331"/>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1470126244519_988083_6027" name="" memberEnd="_16_5_4_940029b_1470126244519_969163_6037 _16_5_4_940029b_1470126244535_199390_6043">
            <ownedEnd xmi:id="_16_5_4_940029b_1470126244535_199390_6043" name="" visibility="private" type="_16_5_4_940029b_1470126244519_807784_6025" association="_16_5_4_940029b_1470126244519_988083_6027"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470126244519_809943_6030" name="genehmigungsfreistellung.ergebnis.0602">
            <ownedComment xmi:id="_16_5_4_940029b_1470126244535_117382_6062" annotatedElement="_16_5_4_940029b_1470126244519_809943_6030" body="&lt;para>Mittels dieser Nachricht teilt die Gemeinde dem Bauherrn das Ergebnis der Prüfung seiner Anzeige mit. Der Bauherr erfährt, ob sein Vorhaben genehmigungspflichtig ist. Auch erhält er Informationen, ob die Gemeinde eine Untersagung gemäß § 15 BauGB beantragt hat.&lt;/para>"/>
            <generalization xmi:id="_16_5_4_940029b_1470126244535_150476_6058" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126244535_764192_6060" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1470126244535_995070_6143" annotatedElement="_16_5_4_940029b_1470126244535_764192_6060" body="&lt;para>Bezug auf die Anzeige des Bauherrn gegenüber der Gemeinde. Nachricht 0600, auf die die Gemeinde mit dieser Nachricht antwortet.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126244535_635201_6142" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126244535_365039_6144" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470150896189_777415_5868" name="ergebnisDesVerfahrens" visibility="private" type="_16_5_4_940029b_1470154418625_431141_6144" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470150896189_237118_5871" annotatedElement="_16_5_4_940029b_1470150896189_777415_5868" body="&lt;para>Die Gemeinde trägt in dieses Element ein, welches Ergebnis die gemeindliche Prüfung der Anzeige ergeben hat.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470150988791_447245_5882" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470150988791_373330_5883" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470126429774_41805_6269" name="genehmigungsfreistellung.anzeigeBAB.0601">
            <ownedComment xmi:id="_16_5_4_940029b_1470126429790_850115_6278" annotatedElement="_16_5_4_940029b_1470126429774_41805_6269" body="&lt;para>Mit dieser Nachricht unterrichtet die Gemeinde die Bauaufsichtsbehörde über die eingegangene Anzeige der Genehmigungsfreistellung.&lt;/para>"/>
            <generalization xmi:id="_16_5_4_940029b_1470126429774_956813_6271" general="_16_5_4_940029b_1461085723092_220631_5163"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126429774_582085_6272" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1470126429790_976529_6283" annotatedElement="_16_5_4_940029b_1470126429774_582085_6272" body="&lt;para>Bezug auf die Anzeige des Bauherrn gegenüber der Gemeinde. Nachricht 0600, die die Gemeinde erhalten hat.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126429790_463436_6282" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126429790_256609_6284" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126429774_809448_6274" name="bauvorhaben" visibility="private" type="_16_5_4_940029b_1461084279278_496533_4827" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470126429790_749441_6291" annotatedElement="_16_5_4_940029b_1470126429774_809448_6274" body="&lt;para>Dies ist die Dokumentation zum Bauvorhaben, für das der Bauherr die Genehmigungsfreistellung anzeigt.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126429790_393018_6290" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126429790_751261_6292" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126429790_186432_6275" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470126429790_23855_6295" annotatedElement="_16_5_4_940029b_1470126429790_186432_6275" body="&lt;para>In diesem Element sind die durch den Bauherrn beigefügten Anlagen enthalten.&lt;/para>&#xA;&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126429790_948038_6294" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126429790_301771_6296" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470150408076_125263_5861" name="alsBauantragWeiterzufuehren" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470150408076_957686_5864" annotatedElement="_16_5_4_940029b_1470150408076_125263_5861" body="&lt;para>Hier ist dokumentiert, ob der  Bauherr wünscht, dass der Vorgang bei abschlägiger Entscheidung als ein Baugenehmigungsverfahren weitergeführt werden soll  (&quot;true&quot;, andernfalls &quot;false&quot;).&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470150996165_45481_5884" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470150996165_730992_5885" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1470126430634_353642_6319" name="genehmigungsfreistellung.ergebnisBAB.0603">
            <ownedComment xmi:id="_16_5_4_940029b_1470126430634_300418_6328" annotatedElement="_16_5_4_940029b_1470126430634_353642_6319" body="&lt;para>Diese Nachricht unterrichtet die Bauaufsichtsbehörde über das Ergebnis der Prüfung, das dem Bauherrn von der Gemeinde übermittelt wurde.&lt;/para>"/>
            <generalization xmi:id="_16_5_4_940029b_1470126430634_800715_6321" general="_16_5_4_940029b_1461085723092_220631_5163"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470126430634_266001_6322" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1470126430634_816367_6333" annotatedElement="_16_5_4_940029b_1470126430634_266001_6322" body="&lt;para>Bezug auf die Anzeige des Bauherrn gegenüber der Gemeinde. Nachricht 0600, die die Gemeinde erhalten hat.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470126430634_262515_6332" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470126430634_228100_6334" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1470155702143_49172_6175" name="ergebnisDesVerfahrens" visibility="private" type="_16_5_4_940029b_1470154418625_431141_6144" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1470155702143_761828_6178" annotatedElement="_16_5_4_940029b_1470155702143_49172_6175" body="&lt;para>Die Gemeinde trägt in dieses Element ein, welches Ergebnis der gemeindlichen Prüfung der Anzeige sie dem Bauherrn übermittelt hat.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1470155702143_432787_6177" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1470155702143_686918_6179" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1475787171501_129307_6064" clientDependency="_16_5_4_940029b_1475787171532_582012_6067" name="Baulasten" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787171532_553648_6066" name="baulasten.vorlageErklaerung.0700">
            <ownedComment xmi:id="_16_5_4_940029b_1475787171548_750236_6082" annotatedElement="_16_5_4_940029b_1475787171532_553648_6066" body="&lt;para>Diese Nachricht dient dazu, der Bauaufsichtsbehörde die Baulast-Erklärung sowie ergänzende Dokumentationen zuzustellen.&lt;/para>&#xA;&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475787171548_293734_6077" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476034193320_413197_7498" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1476034193320_486769_7501" annotatedElement="_16_5_4_940029b_1476034193320_413197_7498" body="&lt;para>Im Kontext einer nicht-selbständigen Baulasterklärung wird hier der Bezug zu einem laufenden Baugenehmigungsverfahren hergestellt. Im anderen Fall existiert noch keine Vorgangsnummer, so dass dieses Element nicht verwendet wird.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476037930924_45174_7802" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476037930924_657862_7803" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476034176681_146181_7491" name="beteiligtePersonen" visibility="private" type="_16_5_4_940029b_1476034342357_954336_7610" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476034176681_662564_7494" annotatedElement="_16_5_4_940029b_1476034176681_146181_7491" body="&lt;para>Die am Baulastverfahren beteiligten Pesonen sind unterhalb dieses Elements einzutragen.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034176681_451156_7493" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034176681_863088_7495" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476034869674_250931_7672" name="beteiligteGrundstuecke" visibility="private" type="_16_5_4_940029b_1476034761055_276755_7650" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476034869674_313398_7675" annotatedElement="_16_5_4_940029b_1476034869674_250931_7672" body="&lt;para>Hier werden die für das Baulastverfahren relevanten Grundstücke eingetragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034869674_755940_7674" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034869674_297108_7676" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476035557766_218550_7740" name="erklaerung" visibility="private" type="_16_5_4_940029b_1476035195880_924265_7679" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476035557766_177073_7743" annotatedElement="_16_5_4_940029b_1476035557766_218550_7740" body="&lt;para>Der Zweck der angestrebten Baulast sowie der zu regelnde Sachverhalt werden hier beschrieben.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476035557766_402423_7742" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476035557766_450421_7744" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476034452204_375976_7643" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476034452204_918858_7646" annotatedElement="_16_5_4_940029b_1476034452204_375976_7643" body="&lt;para>Hier sind alle Pläne darzustellen, die für die Eindeutigkeit der Baulasterklärung relevant sind.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034452204_83277_7645" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034452204_262687_7647" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1475787171532_582012_6067" name="" client="_16_5_4_940029b_1475787171501_129307_6064" supplier="_16_5_4_1d100e5_1384794877872_302539_331"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787171532_608660_6069" name="baulasten.nachforderung.0701">
            <ownedComment xmi:id="_16_5_4_940029b_1475787171548_431360_6090" annotatedElement="_16_5_4_940029b_1475787171532_608660_6069" body="&lt;para>Diese Nachricht enthält die Befunde der Bauaufsichtsbehörde zu der eingereichten Baulasterklärung bzw. den beigefügten Unterlagen.&lt;/para>&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475787171548_592090_6086" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_915891_6087" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_70672_6148" annotatedElement="_16_5_4_940029b_1475787171548_915891_6087" body="&lt;para>In diesem Element wird der Vorgang (Vorgangsnummer, unter der die Behörde die Baulasterklärung bearbeitet) genannt bzw. dem Antragsteller mitgeteilt  bzw. die Nachricht baulasten.vorlageErklaerung.0700 eingetragen, durch deren Eingang bei der Bauaufsichtsbehörde der Vorgang ausgelöst worden ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_798044_6147" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_875996_6149" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_559022_6088" name="befundliste" visibility="private" type="_16_5_4_940029b_1467843232886_870322_5578" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_27124_6152" annotatedElement="_16_5_4_940029b_1475787171548_559022_6088" body="&lt;para>Hier sind die Ergebnisse der formellen Prüfung enthalten. Die Liste nennt die  Mängel, die bei der Prüfung der Baulast-Erklärung aufgefallen sind.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_867276_6151" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_349182_6153" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787171532_426875_6070" name="baulasten.information.0702">
            <ownedComment xmi:id="_16_5_4_940029b_1475787171548_855341_6097" annotatedElement="_16_5_4_940029b_1475787171532_426875_6070" body="&lt;para>Die Akteure, die die Baulast-Erklärung vorgelegt haben, werden durch diese Nachricht über das Ergebnis der&#xA;Prüfung informiert.&lt;/para>&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475787171548_507526_6092" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_545414_6093" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_791250_6162" annotatedElement="_16_5_4_940029b_1475787171548_545414_6093" body="&lt;para>In diesem Element wird der laufende Vorgang der Bearbeitung der Baulasterklärung genannt und die Nachricht baulasten.vorlageErklaerung.0700 genannt , durch deren Eingang bei der Bauaufsichtsbehörde der Vorgang ausgelöst worden ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_343907_6161" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_972450_6163" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476036221822_871585_7757" name="sachverhalt" visibility="private" type="_16_5_4_940029b_1476036643713_810494_7775">
              <ownedComment xmi:id="_16_5_4_940029b_1476036221822_151735_7760" annotatedElement="_16_5_4_940029b_1476036221822_871585_7757" body="&lt;para>Dieses Element enthält die Ergebnisse der Prüfung der Baulasterklärung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036221822_795447_7759" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036221822_723550_7761" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476036129706_61593_7750" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476036129706_626260_7753" annotatedElement="_16_5_4_940029b_1476036129706_61593_7750" body="&lt;para>Hier ist im Erfolgsfall die Dokumentation der vorgenommenen Eintragung ins BL-Verzeichnis enthalten.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476040546071_823235_7804" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476040546071_39424_7805" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787171532_583404_6072" name="baulasten.gebuehrenbescheid.0703">
            <ownedComment xmi:id="_16_5_4_940029b_1475787171548_4646_6109" annotatedElement="_16_5_4_940029b_1475787171532_583404_6072" body="&lt;para>Diese Nachricht enthält Informationen über die fälligen Gebühren, sowie die Aufforderung, diese auf&#xA;der Basis von Zahlungsinformationen zu entrichten.&lt;/para>&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475787171548_842025_6105" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_688751_6106" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_991110_6194" annotatedElement="_16_5_4_940029b_1475787171548_688751_6106" body="&lt;para>In diesem Element wird der laufende Vorgang der Bearbeitung der Baulasterklärung genannt und die Nachricht baulasten.vorlageErklaerung.0700 genannt , durch deren Eingang bei der Bauaufsichtsbehörde der Vorgang ausgelöst worden ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_925501_6193" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_72846_6195" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_133831_6107" name="gebuehrenbescheid" visibility="private" type="_16_5_4_940029b_1467904417963_15998_6086" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_904759_6198" annotatedElement="_16_5_4_940029b_1475787171548_133831_6107" body="&lt;para>Unterhalb dieses Element finden sich die Angaben zur Gebührenberechnung und -begründung, sowie die Zahlungsdaten und weitere Informationen.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_103817_6197" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_813638_6199" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787171548_533886_6108" name="frist" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1475787171564_446176_6202" annotatedElement="_16_5_4_940029b_1475787171548_533886_6108" body="&lt;para>Dies ist die durch die Behörde gesetzte Zahlungsfrist.&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787171564_839258_6201" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787171564_139044_6203" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1476034334212_405024_7609" name="Datentypen" URI="">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476034342357_954336_7610" name="Anonym_BeteiligteBaulast">
              <ownedComment xmi:id="_16_5_4_940029b_1476034342357_419551_7616" annotatedElement="_16_5_4_940029b_1476034342357_954336_7610" body="&lt;para>Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para>"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476034342357_750208_7612" name="baulastgeber" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
                <ownedComment xmi:id="_16_5_4_940029b_1476034342357_825845_7619" annotatedElement="_16_5_4_940029b_1476034342357_750208_7612" body="&lt;para>Hier sind die Daten des Baulastgebers einzutragen.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034419713_89494_7641" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034419713_39063_7642" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476034342357_351348_7613" name="beguenstigter" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423">
                <ownedComment xmi:id="_16_5_4_940029b_1476034342357_893299_7623" annotatedElement="_16_5_4_940029b_1476034342357_351348_7613" body="&lt;para>Hier sind die Daten des Begünstigten (im Kontext eines Baugenehmigungsverfahrens ist dies der Bauherr) einzutragen.&lt;/para>&#xA;&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034342357_805157_7622" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034342357_467936_7624" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476034761055_276755_7650" name="Anonym_GrundstueckeBaulast">
              <ownedComment xmi:id="_16_5_4_940029b_1476034761055_395438_7653" annotatedElement="_16_5_4_940029b_1476034761055_276755_7650" body="&lt;para>Typ für die an der Umsetzung eines Bauprojekts beteiligten Parteien (Personen und Organisationen).&lt;/para>"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476034761055_188910_7651" name="belastetesGrundstueck" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594">
                <ownedComment xmi:id="_16_5_4_940029b_1476034761055_796237_7656" annotatedElement="_16_5_4_940029b_1476034761055_188910_7651" body="&lt;para>Für jedes aufzuführende belastete Grundstück ist ein Element zu füllen.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034834720_212848_7668" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034834720_752043_7669" name="" value="*"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476034761055_897066_7652" name="beguenstigtesGrundstueck" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594">
                <ownedComment xmi:id="_16_5_4_940029b_1476034761055_318880_7660" annotatedElement="_16_5_4_940029b_1476034761055_897066_7652" body="&lt;para>Für jedes aufzuführende begünstigte Grundstück  ist ein Element zu füllen.&lt;/para>&#xA;&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476034840717_883475_7670" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476034840717_895118_7671" name="" value="*"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476036643713_810494_7775" name="Anonym_Entscheidung">
              <ownedComment xmi:id="_16_5_4_940029b_1476036643713_646651_7779" annotatedElement="_16_5_4_940029b_1476036643713_810494_7775" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Bescheides, den die Bauaufsichtsbehörde nach Prüfung eines Antrags erlässt.&lt;/para>"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476036643713_549781_7776" name="baulastAkzeptiert" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1476036643713_439022_7782" annotatedElement="_16_5_4_940029b_1476036643713_549781_7776" body="&lt;para>Falls die Baulast akzeptiert und eingetragen wurde, ist hier 'true' zu übermitteln, anderenfalls 'false'.&lt;/para>&#xA;"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036643713_759531_7781" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036643713_115751_7783" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476036643713_107737_7777" name="begruendung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
                <ownedComment xmi:id="_16_5_4_940029b_1476036643713_112608_7786" annotatedElement="_16_5_4_940029b_1476036643713_107737_7777" body="&lt;para>Falls die Baulast durch die Behörde nicht akzeptiert und eingetragen wurde, wird in diesem Element die Begründung für diese Entscheidung geliefert.&lt;/para>&#xA;&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476036732771_166023_7798" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476036732771_802106_7799" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1475787797941_867272_6679" clientDependency="_16_5_4_940029b_1475787797957_970832_6682 _16_5_4_940029b_1476073869162_200619_6774" name="UeberwachungspflichtigeAnlagen" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787797941_348773_6681" name="ueberwachungspflichtigeAnlagen.pruefbescheinigung.0800">
            <ownedComment xmi:id="_16_5_4_940029b_1475787797957_323695_6691" annotatedElement="_16_5_4_940029b_1475787797941_348773_6681" body="&lt;para>Diese Nachricht dient zur Übermittlung der Prüfbescheinigung an die Bauaufsichtsbehörde. Sie enthält alle relevanten Informationen zur Bewertung der Wirksamkeit und Betriebssicherheit der geprüften überwachungspflichtigen Anlagen.&lt;/para>&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475787797957_686967_6689" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476071161612_359923_6541" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1476071161612_423425_6544" annotatedElement="_16_5_4_940029b_1476071161612_359923_6541" body="&lt;para>In diesem Element wird die Vorgangsnummer bzw. das Aktenzeichen zur erteilten Baugenehmigung übermittelt, die der Errichtung des Gebäudes und der technischen Anlage(n) zu Grunde lag.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476071161612_861538_6543" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476071161612_722962_6545" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1477926836011_430371_4781" name="gebaeude" visibility="private" type="_16_5_4_940029b_1460650473351_39062_3594">
              <ownedComment xmi:id="_16_5_4_940029b_1477926836058_899596_4784" annotatedElement="_16_5_4_940029b_1477926836011_430371_4781" body="&lt;para>Hier wird der Ort der Prüfung bezeichnet, nämlich Anschrift und Flurstück zum Gebäude, in dem die geprüften technischen Anlagen installiert sind.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477926836043_825815_4783" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477926836058_213416_4785" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476071641330_487967_6682" name="pruefgegenstand" visibility="private" type="_16_5_4_940029b_1476071320283_102133_6652">
              <ownedComment xmi:id="_16_5_4_940029b_1476071641330_200090_6685" annotatedElement="_16_5_4_940029b_1476071641330_487967_6682" body="&lt;para>Jede Instanz dieses Elements beinhaltet Informationen zu einem Gegenstand der Prüfung (eine bestimmte technische Anlage in dem lokalisierten Gebäude) und zum Ergebnis der Prüfung dieses Gegenstands. Pro Element wird genau eine technische Anlage referenziert; die Prüfung kann mehrere technische Anlagen in dem Gebäude zum Gegenstand haben.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477927172218_812720_4788" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477927172218_297343_4789" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476072197571_935301_6716" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1476072197571_990795_6719" annotatedElement="_16_5_4_940029b_1476072197571_935301_6716" body="&lt;para>Die Anlagen enthalten den Prüfbericht, der auch die Bewertung des Prüfergebnisses vornimmt und Konsequenzen empfiehlt. Der Inhalt des Prüfberichts ist in den Musterprüfgrundsätzen definiert (Anlage zur Musterprüfverordnung Ziffer 4). Der Betreiber der technischen Anlagen hat den Prüfbericht typischerweise als Papierdokument vom Prüfsachverständigen erhalten.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476072197571_435460_6718" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476072197571_806625_6720" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1475787797957_970832_6682" name="" client="_16_5_4_940029b_1475787797941_867272_6679" supplier="_16_5_4_1d100e5_1384794877872_302539_331"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475787797957_934854_6684" name="ueberwachungspflichtigeAnlagen.erinnerung.0801">
            <ownedComment xmi:id="_16_5_4_940029b_1475787797957_295334_6699" annotatedElement="_16_5_4_940029b_1475787797957_934854_6684" body="&lt;para>Diese Nachricht dient der Information des Betreibers, dass eine Prüfbescheinigung überfällig ist.&lt;/para>&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475787797957_357678_6695" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475787797957_940393_6696" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475787797957_698472_6721" annotatedElement="_16_5_4_940029b_1475787797957_940393_6696" body="&lt;para>In diesem Element wird die Vorgangsnummer bzw. das Aktenzeichen zur erteilten Baugenehmigung übermittelt, die der Errichtung des Gebäudes und der technischen Anlage(n) zu Grunde lag.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475787797957_839365_6720" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475787797957_497721_6722" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476072284887_285728_6726" name="pruefgegenstand" visibility="private" type="_16_5_4_940029b_1476071320283_102133_6652">
              <ownedComment xmi:id="_16_5_4_940029b_1476072284887_79764_6729" annotatedElement="_16_5_4_940029b_1476072284887_285728_6726" body="&lt;para>Dieses Element bezeichnet den Gegenstand der Prüfung, eine bestimmte technische Anlage in dem lokalisierten Gebäude. Pro Element wird genau eine technische Anlage referenziert. Die Prüfung kann mehrere technische Anlagen in dem Gebäude zum Gegenstand haben.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476072284887_419850_6728" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476072284887_492927_6730" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1476072309124_702843_6733" name="anlassDerPruefung" visibility="private" type="_16_5_4_940029b_1476071806236_935553_6689">
              <ownedComment xmi:id="_16_5_4_940029b_1476072309124_991195_6736" annotatedElement="_16_5_4_940029b_1476072309124_702843_6733" body="&lt;para>In diesem Element wird der Anlass der durchgeführten Prüfung genannt, über deren Ergebnis berichtet wird.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476072309124_705640_6735" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476072309124_602922_6737" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1476071227800_336263_6651" name="Datentypen" URI="">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476071320283_102133_6652" name="Anonym_Pruefgegenstand">
              <ownedComment xmi:id="_16_5_4_940029b_1476071320283_917862_6656" annotatedElement="_16_5_4_940029b_1476071320283_102133_6652" body="&lt;para>Dieser Typ deckt Informationen ab zum Gegenstand (eine bestimmte technische Anlage in dem lokalisierten Gebäude) und zum Ergebnis der Prüfung dieses Gegenstands.&lt;/para>"/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1546876540173_230781_11687" name="identifikation" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
                <ownedComment xmi:id="_18_0_2_940029b_1546876540173_418353_11689" annotatedElement="_18_0_2_940029b_1546876540173_230781_11687" body="&lt;para>Hier ist die Identifikation des Prüfgegenstands, z.B. die Seriennummer, einzutragen. &lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546876540173_868556_11690" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546876540173_479061_11688" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476071352293_54581_6675" name="bezeichnung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
                <ownedComment xmi:id="_16_5_4_940029b_1476071352293_234807_6678" annotatedElement="_16_5_4_940029b_1476071352293_54581_6675" body="&lt;para>Hier steht eine deskriptive Bezeichnung des Prüfgegenstands (z.B. &lt;quote>Lüftungsanlage im Gebäudetrakt Süd&lt;/quote>).&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476071352293_596218_6677" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476071352293_145371_6679" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476071320283_243150_6655" name="artDerTechnischenAnlage" visibility="private" type="_18_0_2_940029b_1547043769518_308840_11689">
                <ownedComment xmi:id="_16_5_4_940029b_1476071320283_605640_6667" annotatedElement="_16_5_4_940029b_1476071320283_243150_6655" body="&lt;para>Dieses Element enthält Angaben zur Art der geprüften technischen Anlage.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476073163242_885705_6742" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476073163242_603300_6743" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476072133185_168795_6709" name="anlassDerPruefung" visibility="private" type="_16_5_4_940029b_1476071806236_935553_6689">
                <ownedComment xmi:id="_16_5_4_940029b_1476072133185_239755_6712" annotatedElement="_16_5_4_940029b_1476072133185_168795_6709" body="&lt;para>In diesem Element wird zum gegebenen Prüfgegenstand der Anlass der durchgeführten Prüfung genannt.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476072133185_405504_6711" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476072133185_372606_6713" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547045980769_728214_11906" name="pruefergebnis" visibility="private" type="_18_0_2_940029b_1547045072324_235873_11795">
                <ownedComment xmi:id="_18_0_2_940029b_1547045980769_681456_11908" annotatedElement="_18_0_2_940029b_1547045980769_728214_11906" body="&lt;para>In dieses Element sind zum Prüfgegenstand die wichtigsten Ergebnisse der durchgeführten Prüfung einzutragen. Weitere Details zum Prüfergebnis sind dem Prüfbericht zu entnehmen, der in der Anlage zur vorliegenden Nachricht enthalten ist.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547045980769_22592_11909" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547045980769_177765_11907" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1476071806236_935553_6689" name="Anonym_Anlass">
              <ownedComment xmi:id="_16_5_4_940029b_1476071806237_778074_6692" annotatedElement="_16_5_4_940029b_1476071806236_935553_6689" body=""/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476071806236_711433_6690" name="anlass" visibility="private" type="_16_5_4_43c01ae_1406133066375_719523_2502">
                <ownedComment xmi:id="_16_5_4_940029b_1476071806237_823395_6695" annotatedElement="_16_5_4_940029b_1476071806236_711433_6690" body="&lt;para>Dieses Element nennt den Anlass der durchgeführten Prüfung. Es deckt eine Reihe von Standardfällen ab.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1477926362051_479160_4779" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1477926362051_41711_4780" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1476071806237_809464_6691" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467899960094_58945_5827">
                <ownedComment xmi:id="_16_5_4_940029b_1476071806238_541409_6699" annotatedElement="_16_5_4_940029b_1476071806237_809464_6691" body="&lt;para>Hier werden ggf. die Nebenbestimmungen der Baugenehmigung, insofern diese Prüfungen vorsehen, aufgeführt. Diese können ebenfalls Anlass einer durchgeführten Prüfung sein.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1476071806238_278261_6698" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1476071806238_821151_6700" name="" value="*"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1547045072324_235873_11795" name="MppvoPruefergebnis">
              <ownedComment xmi:id="_18_0_2_940029b_1547045072324_962034_11796" annotatedElement="_18_0_2_940029b_1547045072324_235873_11795" body="&lt;para>Dieser Typ deckt zum Prüfgegenstand die wichtigsten Ergebnisse der durchgeführten Prüfung ab. &lt;/para>"/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547045110341_874275_11818" name="keinMangel" visibility="private">
                <ownedComment xmi:id="_18_0_2_940029b_1547045110341_198908_11820" annotatedElement="_18_0_2_940029b_1547045110341_874275_11818" body="&lt;para>Falls in der Prüfung der technischen Anlage kein Mangel festgestellt wurde (alle Pflichteigenschaften für den freigegebenen Betrieb sind gewährleistet), enthält dieses Element &quot;true&quot;, andernfalls &quot;false&quot;. &lt;/para>&#xA;"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547045110341_381761_11821" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547045110341_981829_11819" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547046170390_811627_11913" name="nachpruefung" visibility="private" type="_18_0_2_940029b_1547045277419_164940_11825">
                <ownedComment xmi:id="_18_0_2_940029b_1547046170390_702624_11915" annotatedElement="_18_0_2_940029b_1547046170390_811627_11913" body="&lt;para>Dieses Element enthält die Festlegungen im Prüfergebnis zu einer ggf. erforderlichen Nachprüfung. &lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547046170390_976643_11916" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547046170390_595232_11914" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547048547697_826810_12147" name="weiterbetrieb" visibility="private" type="_18_0_2_940029b_1547049073773_539328_12223">
                <ownedComment xmi:id="_18_0_2_940029b_1547048547697_641666_12149" annotatedElement="_18_0_2_940029b_1547048547697_826810_12147" body="&lt;para>Dieses Element enthält die Festlegungen im Prüfergebnis zu einem zugelassenen bzw. nicht zugelassenen Weiterbrieb der geprüften technischen Anlage. &lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547048547697_268443_12150" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547048547697_591576_12148" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1547045277419_164940_11825" name="Anonym_Nachpruefung">
              <ownedComment xmi:id="_18_0_2_940029b_1547045277419_99355_11826" annotatedElement="_18_0_2_940029b_1547045277419_164940_11825" body=""/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547045277419_664613_11828" name="nichtErforderlich" visibility="private" isReadOnly="true">
                <ownedComment xmi:id="_18_0_2_940029b_1547045277419_270336_11834" annotatedElement="_18_0_2_940029b_1547045277419_664613_11828" body="&lt;para>Dieses Element ist auszuwählen, falls eine Nachprüfung nicht notwendig ist.&lt;/para>"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547045277419_392877_11835" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547045277419_598346_11833" name="" value="1"/>
                <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="_18_0_2_940029b_1547045960754_633754_11905" name="" value="true"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547045277419_437261_11827" name="erforderlich" visibility="private" type="_18_0_2_940029b_1547045694562_229758_11888">
                <ownedComment xmi:id="_18_0_2_940029b_1547045277419_901866_11830" annotatedElement="_18_0_2_940029b_1547045277419_437261_11827" body="&lt;para>Dieses Element ist auszuwählen, falls eine Nachprüfung notwendig ist. Es enthält Informationen über die dafür vorliegenden Gründe.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547045277419_830067_11831" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547045277419_361480_11829" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1547045694562_229758_11888" name="Anonym_Grund">
              <ownedComment xmi:id="_18_0_2_940029b_1547045694562_762184_11889" annotatedElement="_18_0_2_940029b_1547045694562_229758_11888" body=""/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547045694562_772535_11891" name="grund" visibility="private" type="_18_0_2_940029b_1547045394352_857627_11842">
                <ownedComment xmi:id="_18_0_2_940029b_1547045694562_169784_11898" annotatedElement="_18_0_2_940029b_1547045694562_772535_11891" body="&lt;para>Pro Instanz dieses Elements wird ein Grund genannt dafür, dass eine Nachprüfung notwendig ist (es können mehrere Gründe zutreffen).&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547045694562_116122_11899" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547045694562_38837_11897" name="" value="*"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1547049073773_539328_12223" name="Anonym_WeiterbetriebFrist">
              <ownedComment xmi:id="_18_0_2_940029b_1547049073773_296394_12224" annotatedElement="_18_0_2_940029b_1547049073773_539328_12223" body=""/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547049073773_906495_12225" name="festlegung" visibility="private" type="_18_0_2_940029b_1547048629092_425142_12181">
                <ownedComment xmi:id="_18_0_2_940029b_1547049073773_749017_12228" annotatedElement="_18_0_2_940029b_1547049073773_906495_12225" body="&lt;para>Hier ist die Information zu hinterlegen, ob und ggf. bis zu welcher Frist ein Weiterbetrieb der geprüften technischen Anlage gestattet ist.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547049073773_415050_12229" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547049073773_184849_12227" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1547049073773_833195_12226" name="frist" visibility="private">
                <ownedComment xmi:id="_18_0_2_940029b_1547049073773_661727_12232" annotatedElement="_18_0_2_940029b_1547049073773_833195_12226" body="&lt;para>Falls der Weiterbetrieb nur befristet gestattet wird, ist hier das Datum des Fristablaufs zu hinterlegen.&lt;/para>"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1547049073773_31385_12233" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1547049073773_465116_12231" name="" value="*"/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1476073869162_200619_6774" name="" client="_16_5_4_940029b_1475787797941_867272_6679" supplier="_16_5_4_5b501fb_1387625271062_845493_4821"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1475788011145_184309_6775" clientDependency="_16_5_4_940029b_1475788011145_686026_6778" name="Bauzustand" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475788011145_680098_6777" name="bauzustand.anzeige.0920">
            <ownedComment xmi:id="_16_5_4_940029b_1475788011145_342408_6787" annotatedElement="_16_5_4_940029b_1475788011145_680098_6777" body="&lt;para>Mittels dieser Nachricht kündigt der  Bauherr der Bauaufsichtsbehörde den Zeitpunkt des Erreichens eines bestimmten Bauzustandes an.&lt;/para>&#xA;&#xA;&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475788011145_134420_6785" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475991889489_682821_6120" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475991889489_810325_6123" annotatedElement="_16_5_4_940029b_1475991889489_682821_6120" body="&lt;para>In diesem Elements werden Eintragungen vorgenommen, um auf die Baugenehmigung Bezug zu nehmen, die der aktuellen Baumaßnahmen zugrundliegen. Ggf. wird auf die entsprechende XBau-Nachricht referenziert.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475991889489_79163_6122" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475991889489_421826_6124" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475991951293_941032_6127" name="sachverhalt" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_16_5_4_940029b_1475991951293_870302_6130" annotatedElement="_16_5_4_940029b_1475991951293_941032_6127" body="&lt;para>In diesem Element wird der eingetretene Bauzustand erläutert, der anzuzeigen ist. Es wird auf entsprechende Termine hingewiesen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475991951293_286538_6129" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475991951293_128106_6131" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_940029b_1475788011145_686026_6778" name="" client="_16_5_4_940029b_1475788011145_184309_6775" supplier="_16_5_4_1d100e5_1384794877872_302539_331"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475788011145_785647_6780" name="bauzustand.befundliste.0921">
            <ownedComment xmi:id="_16_5_4_940029b_1475788011145_223457_6795" annotatedElement="_16_5_4_940029b_1475788011145_785647_6780" body="&lt;para>Diese Nachricht teilt dem Bauherrn festgestellte Ausführungsmangel mit, falls die Prüfung des Bauzustandes durch die Behörde ein negatives Ergebnis ergeben hat.&lt;/para>&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475788011145_386082_6791" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475788011145_207234_6792" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475788011145_548148_6817" annotatedElement="_16_5_4_940029b_1475788011145_207234_6792" body="&lt;para>In diesem Elements wird auf die Vorgangsnummer der erteilten Baugenehmigung Bezug genommen, auf deren Basis gearbeitet wird, und auf die Nachricht 0900, mittels derer der geprüfte Bauzustand angezeigt worden ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475788011145_952561_6816" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475788011145_86663_6818" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475788011145_461821_6793" name="pruefung" visibility="private" type="_16_5_4_940029b_1475992822008_751378_7400" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1475788011145_681393_6821" annotatedElement="_16_5_4_940029b_1475788011145_461821_6793" body="&lt;para>Dieses Element enthält die Informationen zur Prüfung und benennt die entsprechenden Mängel.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475788011145_896230_6820" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475788011145_562332_6822" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475788011145_98476_6781" name="bauzustand.freigabe.0922">
            <ownedComment xmi:id="_16_5_4_940029b_1475788011145_877784_6799" annotatedElement="_16_5_4_940029b_1475788011145_98476_6781" body="&lt;para>Mit dieser Nachricht erklärt die Bauaufsichtsbehörde dem Bauherrn ihre Zustimmung zur Fortführung der Bauarbeiten gemäß § 82 Abs. 1 Satz 2 MBO.&lt;/para>&#xA;"/>
            <generalization xmi:id="_16_5_4_940029b_1475788011145_288798_6797" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475788011145_424082_6798" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_16_5_4_940029b_1475788011145_294844_6831" annotatedElement="_16_5_4_940029b_1475788011145_424082_6798" body="&lt;para>Dieses Element enthält die Vorgangsnummer der erteilten Baugenehmigung und referenziert auf die Nachricht 0900, mittels derer der geprüfte Bauzustand angezeigt worden ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475788011145_327651_6830" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475788011145_319330_6832" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1475993913239_980584_7445" name="nebenbestimmung" visibility="private" type="_16_5_4_940029b_1467899960094_58945_5827">
              <ownedComment xmi:id="_16_5_4_940029b_1475993913239_54456_7469" annotatedElement="_16_5_4_940029b_1475993913239_980584_7445" body="&lt;para>Hier können, falls notwendig, Nebenbestimmungen zur erteilten Zustimmung eingefügt werden.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475993913239_967228_7468" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475993913239_714050_7470" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_940029b_1475992764255_817437_7399" name="Datentypen" URI="">
            <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1475992822008_751378_7400" name="Anonym_Pruefung">
              <ownedComment xmi:id="_16_5_4_940029b_1475992822008_355865_7404" annotatedElement="_16_5_4_940029b_1475992822008_751378_7400" body="&lt;para>Dieser Typ enthält die Informationen zur Prüfung auf der Baustelle mit den entsprechenden Befunden ab.&lt;/para>&#xA;"/>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475992858647_974643_7417" name="datum" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1475993425597_453677_7437" annotatedElement="_16_5_4_940029b_1475992858647_974643_7417" body="&lt;para>Dieses Element enthält das Datum des Tages, an dem die Prüfung durchgeführt wurde.&lt;/para>&#xA;"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475993149426_525020_7429" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475993149426_182774_7430" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475992874561_915923_7418" name="pruefer" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517">
                <ownedComment xmi:id="_16_5_4_940029b_1475993367682_458917_7436" annotatedElement="_16_5_4_940029b_1475992874561_915923_7418" body="&lt;para>Hier werden die Daten der Person genannt, die die Prüfung durchgeführt hat.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475993160753_407910_7431" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475993160753_857924_7432" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475993011743_207905_7420" name="ansprechpartnerBaustelle" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517">
                <ownedComment xmi:id="_16_5_4_940029b_1475993365019_755851_7435" annotatedElement="_16_5_4_940029b_1475993011743_207905_7420" body="&lt;para>Hier kann ggf. die Person angegeben werden, mit der auf der Baustelle im Kontext der durchgeführten Prüfung kommuniziert worden ist.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475993169300_799734_7433" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475993169300_867692_7434" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1475992822008_914879_7403" name="befundliste" visibility="private" type="_16_5_4_940029b_1477928375350_829581_4792" aggregation="composite">
                <ownedComment xmi:id="_16_5_4_940029b_1475992822008_639476_7411" annotatedElement="_16_5_4_940029b_1475992822008_914879_7403" body="&lt;para>Dieses Element enthält die Mängelliste, die die Prüfung ergeben hat.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1475992822008_701446_7410" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1475992822008_808322_7412" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_18_0_2_940029b_1541262088322_445082_11811" clientDependency="_18_0_2_940029b_1541262924710_547493_12400 _18_0_2_940029b_1541262990820_399601_12407 _18_0_2_940029b_1541263490594_811963_12421" name="Prozessnachrichten" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541262088322_35304_11814" name="prozessnachrichten.rueckweisung.G2G.1100">
            <ownedComment xmi:id="_18_0_2_940029b_1541262088385_193603_11844" annotatedElement="_18_0_2_940029b_1541262088322_35304_11814" body="&lt;para>Mittels dieser Nachricht wird eine Nachricht abgewiesen, die Fehler enthält, so dass sie nicht zielführend verarbeitet werden kann (Behörde-Behörde-Kommunikation). Der Autor der fehlerhaften Nachricht wird über die Fehler unterrichtet. Die abgewiesene Nachricht wird zur Information aufgeführt. &lt;/para>&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541262088385_434171_11845" name="nachrichtenkopf" visibility="private" type="_16_5_4_940029b_1461085754575_118769_5184" aggregation="composite" association="_18_0_2_940029b_1541262088322_500282_11815">
              <ownedComment xmi:id="_18_0_2_940029b_1541262170416_614451_11904" annotatedElement="_18_0_2_940029b_1541262088385_434171_11845" body="&lt;para>Hier stehen allgemeine Informationen zum Sender und zum Empfänger zur eindeutigen Benennung und Identifizierung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541262170416_689289_11905" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541262170416_662425_11903" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541262088385_220444_11846" name="rueckweisungDaten" visibility="private" type="_18_0_2_940029b_1541324483751_614901_11350" aggregation="composite" association="_18_0_2_940029b_1541262088322_385508_11817">
              <ownedComment xmi:id="_18_0_2_940029b_1541262170416_617292_11908" annotatedElement="_18_0_2_940029b_1541262088385_220444_11846" body="&lt;para>Mit diesem Element wird der Fehler einer gegebenenen Nachricht benannt, der zu der vorliegenden Rückweisung geführt hat.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541262170416_959474_11909" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541262170416_762886_11907" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_18_0_2_940029b_1541262088322_500282_11815" name="" memberEnd="_18_0_2_940029b_1541262088385_434171_11845 _18_0_2_940029b_1541262088385_427103_11850">
            <ownedEnd xmi:id="_18_0_2_940029b_1541262088385_427103_11850" name="" visibility="private" type="_18_0_2_940029b_1541262088322_35304_11814" association="_18_0_2_940029b_1541262088322_500282_11815"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Package" xmi:id="_18_0_2_940029b_1541262088322_950624_11816" name="Datentypen" URI="">
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541262088385_800525_11851" name="Rueckweisungsgrund">
              <ownedComment xmi:id="_18_0_2_940029b_1541262170416_555404_11921" annotatedElement="_18_0_2_940029b_1541262088385_800525_11851" body="&lt;para>Dieser Typ nimmt Angaben zu Art und Ort eines Fehlers auf, der zur Rückweisung der Nachricht geführt hat. &lt;/para>&#xA;&#xA;"/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1541262170416_216816_11922" name="grund" visibility="private" type="_18_0_2_940029b_1541261707920_683057_11719" aggregation="composite">
                <ownedComment xmi:id="_18_0_2_940029b_1541262170432_582703_11958" annotatedElement="_18_0_2_940029b_1541262170416_216816_11922" body="&lt;para>Mit diesem Element wird der Grund übermittelt, aus dem die Nachricht zurückgewiesen wird. Die im Rahmen der hier zu verwendenden Codeliste zur Verfügung gestellten Rückweisungsgründe sind kontextunabhängig und finden daher in allen Übermittlungskontexten Anwendung.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541262170432_568324_11959" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541262170432_43932_11957" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1541262170416_106272_11923" name="fehlertext" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
                <ownedComment xmi:id="_18_0_2_940029b_1541262170432_173694_11962" annotatedElement="_18_0_2_940029b_1541262170416_106272_11923" body="&lt;para>Hier steht ein ergänzender textueller Hinweis auf die Art des Fehlers, der zur Zurückweisung der Nachricht geführt hat. Sofern kein Text angegeben ist (das Element also nicht übermittelt wird), gilt allein die Erläuterung zur im Element grund stehenden Fehlerkennzahl.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541262170432_686678_11963" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541262170432_349374_11961" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541324483751_614901_11350" name="Rueckweisung">
              <ownedComment xmi:id="_18_0_2_940029b_1541324483751_665655_11351" annotatedElement="_18_0_2_940029b_1541324483751_614901_11350" body="&lt;para>Dieser Typ nimmt Angaben zu Art und Ort eines Fehlers auf, der zur Rückweisung der Nachricht geführt hat. &lt;/para>&#xA;&#xA;"/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1541324505462_418915_11367" name="rueckweisungsgrund" visibility="private" type="_18_0_2_940029b_1541262088385_800525_11851" aggregation="composite">
                <ownedComment xmi:id="_18_0_2_940029b_1541324505465_120963_11371" annotatedElement="_18_0_2_940029b_1541324505462_418915_11367" body="&lt;para>Jede Instanz dieses Elements enthält Informationen zu einem Fehler bzw. einem Mangel, der in Bezug auf die erhaltene Nachricht identifiziert wurde.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324505465_779282_11372" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324505464_44971_11370" name="" value="*"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1541324505463_80054_11368" name="idNachricht" visibility="private" type="_16_5_4_940029b_1461085771571_78551_5204">
                <ownedComment xmi:id="_18_0_2_940029b_1541324505466_804390_11375" annotatedElement="_18_0_2_940029b_1541324505463_80054_11368" body="&lt;para>Identifikationsmerkmale der zurückgewiesenen XBau-Nachricht, die der Autor der Rückweisung zu einem Zeitpunkt in der Vergangenheit empfangen hat.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324505466_688423_11376" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324505466_186950_11374" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1541324505464_278413_11369" name="nachricht" visibility="private">
                <ownedComment xmi:id="_18_0_2_940029b_1541324505467_865555_11379" annotatedElement="_18_0_2_940029b_1541324505464_278413_11369" body="&lt;para>Dieses Element bildet die zurückgewiesene Nachricht im Binärformat ab.&lt;/para>"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191711843_120906_985"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324505468_776322_11380" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324505467_904601_11378" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1552127281868_654162_14786" name="BefundlisteFormell">
              <ownedComment xmi:id="_18_0_2_940029b_1552127281871_346470_14789" annotatedElement="_18_0_2_940029b_1552127281868_654162_14786" body="&lt;para>Dieser Typ beinhaltet die Befunde der formellen Prüfung eines Antrags, einer Anzeige oder einer Erklärung. Für jeden Befund sind die entsprechenden Parameter gefüllt, die Inhalt und Bezug des Befundes für den Antragsteller bzw. Anfragenden nachvollziehbar machen.&lt;/para>"/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1552127281871_563444_14790" name="befund" visibility="private" type="_18_0_2_940029b_1552127281869_824594_14787" aggregation="composite" association="_18_0_2_940029b_1552127281870_107742_14788">
                <ownedComment xmi:id="_18_0_2_940029b_1552127281876_873618_14799" annotatedElement="_18_0_2_940029b_1552127281871_563444_14790" body="&lt;para>Dieses Element stellt genau einen Befund der Befundliste dar.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552127281876_187299_14800" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552127281876_506491_14798" name="" value="*"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1552127281869_824594_14787" name="Anonym_BefundFormell">
              <ownedComment xmi:id="_18_0_2_940029b_1552127281872_940165_14792" annotatedElement="_18_0_2_940029b_1552127281869_824594_14787" body=""/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1552127281872_444985_14793" name="artDesBefundes" visibility="private" type="_18_0_2_940029b_1552127588117_500969_14828">
                <ownedComment xmi:id="_18_0_2_940029b_1552127281877_438571_14803" annotatedElement="_18_0_2_940029b_1552127281872_444985_14793" body="&lt;para>In diesem Element wird die Befundkategorie angegeben, der dieser Befund zugeordnet werden kann.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552127281877_748516_14804" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552127281877_598367_14802" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1552127281875_614895_14796" name="beschreibung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
                <ownedComment xmi:id="_18_0_2_940029b_1552127281878_429485_14815" annotatedElement="_18_0_2_940029b_1552127281875_614895_14796" body="&lt;para>Hier wird der Sachverhalt des Befundes beschrieben. Dieser Sachverhalt enthält Details, die für den Adressaten hilfreich sind ergänzend zur angegebenen Art des Befundes.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552127281878_929087_14816" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552127281878_454104_14814" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Association" xmi:id="_18_0_2_940029b_1552127281870_107742_14788" name="" memberEnd="_18_0_2_940029b_1552127281871_563444_14790 _18_0_2_940029b_1552127281876_702012_14797">
              <ownedEnd xmi:id="_18_0_2_940029b_1552127281876_702012_14797" name="" visibility="private" type="_18_0_2_940029b_1552127281868_654162_14786" association="_18_0_2_940029b_1552127281870_107742_14788"/>
            </packagedElement>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_18_0_2_940029b_1541262088322_385508_11817" name="" memberEnd="_18_0_2_940029b_1541262088385_220444_11846 _18_0_2_940029b_1541262129452_125565_11874">
            <ownedEnd xmi:id="_18_0_2_940029b_1541262129452_125565_11874" name="" visibility="private" type="_18_0_2_940029b_1541262088322_35304_11814" association="_18_0_2_940029b_1541262088322_385508_11817"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_2_940029b_1541262924710_547493_12400" name="" client="_18_0_2_940029b_1541262088322_445082_11811" supplier="_16_5_4_5b501fb_1400580960261_350236_1101"/>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_2_940029b_1541262990820_399601_12407" name="" client="_18_0_2_940029b_1541262088322_445082_11811" supplier="_16_5_4_1d100e5_1384794877872_302539_331"/>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_2_940029b_1541263490594_811963_12421" name="" client="_18_0_2_940029b_1541262088322_445082_11811" supplier="_16_5_4_5b501fb_1387625271062_845493_4821"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541322508385_460887_11132" name="prozessnachrichten.eingangsbestaetigung.1120">
            <ownedComment xmi:id="_18_0_2_940029b_1541322508385_41284_11133" annotatedElement="_18_0_2_940029b_1541322508385_460887_11132" body="&lt;para>Diese Nachricht wird durch die Bauaufsichtsbehörde verwendet, um als Reaktion auf einen Antrag (modifizierten Antrag, Rücknahme eines Antrags, Anzeige) zu informieren, dass das Anliegen eingegangen ist und sich in Bearbeitung befindet. &lt;/para>&#xA;&#xA;&lt;para>Sie enthält die nötigen Informationen, um den Bezug auf die Nachricht, deren Eingang sie bestätigt, herzustellen.&lt;/para>&#xA;"/>
            <generalization xmi:id="_18_0_2_940029b_1541322508385_212039_11136" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541322508385_732710_11134" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_18_0_2_940029b_1541322508385_165187_11139" annotatedElement="_18_0_2_940029b_1541322508385_732710_11134" body="&lt;para>Dieses Element enthält, um Bezug zu nehmen, die Vorgangsnummer bzw. die Referenz des Antrags (Zeichen des Antragstellers).&lt;/para>&#xA;&#xA;&lt;para>Außerdem enthält es - mandatorisch - eine Referenzierung auf die Nachricht, durch die der Antrag (modifizierter Antrag) bzw. die Anzeige eingereicht worden ist, deren Empfang bestätigt wird.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541322508385_702549_11140" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541322508385_491258_11138" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541322508385_781677_11135" name="information" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1541322508385_845654_11143" annotatedElement="_18_0_2_940029b_1541322508385_781677_11135" body="&lt;para>Hier kann die Bauaufsichtsbehörde ergänzend erläuternden Text in die Nachricht einfügen.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541322508385_263053_11144" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541322508385_744491_11142" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541324792735_66330_11388" name="prozessnachrichten.rueckweisung.G2privat.1101">
            <ownedComment xmi:id="_18_0_2_940029b_1541324792922_753161_11421" annotatedElement="_18_0_2_940029b_1541324792735_66330_11388" body="&lt;para>Mittels dieser Nachricht wird eine Nachricht abgewiesen, die Fehler enthält, so dass sie nicht zielführend verarbeitet werden kann (Rückweisung per Behörde-an-Privat-Kommunikation). Der Autor der fehlerhaften Nachricht wird über die Fehler unterrichtet. Die abgewiesene Nachricht wird zur Information aufgeführt. &lt;/para>&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541324792922_919852_11422" name="nachrichtenkopf" visibility="private" type="_16_5_4_940029b_1461155864757_385317_5310" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1541324792922_711919_11427" annotatedElement="_18_0_2_940029b_1541324792922_919852_11422" body="&lt;para>Hier stehen allgemeine Informationen zum Sender und zum Empfänger zur eindeutigen Benennung und Identifizierung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324792922_886180_11428" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324792922_807363_11426" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541324792922_493749_11423" name="rueckweisungDaten" visibility="private" type="_18_0_2_940029b_1541324483751_614901_11350" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1541324792922_908608_11431" annotatedElement="_18_0_2_940029b_1541324792922_493749_11423" body="&lt;para>Mit diesem Element wird der Fehler einer gegebenenen Nachricht benannt, der zu der vorliegenden Rückweisung geführt hat.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324792922_168433_11432" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324792922_151269_11430" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541324793639_876376_11504" name="prozessnachrichten.rueckweisung.privat2G.1102">
            <ownedComment xmi:id="_18_0_2_940029b_1541324793649_55856_11526" annotatedElement="_18_0_2_940029b_1541324793639_876376_11504" body="&lt;para>Mittels dieser Nachricht wird eine Nachricht abgewiesen, die Fehler enthält, so dass sie nicht zielführend verarbeitet werden kann  (Rückweisung per Privat-an-Behörde-Kommunikation). Der Autor der fehlerhaften Nachricht wird über die Fehler unterrichtet. Die abgewiesene Nachricht wird zur Information aufgeführt. &lt;/para>&#xA;&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541324793649_12154_11527" name="nachrichtenkopf" visibility="private" type="_16_5_4_940029b_1461154163204_109593_4976" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1541324793650_231936_11532" annotatedElement="_18_0_2_940029b_1541324793649_12154_11527" body="&lt;para>Hier stehen allgemeine Informationen zum Sender und zum Empfänger zur eindeutigen Benennung und Identifizierung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324793650_140228_11533" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324793650_814166_11531" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541324793649_822396_11528" name="rueckweisungDaten" visibility="private" type="_18_0_2_940029b_1541324483751_614901_11350" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1541324793651_734599_11536" annotatedElement="_18_0_2_940029b_1541324793649_822396_11528" body="&lt;para>Mit diesem Element wird der Fehler einer gegebenenen Nachricht benannt, der zu der vorliegenden Rückweisung geführt hat.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324793651_497175_11537" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324793651_256003_11535" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1544645191493_157552_17875" name="prozessnachrichten.aktenzeichen.1121">
            <ownedComment xmi:id="_18_0_2_940029b_1544645191508_896111_17876" annotatedElement="_18_0_2_940029b_1544645191493_157552_17875" body="&lt;para>Diese Nachricht wird durch die Bauaufsichtsbehörde verwendet, um einen Antragsteller über die zugewiesene Vorgangsnummer bzw. das zugewiesene Aktenzeichen zu informieren.&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1544645191508_158807_17879" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1544645191508_472848_17877" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_18_0_2_940029b_1544645191508_149079_17882" annotatedElement="_18_0_2_940029b_1544645191508_472848_17877" body="&lt;para>Dieses Element enthält zur Information die Vorgangsnummer bzw. das Aktenzeichen, unter der die Behörde das Anliegen bearbeitet. Mit der Angabe der Referenz des Antragstellers wird der Bezug für diesen hergestellt.&lt;/para>&#xA;&#xA;&lt;para>Eine Referenzierung auf eine Nachricht wird in diese Nachricht nicht eingetragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1544645191508_97486_17883" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1544645191508_975790_17881" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1546756092187_518710_11657" name="prozessnachrichten.ruecknahme.1130">
            <ownedComment xmi:id="_18_0_2_940029b_1546756092187_797342_11658" annotatedElement="_18_0_2_940029b_1546756092187_518710_11657" body="&lt;para>Diese Nachricht kann durch einen Antragsteller verwendet werden, um einen in der Vergangenheit gestellten Antrag zurückzuziehen bzw. die Absicht einer solchen Rücknahme zu kommunizieren.&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1546756092187_116599_11660" general="_16_5_4_940029b_1461154142365_974763_4934"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1546756092187_987489_11659" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_18_0_2_940029b_1546756092187_816682_11663" annotatedElement="_18_0_2_940029b_1546756092187_987489_11659" body="&lt;para>In dieses Element sind die Referenzen von Antragsteller und ggf. Behörde einzutragen.&lt;/para>&#xA;&#xA;&lt;para>Eine Referenzierung auf eine Nachricht wird in diese Nachricht nicht eingetragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546756092187_550162_11664" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546756092187_189226_11662" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1546757320148_429240_11989" name="information" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1546757320148_240062_11991" annotatedElement="_18_0_2_940029b_1546757320148_429240_11989" body="&lt;para>Hier kann optional durch den Antragsteller eine Begründung  eingetragen werden.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546757320148_318697_11992" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546757320148_412698_11990" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1546777730975_736188_11859" name="anlagen" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1546777730975_865952_11861" annotatedElement="_18_0_2_940029b_1546777730975_736188_11859" body="&lt;para>Ggf. will der Antragsteller der Rücknahme des Antrags ein Schreiben beilegen. Das lässt sich mit diesem Element abbilden.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546777730975_673821_11862" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546777730975_388993_11860" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1546778584008_952063_11942" name="prozessnachrichten.quittierungRuecknahme.1131">
            <ownedComment xmi:id="_18_0_2_940029b_1546778584008_602047_11943" annotatedElement="_18_0_2_940029b_1546778584008_952063_11942" body="&lt;para>Diese Nachricht wird von der Bauaufsichtsbehörde verwendet, um  die Rücknahme des Antrags durch den Antragsteller zu quittieren, also zu bestätigen, dass die Rücknahme durch die Bauaufsichtsbehörde akzeptiert wurde (mit gegebenen Konsequenzen für den Antragsteller). Ggf. kann sie aber auch die Information enthalten, dass der Antrag nicht mehr zurückgenommen werden kann.&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1546778584008_898823_11947" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1546778584008_912671_11944" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_18_0_2_940029b_1546778584008_501771_11950" annotatedElement="_18_0_2_940029b_1546778584008_912671_11944" body="&lt;para>In dieses Element sind die Referenzen von Antragsteller und ggf. Behörde einzutragen.&lt;/para>&#xA;&#xA;&lt;para>Es ist die Nachricht des Antragstellers zu referenzieren, mittels derer er über seine Absicht informiert hat, den Antrag zurückzunehmen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546778584008_334154_11951" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546778584008_517372_11949" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1546780686209_577757_12204" name="ruecknahmeAkzeptiert" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1546780686225_95989_12206" annotatedElement="_18_0_2_940029b_1546780686209_577757_12204" body="&lt;para>Falls die Rücknahme des Antrags durch die Bauaufsichtsbehörde akzeptiert wurde, wird in diesem Element &quot;true&quot; übermittelt. &lt;/para>&#xA;&lt;para>Andernfalls wird &quot;false&quot; übermittelt. Dann ist eine Rücknahme des Antrags nicht mehr möglich, weil bereits ein Bescheid erteilt wurde, der dem Antragsteller auf dem vorgesehenen Wege zugehen wird oder bereits zugegangen ist.&lt;/para>&#xA;&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546780686225_370147_12207" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546780686225_440054_12205" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1546778584008_302817_11945" name="information" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1546778584008_690799_11954" annotatedElement="_18_0_2_940029b_1546778584008_302817_11945" body="&lt;para>Hier kann optional eine Begründung oder Erläuterung der Bauaufsichtsbehörde eingetragen werden.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546778584008_365051_11955" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546778584008_703346_11953" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1552126388478_40002_14677" name="prozessnachrichten.formellePruefungBefundliste.1140">
            <ownedComment xmi:id="_18_0_2_940029b_1552126388479_448931_14678" annotatedElement="_18_0_2_940029b_1552126388478_40002_14677" body="&lt;para>Diese Nachricht bezieht sich auf einen gestellten Antrag oder eine übermittelte Anzeige oder Erklärung. Enthalten sind die Ergebnisse einer formellen Prüfung (Befunde) sowie ggf. eine Frist, innerhalb derer Antrag bzw. Anzeige anzupassen ist (bei einer Anpassung kann es sich um Korrekturen oder um eine Vervollständigung handeln).&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1552126388480_678844_14682" general="_16_5_4_940029b_1461155848215_275954_5270"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552126388479_186666_14679" name="bezug" visibility="private" type="_16_5_4_940029b_1465368877212_444325_5428">
              <ownedComment xmi:id="_18_0_2_940029b_1552126388480_952886_14685" annotatedElement="_18_0_2_940029b_1552126388479_186666_14679" body="&lt;para>Bezug auf Vorgang und Nachricht, auf die sich die Inhalte der vorliegenden Nachricht beziehen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552126388480_450655_14686" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552126388480_602088_14684" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552126388479_582729_14680" name="befundliste" visibility="private" type="_18_0_2_940029b_1552127281868_654162_14786" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1552126388480_701304_14689" annotatedElement="_18_0_2_940029b_1552126388479_582729_14680" body="&lt;para>In diesem Element sind die Ergebnisse der formellen Prüfung enthalten. Sie haben die Form einer Liste von Mängeln des geprüften Gegenstandes.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552126388481_679365_14690" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552126388480_361408_14688" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552126388479_960148_14681" name="frist" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1552126388481_253963_14693" annotatedElement="_18_0_2_940029b_1552126388479_960148_14681" body="&lt;para>In dieses Element wird - falls im entsprechenden Vorgang vorgesehen - die durch die Behörde gesetzte Frist eingetragen, innerhalb derer die genannten Mängel zu beseitigen und die Unterlagen erneut einzureichen sind.&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552126388481_818106_14694" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552126388481_683596_14692" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
      </packagedElement>
      <packagedElement xmi:type="uml:Dependency" xmi:id="_16_5_4_5b501fb_1398421542326_660552_1933" name="" client="_16_5_4_1d100e5_1384794823532_59933_328" supplier="_16_5_4_5b501fb_1375258090807_886576_2132"/>
      <packagedElement xmi:type="uml:Package" xmi:id="_16_5_4_5b501fb_1400580960261_350236_1101" clientDependency="_16_5_4_940029b_1427804799647_414396_3790" name="Codes" URI="">
