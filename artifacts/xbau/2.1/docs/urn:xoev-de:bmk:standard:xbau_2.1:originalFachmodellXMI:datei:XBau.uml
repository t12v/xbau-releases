            <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1478973756024_330431_5147" name="" value="1"/>
