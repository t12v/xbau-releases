              </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541254566690_842614_11255" name="BezugStatistikmeldung">
              <ownedComment xmi:id="_18_0_2_940029b_1541255033224_881613_11288" annotatedElement="_18_0_2_940029b_1541254566690_842614_11255" body="&lt;para>Dieser Typ enthält dient dem Zusammenhang zu einem Vorgang der Bauaufsichtsbehörde und zur Bezugnahme durch die Statistik.&lt;/para>&#xA;"/>
              <generalization xmi:id="_18_0_2_940029b_1541254581034_936532_11278" general="_16_5_4_940029b_1465368877212_444325_5428"/>
              <ownedAttribute xmi:id="_18_0_2_940029b_1541254684499_787735_11280" name="identnummer" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
                <ownedComment xmi:id="_18_0_2_940029b_1541254684499_761367_11282" annotatedElement="_18_0_2_940029b_1541254684499_787735_11280" body="&lt;para>Diese Nummern werden von Destatis auf Vorrat zur Verfügung gestellt. &lt;/para>&#xA;&lt;para>Anlass Baufertigstellung: Durch die Baubehörde ist die Nummer zu verwenden, die sie im Rahmen der Statistikmeldung Baugenehmigung bereits verwendet hat.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541254684499_296470_11283" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541254684499_211804_11281" name="" value="1"/>
              </ownedAttribute>
            </packagedElement>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_2_8c5027b_1531483729905_661752_10895" name="" client="_16_5_4_940029b_1469886407614_283581_5959" supplier="_18_0_2_8c5027b_1530282138443_112084_9469"/>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1540992210991_370356_10891" name="informationsempfaenger.statistikmeldung.0410">
            <ownedComment xmi:id="_18_0_2_940029b_1540992211011_150259_10892" annotatedElement="_18_0_2_940029b_1540992210991_370356_10891" body="&lt;para>Diese Nachricht übermittelt Daten zu bestimmten bauaufsichtlichen Anlässen an die amtliche Statistik.&lt;/para>"/>
            <generalization xmi:id="_18_0_2_940029b_1540992211016_956237_10900" general="_16_5_4_940029b_1461085723092_220631_5163"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1540992211012_40_10893" name="bezug" visibility="private" type="_18_0_2_940029b_1541254566690_842614_11255">
              <ownedComment xmi:id="_18_0_2_940029b_1540992211017_261083_10903" annotatedElement="_18_0_2_940029b_1540992211012_40_10893" body="&lt;para>Dieses Element nennt den Vorgang der Bauaufsichtsbehörde, aus dem die Informationen entnommen sind. Für Zwecke der Bezugnahme auf der Seite der Statistik ist auch die entsprechende Identifikationsnummer der Statistik eingetragen.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1540992211018_957014_10904" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1540992211016_209128_10902" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1540992211013_300876_10894" name="anlass" visibility="private" type="_18_0_2_940029b_1540999289067_891110_11419" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1540992211018_28820_10907" annotatedElement="_18_0_2_940029b_1540992211013_300876_10894" body="&lt;para>Hier wird der Anlass genannt, also das bauaufsichtliche Ereignis, das zu dieser Benachrichtigung geführt hat&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1540992211018_523457_10908" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1540992211018_625495_10906" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1540993503438_430303_11077" name="allgemeineAngaben" visibility="private" type="_18_0_2_940029b_1540993426387_550401_11051" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1540993503438_442351_11079" annotatedElement="_18_0_2_940029b_1540993503438_430303_11077" body="&lt;para>Dieses Element enthält die Daten, die zu jeder Statistikmeldung enthalten sind (alle Anlässe). &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1540993503438_647356_11080" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1540993503438_128152_11078" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1540999015328_257929_11369" name="datenAnlass" visibility="private" type="_18_0_2_940029b_1540998120907_538579_11241" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1540999015328_394936_11371" annotatedElement="_18_0_2_940029b_1540999015328_257929_11369" body="&lt;para>Dieses Element enthält die Daten, die speziell zum gegebenen Anlass zu übermitteln sind.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1540999015328_264900_11372" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1540999015328_229032_11370" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1540997994974_793775_11234" name="ansprechpartner" visibility="private" type="_18_0_2_940029b_1540997901916_158858_11210" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1540997994974_434325_11236" annotatedElement="_18_0_2_940029b_1540997994974_793775_11234" body="&lt;para>Unterhalb dieses Elements werden Namen und Erreichbarkeit des Ansprechpartners für Rückfragen zu den übermittelten Daten eingetragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1540997994974_398103_11237" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1540997994974_770121_11235" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
