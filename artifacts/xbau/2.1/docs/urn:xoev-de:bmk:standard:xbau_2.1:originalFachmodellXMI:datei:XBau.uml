              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461154163204_752373_4985" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461154163204_446007_4980" name="leser" visibility="private" type="_16_5_4_1eeb04c1_1364313722451_850604_9366" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461162291158_909672_5900" annotatedElement="_16_5_4_940029b_1461154163204_446007_4980" body="&lt;para>Hier wird die Fachbehörde bzw. Organisation genannt, für die die vorliegende Nachricht bestimmt ist.&lt;/para>"/>
