            <ownedComment xmi:id="_16_5_4_940029b_1479100307660_18260_5244" annotatedElement="_16_5_4_940029b_1479100307660_218642_5237" body="&lt;para>Die Version der Codeliste, welche der Interpretation des übermittelten Schlüssels zu Grunde gelegt werden soll.&lt;/para>&#xA;&#xA;"/>
