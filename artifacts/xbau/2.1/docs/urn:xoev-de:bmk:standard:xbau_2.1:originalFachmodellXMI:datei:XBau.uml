            </node>
            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1462359357898_557160_7167" name="Angepasste &#xA;Beteiligungsaufforderung&#xA;Nachricht 0302" visibility="public" outgoing="_16_5_4_940029b_1462359357898_493243_7161" incoming="_16_5_4_940029b_1462359357898_295275_7157">
