            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1478883858583_517318_4703" name="Beauftragung des Prüfingenieurs&#xA;Nachricht 0500" visibility="public" outgoing="_16_5_4_940029b_1478883858568_642973_4686" incoming="_16_5_4_940029b_1478883858568_384526_4661">
