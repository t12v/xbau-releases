              <ownedComment xmi:id="_18_0_2_8c5027b_1516030775272_656835_9448" annotatedElement="_18_0_2_8c5027b_1516030775272_654665_9446" body="&lt;para>Hier werden ggf. ergänzende Hinweise zur Stellungnahme gegeben.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_8c5027b_1516030775272_812117_9449" name=""/>
