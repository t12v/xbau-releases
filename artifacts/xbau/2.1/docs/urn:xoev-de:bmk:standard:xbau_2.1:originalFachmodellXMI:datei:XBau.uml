        <packagedElement xmi:type="uml:Package" xmi:id="_18_0_6_5b501fb_1525274794723_205467_10083" clientDependency="_18_0_6_5b501fb_1525277982054_553084_10670" name="Lichtbild" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_6_5b501fb_1525274794734_702635_10086" name="Lichtbild">
            <ownedComment xmi:id="_18_0_6_5b501fb_1525274795033_162511_10131" annotatedElement="_18_0_6_5b501fb_1525274794734_702635_10086" body="&lt;para>Mit diesem Datentyp wird ein Lichtbild im Binärformat übermittelt, inklusive der Angabe des Bildformats als MIME-Type.&lt;/para>"/>
            <generalization xmi:id="_18_0_6_5b501fb_1525274795033_985357_10132">
              <general xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191711843_120906_985"/>
            </generalization>
            <ownedAttribute xmi:id="_18_0_6_5b501fb_1525276833107_154225_10637" name="mimeType" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_18_0_6_5b501fb_1525277023777_303651_10639" annotatedElement="_18_0_6_5b501fb_1525276833107_154225_10637" body="&lt;para>Mit diesem Attribut wird das Format des übermittelten Lichtbilds als MIME-Type übermittelt.&lt;/para>"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_6_5b501fb_1525277982054_553084_10670" name="" client="_18_0_6_5b501fb_1525274794723_205467_10083" supplier="_16_5_4_5b501fb_1387625271062_845493_4821"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_18_0_6_5b501fb_1539010141652_449226_9893" clientDependency="_18_0_6_5b501fb_1539010824282_36689_9925" name="AZRNummer" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_6_5b501fb_1539010147228_409531_9894" name="AZRNummer">
            <ownedComment xmi:id="_18_0_6_5b501fb_1539010147230_706998_9895" annotatedElement="_18_0_6_5b501fb_1539010147228_409531_9894" body="&lt;para>Mit diesem Datentyp wird die AZR-Nummer übermittelt. Sie beginnt mit sechs Ziffern, die das Datum der Erstanlage des AZR-Datensatzes wie folgt darstellen: JJMMTT. Darauf folgt eine beliebige Folge von sechs weiteren Ziffern.&lt;/para>"/>
            <generalization xmi:id="_18_0_6_5b501fb_1539010147231_874097_9896" general="_16_5_4_5b501fb_1387625271095_781237_4845"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_6_5b501fb_1539010824282_36689_9925" name="" client="_18_0_6_5b501fb_1539010141652_449226_9893" supplier="_16_5_4_5b501fb_1387625271062_845493_4821"/>
