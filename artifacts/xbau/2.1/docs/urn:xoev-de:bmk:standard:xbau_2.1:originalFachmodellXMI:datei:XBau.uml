                <ownedComment xmi:id="_18_0_2_940029b_1540998120907_74577_11247" annotatedElement="_18_0_2_940029b_1540998120907_294259_11243" body="&lt;para>In dieses Element ist das Datum der Baugenehmigung bzw. der Genehmigungsfreistellung einzutragen.&lt;/para>"/>
