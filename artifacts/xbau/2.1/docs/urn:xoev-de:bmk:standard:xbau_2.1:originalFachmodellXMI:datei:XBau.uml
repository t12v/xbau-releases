                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291323_377827_6153" annotatedElement="_16_5_4_5b501fb_1387625291122_748817_5240" body="Gibt die Behörde an, die das Ausweisdokument ausgestellt hat."/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291323_421642_6154" name="" visibility="private" type="_16_5_4_5b501fb_1387625291106_495606_5168" association="_16_5_4_5b501fb_1387625291122_748817_5240"/>
