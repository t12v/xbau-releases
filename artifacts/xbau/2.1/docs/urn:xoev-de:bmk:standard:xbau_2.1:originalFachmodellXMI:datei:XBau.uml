                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291322_487055_6147" annotatedElement="_16_5_4_5b501fb_1387625291122_356588_5238" body="Der frühere Familienname ist der Nachname, den eine Person vor einer Nachnamensänderung geführt hat. &#xA;"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291322_504162_6148" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291122_356588_5238"/>
