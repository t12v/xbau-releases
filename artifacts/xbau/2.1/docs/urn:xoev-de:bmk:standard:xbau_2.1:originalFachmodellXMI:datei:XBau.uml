            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1461155089936_157310_5205" name="autor" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461155089936_970666_5208" annotatedElement="_16_5_4_940029b_1461155089936_157310_5205" body="&lt;para>Hier wird die Fachbehörde bzw. Organisation genannt, die die vorliegende Nachricht erstellt hat.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1461155089936_297145_5207" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1461155089936_451052_5209" name="" value="1"/>
