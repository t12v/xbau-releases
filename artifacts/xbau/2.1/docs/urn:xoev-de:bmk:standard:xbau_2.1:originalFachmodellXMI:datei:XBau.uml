                <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="_18_0_2_940029b_1540998435918_555124_11305" name="" value="true"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_18_0_2_940029b_1540998370786_34016_11282" name="aenderungenBeschreibung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734" aggregation="composite">
                <ownedComment xmi:id="_18_0_2_940029b_1540998370786_882517_11292" annotatedElement="_18_0_2_940029b_1540998370786_34016_11282" body="&lt;para>In diesem Element sind die Änderungen formlos zu beschreiben.&lt;/para>&#xA;"/>
