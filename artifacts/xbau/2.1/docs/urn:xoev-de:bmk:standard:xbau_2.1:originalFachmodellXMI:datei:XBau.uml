                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291322_68605_6150" annotatedElement="_16_5_4_5b501fb_1387625291122_625053_5239" body="Angaben zum Zeitraum, in welchem der Familienstand einer natürlichen Person gültig ist. "/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291322_94752_6151" name="" visibility="private" type="_16_5_4_5b501fb_1387625291098_333760_5159" association="_16_5_4_5b501fb_1387625291122_625053_5239"/>
