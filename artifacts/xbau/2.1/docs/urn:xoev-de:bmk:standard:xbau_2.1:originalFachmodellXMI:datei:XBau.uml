            <ownedComment xmi:id="_16_5_4_940029b_1467902983357_784193_5951" annotatedElement="_16_5_4_940029b_1467902983357_400947_5945" body="&lt;para>Dieser Typ enthält die Angaben, die für die bargeldlose Bezahlung gemäß SEPA benötigt werden. &lt;/para>"/>
