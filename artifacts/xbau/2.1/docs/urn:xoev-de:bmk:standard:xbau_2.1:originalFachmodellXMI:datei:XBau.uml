              <ownedComment xmi:id="_16_5_4_940029b_1467904837994_535056_6148" annotatedElement="_16_5_4_940029b_1467904837994_276507_6145" body="&lt;para>Dieses Element enthält die Angaben, die der Anwender zur Veranlassung einer bargeldlosen Bezahlung gemäß SEPA benötigt. &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467904837994_607361_6147" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467904837994_255789_6149" name="" value="1"/>
            </ownedAttribute>
