                  <ownedComment xmi:id="_16_5_4_5b501fb_1406633287298_650799_6574" annotatedElement="_16_5_4_5b501fb_1406633287120_309022_5622" body="Hier werden Angaben zum Familienstand einer natürlichen Person gemacht."/>
