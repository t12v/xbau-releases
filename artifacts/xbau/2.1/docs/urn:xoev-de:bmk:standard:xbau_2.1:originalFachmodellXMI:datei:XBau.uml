          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1467904417963_15998_6086" name="Gebuehrenbescheid">
            <ownedComment xmi:id="_16_5_4_940029b_1467904417963_446498_6094" annotatedElement="_16_5_4_940029b_1467904417963_15998_6086" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Gebührenbescheids der Bauaufsichtsbehörde. Es sind die Daten zu Gegenstand, Herleitung, Betrag und Bezahlung der Gebühren enthalten.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467904417963_810785_6088" name="istVorauszahlungsbescheid" visibility="private">
              <ownedComment xmi:id="_16_5_4_940029b_1467904417963_207101_6097" annotatedElement="_16_5_4_940029b_1467904417963_810785_6088" body="&lt;para>Falls es sich nicht um den abschließenden Gebührenbescheid, sondern um einen Vorauszahlungsbescheid handelt, ist hier true einzutragen. Dann weiß der Empfänger, dass weitere Gebührenbescheide zum angegebenen Vorgang zu erwarten sind.&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467904417963_35437_6096" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467904417963_914128_6098" name="" value="1"/>
            </ownedAttribute>
