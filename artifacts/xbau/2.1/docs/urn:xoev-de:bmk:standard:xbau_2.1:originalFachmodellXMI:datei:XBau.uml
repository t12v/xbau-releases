            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1462359358764_653751_7463" name="Ergebnis der Prüfung&#xA;Nachricht 0602" visibility="public" outgoing="_16_5_4_940029b_1462359358764_758456_7440" incoming="_16_5_4_940029b_1462359358764_671802_7435">
              <ownedComment xmi:id="_16_5_4_940029b_1462359360091_970817_8111" annotatedElement="_16_5_4_940029b_1462359358764_653751_7463" body="&lt;para>Sachverständige Stellen versenden eine 'Stellungsnahme' an die BAB.&lt;/para>"/>
            </node>
            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1462359358764_347967_7464" name="Anzeige des &#xA;Bauvorhabens&#xA;Nachricht 0600" visibility="public" outgoing="_16_5_4_940029b_1462359358764_534581_7436" incoming="_16_5_4_940029b_1462359358764_480476_7429">
              <ownedComment xmi:id="_16_5_4_940029b_1462359360091_723355_8112" annotatedElement="_16_5_4_940029b_1462359358764_347967_7464" body="&lt;para>Die BAB versendet die Nachricht 'Aufforderung zur Prüfung und Stellungnahme' an die zuständige Behörde / Dienststelle.&lt;/para>"/>
            </node>
            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1462359358764_112003_7465" name="Anzeige des &#xA;Prüfergebnisses&#xA;Nachricht 0603" visibility="public" outgoing="_16_5_4_940029b_1462359358764_454094_7445 _16_5_4_940029b_1462359358764_357760_7447" incoming="_16_5_4_940029b_1462359358764_326851_7456">
