                <ownedComment xmi:id="_18_0_2_940029b_1540993007041_642399_11013" annotatedElement="_18_0_2_940029b_1540993007041_520600_11011" body="&lt;para>In diesem Element werden Daten zu  den beteiligten Personen übermittelt, soweit für die Anlässe relevant. &lt;/para>&#xA;"/>
