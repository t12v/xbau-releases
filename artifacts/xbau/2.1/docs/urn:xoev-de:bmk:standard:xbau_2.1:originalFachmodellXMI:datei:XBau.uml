          <ownedAttribute xmi:id="_16_5_4_940029b_1483136948155_232593_4954" name="code" visibility="private">
            <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483136948171_677094_4962" name="" value="1"/>
