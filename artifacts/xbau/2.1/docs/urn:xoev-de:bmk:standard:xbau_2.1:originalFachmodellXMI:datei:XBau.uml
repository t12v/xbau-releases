                <ownedComment xmi:id="_18_0_2_940029b_1540993140021_667760_11026" annotatedElement="_18_0_2_940029b_1540993140021_956138_11020" body="&lt;para>Hier ist der Akteur einzutragen, der am Verfahren als Bauherr beteiligt ist.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1540993140021_28992_11027" name=""/>
