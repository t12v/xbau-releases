            <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552071235498_183228_14679" name="" value="1"/>
            <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552071235498_920056_14677" name="" value="1"/>
          </ownedAttribute>
          <ownedAttribute xmi:id="_18_0_2_940029b_1552071235498_475071_14671" name="listVersionID" visibility="private" isReadOnly="true">
            <ownedComment xmi:id="_18_0_2_940029b_1552071235498_886544_14682" annotatedElement="_18_0_2_940029b_1552071235498_475071_14671" body="&lt;para>Die Version der Codeliste, welche der Interpretation des übermittelten Schlüssels zu Grunde gelegt werden soll.&lt;/para>&#xA;&#xA;"/>
