            <ownedComment xmi:id="_16_5_4_940029b_1467903322701_819141_5993" annotatedElement="_16_5_4_940029b_1467903322701_974436_5987" body="&lt;para>Dieser Typ entält die Daten zu einer Position des Gebührenbescheids.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1467903322701_564115_5991" name="erlaeuterung" visibility="private" type="_16_5_4_5b501fb_1387625271095_781237_4845">
              <ownedComment xmi:id="_16_5_4_940029b_1467903322701_785324_6004" annotatedElement="_16_5_4_940029b_1467903322701_564115_5991" body="&lt;para>Hier ist eine Begründung bzw. eine Herleitung (Bsp. Stückpreis mal Anzahl; Bsp. Rahmen mit Bezug auf Aufwand; Bsp. Grund bzw. Gegenstand der Auslage ) zur Position einzutragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1467903604418_957260_6044" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1467903604418_29812_6045" name="" value="1"/>
            </ownedAttribute>
