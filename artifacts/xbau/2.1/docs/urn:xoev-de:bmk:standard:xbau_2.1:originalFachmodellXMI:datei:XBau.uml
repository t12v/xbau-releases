          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_5_44f60732_1461234672864_964463_8089" clientDependency="_18_0_5_44f60732_1461234884790_337750_8185 _18_0_5_44f60732_1461234900577_580943_8188" name="quittung">
