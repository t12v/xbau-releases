                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291322_501552_6141" annotatedElement="_16_5_4_5b501fb_1387625291122_780644_5236" body="Informationen zur autorisierenden Registrierung  einer Organisation in einem fachlichen Register."/>
