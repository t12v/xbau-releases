            </node>
            <node xmi:type="uml:CentralBufferNode" xmi:id="_16_5_4_940029b_1478883858583_863739_4705" name="Ergebnis der formellen Prüfung&#xA;Nachricht 0502" visibility="public" outgoing="_16_5_4_940029b_1478883858568_731958_4671" incoming="_16_5_4_940029b_1478883858568_847198_4663">
