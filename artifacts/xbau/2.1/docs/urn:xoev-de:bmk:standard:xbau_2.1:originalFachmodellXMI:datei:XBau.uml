                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291318_461038_6063" annotatedElement="_16_5_4_5b501fb_1387625291119_32073_5210" body="Der Ehename ist der von beiden Ehegatten durch Erklärung bestimmte gemeinsame Familienname der Ehegatten. Zum Ehenamen kann der Geburtsname eines der Ehegatten oder der zur Zeit der Erklärung von einem Ehegatten geführte Name bestimmt werden."/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291318_741291_6064" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291119_32073_5210"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291120_51531_5211" name="" memberEnd="_16_5_4_5b501fb_1387625291265_139616_5810 _16_5_4_5b501fb_1387625291318_231666_6067">
