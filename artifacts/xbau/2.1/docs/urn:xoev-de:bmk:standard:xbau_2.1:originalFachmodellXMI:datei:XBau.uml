              <ownedAttribute xmi:id="_16_5_4_940029b_1483129729635_774638_5158" name="stundensatz" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1483129729635_269139_5169" annotatedElement="_16_5_4_940029b_1483129729635_774638_5158" body="&lt;para>Der Stundensatz der der Berechnung des voraussitchtlichen Aufwands zugrundeliegt (in Eurocent).&lt;/para>"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1483129729635_631388_5168" name="" value="1"/>
