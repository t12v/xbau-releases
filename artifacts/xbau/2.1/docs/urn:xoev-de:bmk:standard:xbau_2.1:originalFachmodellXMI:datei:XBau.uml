  <XOEVProfil:xoevABIE xmi:id="_3whgX1U7Eem76qy_rce7yg" base_Class="_16_5_4_1eeb04c1_1364382738190_314891_1582"/>
  <XOEVProfil:xoevABIE xmi:id="_3whgYFU7Eem76qy_rce7yg" base_Class="_16_5_4_1eeb04c1_1380019686134_103237_1614"/>
  <XOEVProfil:xoevABIE xmi:id="_3whgYVU7Eem76qy_rce7yg" base_Class="_16_5_4_b7102e0_1292420010055_54472_505" MotivationDerAbweichung="Die Klasse heißt Meldeanschrift und nicht Anschrift, weil sie zur Übermittlung von Anschriften vorgesehen ist, an denen Personen in der Meldebehörde gemeldet sein können."/>
  <XOEVProfil:xoevABIE xmi:id="_3whgYlU7Eem76qy_rce7yg" base_Class="_16_5_4_1ccb0481_1425468921949_760319_2133"/>
  <XOEVProfil:xoevABIE xmi:id="_3whgY1U7Eem76qy_rce7yg" base_Class="_18_0_6_5b501fb_1539010147228_409531_9894" MotivationDerAbweichung="Es wird weder eine Beschreibung noch eine Gültigkeit  in diesem Kontext benötigt. &#xA;Die AZRNummer wird direkt über eine beschränkte Verwendung von String.Latin umgesetzt."/>
  <XOEVProfil:xoevABIE xmi:id="_3whgZFU7Eem76qy_rce7yg" base_Class="_16_5_4_1eeb04c1_1351595172450_828165_1636" Abweichung="Die Auslandsanschrift aus XInneres enthält das Druckbild einer Auslandsanschrift in unstrukturierter Form." MotivationDerAbweichung="Für die Übermittlung von  ausländischen Anschriften ist der strukturierte Ansatz der Kernkomponente nicht geeignet. Aus diesem Grund wurde in XInneres ein Datentyp für ausländische Anschriften konzipiert, der sich an dem Druckbild einer Anschrift und der entsprechenden DIN-Norm orientiert. "/>
  <XOEVProfil:xoevABIE xmi:id="_3whgZVU7Eem76qy_rce7yg" base_Class="_16_5_4_1eeb04c1_1380019660674_995526_1587" MotivationDerAbweichung="Im Interesse der Wiederverwendung der Meldeanschrift wurde die postalische Inlandsanschrift als Choice zwischen Gebäude- und Postfachanschriften modelliert."/>
  <XOEVProfil:xoevABIE xmi:id="_3whgZlU7Eem76qy_rce7yg" base_Class="_16_5_4_5b501fb_1406633287063_172287_5381"/>
