  <XOEVProfil:xoevCodeliste xmi:id="_3wrQf1U7Eem76qy_rce7yg" base_Enumeration="_18_0_6_5b501fb_1501844208991_853690_8796" nameLang="Gemeinden, dargestellt durch den Amtlichen Gemeindeschlüssel(AGS) des Statistischen Bundesamtes" nameKurz="AGS" nameTechnisch="ags" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:ags" beschreibung="&lt;para>Diese Codeliste stellt alle Gemeinden Deutschlands durch den Amtlichen Gemeindeschlüssel (AGS) dar, wie im Gemeindeverzeichnis des Statistischen Bundesamtes enthalten.&lt;/para>" herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQgFU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_1eeb04c1_1392816805317_775359_2248" nameLang="Fehlercodes in XInneres" nameKurz="Fehlercodes in XInneres" nameTechnisch="fehlercodes" kennung="urn:de:xinneres:codeliste:fehlercodes" beschreibung="&lt;para>Diese Tabelle führt mögliche Gründe für eine Rücksendung einer Nachricht an den Absender auf. Mit dem Präfix des jeweiligen Schlüssels wird folgende Systematik festgelegt: T (Transportproblem), X (formales Problem mit XML), V (Versionsproblem), S (nicht spezifikationskonform).&lt;/para>&#xA;" herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQgVU7Eem76qy_rce7yg" base_Enumeration="_18_0_6_5b501fb_1501844209006_717584_8892" nameLang="Präfixe im DVDV" nameKurz="DVDV.Praefixe" nameTechnisch="dvdv.praefix" kennung="urn:xoev-de:bund:bmi:bit:codeliste:dvdv.praefix" beschreibung="&lt;para>Diese Codeliste enthält alle Präfixe, welche im DVDV zum Einsatz kommen. Diese Präfixe werden für die fachliche Adressierung über das DVDV verwendet.&lt;/para>&#xA;&#xA;&#xA;" herausgebernameLang="Informationstechnikzentrum Bund" herausgebernameKurz="BMI/ITZBund"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQglU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_1eeb04c1_1415191648098_18372_2387" nameLang="Kommunikationskanal / Erreichbarkeit" nameKurz="Erreichbarkeit" nameTechnisch="erreichbarkeit" kennung="urn:de:xoev:codeliste:erreichbarkeit" beschreibung="&lt;para>Eine Liste der Kommunikationsmedien und -kanäle, über die man eine Person oder Institution erreichen kann.&lt;/para>" herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQg1U7Eem76qy_rce7yg" base_Enumeration="_18_0_6_5b501fb_1501844209022_164103_8962" nameLang="Codeliste Staat aus der Staats- und Gebietssystematik des Statistischen Bundesamtes" nameKurz="Destatis.Staat" nameTechnisch="staat" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:staat" beschreibung="&lt;para>Eine auf der Staats- und Gebietssystematik des Statistischen Bundesamtes basierende Liste von Schlüsselwerten zur eindeutigen Bezeichnung von Staaten im Kontext der Übermittlung eines Druckbildes einer Anschrift im Ausland. Für die Übermittlung in XInneres ist die jeweils gültige Fassung der Staats- und Gebietssystematik zu verwenden.&lt;/para>" herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQhFU7Eem76qy_rce7yg" base_Enumeration="_16_5_4_1eeb04c1_1386164360372_41461_2101" nameLang="Nachrichtentypen in XInneres" nameKurz="Nachrichtentypen in XInneres" nameTechnisch="nachrichtentyp" kennung="urn:de:xinneres:codeliste:nachrichtentyp" beschreibung="&lt;para>Die Liste von eindeutigen Bezeichner für Nachrichtentypen im &amp;xrecent;.&lt;/para>" herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQhVU7Eem76qy_rce7yg" base_Enumeration="_18_0_6_5b501fb_1528010622497_482128_10092" nameLang="Quittungsrelevanter Sachverhalt" nameKurz="Quittungsrelevanter Sachverhalt" nameTechnisch="quittungsrelevanter-sachverhalt" kennung="urn:xoev-de:xinneres:codeliste:quittungsrelevanter-sachverhalt" beschreibung="&lt;para>Diese Codeliste umfasst die quittungsrelevanten Sachverhalte für XInneres.&lt;/para>&#xA;" herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQhlU7Eem76qy_rce7yg" base_Enumeration="_18_0_6_5b501fb_1501844208991_882577_8744" nameLang="DVDV Behördenschlüssel der Bundesbehörden" nameKurz="DVDV.Behoerdenschluessel.Bundesbehoerden" nameTechnisch="dvdv.behoerdenschluessel" kennung="urn:xoev-de:bund:bmi:bit:codeliste:dvdv.behoerdenschluessel" beschreibung="&lt;para>Diese Codeliste enthält die Behördenschlüssel zur Präfix dbs. Ein solcher Behördenschlüssel wird unter anderem für Bundes- und Landesbehörden von der Koordinierenden Stelle DVDV vergeben.&lt;/para>&#xA;" herausgebernameLang="Informationstechnikzentrum Bund" herausgebernameKurz="BMI/ITZBund"/>
  <XOEVProfil:xoevCodeliste xmi:id="_3wrQh1U7Eem76qy_rce7yg" base_Enumeration="_18_0_2_940029b_1547048659704_458643_12208" nameLang="MPPVO Prüfung technische Anlage Weiterbetrieb" nameKurz="MPPVO Prüfung technische Anlage Weiterbetrieb" nameTechnisch="mppvotechnischeanlageweiterbetrieb" kennung="urn:xoev-de:xbau:codeliste:mppvotechnischeanlageweiterbetrieb" beschreibung="Ergebnis der Prüfung einer überwachungspflilchtigen Anlage: mögliche Festlegungen zum Weiterbetrieb" herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK"/>
