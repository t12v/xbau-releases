            <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1540993140021_58708_11018" name="BeteiligteBauprojekt">
              <ownedComment xmi:id="_18_0_2_940029b_1540993140021_994155_11019" annotatedElement="_18_0_2_940029b_1540993140021_58708_11018" body="&lt;para>Typ für die am Bauprojekt beteiligten Parteien (Personen und Organisationen), die für eine Meldung an die Statistik relevant sind.&lt;/para>"/>
