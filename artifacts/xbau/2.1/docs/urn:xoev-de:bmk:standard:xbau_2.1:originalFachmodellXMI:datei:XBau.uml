              </ownedAttribute>
              <ownedAttribute xmi:id="_16_5_4_940029b_1483129867536_906657_5184" name="geschaetzteGebuehr" visibility="private">
                <ownedComment xmi:id="_16_5_4_940029b_1483129867536_847644_5187" annotatedElement="_16_5_4_940029b_1483129867536_906657_5184" body="&lt;para>Die sich auf der Basis von Stundensatz und voraussichtlich zu leistendem Aufwand ergebende Gebühr (in Eurocent).&lt;/para>"/>
                <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
