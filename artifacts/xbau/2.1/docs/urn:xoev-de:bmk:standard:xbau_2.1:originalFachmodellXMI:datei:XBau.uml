            <node xmi:type="uml:CallBehaviorAction" xmi:id="_16_5_4_940029b_1462359357898_698616_7171" name="Stellungnahme / Bescheid erstellen und abschicken" visibility="public" inPartition="_16_5_4_940029b_1462359357898_828047_7164" outgoing="_16_5_4_940029b_1462359357898_598908_7158" incoming="_16_5_4_940029b_1462359357898_88745_7156">
