				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1287395686258_528623_346' name='Leistungserbringer' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1287396077285_450575_620' body='Mit dieser Eigenschaft kann der Leistungserbringer bezüglich des ausgewählten Dienstes angegeben werden. Diese Information wird momentan in der Übersichtstabelle zu den Diensten genutzt.'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1287395686258_528623_346'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1287395782554_408332_613'/>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1287395782577_288791_614' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1287395712310_824936_347' name='Hinweis' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1287396142749_717251_621' body='Mit dieser Eigenschaft können Hinweise zur produktiven Nutzung des Dienstes (z.B. bzgl. DVDV) gegeben werden. Sie werden momentan in der Übersichtstabelle zu den Diensten aufgeführt.'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1287395712310_824936_347'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1287395844802_419781_615'/>
					<xmi:Extension extender='MagicDraw UML 18.0'>
