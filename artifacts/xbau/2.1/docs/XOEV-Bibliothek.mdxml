							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387625291164_857013_5406' name='grund' visibility='private' type='_16_5_4_5b501fb_1387625280047_322339_5028'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291339_9713_6347' body='&lt;para&gt;Der Grund gibt die Rechtsgrundlage an, aufgrund derer die Auskunftssperre besteht und aus der sich die Konsequenzen für die Zulässigkeit von Auskünften und Datenübermittlungen eindeutig ableiten.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291164_857013_5406'/>
								</ownedComment>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1387625291339_560954_6346'/>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1387625291339_647429_6348' value='1'/>
									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387625291165_711583_5407' name='gueltigkeit' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1387625291110_970069_5173' association='_16_5_4_5b501fb_1387625291123_740309_5242'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291339_299846_6351' body='&lt;para&gt;Die &quot;gueltigkeit&quot; gibt mit Beginn- und/oder Endzeitpunkt den Zeitraum an, für den eine Auskunftssperre besteht.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291165_711583_5407'/>
								</ownedComment>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1387625291339_525177_6350'/>
								<xmi:Extension extender='MagicDraw UML 18.0'>
