							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387625291188_278053_5495' name='staatsangehoerigkeit' visibility='private' type='_16_5_4_5b501fb_1387625280047_322339_5028'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291358_904184_6567' body='&lt;para&gt;Die Komponente &quot;staatsangehoerigkeit&quot; enthält einen Schlüssel zur Identifikation einer Staatsangehörigkeit.&lt;/para&gt;&#10;&#10;&lt;para&gt;Anmerkung: Als Codeliste wird der systematische Staatsangehörigkeits- und Gebietsschlüssel, herausgegeben vom Statistischen Bundesamt, verwendet.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291188_278053_5495'/>
								</ownedComment>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1387625291358_794257_6566' value='1'/>
									</modelExtension>
								</xmi:Extension>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1387625291358_331973_6568' value='1'/>
									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
						</packagedElement>
						<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1387625291104_134064_5166' name='Staat'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291194_792912_5520' body='&lt;para&gt;Als Staat bezeichnet man eine politische Ordnung, die ein gemeinsames als Staatsgebiet abgegrenztes Territorium, ein dazugehöriges Staatsvolk und eine Machtausübung über dieses umfasst.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291104_134064_5166'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 18.0'>
								<modelExtension>
									<ownedDiagram xmi:type='uml:Diagram' xmi:id='_16_5_4_5b501fb_1387625291194_926079_5521' name='Staat' visibility='public' ownerOfDiagram='_16_5_4_5b501fb_1387625291104_134064_5166'>
