									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387625291258_219743_5784' name='gueltigkeit' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1387625291110_970069_5173' association='_16_5_4_5b501fb_1387625291117_476987_5190'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291387_128443_6883' body='&lt;para&gt;Angaben zum Gültigkeitszeitraum einer Identifikationsnummer.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291258_219743_5784'/>
								</ownedComment>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1387625291387_586877_6882'/>
