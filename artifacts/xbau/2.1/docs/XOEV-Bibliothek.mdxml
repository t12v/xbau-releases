				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1388930023739_136337_3439' name='staatsangehoerigkeit' visibility='private' type='_16_5_4_5b501fb_1388930177171_360126_3547'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1388930023759_841727_3465' body='&lt;para&gt;Die Komponente &quot;staatsangehoerigkeit&quot; enthält einen Schlüssel zur Identifikation einer Staatsangehörigkeit.&lt;/para&gt;&#10;&#10;&lt;para&gt;Anmerkung: Als Codeliste wird der systematische Staatsangehörigkeits- und Gebietsschlüssel, herausgegeben vom Statistischen Bundesamt, verwendet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1388930023739_136337_3439'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1388930023758_448355_3464' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1388930023759_427338_3466' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1388930177171_360126_3547' name='Code.Staatsangehoerigkeit'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1388930177176_166992_3553' body='&lt;para&gt;Der XÖV-Datentyp Code ermöglicht die Übermittlung von Inhalten, so genannter &lt;emphasis&gt;Codes&lt;/emphasis&gt;, aus vordefinierten Codelisten. Codelisten fassen eine Menge von Codes zusammen, welche in einem spezifischen thematischen Kontext eine eindeutige Semantik aufweisen.&lt;footnote&gt;&lt;para&gt;&amp;clRef;&lt;/para&gt;&lt;/footnote&gt; Beispielsweise kann eine Codeliste für die Bestimmung des Familienstands einer Person Codes wie &quot;ld&quot; und &quot;vh&quot; umfassen, welche eine Person als ledig bzw. verheiratet identifizieren können.&lt;/para&gt; &#10;&#10;&lt;para&gt;Eine entscheidende Eigenschaft des Datentyps ist die Möglichkeit auf differenzierte Weise Bezug zu Codelisten zu nehmen, sei es als Standard-Codeliste, benannte Codeliste, versionsfreie, oder generische Codeliste.&lt;footnote&gt;&lt;para&gt;&amp;clTypenRef;&lt;/para&gt;&lt;/footnote&gt; In jedem Fall ist eine eindeutige Identifizierung der zugrundeliegenden Codeliste möglich.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_5b501fb_1388930177171_360126_3547'/>
				</ownedComment>
				<generalization xmi:type='uml:Generalization' xmi:id='_16_5_4_5b501fb_1388930226898_544185_3608'>
					<general href='local:/PROJECT-d936a7e33032315b91e413bd183a836?resource=com.nomagic.magicdraw.uml_umodel.shared_umodel#_16_5_4_5b501fb_1387625280047_322339_5028'>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<referenceExtension referentPath='XOEV-Bibliothek::XOEV-Datentypen::Code::1.0::Code' referentType='Class'/>
						</xmi:Extension>
					</general>
				</generalization>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1388930177172_745858_3549' name='code' visibility='private'>
					<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191873500_204582_1633'>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<referenceExtension referentPath='XOEV-Profil::W3C Data Types::token' referentType='Class'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1388930177177_577732_3557' body='&lt;para&gt;In diesem XML-Element wird der eigentliche Code einer Codeliste übermittelt.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1388930177172_745858_3549'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1388930177176_47340_3556' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1388930177177_794423_3558' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1388930177173_313008_3550' name='name' visibility='private'>
					<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191848984_108685_1498'>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<referenceExtension referentPath='XOEV-Profil::W3C Data Types::normalizedString' referentType='Class'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1388930177177_990003_3561' body='&lt;para&gt;Mit diesem optionalen XML-Element kann der in der Regel von einem Menschen interpretierbare Wert eines Codes übermittelt werden.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1388930177173_313008_3550'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1388930177177_840815_3560'/>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1388930177177_855635_3562' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1388930177174_237594_3551' name='listURI' visibility='private' isReadOnly='true'>
					<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191702187_214129_966'>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<referenceExtension referentPath='XOEV-Profil::W3C Data Types::anyURI' referentType='Class'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1388930177178_703587_3565' body='&lt;para&gt;Mit diesem XML-Attribut wird der Uniform Resource Identifier (URI) der Codeliste übermittelt, in deren Kontext der jeweilige Code zu interpretieren ist. Der URI identifiziert die Codeliste, nicht jedoch deren Version eindeutig. &lt;/para&gt;&#10;&#10;&lt;para&gt;Die Bestimmung des URI einer Codeliste bei der Übertragung eines Codes ist zwingend. Wird bereits im Rahmen des XÖV-Standards ein URI vorgegeben (es handelt sich in diesem Fall um eine Standard-, benannte, oder versionsfreie Codeliste) darf auf eine nochmalige Angabe des URI bei der Übermittlung eines Codes verzichtet werden. Aus diesem Grund ist das XML-Attribut listURI als optional deklariert.&lt;/para&gt;&#10;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1388930177174_237594_3551'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1388930337926_301653_3613'/>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1388930337926_925618_3614' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:OpaqueExpression' xmi:id='_16_5_4_5b501fb_1388930337928_105044_3615'>
						<body>urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:staatsangehoerigkeit</body>
					</defaultValue>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1388930177175_113789_3552' name='listVersionID' visibility='private'>
					<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191848984_108685_1498'>
						<xmi:Extension extender='MagicDraw UML 18.0'>
							<referenceExtension referentPath='XOEV-Profil::W3C Data Types::normalizedString' referentType='Class'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1388930177178_412159_3569' body='&lt;para&gt;Die konkrete Version der zu nutzenden Codeliste wird mit diesem XML-Attribut übertragen.&lt;/para&gt;&#10;&#10;&lt;para&gt;Analog zum listURI ist die Bestimmung der Version einer Codeliste bei der Übertragung eines Codes zwingend. Die Version kann jedoch ebenso bereits im XÖV-Standard festgelegt werden (es handelt sich in diesem Fall um eine Standard-, oder eine benannte Codeliste).&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1388930177175_113789_3552'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1388930177178_381514_3568'/>
					<xmi:Extension extender='MagicDraw UML 18.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1388930177178_915583_3570' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Dependency' xmi:id='_16_5_4_5b501fb_1388989223805_259976_1683'>
				<client xmi:idref='_16_5_4_5b501fb_1388918821545_606008_2815'/>
