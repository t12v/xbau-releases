							</packagedElement>
							<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_5b501fb_1406633287082_790556_5450'>
								<memberEnd xmi:idref='_16_5_4_5b501fb_1406633287107_69716_5567'/>
								<memberEnd xmi:idref='_16_5_4_5b501fb_1406633287263_907421_6256'/>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287263_203522_6255' body='Die Anschrift einer Behörde. Hierbei kann es sich z.B. um den Sitz der Behörde, eine Besucher- oder Lieferanschrift handeln.'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287082_790556_5450'/>
								</ownedComment>
								<ownedEnd xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287263_907421_6256' visibility='private' type='_16_5_4_5b501fb_1406633287056_222507_5361' association='_16_5_4_5b501fb_1406633287082_790556_5450'/>
							</packagedElement>
