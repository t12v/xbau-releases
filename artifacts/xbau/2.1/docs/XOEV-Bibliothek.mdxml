	<XOEV_Profil:xoevBibliothek xmi:id='_16_5_4_5b501fb_1375345113195_985510_770application1' base_Model='_16_5_4_5b501fb_1375258090807_886576_2132' nameLang='XÖV-Bibliothek: Spezifikation der XÖV-Bausteine' nameKurz='XÖV-Bibliothek' nameTechnisch='XOEV-Bibliothek' kennung='urn:xoev-de:kosit:xoev:bibliothek:xoevbibliothek' beschreibung='Die XÖV-Bibliothek ist seit der Version 2.0 des XÖV-Handbuchs der zentrale Ort zur Verwaltung und Bereitstellung aller XÖV-spezifischer, zur Wiederverwendung vorgesehener Datentypen, Kernkomponenten und (zukünftiger) Prozessmuster, so genannter XÖV-Bausteine.' herausgebernameLang='Koordinierungsstelle für IT-Standards' herausgebernameKurz='KoSIT' externeWebsite='http://www.xoev.de/de/bibliothek' statusVerwendung='AKTUELL'/>
	<xmi:Extension extender='MagicDraw UML 18.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
	<XOEV_Profil:xoevVersionBibliothek xmi:id='_16_5_4_5b501fb_1375345113195_985510_770application2' base_Model='_16_5_4_5b501fb_1375258090807_886576_2132' version='2017-08-01' statusVerwendung='AKTUELL' lizenz='Creative Commons Namensnennung - Keine Bearbeitung 4.0 International' bezugsort='http://www.xoev.de/de/bibliothek' aenderungZurVorversion='Die Metadaten der XÖV-Datentypen, -Kernkomponenten und -Bibliothek sowie ihrer Versionen wurden im UML-Modell der XÖV-Bibliothek mittels der im XÖV-Profil dafür vorgesehenen Stereotypen dokumentiert. In diesem Rahmen wurde die Bibliothek auf das neue XÖV-Profil in der Version 1.5.0 aktualisiert. Die Metadaten zu XÖV-Datentypen, -Kernkomponenten und der Bibliothek wurden in das Spezifikationsdokument zur Bibliothek aufgenommen. Der Abschnitt &quot;Identifikation der XÖV-Kernkomponenten&quot; wurde entfernt, da eine Kernkomponente zukünftig anhand ihrer Kennung und Version identifiziert werden kann und die Namen der Eigenschaften einer Kernkomponente im Kontext der jeweiligen Kernkomponente eindeutig sind.'/>
	<xmi:Extension extender='MagicDraw UML 18.0'>
		<modelPart name='com.nomagic.magicdraw.uml_model.shared_model'/>
	</xmi:Extension>
