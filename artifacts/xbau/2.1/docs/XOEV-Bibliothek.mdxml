							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387625291296_677464_5915' name='behoerdenkennung' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1387625291099_924562_5160' association='_16_5_4_5b501fb_1387625291120_7333_5218'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291415_134141_7153' body='&lt;para&gt;Die Behördenkennung ist ein System zur eindeutigen Identifikation einer Behörde bspw. im DVDV.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291296_677464_5915'/>
								</ownedComment>
