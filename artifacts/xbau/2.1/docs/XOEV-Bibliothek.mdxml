					<xmi:Extension extender='MagicDraw UML 18.0'>
						<referenceExtension referentPath='XOEV-Bibliothek::XOEV-Kernkomponenten::1.1::fachuebergreifend::Anschrift::verwaltungspolitischeKodierung' referentType='Property'/>
