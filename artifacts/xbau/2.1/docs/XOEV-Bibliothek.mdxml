								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287199_567921_5970' name='gueltigkeit' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287063_172287_5381' association='_16_5_4_5b501fb_1406633287198_872635_5966'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287346_287629_7167' body='&lt;para&gt;Hier werden Angaben zum Zeitraum der Gültigkeit einer &quot;Registrierung&quot; gemacht.&lt;/para&gt;&#10;&#10;&lt;para&gt;Anmerkung: Bei der Gültigkeit handelt es sich um den Zeitraum zwischen dem Datum der Eintragung in ein Register und dem Datum, an dem der Eintrag aus dem Register gelöscht wurde.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287199_567921_5970'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287346_651630_7166'/>
