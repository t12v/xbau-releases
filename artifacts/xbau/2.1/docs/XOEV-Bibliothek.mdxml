								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287199_751651_5968' name='id' visibility='private' type='_16_5_4_5b501fb_1387625271095_781237_4845'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287345_106668_7159' body='&lt;para&gt;Die &quot;id&quot; gibt die Identifikationsnummer im Register an.&lt;/para&gt; &#10;&#10;&lt;para&gt;Beispiel: Handelsregisternummer&lt;/para&gt;'>
