										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287186_569212_5916' name='registrierung' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287061_546919_5374' association='_16_5_4_5b501fb_1406633287183_161413_5905'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287337_260370_7083' body='&lt;para&gt;Informationen zur autorisierenden Registrierung  einer Organisation in einem fachlichen Register.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287186_569212_5916'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287337_397770_7082'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287337_386264_7084' value='*'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287186_349418_5917' name='identifikation' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287058_953241_5367' association='_16_5_4_5b501fb_1406633287145_892863_5736'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287337_278314_7087' body='&lt;para&gt;Die &quot;identifikation&quot; einer &quot;Organisation&quot; fasst alle Elemente zusammen, die eine Organisation in einem fachlichen Kontext eindeutig unter anderen Organisationen identifiziert.&lt;/para&gt;&#10;&#10;&lt;para&gt;Anmerkung: Neben der konkreten ID wird der fachliche Typ der ID  wie z.B. Steuernummer,  UmsatzsteuerID festgelegt.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287186_349418_5917'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287337_73321_7086'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287337_149126_7088' value='*'/>
								</ownedAttribute>
							</packagedElement>
