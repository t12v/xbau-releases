								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287093_214728_5497' name='grund' visibility='private' type='_16_5_4_5b501fb_1387625280047_322339_5028'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287281_135142_6360' body='&lt;para&gt;Der Grund gibt die Rechtsgrundlage an, aufgrund derer die Auskunftssperre besteht und aus der sich die Konsequenzen für die Zulässigkeit von Auskünften und Datenübermittlungen eindeutig ableiten.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287093_214728_5497'/>
									</ownedComment>
