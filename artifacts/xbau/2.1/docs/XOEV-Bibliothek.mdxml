							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387625291303_209425_5941' name='ehename' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1387625291106_385217_5169' association='_16_5_4_5b501fb_1387625291119_32073_5210'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291425_121559_7226' body='&lt;para&gt;Der Ehename ist der von beiden Ehegatten durch Erklärung bestimmte gemeinsame Familienname der Ehegatten. Zum Ehenamen kann der Geburtsname eines der Ehegatten oder der zur Zeit der Erklärung von einem Ehegatten geführte Name bestimmt werden.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291303_209425_5941'/>
								</ownedComment>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1387625291425_613503_7225'/>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1387625291425_478003_7227' value='1'/>
									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387625291303_622764_5942' name='familienname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1387625291106_385217_5169' association='_16_5_4_5b501fb_1387625291120_932766_5216'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291425_176285_7230' body='&lt;para&gt;Der Familienname ist der aktuelle Nachname einer Person und Ausdruck einer bestimmten Familienzugehörigkeit dieser Person.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291303_622764_5942'/>
								</ownedComment>
