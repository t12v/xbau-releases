							<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1406633287062_833099_5377' name='Staat'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287220_240010_6049' body='&lt;para&gt;Als Staat bezeichnet man eine politische Ordnung, die ein gemeinsames als Staatsgebiet abgegrenztes Territorium, ein dazugehöriges Staatsvolk und eine Machtausübung über dieses umfasst.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287062_833099_5377'/>
								</ownedComment>
