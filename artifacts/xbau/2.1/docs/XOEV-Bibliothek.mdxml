								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287139_797638_5711' name='geschlecht' visibility='private' type='_16_5_4_5b501fb_1387625280047_322339_5028'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287307_332814_6685' body='&lt;para&gt;Das &quot;geschlecht&quot; bezeichnet das biologische Geschlecht eines Lebewesens.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287139_797638_5711'/>
									</ownedComment>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287307_908418_6684' value='1'/>
										</modelExtension>
									</xmi:Extension>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287307_348418_6686' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287139_56161_5712' name='gueltigkeit' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287063_172287_5381' association='_16_5_4_5b501fb_1406633287139_189015_5708'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287307_571423_6689' body='&lt;para&gt;Die &quot;gueltigkeit&quot; gibt mit  Beginn- und/oder Endzeitpunkt den Zeitraum an, in dem ein Lebewesen ein bestimmtes Geschlecht hat.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287139_56161_5712'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287307_44573_6688'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
