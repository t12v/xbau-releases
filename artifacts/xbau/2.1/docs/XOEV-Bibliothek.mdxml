							<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1406633287060_530611_5371' name='NatuerlichePerson'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287176_467700_5881' body='&lt;para&gt;Eine natürliche Person ist der Mensch in seiner Rolle als Rechtssubjekt, d. h. als Träger von Rechten und Pflichten. &#10;Mit der Vollendung seiner Geburt wird ein Mensch rechtsfähig und damit zu einer natürlichen Person (§ 1 BGB). Der Mensch verliert seine Rechtsfähigkeit mit dem Tod.&lt;/para&gt; &#10;&#10;&lt;para&gt;Rechtssubjekte, die keine natürlichen Personen sind, nennt man juristische Personen.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287060_530611_5371'/>
								</ownedComment>
								<xmi:Extension extender='MagicDraw UML 18.0'>
									<modelExtension>
										<ownedDiagram xmi:type='uml:Diagram' xmi:id='_16_5_4_5b501fb_1406633287176_388879_5882' name='Natürliche Person' visibility='public' ownerOfDiagram='_16_5_4_5b501fb_1406633287060_530611_5371'>
											<xmi:Extension extender='MagicDraw UML 18.0'>
												<diagramRepresentation>
