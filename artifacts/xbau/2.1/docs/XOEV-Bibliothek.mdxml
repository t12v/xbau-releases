								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291341_920274_6377' body='&lt;para&gt;Hier werden Angaben zum Zeitraum gemacht, in dem eine natürliche Person einer Religionsgemeinschaft angehört.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625291171_567642_5432'/>
								</ownedComment>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1387625291341_71396_6376'/>
								<xmi:Extension extender='MagicDraw UML 18.0'>
