								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287199_739678_5969' name='registrierendeBehoerde' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287056_222507_5361' association='_16_5_4_5b501fb_1406633287106_999345_5560'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287346_996575_7163' body='&lt;para&gt;Angaben zur Behörde, die das Register führt.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiel: Amtsgericht&lt;/para&gt;'>
