									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287346_777237_7171' body='&lt;para&gt;Der &quot;registertyp&quot; gibt an, um welche Art von Register es sich handelt.&lt;/para&gt; &#10;&#10;&lt;para&gt;Beispiele: Handelsregister, Vereinsregister&lt;/para&gt;'>
