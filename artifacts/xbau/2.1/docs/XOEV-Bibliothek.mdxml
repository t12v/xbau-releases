								</xmi:Extension>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287120_782512_5625' name='familienstand' visibility='private' type='_16_5_4_5b501fb_1387625280047_322339_5028'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287298_348583_6580' body='&lt;para&gt;Der Familienstand einer Person gibt im Personenstandswesen an, ob diese ledig, verheiratet, geschieden oder verwitwet ist, oder eine entsprechende Rechtsstellung bezüglich einer Lebenspartnerschaft besteht.&lt;/para&gt; '>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287120_782512_5625'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287298_230119_6579'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287298_614144_6581' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287120_135183_5626' name='gueltigkeit' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287063_172287_5381' association='_16_5_4_5b501fb_1406633287120_482617_5623'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287299_387534_6584' body='&lt;para&gt;Angaben zum Zeitraum, in welchem der Familienstand einer natürlichen Person gültig ist.&lt;/para&gt;&#10;&#10;&lt;para&gt;Anmerkung: Die Gültigkeit einer Ehe umfasst den Zeitraum zwischen dem Datum der Eheschließung bis Beendigung der Ehe.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287120_135183_5626'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287299_577494_6583'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287299_498208_6585' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287120_854304_5627' name='zusatz' visibility='private' type='_16_5_4_5b501fb_1387625271095_781237_4845'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287299_243647_6588' body='&lt;para&gt;Als &quot;zusatz&quot; werden interpersonelle Beziehungen erfasst, die für das Aussageverweigerungsrecht relevant sind.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiele: getrennt lebend, verlobt&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287120_854304_5627'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287299_950666_6587'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287299_246601_6589' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287121_895872_5628' name='grund' visibility='private' type='_16_5_4_5b501fb_1387625280047_322339_5028'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287299_325204_6592' body='&lt;para&gt;Gibt den rechtlichen Grund der Beendigung oder Nichtigkeit der letzten Ehe oder Lebenspartnerschaft an.&lt;/para&gt;&#10;&#10;&lt;para&gt;Anmerkung: Codeliste DSMeld Blatt 1405&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287121_895872_5628'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287299_314653_6591'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287299_572659_6593' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287121_410770_5629' name='behoerde' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287056_222507_5361' association='_16_5_4_5b501fb_1406633287106_623203_5559'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287299_975915_6596' body='&lt;para&gt;Behörde, die den Familienstand amtlich gemacht hat.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287121_410770_5629'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287299_323857_6595'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287299_194686_6597' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
							</packagedElement>
							<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1406633287057_833083_5364' name='Geburt'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287127_186943_5657' body='&lt;para&gt;Unter &quot;Geburt&quot; werden geburtsbezogene Informationen zusammengefasst.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287057_833083_5364'/>
								</ownedComment>
