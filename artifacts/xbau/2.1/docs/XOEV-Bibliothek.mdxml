								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287156_696547_5795' name='ehename' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287064_279903_5386'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287313_744228_6770' body='&lt;para&gt;Der Ehename ist der von beiden Ehegatten durch Erklärung bestimmte gemeinsame Familienname der Ehegatten. Zum Ehenamen kann der Geburtsname eines der Ehegatten oder der zur Zeit der Erklärung von einem Ehegatten geführte Name bestimmt werden.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287156_696547_5795'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_714542_6769'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_409694_6771' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287157_266241_5796' name='familienname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287065_138977_5391'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287313_76689_6774' body='&lt;para&gt;Der Familienname ist der aktuelle Nachname einer Person und Ausdruck einer bestimmten Familienzugehörigkeit dieser Person.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287157_266241_5796'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_240957_6773'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_41941_6775' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287157_758880_5797' name='lebenspartnerschaftsname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287064_266930_5384'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287313_730328_6778' body='&lt;para&gt;Der Lebenspartnerschaftsname ist der von beiden Lebenspartnern durch Erklärung bestimmte gemeinsame Name der Lebenspartner. Zum Lebenspartnerschaftsnamen kann der Geburtsname eines der Lebenspartner oder der zur Zeit der Erklärung von einem Lebenspartner geführte Name bestimmt werden.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287157_758880_5797'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_684069_6777'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_759741_6779' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287157_167211_5798' name='geburtsname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287064_845471_5389'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287313_97346_6782' body='&lt;para&gt;Der Geburtsname ist der Nachname einer Person, der sich jeweils aus dem Geburtseintrag für diese Person ergibt. Der Geburtsname ist i.d.R. der Nachname, der vor der ersten Eheschließung oder Lebenspartnerschaft geführt wurde.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287157_167211_5798'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_874866_6781'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_480715_6783' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287158_624278_5799' name='fruehererFamilienname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287064_937712_5385'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287313_750972_6786' body='&lt;para&gt;Der frühere Familienname ist der Nachname, den eine Person vor einer Nachnamensänderung geführt hat.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287158_624278_5799'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_777560_6785'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287313_308578_6787' value='*'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287158_560_5800' name='vorname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287064_936049_5387'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287313_421688_6790' body='&lt;para&gt;Der Vorname ist der Name bzw. der Teil des Namens, der nicht die Zugehörigkeit zu einer Familie ausdrückt, sondern das Individuum innerhalb der Familie bezeichnet und dazu dient, es von anderen Familienmitgliedern zu unterscheiden.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287158_560_5800'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_901707_6789'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287313_344824_6791' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287158_865157_5801' name='rufname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287064_166562_5388'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287314_311325_6794' body='&lt;para&gt;Der Rufname ist der im alltäglichen Gebrauch zu nutzende Vorname.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287158_865157_5801'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287314_846906_6793'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287314_961143_6795' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287158_144822_5802' name='fruehererVorname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287065_828349_5393'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287314_598114_6798' body='&lt;para&gt;Der frühere Vorname ist der Vorname, der vor einer Vornamensänderung geführt wurde.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287158_144822_5802'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287314_257705_6797'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287314_931750_6799' value='*'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287159_535018_5803' name='titel' visibility='private' type='_16_5_4_5b501fb_1387625271095_781237_4845'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287314_150767_6802' body='&lt;para&gt;Ein Titel wird häufig im Zusammenhang mit Namen verwendet, ist aber  kein orginärer Bestandteil des Namens. Im Unterschied dazu gehören Adelstitel zum Familiennamen und sind daher in diesem Verständnis kein Titel. Zu den Titeln zählen beispielsweise akademische Grade, Dienst- und Amtsbezeichnungen oder militärische Ränge. Es können auch Titel übermittelt werden, die keine Titel im Sinne des Meldewesens sind.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiel: Dr.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287159_535018_5803'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287314_529797_6801'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287314_653959_6803' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287159_153097_5804' name='anrede' visibility='private' type='_16_5_4_5b501fb_1387625271095_781237_4845'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287314_665986_6806' body='&lt;para&gt;Die Anrede ist der Namenszusatz (auch eine Anrede ohne Namen nur mit Titel ist eine Anrede!) bei der Anrede (mündlich oder schriftlich) oder bei einem Anruf (fernmündlich) an eine Person oder Personengruppe.&lt;/para&gt;&#10;&#10;&lt;para&gt;Anmerkung: Die komplette Anrede einer Person kann in einem Feld übermittelt werden.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiel: Herr, Frau, Herr Staatssekretär, Frau Bundeskanzlerin, Herr Botschafter, Eure Eminenz&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287159_153097_5804'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287314_453345_6805'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287314_795619_6807' value='*'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287159_936116_5805' name='namenssuffix' visibility='private' type='_16_5_4_5b501fb_1387625271095_781237_4845'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287314_671319_6810' body='&lt;para&gt;Ein Namenssuffix ist ein Zusatz zu einem Namen, der ohne Komma hinter den Familiennamen gestellt wird. Als Namenssuffix können beispielsweise  akademische Grade oder Dienst- und Funktionsbezeichnungen übermittelt werden. Adelstitel sind Bestandteil des Familiennamens und zählen nicht zu den zulässigen Namenssuffixen.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiele: a.d., MdB, M.A.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287159_936116_5805'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287314_605221_6809'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287314_99699_6811' value='*'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287159_564542_5806' name='alternativeRepraesentation' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287055_372997_5357' association='_16_5_4_5b501fb_1406633287076_675085_5421'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287314_94088_6814' body='&lt;para&gt;Die Komponente &quot;alternativeRepraesentation&quot; beinhaltet den Namen einer natürlichen Person in einer Form, die einer festgelegten Konvention folgt. Die in der Komponente  &quot;AlternativeRepraesentation&quot; übermittelten Informationen müssen redundant zu den anderen Elementen der Komponente &quot;NameNatuerlichePerson&quot; sein, sie dürfen diese nicht ersetzen.&lt;/para&gt;&#10;&#10;&lt;para&gt;Anmerkung: Im Zusammenhang mit ausländischen Namen kann diese Komponente z.B. genutzt werden, um die gesamte Namenskette einzutragen oder den Namen in Originalschreibweise zu übermitteln.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiel: Ein Beispiel für alternative Repräsentation ist die Übermittlung des Namens &quot;Andrè Müller&quot; nach ICAO-Standard, in dem keine Umlaute erlaubt sind, und daher der Name als &quot;ANDRE MUELLER&quot; übertragen wird.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287159_564542_5806'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287314_709181_6813'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287315_749114_6815' value='*'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287160_283785_5807' name='ordensname' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287065_717326_5390'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287315_387119_6818' body='&lt;para&gt;Ein Ordensname ist ein Name, der als Pseudonym von einer Ordensperson geführt wird.&lt;/para&gt;&#10;&#10;&lt;para&gt;Es sind nur solche Ordensnamen anzugeben, die in den Personalausweis oder Pass eingetragen werden dürfen.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiele: Bruder Jakob, &#10;Mutter Teresa&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287160_283785_5807'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287315_371498_6817'/>
									<xmi:Extension extender='MagicDraw UML 18.0'>
										<modelExtension>
											<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287315_648993_6819' value='1'/>
										</modelExtension>
									</xmi:Extension>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287160_833805_5808' name='kuenstlername' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287065_539231_5392'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287315_523350_6822' body='&lt;para&gt;Ein Künstlername ist ein Name, der als Pseudonym von einem Künstler geführt wird.&lt;/para&gt; &#10;&#10;&lt;para&gt;Es sind nur solche Künstlernamen anzugeben, die in den Personalausweis oder Pass eingetragen werden dürfen.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiel: Sting, Madonna&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287160_833805_5808'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287315_569248_6821'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287315_218970_6823' value='*'/>
								</ownedAttribute>
								<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406633287160_58486_5809' name='weitererName' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1406633287054_71998_5356' association='_16_5_4_5b501fb_1406633287064_912439_5383'>
									<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287315_523864_6826' body='&lt;para&gt;Ein weiterer Name ist ein Name, der nicht Bestandteil des Vor- oder Nachnamens einer Person und weder Künstlername noch Ordensname ist.&lt;/para&gt;'>
										<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287160_58486_5809'/>
									</ownedComment>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1406633287315_19489_6825'/>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1406633287315_804640_6827' value='*'/>
								</ownedAttribute>
							</packagedElement>
							<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_5b501fb_1406633287059_189238_5370' name='NameOrganisation'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1406633287167_158632_5838' body='&lt;para&gt;&quot;NameOrganisation&quot; fasst die Angaben zum Namen einer Organisation zusammen.&lt;/para&gt; '>
									<annotatedElement xmi:idref='_16_5_4_5b501fb_1406633287059_189238_5370'/>
								</ownedComment>
