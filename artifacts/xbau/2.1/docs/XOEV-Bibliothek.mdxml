											<binaryObject streamContentID='BINARY-c8867d4f-2fe5-4841-90f1-8c44389032ba' xmi:id='_dEzgYnIeEee1ROQDxu8Lbw' xsi:type='binary:StreamIdentityBinaryObject'/>
											<usedObjects href='PROJECT-d936a7e33032315b91e413bd183a836?resource=com.nomagic.magicdraw.uml_umodel.shared_umodel#_16_5_4_5b501fb_1387625291107_242212_5170'/>
											<usedObjects href='#_16_5_4_5b501fb_1388917956343_874992_1575'/>
											<usedObjects href='PROJECT-d936a7e33032315b91e413bd183a836?resource=com.nomagic.magicdraw.uml_umodel.shared_umodel#_16_5_4_5b501fb_1387625291104_134064_5166'/>
