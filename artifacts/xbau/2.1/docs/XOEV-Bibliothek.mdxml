						<packagedElement xmi:type='uml:Association' xmi:id='_16_5_4_5b501fb_1387625291120_610736_5219'>
							<memberEnd xmi:idref='_16_5_4_5b501fb_1387625291304_506286_5946'/>
							<memberEnd xmi:idref='_16_5_4_5b501fb_1387625291319_12886_6091'/>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387625291319_251390_6090' body='Der Vorname ist der Name bzw. der Teil des Namens, der nicht die Zugehörigkeit zu einer Familie ausdrückt, sondern das Individuum innerhalb der Familie bezeichnet und dazu dient, es von anderen Familienmitgliedern zu unterscheiden. '>
