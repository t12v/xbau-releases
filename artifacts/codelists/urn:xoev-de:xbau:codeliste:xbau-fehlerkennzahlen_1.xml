<?xml version="1.0" encoding="UTF-8"?>
<gc:CodeList xmlns:gc="http://docs.oasis-open.org/codelist/ns/genericode/1.0/" xmlns:xoev-cl="http://xoev.de/schemata/genericode/1_0" xmlns:xoev-cl-2="http://xoev.de/schemata/genericode/2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <Annotation>
    <Description>
      <!--Metadaten entsprechend XÖV-Handbuch 2.0-->
      <xoev-cl:beschreibung>Codeliste der Fehlerkennzahlen für die Klassifikation von Fehlern, die in XBau-Nachrichteninstanzen angetroffen werden. Die Einträge bestehen aus Fehlerkennzahl und der Angabe deren Bedeutung. Gruppen von Codes: X - formales Problem mit XML oder mit (Inhalten von) Schlüsseltabellen, V - Versionsproblem, S - nicht spezifikationskonform, A - Problem mit Anlagen zur empfangenen Nachricht.</xoev-cl:beschreibung>
      <xoev-cl:datumgueltigkeitab>2019-01-01</xoev-cl:datumgueltigkeitab>
      <!--Metadaten entsprechend XÖV-Handbuch 2.1-->
      <xoev-cl-2:nameKurz>XBau Fehlerkennzahlen</xoev-cl-2:nameKurz>
      <xoev-cl-2:beschreibung-codeliste>Codeliste der Fehlerkennzahlen für die Klassifikation von Fehlern, die in XBau-Nachrichteninstanzen angetroffen werden. Die Einträge bestehen aus Fehlerkennzahl und der Angabe deren Bedeutung. Gruppen von Codes: X - formales Problem mit XML oder mit (Inhalten von) Schlüsseltabellen, V - Versionsproblem, S - nicht spezifikationskonform, A - Problem mit Anlagen zur empfangenen Nachricht.</xoev-cl-2:beschreibung-codeliste>
      <xoev-cl-2:herausgebernameKurz>BMK</xoev-cl-2:herausgebernameKurz>
      <xoev-cl-2:beschreibung-versionCodeliste>Diese Version besteht aus einer ersten Zusammenstellung von Fehlern, die in der Praxis angetroffen werden.</xoev-cl-2:beschreibung-versionCodeliste>
      <xoev-cl-2:datumGueltigkeitAb>2019-01-01</xoev-cl-2:datumGueltigkeitAb>
      <xoev-cl-2:versionXOEVHandbuch>2.1</xoev-cl-2:versionXOEVHandbuch>
    </Description>
  </Annotation>
  <Identification>
    <ShortName>xbau-fehlerkennzahlen</ShortName>
    <LongName>XBau Fehlerkennzahlen</LongName>
    <Version>1</Version>
