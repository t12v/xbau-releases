    <packagedElement xmi:type="uml:Package" xmi:id="_12_0_8f90291_1163703146375_8469_2064" name="XML Schema constraints" URI="">
      <ownedRule xmi:id="_12_0_8f90291_1163575123937_950942_1219" name="Not XML Schema Types for XSDattribute" constrainedElement="magicdraw_1046682040730_843189_181">
        <ownedComment xmi:id="_12_0_8f90291_1163575454812_25968_1228" annotatedElement="_12_0_8f90291_1163575123937_950942_1219" body="XML Schema – specific types, not simple UML types should be used."/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163575353828_963914_1220" name="">
          <language>OCL2.0</language>
          <body>(not type.oclIsUndefined()) implies (type.oclIsKindOf(XSDsimpleType) or type.oclIsKindOf(XSDcomplexType) or (type.oclIsKindOf(XSDcomponent) and type.name='anyType'))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163575564875_903163_1229" name="Not XML Schema Types for XSDelement" constrainedElement="magicdraw_1046682074970_241068_216">
        <ownedComment xmi:id="_12_0_8f90291_1163575564875_184456_1231" annotatedElement="_12_0_8f90291_1163575564875_903163_1229" body="XML Schema – specific types, not simple UML types should be used."/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163575564875_842586_1230" name="">
          <language>OCL2.0</language>
          <body>(not type.oclIsUndefined()) implies type.oclIsKindOf(XSDsimpleType) or type.oclIsKindOf(XSDcomplexType) or (type.oclIsKindOf(XSDcomponent) and name='anyType')</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163578065437_960718_1249" name="No xsdattribute in xsdsimpletype" constrainedElement="magicdraw_1046682040730_843189_181">
        <ownedComment xmi:id="_12_0_8f90291_1163578065437_986038_1251" annotatedElement="_12_0_8f90291_1163578065437_960718_1249" body="No XSDAttributes in XSDSimpleTypes"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163578065437_66190_1250" name="">
          <language>OCL2.0</language>
          <body>not owner.appliedStereotypeInstance.oclIsUndefined() and
owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') ->size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163576703203_207632_1239" name="No xsdelement in xsdsimpletype" constrainedElement="magicdraw_1046682074970_241068_216">
        <ownedComment xmi:id="_12_0_8f90291_1163577439390_112336_1248" annotatedElement="_12_0_8f90291_1163576703203_207632_1239" body="No XSDElements in XSDSimpleTypes"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163576860328_549439_1240" name="">
          <language>OCL2.0</language>
          <body>not owner.appliedStereotypeInstance.oclIsUndefined() and
owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') -> size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163579728187_658670_1301" name="xsdattribute in xsdsimplecontent" constrainedElement="magicdraw_1046682040730_843189_181">
        <ownedComment xmi:id="_12_0_8f90291_1163579728187_686842_1303" annotatedElement="_12_0_8f90291_1163579728187_658670_1301" body="No XSDAttributes in XSDsimpleContent"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163579728187_69197_1302" name="">
          <language>OCL2.0</language>
          <body>not owner.appliedStereotypeInstance.oclIsUndefined() and owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleContent') ->asSet()->size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163578227171_428030_1260" name="Simple Type Derived by Extension" constrainedElement="magicdraw_1046684263597_121702_458">
        <ownedComment xmi:id="_12_0_8f90291_1163578556218_779910_1269" annotatedElement="_12_0_8f90291_1163578227171_428030_1260" body="SimpleType can not be derived by extension"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163578287609_871345_1261" name="">
          <language>OCL2.0</language>
          <body>not specific.appliedStereotypeInstance.oclIsUndefined() and specific.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') ->size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163579507359_662856_1290" name="xsdattributegroup on Simpletype or Complextype" constrainedElement="magicdraw_1046684505444_590497_493">
        <ownedComment xmi:id="_12_0_8f90291_1163579507359_147186_1292" annotatedElement="_12_0_8f90291_1163579507359_662856_1290" body="XSDattributeGroup stereotype can not be placed on simpletype, complextype, it is used as standalone"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163579507359_398587_1291" name="">
          <language>OCL2.0</language>
          <body>not appliedStereotypeInstance.oclIsUndefined() and
appliedStereotypeInstance.classifier->select (name='XSDsimpleType' or name='XSDcomplexType') ->size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163578725265_389339_1270" name="xsdgroup on Simpletype or Complextype" constrainedElement="magicdraw_1046683708328_985822_255">
        <ownedComment xmi:id="_12_0_8f90291_1163579433906_146810_1289" annotatedElement="_12_0_8f90291_1163578725265_389339_1270" body="XSDgroup stereotype can not be placed on simpletype, complextype, it is used as standalone"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163578757406_908200_1271" name="">
          <language>OCL2.0</language>
          <body>not appliedStereotypeInstance.oclIsUndefined() and
appliedStereotypeInstance.classifier->select (name='XSDsimpleType' or name='XSDcomplexType') ->size()=0</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163574251343_528213_1076" name="No targetNamespace on Schema" constrainedElement="magicdraw_1046691534852_460080_805">
        <ownedComment xmi:id="_12_0_8f90291_1163574515796_398242_1085" annotatedElement="_12_0_8f90291_1163574251343_528213_1076" body="targetNamespace tag should be defined on schema element"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163574392828_587326_1080" name="">
          <language>OCL2.0</language>
          <body>not targetNamespace.oclIsUndefined()</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163528180656_366939_778" name="No Link to Namespace" constrainedElement="magicdraw_1046691534852_460080_805">
        <ownedComment xmi:id="_12_0_8f90291_1163574208890_231056_1075" annotatedElement="_12_0_8f90291_1163528180656_366939_778" body="Properties should not use the primitive types from UML standard profile, should use corresponding classes from XML schema profile"/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163528263890_148581_779" name="">
          <language>OCL2.0</language>
          <body>let owners : Set(UML2_Metamodel::ElementImport)=ownedElement->select(oclIsKindOf(xmlns))->collect(oclAsType(UML2_Metamodel
::ElementImport))->asSet() in owners.importedElement.name -> exists (n|n='http://www.w3.org/2001/XMLSchema')</body>
        </specification>
      </ownedRule>
    </packagedElement>
