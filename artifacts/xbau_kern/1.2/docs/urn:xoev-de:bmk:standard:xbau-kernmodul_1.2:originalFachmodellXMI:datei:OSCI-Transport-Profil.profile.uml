    <ownedAttribute xmi:id="_16_5_4_5b501fb_1287395686258_528623_346" name="Leistungserbringer" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1287396077285_450575_620" annotatedElement="_16_5_4_5b501fb_1287395686258_528623_346" body="Mit dieser Eigenschaft kann der Leistungserbringer bezüglich des ausgewählten Dienstes angegeben werden. Diese Information wird momentan in der Übersichtstabelle zu den Diensten genutzt."/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1287395782554_408332_613" name=""/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1287395782577_288791_614" name="" value="1"/>
    </ownedAttribute>
    <ownedAttribute xmi:id="_16_5_4_5b501fb_1287395712310_824936_347" name="Hinweis" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1287396142749_717251_621" annotatedElement="_16_5_4_5b501fb_1287395712310_824936_347" body="Mit dieser Eigenschaft können Hinweise zur produktiven Nutzung des Dienstes (z.B. bzgl. DVDV) gegeben werden. Sie werden momentan in der Übersichtstabelle zu den Diensten aufgeführt."/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1287395844802_419781_615" name=""/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1287395844802_356062_616" name="" value="1"/>
    </ownedAttribute>
    <ownedAttribute xmi:id="_16_5_4_5b501fb_1287395972027_726252_617" name="Nachrichtenbeschreibung" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1287396454388_485124_622" annotatedElement="_16_5_4_5b501fb_1287395972027_726252_617" body="In der Übersichtstabelle zu den Diensten werden in der Spalte &quot;Nachrichten&quot; alle Nachrichten des Dienstes aufgeführt (Nachrichtennummern). Häufig macht ein ergänzender Kommentar zu den Nummern Sinn. Dieser kann mit der Eigenschaft &quot;NachrichtenBeschreibung&quot; vorgenommen werden.&#xA;&#xA;Falls die genannte Liste von Nachrichtennummern nicht herausgeschrieben werden soll, muss zu Beginn des Eintrags &quot;[nl]&quot; (no list) stehen. Darauf können beliebige Inhalte folgen."/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1287396004877_208102_618" name=""/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1287396004877_249935_619" name="" value="1"/>
    </ownedAttribute>
    <ownedAttribute xmi:id="_16_5_4_5b501fb_1445441254453_81289_2986" name="NamensraumOhneDateiname" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1445441338427_848998_2990" annotatedElement="_16_5_4_5b501fb_1445441254453_81289_2986" body="Mit dieser Eigenschaft kann der Namensraumbestandteil des WSDL-Dokuments bestimmt werden, welcher zusammen mit dem Namen der WSDL-Datei den vollständigen Namensraum bildet.&#xA;&#xA;Wird diese Eigenschaft nicht befüllt, wird der Namensraum nach einem festen Muster (aus Projektnamensraum, Projektpräfix, Projektversion und Dienstname) gebildet."/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1445441271730_827301_2988" name=""/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1445441271730_178532_2989" name="" value="1"/>
    </ownedAttribute>
    <ownedAttribute xmi:id="_16_5_4_5b501fb_1445441855243_435466_2991" name="Dateiname" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1445441941117_954035_2995" annotatedElement="_16_5_4_5b501fb_1445441855243_435466_2991" body="Mit dieser Eigenschaft kann der Name der WSDL-Datei festgelegt werden. &#xA;&#xA;Ist diese Eigenschaft nicht befüllt, wird der Name nach einem festen Muster gebildet."/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_5b501fb_1445441865772_111674_2993" name=""/>
      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_5b501fb_1445441865772_35089_2994" name="" value="1"/>
    </ownedAttribute>
    <ownedAttribute xmi:id="_16_5_4_5b501fb_1445444013716_428920_3761" name="SubjectOperation" visibility="private">
      <ownedComment xmi:id="_16_5_4_5b501fb_1445444119498_190928_3763" annotatedElement="_16_5_4_5b501fb_1445444013716_428920_3761" body="Mit dieser Eigenschaft kann der Wert des Attributs &quot;subject&quot; der WSDL-Operation bestimmt werden. &#xA;&#xA;Wird diese Eigenschaft nicht befüllt, wird der Wert des Attributs einem festen Muster folgend gebildet."/>
      <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
