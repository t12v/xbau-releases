                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291316_24883_6033" annotatedElement="_16_5_4_5b501fb_1387625291119_100186_5200" body="Die &quot;behoerdenidentifikation&quot; fasst alle Elemente zusammen, die eine Behörde eindeutig unter anderen Behörden identifiziert. &#xA;&#xA;"/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291317_153150_6034" name="" visibility="private" type="_16_5_4_5b501fb_1387625291115_477657_5180" association="_16_5_4_5b501fb_1387625291119_100186_5200"/>
              </packagedElement>
