  <XOEVProfil:xoevABIE xmi:id="_VFgSV5ZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1380019686134_103237_1614"/>
  <XOEVProfil:xoevABIE xmi:id="_VFgSWJZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1380019783198_447885_1675" MotivationDerAbweichung="Das zusätzliche Kindelement ist erforderlich, um Hausnummernbereich übermitteln zu können."/>
  <XOEVProfil:xoevABIE xmi:id="_VFgSWZZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1ccb0481_1425468921949_760319_2133"/>
  <XOEVProfil:xoevABIE xmi:id="_VFg5UJZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1380019660674_995526_1587" MotivationDerAbweichung="Im Interesse der Wiederverwendung der Meldeanschrift wurde die postalische Inlandsanschrift als Choice zwischen Gebäude- und Postfachanschriften modelliert."/>
  <XOEVProfil:xoevABIE xmi:id="_VFg5UZZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1364313776811_220119_9414"/>
  <XOEVProfil:xoevABIE xmi:id="_VFg5UpZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1364313732581_658593_9386"/>
  <XOEVProfil:xoevABIE xmi:id="_VFg5U5ZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1364382738190_314891_1582"/>
  <XOEVProfil:xoevABIE xmi:id="_VFg5VJZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1364313722451_850604_9366"/>
  <XOEVProfil:xoevABIE xmi:id="_VFg5VZZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1351595172450_828165_1636" Abweichung="Die Auslandsanschrift aus XInneres enthält das Druckbild einer Auslandsanschrift in unstrukturierter Form." MotivationDerAbweichung="Für die Übermittlung von  ausländischen Anschriften ist der strukturierte Ansatz der Kernkomponente nicht geeignet. Aus diesem Grund wurde in XInneres ein Datentyp für ausländische Anschriften konzipiert, der sich an dem Druckbild einer Anschrift und der entsprechenden DIN-Norm orientiert. "/>
  <XOEVProfil:xoevABIE xmi:id="_VFg5VpZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_1eeb04c1_1347641474771_173159_1510"/>
  <XOEVProfil:xoevABIE xmi:id="_VFg5V5ZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_b7102e0_1292420010055_54472_505" MotivationDerAbweichung="Die Klasse heißt Meldeanschrift und nicht Anschrift, weil sie zur Übermittlung von Anschriften vorgesehen ist, an denen Personen in der Meldebehörde gemeldet sein können."/>
