          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1386161210447_393163_1615" name="weiterleitung.weiterleitung.0030">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1386163985094_253348_2035" annotatedElement="_16_5_4_1eeb04c1_1386161210447_393163_1615" body="&lt;para>Mit dieser Nachricht leitet eine nicht (mehr) zuständige Stelle eine Nachricht an die aus ihrer Sicht aktuell zuständige Stelle weiter.&lt;/para>&#xA;"/>
