              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1431428181518_308623_3226" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1431428181518_633421_3227" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1431428181560_304677_3228" name="unbekannt" visibility="private" isReadOnly="true">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1431429930940_695892_3269" annotatedElement="_16_5_4_1eeb04c1_1431428181560_304677_3228" body="&lt;para>Das Merkmal mit dem angezeigt wird, dass das Datum unbekannt ist.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1431428197219_160953_3230" name="" value="1"/>
