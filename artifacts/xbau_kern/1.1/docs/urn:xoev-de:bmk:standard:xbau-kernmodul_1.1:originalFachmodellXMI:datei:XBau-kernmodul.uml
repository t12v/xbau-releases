              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1592078037646_653892_14451" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1422888807308_342425_3010" clientDependency="_16_5_4_8ae0277_1427196979970_783012_8890" name="Staat">
            <ownedComment xmi:id="_16_5_4_940029b_1422888807323_361464_3013" annotatedElement="_16_5_4_940029b_1422888807308_342425_3010" body="&lt;para>Als Staat bezeichnet man eine politische Ordnung, die ein gemeinsames als Staatsgebiet abgegrenztes Territorium, ein dazugehöriges Staatsvolk und eine Machtausübung über dieses umfasst.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1422888807323_584813_3012" name="staat" visibility="private" type="_16_5_4_8a30247_1423043972175_271232_6283">
              <ownedComment xmi:id="_16_5_4_940029b_1422888807386_708822_3048" annotatedElement="_16_5_4_940029b_1422888807323_584813_3012" body="&lt;para>Dieses verwendet einen Schlüssel zur Identifikation eines Staates.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1422888807386_664297_3047" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1422888807386_299198_3049" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1566914340130_207583_14410" name="VerwaltungspolitischeKodierung">
            <ownedComment xmi:id="_18_0_2_940029b_1566914340645_533141_14443" annotatedElement="_18_0_2_940029b_1566914340130_207583_14410" body="&lt;para>Dieser Typ beinhaltet Daten, die die eindeutige Zuordnung (z.B. eines Grundstücks) innerhalb der Gemeindegliederung der Länder ermöglichen.&lt;/para> "/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1566914340645_563300_14446" name="bundesland" visibility="private" type="_16_5_4_8a30247_1423044461203_939066_6394">
              <ownedComment xmi:id="_18_0_2_940029b_1566914340645_572523_14461" annotatedElement="_18_0_2_940029b_1566914340645_563300_14446" body="&lt;para>In dieses Element ist das Bundesland einzutragen.&lt;/para>&#xA;&#xA;&#xA;"/>
