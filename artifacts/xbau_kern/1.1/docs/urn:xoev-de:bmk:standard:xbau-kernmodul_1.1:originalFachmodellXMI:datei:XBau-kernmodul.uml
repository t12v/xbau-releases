              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977828419_252084_7451" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460622920874_103982_4471" name="natuerlichePerson" visibility="private" type="_16_5_4_940029b_1460619307903_831925_3517" aggregation="composite" association="_16_5_4_940029b_1460622920874_846896_4469">
              <ownedComment xmi:id="_16_5_4_940029b_1460622920874_478403_4474" annotatedElement="_16_5_4_940029b_1460622920874_103982_4471" body="&lt;para>In dieses Element sind die Angaben zu der natürlichen Person einzutragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460622920874_265752_4473" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460622920874_805149_4475" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460619307903_831925_3517" clientDependency="_18_0_2_940029b_1513951637567_197418_9729" name="AmBauBeteiligtePerson">
            <ownedComment xmi:id="_16_5_4_940029b_1460619307918_202040_3525" annotatedElement="_16_5_4_940029b_1460619307903_831925_3517" body="&lt;para>Dieser Typ fasst die Merkmale zusammen, die typischerweise zu am Bau beteiligten natürlichen Personen genannt werden bzw. zu nennen sind. &lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460619307918_202687_3519" clientDependency="_18_0_2_940029b_1552467670464_818516_14343" name="name" visibility="private" type="_16_5_4_8a30247_1422955073653_603895_5103">
              <ownedComment xmi:id="_16_5_4_940029b_1460619307918_517815_3528" annotatedElement="_16_5_4_940029b_1460619307918_202687_3519" body="&lt;para>In dieses Element sind die Angaben zu den Namen der Person einzutragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621351010_776728_4051" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621351010_693379_4052" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460619307918_770102_3520" name="anschrift" visibility="private" type="_16_5_4_8a30247_1422884384004_352244_4233">
              <ownedComment xmi:id="_16_5_4_940029b_1460619307918_585177_3532" annotatedElement="_16_5_4_940029b_1460619307918_770102_3520" body="&lt;para>In dieses Objekt sind die Angaben zur Anschrift der Person einzutragen. Welche Anschrift dafür auszuwählen ist, ist nicht festgelegt. Wichtig ist, dass es eine zustellfähige Anschrift sein muss (für den Zweck der verbindlichen Zustellung).&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460622442815_634129_4123" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460622442815_531805_4124" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460619307918_566376_3524" name="kommunikation" visibility="private" type="_16_5_4_8a30247_1422894619924_503273_3379">
              <ownedComment xmi:id="_16_5_4_940029b_1460619307918_756628_3548" annotatedElement="_16_5_4_940029b_1460619307918_566376_3524" body="&lt;para>In dieses Objekt sind Angaben einzutragen, die benötigt werden, um mit der Person zu kommunizieren (z. B. per Brief oder per Telefon). Diese Daten dienen der persönlichen Erreichbarkeit; die Unterscheidung, ob es sich um eine private oder eine geschäftliche E-Mail-Adresse handelt, ist nicht erheblich.).&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460622475673_81049_4129" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460622475673_312080_4130" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1460622920874_846896_4469" name="" memberEnd="_16_5_4_940029b_1460622920874_103982_4471 _16_5_4_940029b_1460622920874_634152_4470">
            <ownedEnd xmi:id="_16_5_4_940029b_1460622920874_634152_4470" name="" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423" association="_16_5_4_940029b_1460622920874_846896_4469"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8a30247_1422977828419_100798_7445" name="" memberEnd="_16_5_4_8a30247_1422977828419_207131_7447 _16_5_4_8a30247_1422977828419_632855_7446">
            <ownedEnd xmi:id="_16_5_4_8a30247_1422977828419_632855_7446" name="" visibility="private" type="_16_5_4_8a30247_1408703057450_27821_3423" association="_16_5_4_8a30247_1422977828419_100798_7445"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_2_940029b_1513951637567_197418_9729" name="" client="_16_5_4_940029b_1460619307903_831925_3517" supplier="_16_5_4_5b501fb_1387625291102_608193_5164"/>
          <packagedElement xmi:type="uml:Dependency" xmi:id="_18_0_2_940029b_1552467670464_818516_14343" name="" client="_16_5_4_940029b_1460619307918_202687_3519" supplier="_16_5_4_5b501fb_1387625291178_204613_5460"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_19_0_3_136d03d4_1612479007081_8721_9329" name="Anlagen" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1611752450693_63128_15571" name="MetadatenAnlage" isAbstract="true">
            <ownedComment xmi:id="_19_0_3_136d03d4_1611752450698_448880_15572" annotatedElement="_19_0_3_136d03d4_1611752450693_63128_15571" body="&lt;para>Dieser Kernmodul-Basistyp bildet die Metadaten zu einer Bauvorlage bzw. sonstigen Anlage ab, die gemäß der Architektur der Übertragung von &lt;link linkend=&quot;spezifikation.infrastrukturtechnologie.primaerdokumente&quot;>Primärdokumenten&lt;/link> im Zusammenhang mit einer XBau-Fachnachricht benötigt werden.&lt;/para>&#xA;&lt;para>XBau-Fachmodule können nach ihrem Bedarf vom vorliegenden Basistyp ableiten.&lt;/para>"/>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611752450698_501601_15573" name="bezeichnung" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611752450708_984319_15583" annotatedElement="_19_0_3_136d03d4_1611752450698_501601_15573" body="&lt;para>Hier ist eine deskriptive Bezeichnung der Bauvorlage bzw. sonstigen Anlage einzutragen, z. B. &quot;Grundriss 3. OG&quot;. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611752450709_689247_15584" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611752450708_355737_15582" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611752450699_664861_15574" name="versionsnummer" visibility="private">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611752450710_998750_15587" annotatedElement="_19_0_3_136d03d4_1611752450699_664861_15574" body="&lt;para>Hier ist eine Versionsnummer einzutragen. Sie dient dazu, (sequentiell eingereichte) Bauvorlagen (oder sonstige Anlagen) zu unterscheiden, die dieselbe Bezeichnung tragen.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611752450710_642377_15588" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611752450709_540261_15586" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611752450700_809244_15575" name="datum" visibility="private">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611752450711_710501_15591" annotatedElement="_19_0_3_136d03d4_1611752450700_809244_15575" body="&lt;para>Hier ist das Datum der Erstellung bzw. der letzten Bearbeitung dieser Bauvorlage bzw. sonstigen Anlage einzutragen.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611752450711_488611_15592" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611752450711_356414_15590" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611752450700_172558_15576" name="anlageart" visibility="private" type="_16_5_4_5b501fb_1387625280047_322339_5028">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611752450712_617215_15595" annotatedElement="_19_0_3_136d03d4_1611752450700_172558_15576" body="&lt;para>Unterhalb dieses Elements wird die Art dieser Bauvorlage oder sonstigen Anlage näher spezifiziert.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611752450712_61130_15596" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611752450712_371848_15594" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611752450701_695078_15577" name="mimeType" visibility="private" type="_16_5_4_940029b_1483303261965_543138_5139">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611752450713_297062_15599" annotatedElement="_19_0_3_136d03d4_1611752450701_695078_15577" body="&lt;para>Dieses Element nennt - analog zur Übermittlung von E-Mail-Anlagen - den MIME-Typ der angehängten oder verlinkten Bauvorlage bzw. sonstigen Anlage (z.B. text/xml, text/plain, application/gzip oder application/pdf). &lt;/para>&#xA;&lt;para>Die Angabe ist mandatorisch, weil eine für den Empfänger zur Verarbeitung der Daten notwendige Information.&lt;/para>&#xA;&lt;para>Als Anlagen können u.a. auch IFC-Darstellungen (gemäß der Technologie Building Information Modeling (BIM)) des Bauvorhabens übermittelt werden. Entsprechende Kennzeichnungen des mimeTypes (ifc, ifcXML, fcZIP) sind dafür verfügbar.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611752450713_7750_15600" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611752450713_200457_15598" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1621436465618_164867_9405" name="anhangOderVerlinkung" visibility="private" type="_19_0_3_940029b_1621589626990_578637_9405">
              <ownedComment xmi:id="_19_0_3_940029b_1621436465626_718701_9407" annotatedElement="_19_0_3_940029b_1621436465618_164867_9405" body="&lt;para>Eine Instanz dieses Elements enthält passende Metadaten zur Bauvorlage bzw. sonstigen Anlage, je nachdem ob diese (i) als Anhang mit dieser XBau-Nachricht übermittelt wird oder ob sie (ii) über einen Link zugänglich gemacht  wird, der in diese XBau-Nachricht eingetragen ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1621436465627_780459_9408" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1621436465624_860109_9406" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460560241523_867175_3826" name="Anlagen">
            <ownedComment xmi:id="_16_5_4_940029b_1461259171039_660685_5520" annotatedElement="_16_5_4_940029b_1460560241523_867175_3826" body="&lt;para>Dieser Typ dient dazu, die Metadaten zu Dokumenten aufzunehmen, die einer XBau-Kommunikation (z.B. Antragstellung) als Anlagen beigefügt sind. Als Anlagen sind in erster Linie Bauvorlagen zu nennen, in vielen Fällen zusätzlich weitere Anlagen (wie Nachweise und ergänzende Dokumentationen) und sonstiges Schriftgut.&lt;/para>&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460733760899_910997_4047" name="anlage" visibility="private" type="_19_0_3_940029b_1629982120314_774000_9457" aggregation="composite">
              <ownedComment xmi:id="_16_5_4_940029b_1461160810037_905663_5869" annotatedElement="_16_5_4_940029b_1460733760899_910997_4047" body="&lt;para>Jede Instanz dieses Elements steht für eine Anlage (Bauvorlage, Primärdokument, sonstige Anlage) zum vorliegenden Antrag bzw. zur übermittelten XBau-Fachnachricht.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460733760899_826458_4049" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460733760899_101516_4050" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_940029b_1621589626990_578637_9405" name="AnhangOderVerlinkung">
            <ownedComment xmi:id="_19_0_3_940029b_1621589627004_405867_9406" annotatedElement="_19_0_3_940029b_1621589626990_578637_9405" body="&lt;para>Dieser Typ beschreibt die Mechanismen, mit denen eine Bauvorlage oder sonstige Anlage im Zusammenhang mit einer XBau-Fachnachricht übermittelt wird.&lt;/para>&#xA;&lt;para>Die Bauvorlage bzw. sonstige Anlage wird entweder als Anhang (Attachment) zur XBau-Fachnachricht übermittelt (Metadaten dokumentid und dateiname). &lt;/para>&#xA;&lt;para>Oder sie wird dem Adressaten per Verlinkung zur Verfügung gestellt, also über ein Quellsystem, das sich in seiner Kontrolle befindet (Element uriVerlinkung).&lt;/para>"/>
            <ownedAttribute xmi:id="_19_0_3_940029b_1621589627005_510551_9407" name="anhang" type="_19_0_3_940029b_1621589794838_197505_9429">
              <ownedComment xmi:id="_19_0_3_940029b_1621589627015_758997_9411" annotatedElement="_19_0_3_940029b_1621589627005_510551_9407" body="&lt;para>Das Dokument wird als &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; linkend=&quot;spezifikation.infrastrukturtechnologie.primaerdokumente.anhang&quot;>Anhang&lt;/link> mit dieser XBau-Fachnachricht übertragen.&lt;/para>&#xA;&lt;para>Dazu stehen unterhalb dieses Elements die passenden Metadaten .&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1621589627017_681608_9412" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1621589627014_109122_9410" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1621589712845_8322_9422" name="uriVerlinkung" visibility="private">
              <ownedComment xmi:id="_19_0_3_940029b_1621589712847_788516_9424" annotatedElement="_19_0_3_940029b_1621589712845_8322_9422" body="&lt;para>Falls das Dokument über einen Link zugänglich gemacht werden soll, ist der Link in dieses Element einzutragen.&lt;/para>&#xA;&lt;para>Der Link identifiziert die Anlage (Primärdokument) in einem Quellsystem (das sich in Kontrolle der Behörde befindet) eindeutig. Die Verlinkung auf ein Quellsystem entspricht der Architektur der (externen) &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; linkend=&quot;spezifikation.infrastrukturtechnologie.primaerdokumente.verlinkung&quot;>Verlinkung.&lt;/link>&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191702187_214129_966"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1621589712847_141794_9425" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1621589712846_719067_9423" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_940029b_1621589794838_197505_9429" name="MetadatenAnhang">
            <ownedComment xmi:id="_19_0_3_940029b_1621589794839_126528_9430" annotatedElement="_19_0_3_940029b_1621589794838_197505_9429" body="&lt;para>Dieser Typ dient zur Aufnahme der Metadaten eines lokalen Anhangs, der mit einer XBau-Fachnachricht übertragen wird.&lt;/para>"/>
            <ownedAttribute xmi:id="_19_0_3_940029b_1621589794846_514231_9436" name="dokumentid" visibility="private">
              <ownedComment xmi:id="_19_0_3_940029b_1621589794859_688977_9461" annotatedElement="_19_0_3_940029b_1621589794846_514231_9436" body="&lt;para>Die innerhalb des Transportcontainers eindeutige Kennung des Dokuments. &lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191702187_214129_966"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1621589794860_799923_9462" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1621589794859_9498_9460" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1621589794847_717344_9437" name="dateiname" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1621589794861_119118_9465" annotatedElement="_19_0_3_940029b_1621589794847_717344_9437" body="&lt;para>Hier ist der Name der Datei (Primärdokument) einzutragen, eindeutig innerhalb des Transportcontainers. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1621589794861_833022_9466" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1621589794861_595073_9464" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_940029b_1629982120314_774000_9457" name="MetadatenAnlageDirekt">
            <ownedComment xmi:id="_19_0_3_940029b_1629982120328_521027_9458" annotatedElement="_19_0_3_940029b_1629982120314_774000_9457" body="&lt;para>Dieser Typ nimmt die Metadaten zu einer Bauvorlage bzw. sonstigen Anlage auf, die gemäß der Architektur der Übertragung von &lt;link linkend=&quot;spezifikation.infrastrukturtechnologie.primaerdokumente&quot;>Primärdokumenten&lt;/link> im Zusammenhang mit einer XBau-Fachnachricht benötigt werden.&lt;/para>"/>
            <ownedAttribute xmi:id="_19_0_3_940029b_1629982120328_598268_9459" name="bezeichnung" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1629982120342_675956_9467" annotatedElement="_19_0_3_940029b_1629982120328_598268_9459" body="&lt;para>Hier ist eine deskriptive Bezeichnung der Bauvorlage bzw. sonstigen Anlage einzutragen, z. B. &quot;Grundriss 3. OG&quot;. &lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1629982120343_436891_9468" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1629982120341_33350_9466" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1629982120331_680082_9460" name="versionsnummer" visibility="private">
              <ownedComment xmi:id="_19_0_3_940029b_1629982120344_944458_9471" annotatedElement="_19_0_3_940029b_1629982120331_680082_9460" body="&lt;para>Hier ist eine Versionsnummer einzutragen. Sie dient dazu, (sequentiell eingereichte) Bauvorlagen (oder sonstige Anlagen) zu unterscheiden, die dieselbe Bezeichnung tragen.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191855828_468108_1536"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1629982120345_811946_9472" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1629982120344_715173_9470" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1629982120332_763149_9461" name="datum" visibility="private">
              <ownedComment xmi:id="_19_0_3_940029b_1629982120346_166138_9475" annotatedElement="_19_0_3_940029b_1629982120332_763149_9461" body="&lt;para>Hier ist das Datum der Erstellung bzw. der letzten Bearbeitung dieser Bauvorlage bzw. sonstigen Anlage einzutragen.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1629982120346_901864_9476" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1629982120346_943754_9474" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1629982120333_73780_9462" name="anlageart" visibility="private" type="_19_0_3_940029b_1629982356132_732557_9504">
              <ownedComment xmi:id="_19_0_3_940029b_1629982120348_473495_9479" annotatedElement="_19_0_3_940029b_1629982120333_73780_9462" body="&lt;para>Unterhalb dieses Elements wird die Art dieser Bauvorlage oder sonstigen Anlage näher spezifiziert.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1629982120348_531070_9480" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1629982120347_95412_9478" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1629982120333_276783_9463" name="mimeType" visibility="private" type="_16_5_4_940029b_1483303261965_543138_5139">
              <ownedComment xmi:id="_19_0_3_940029b_1629982120349_392920_9483" annotatedElement="_19_0_3_940029b_1629982120333_276783_9463" body="&lt;para>Dieses Element nennt - analog zur Übermittlung von E-Mail-Anlagen - den MIME-Typ der angehängten oder verlinkten Bauvorlage bzw. sonstigen Anlage (z.B. text/xml, text/plain, application/gzip oder application/pdf). &lt;/para>&#xA;&lt;para>Die Angabe ist mandatorisch, weil eine für den Empfänger zur Verarbeitung der Daten notwendige Information.&lt;/para>&#xA;&lt;para>Als Anlagen können u.a. auch IFC-Darstellungen (gemäß der Technologie Building Information Modeling (BIM)) des Bauvorhabens übermittelt werden. Entsprechende Kennzeichnungen des mimeTypes (ifc, ifcXML, fcZIP) sind dafür verfügbar.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1629982120350_122316_9484" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1629982120349_103595_9482" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1629982120334_800022_9464" name="anhangOderVerlinkung" visibility="private" type="_19_0_3_940029b_1621589626990_578637_9405">
              <ownedComment xmi:id="_19_0_3_940029b_1629982120351_982520_9487" annotatedElement="_19_0_3_940029b_1629982120334_800022_9464" body="&lt;para>Eine Instanz dieses Elements enthält passende Metadaten zur Bauvorlage bzw. sonstigen Anlage, je nachdem ob diese (i) als Anhang mit dieser XBau-Nachricht übermittelt wird oder ob sie (ii) über einen Link zugänglich gemacht  wird, der in diese XBau-Nachricht eingetragen ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1629982120351_694913_9488" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1629982120350_226592_9486" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_19_0_3_136d03d4_1612479073596_772047_9334" name="TextUndBezug" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1611781889004_410228_10088" name="Anonym_Link">
            <ownedComment xmi:id="_19_0_3_136d03d4_1611781889005_455806_10089" annotatedElement="_19_0_3_136d03d4_1611781889004_410228_10088" body=""/>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611781889005_408024_10090" name="url" visibility="private">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611781889006_302590_10093" annotatedElement="_19_0_3_136d03d4_1611781889005_408024_10090" body="&lt;para>Hier ist die URL einer Webseite oder Ressource anzugeben.&lt;/para>&#xA;&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191702187_214129_966"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611781889007_931920_10094" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611781889006_336912_10092" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611781889006_612710_10091" name="beschreibung" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611781889007_996082_10097" annotatedElement="_19_0_3_136d03d4_1611781889006_612710_10091" body="&lt;para>Hier ist die zur URL passende Beschreibung der Webseite oder Ressource einzutragen. &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611781889007_685107_10098" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611781889007_980938_10096" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1611781871673_705551_10079" name="Anonym_LinkListe">
            <ownedComment xmi:id="_19_0_3_136d03d4_1611781871674_8741_10080" annotatedElement="_19_0_3_136d03d4_1611781871673_705551_10079" body=""/>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611781871674_544000_10081" name="link" visibility="private" type="_19_0_3_136d03d4_1611781889004_410228_10088">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611781871675_452931_10083" annotatedElement="_19_0_3_136d03d4_1611781871674_544000_10081" body="&lt;para>Jedes instanziierte Element steht für einen Link auf eine Webseite oder Ressource.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611781871675_959785_10084" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611781871674_855158_10082" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1465368877212_444325_5428" name="Bezug">
            <ownedComment xmi:id="_16_5_4_940029b_1465369587050_970021_5510" annotatedElement="_16_5_4_940029b_1465368877212_444325_5428" body="&lt;para>Dieser Typ gestattet Eintragungen, um auf einen Antrag, einen Vorgang und ggf. auf eine Nachricht, die im Rahmen dieses Vorgangs gesendet worden ist, Bezug zu nehmen. &lt;/para>"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1546720734944_199093_13359" name="referenz" visibility="private" type="_16_5_4_1eeb04c1_1431421674715_699590_2654">
              <ownedComment xmi:id="_18_0_2_940029b_1546720734959_14595_13361" annotatedElement="_18_0_2_940029b_1546720734944_199093_13359" body="&lt;para>Hier ist der Identifier des Antragsservice (der mit dem Antrag bzw. der Anzeige bei der Bauaufsichtsbehörde (bzw. Aufsichtsbehörde für den Breitbandausbau) eingegangen ist) oder der Abfrage (auf die die vorliegende Nachricht eine Antwort ist) anzugeben.&lt;/para>&#xA;&lt;para>Falls die vorliegende Nachricht an ein Online-Portal gerichtet ist, kann so der Projektraum bzw. Postkorb angesteuert werden.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546720734959_437875_13362" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546720734959_220578_13360" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465369045932_696516_5487" name="vorgang" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_940029b_1465369445636_190258_5508" annotatedElement="_16_5_4_940029b_1465369045932_696516_5487" body="&lt;para>Eine Instanz dieses Elements enthält, falls ein solches vergeben wurde, das Zeichen (Aktenzeichen) des von der Bauaufsichtsbehörde (bzw. Aufsichtsbehörde für den Breitbandausbau) geführten Vorgangs, innerhalb dessen diese Nachricht übermittelt wird. &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465369058452_265785_5489" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465369058452_98569_5490" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1612387491891_70335_9576" name="bezugNachricht" visibility="private" type="_16_5_4_1eeb04c1_1364308914704_16162_1623">
              <ownedComment xmi:id="_19_0_3_136d03d4_1612387592075_194225_9582" annotatedElement="_19_0_3_136d03d4_1612387491891_70335_9576" body="&lt;para>Falls ein solcher Zusammenhang vorliegt, sind hier die Kennungen der Nachricht einzutragen, auf die sich diese Nachricht bezieht.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1612387564308_84214_9580" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1612387564308_525826_9581" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1601245573232_871949_15379" name="Nachweisdaten">
            <ownedComment xmi:id="_19_0_3_136d03d4_1601245610915_709820_15381" annotatedElement="_19_0_3_136d03d4_1601245573232_871949_15379" body="&lt;para>Dieser Typ bildet Nachweisdaten zu behördlichen Vorgängen ab.&lt;/para>"/>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1601245613095_453060_15382" name="behoerde" visibility="private">
              <ownedComment xmi:id="_19_0_3_136d03d4_1601245704076_125051_15394" annotatedElement="_19_0_3_136d03d4_1601245613095_453060_15382" body="&lt;para>In dieses Element ist die zuständige Behörde einzutragen.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1605090075410_873194_15285" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1605090075410_573890_15286" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1601245625528_78234_15383" name="datum" visibility="private">
              <ownedComment xmi:id="_19_0_3_136d03d4_1601245714548_305112_15395" annotatedElement="_19_0_3_136d03d4_1601245625528_78234_15383" body="&lt;para>In dieses Element ist das Datum einzutragen.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191726109_379108_1042"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1605090083293_564430_15287" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1605090083293_537380_15288" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1601245635439_872357_15384" name="aktenzeichen" visibility="private">
              <ownedComment xmi:id="_19_0_3_136d03d4_1601245728038_658552_15396" annotatedElement="_19_0_3_136d03d4_1601245635439_872357_15384" body="&lt;para>In dieses Element ist das Aktenzeichen einzutragen.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1605090098128_900802_15289" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1605090098128_213687_15290" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_940029b_1591038023050_502647_13346" name="ReferenzAbfrage">
            <ownedComment xmi:id="_19_0_3_940029b_1591038023052_266186_13347" annotatedElement="_19_0_3_940029b_1591038023050_502647_13346" body="&lt;para>Dieser Typ deckt die Identifizierung einer Abfrage ab.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_19_0_3_940029b_1591038023052_140224_13348" name="referenzAbfrage" visibility="private" type="_16_5_4_1eeb04c1_1431421674715_699590_2654">
              <ownedComment xmi:id="_19_0_3_940029b_1591038023059_550273_13351" annotatedElement="_19_0_3_940029b_1591038023052_140224_13348" body="&lt;para>Maschinell erzeugter Identifier, der die Anfrage (nicht die Anfragenachricht) eindeutig kennzeichnet. &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1591038023062_426281_13352" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1591038023058_807652_13350" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1546716878558_771130_12819" name="ReferenzAntragsservice">
            <ownedComment xmi:id="_18_0_2_940029b_1546716878574_382210_12820" annotatedElement="_18_0_2_940029b_1546716878558_771130_12819" body="&lt;para>Dieser Typ deckt Daten ab, durch die ein Antragsservice einen Antrags- (oder Anzeigen-)vorgang eindeutig kennzeichnet. &lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1546716878574_879685_12821" name="referenzAntragsservice" visibility="private" type="_16_5_4_1eeb04c1_1431421674715_699590_2654">
              <ownedComment xmi:id="_18_0_2_940029b_1546716878574_479178_12825" annotatedElement="_18_0_2_940029b_1546716878574_879685_12821" body="&lt;para>Initial eingetragener, i.d.R. maschinell erzeugter Identifier, der für den Antragsvorgang steht (nicht für die Antragsnachricht). &lt;/para>&#xA;&#xA;&lt;para>Dieser Identifier geht mit den Antragsnachrichten der Bauaufsichtsbehörde (bzw. Aufsichtsbehörde für den Breitbandausbau) zu und schafft dieser die Möglichkeit, in ihren Reaktionsnachrichten darauf zu referenzieren.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1546716878574_412621_12826" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1546716878574_969813_12824" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1535727067041_864259_10734" name="Text">
            <ownedComment xmi:id="_18_0_2_940029b_1535727067042_958881_10735" annotatedElement="_18_0_2_940029b_1535727067041_864259_10734" body="&lt;para>Diese Typ nimmt Absätze eines formatierungsfreien Textes auf. &lt;/para>"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1535727067042_432901_10736" name="textabsatz" visibility="private">
              <ownedComment xmi:id="_18_0_2_940029b_1535727067043_816131_10739" annotatedElement="_18_0_2_940029b_1535727067042_432901_10736" body="&lt;para>Pro Element wird Text im Umfang eines Absatzes (Freitext) festgehalten.&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191867218_582037_1593"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1535727067044_742452_10740" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1535727067043_593982_10738" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1535726187446_656135_10650" name="TextFormatiert">
            <ownedComment xmi:id="_18_0_2_940029b_1535726187449_311762_10651" annotatedElement="_18_0_2_940029b_1535726187446_656135_10650" body="&lt;para>Diese Typ nimmt Absätze eines Textes auf, so dass das Empfängersystem diesen Text formatierungstreu anzeigen und medienbruchfrei weiterverarbeiten kannn. &lt;/para>"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1535726187450_347378_10652" name="text" visibility="private">
              <ownedComment xmi:id="_18_0_2_940029b_1535726187451_706391_10655" annotatedElement="_18_0_2_940029b_1535726187450_347378_10652" body="&lt;para>Dieses Element steht für einen Textabschnitt, der ggf. einschließlich Formatierung und Abbildungen, auf Basis von HTML-5-Markup eingetragen ist.&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191711843_120906_985"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1535726187451_928146_10656" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1535726187451_993271_10654" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1535726283017_758163_10660" name="textOffice" visibility="private">
              <ownedComment xmi:id="_18_0_2_940029b_1535726283018_124609_10662" annotatedElement="_18_0_2_940029b_1535726283017_758163_10660" body="&lt;para>Dieses Element gestattet es, den Textabschnitt zusätzlich im XML-basierten Format ODF oder OOXML abzubilden.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191711843_120906_985"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1535726283018_164508_10663" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1535726283018_390092_10661" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1611781855355_662927_10055" name="Verlinkung">
            <ownedComment xmi:id="_19_0_3_136d03d4_1611781855356_57394_10056" annotatedElement="_19_0_3_136d03d4_1611781855355_662927_10055" body="&lt;para>Dieser Typ gestattet es, Webressourcen anzugeben für ggf. nötige Reaktionen des Lesers auf die vorliegende Nachricht. &lt;/para>"/>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611781855357_852545_10057" name="linkliste" visibility="private" type="_19_0_3_136d03d4_1611781871673_705551_10079">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611781855359_106696_10062" annotatedElement="_19_0_3_136d03d4_1611781855357_852545_10057" body="&lt;para>Dieses Element steht für eine Liste von verlinkten Angeboten, die vom Autor der Nachricht bereitgestellt werden.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611781855359_563141_10063" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611781855359_554318_10061" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611781855357_991858_10058" name="default" visibility="private">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611781855360_371449_10066" annotatedElement="_19_0_3_136d03d4_1611781855357_991858_10058" body="&lt;para>Falls dieses Elements instanziiert ist, gibt der Autor dadurch an, dass auf ein eigenes Angebot verzichtet wird und dass stattdessen auf eine ggf. bereitgestellte zentrale bzw. einheitlich vorgegebene Möglichkeit verwiesen wird. &lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611781855360_816812_10067" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611781855360_616906_10065" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1611781855358_861039_10059" name="noreply" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_19_0_3_136d03d4_1611781855362_468139_10070" annotatedElement="_19_0_3_136d03d4_1611781855358_861039_10059" body="&lt;para>Falls dieses Element instanziiert ist, ist das das Zeichen, dass weder ein eigenes Angebot bereitgestellt wird, noch auf eine zentrale Lösung verwiesen wird.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1611781855362_517862_10071" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1611781855361_847475_10069" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_19_0_3_136d03d4_1612479353605_22016_9336" name="Datentypen zu Prozessnachrichten" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1552127281869_824594_14787" name="Anonym_BefundFormell">
            <ownedComment xmi:id="_18_0_2_940029b_1552127281872_940165_14792" annotatedElement="_18_0_2_940029b_1552127281869_824594_14787" body=""/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552127281872_444985_14793" name="artDesBefundes" visibility="private" type="_18_0_2_940029b_1552127588117_500969_14828">
              <ownedComment xmi:id="_18_0_2_940029b_1552127281877_438571_14803" annotatedElement="_18_0_2_940029b_1552127281872_444985_14793" body="&lt;para>In diesem Element wird die Befundkategorie angegeben, der dieser Befund zugeordnet werden kann.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552127281877_748516_14804" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552127281877_598367_14802" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552127281875_614895_14796" name="beschreibung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_18_0_2_940029b_1552127281878_429485_14815" annotatedElement="_18_0_2_940029b_1552127281875_614895_14796" body="&lt;para>Hier wird der Sachverhalt des Befundes beschrieben. Dieser Sachverhalt enthält Details, die für den Adressaten hilfreich sind ergänzend zur angegebenen Art des Befundes.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552127281878_929087_14816" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552127281878_454104_14814" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1552127281868_654162_14786" name="BefundlisteFormell">
            <ownedComment xmi:id="_18_0_2_940029b_1552127281871_346470_14789" annotatedElement="_18_0_2_940029b_1552127281868_654162_14786" body="&lt;para>Dieser Typ beinhaltet die Befunde der formellen Prüfung eines Antrags, einer Anzeige oder einer Erklärung. Für jeden Befund sind die entsprechenden Parameter gefüllt, die Inhalt und Bezug des Befundes für den Antragsteller bzw. Anfragenden nachvollziehbar machen.&lt;/para>"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1552127281871_563444_14790" name="befund" visibility="private" type="_18_0_2_940029b_1552127281869_824594_14787" aggregation="composite" association="_18_0_2_940029b_1552127281870_107742_14788">
              <ownedComment xmi:id="_18_0_2_940029b_1552127281876_873618_14799" annotatedElement="_18_0_2_940029b_1552127281871_563444_14790" body="&lt;para>Dieses Element stellt genau einen Befund der Befundliste dar.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1552127281876_187299_14800" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1552127281876_506491_14798" name="" value="*"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541324483751_614901_11350" name="Rueckweisung">
            <ownedComment xmi:id="_18_0_2_940029b_1541324483751_665655_11351" annotatedElement="_18_0_2_940029b_1541324483751_614901_11350" body="&lt;para>Dieser Typ nimmt Angaben zu Art und Ort eines Fehlers auf, der zur Rückweisung der Nachricht geführt hat. &lt;/para>&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541324505462_418915_11367" name="rueckweisungsgrund" visibility="private" type="_18_0_2_940029b_1541262088385_800525_11851" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1541324505465_120963_11371" annotatedElement="_18_0_2_940029b_1541324505462_418915_11367" body="&lt;para>Jede Instanz dieses Elements enthält Informationen zu einem Fehler bzw. einem Mangel, der in Bezug auf die erhaltene Nachricht identifiziert wurde.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324505465_779282_11372" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324505464_44971_11370" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541324505463_80054_11368" name="idNachricht" visibility="private" type="_16_5_4_1eeb04c1_1364308914704_16162_1623">
              <ownedComment xmi:id="_18_0_2_940029b_1541324505466_804390_11375" annotatedElement="_18_0_2_940029b_1541324505463_80054_11368" body="&lt;para>Identifikationsmerkmale der zurückgewiesenen XBau-Nachricht, die der Autor der Rückweisung zu einem Zeitpunkt in der Vergangenheit empfangen hat.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324505466_688423_11376" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324505466_186950_11374" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541324505464_278413_11369" name="nachricht" visibility="private">
              <ownedComment xmi:id="_18_0_2_940029b_1541324505467_865555_11379" annotatedElement="_18_0_2_940029b_1541324505464_278413_11369" body="&lt;para>Dieses Element bildet die zurückgewiesene Fachnachricht ohne Attachments im Binärformat ab..&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191711843_120906_985"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541324505468_776322_11380" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541324505467_904601_11378" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541262088385_800525_11851" name="Rueckweisungsgrund">
            <ownedComment xmi:id="_18_0_2_940029b_1541262170416_555404_11921" annotatedElement="_18_0_2_940029b_1541262088385_800525_11851" body="&lt;para>Dieser Typ nimmt Angaben zu Art und Ort eines Fehlers auf, der zur Rückweisung der Nachricht geführt hat. &lt;/para>&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541262170416_216816_11922" name="grund" visibility="private" type="_18_0_2_940029b_1541261707920_683057_11719" aggregation="composite">
              <ownedComment xmi:id="_18_0_2_940029b_1541262170432_582703_11958" annotatedElement="_18_0_2_940029b_1541262170416_216816_11922" body="&lt;para>Mit diesem Element wird der Grund übermittelt, aus dem die Nachricht zurückgewiesen wird. Die im Rahmen der hier zu verwendenden Codeliste zur Verfügung gestellten Rückweisungsgründe sind kontextunabhängig und finden daher in allen Übermittlungskontexten Anwendung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541262170432_568324_11959" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541262170432_43932_11957" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1541262170416_106272_11923" name="fehlertext" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_18_0_2_940029b_1541262170432_173694_11962" annotatedElement="_18_0_2_940029b_1541262170416_106272_11923" body="&lt;para>Hier steht ein ergänzender textueller Hinweis auf die Art des Fehlers, der zur Zurückweisung der Nachricht geführt hat. Sofern kein Text angegeben ist (das Element also nicht übermittelt wird), gilt allein die Erläuterung zur im Element grund stehenden Fehlerkennzahl.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1541262170432_686678_11963" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1541262170432_349374_11961" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_18_0_2_940029b_1552127281870_107742_14788" name="" memberEnd="_18_0_2_940029b_1552127281871_563444_14790 _18_0_2_940029b_1552127281876_702012_14797">
            <ownedEnd xmi:id="_18_0_2_940029b_1552127281876_702012_14797" name="" visibility="private" type="_18_0_2_940029b_1552127281868_654162_14786" association="_18_0_2_940029b_1552127281870_107742_14788"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1615478976523_673762_9731" name="Identifikation.Nachricht">
            <ownedComment xmi:id="_19_0_3_136d03d4_1615478976525_4203_9732" annotatedElement="_19_0_3_136d03d4_1615478976523_673762_9731" body="&lt;para>Identifkationsmerkmale zu einer Nachricht. Dieser Typ kann im ID-Block zu einer Nachricht verwendet werden oder in einem Abschnitt, der auf eine Nachricht referenziert.&lt;/para>&#xA;"/>
            <generalization xmi:id="_19_0_3_136d03d4_1615478976529_717421_9736" general="_16_5_4_1eeb04c1_1364308914704_16162_1623"/>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1615478976526_667304_9733" name="nachrichtentyp" visibility="private" type="_19_0_3_136d03d4_1615476797907_523392_9724">
              <ownedComment xmi:id="_19_0_3_136d03d4_1615478976530_837001_9739" annotatedElement="_19_0_3_136d03d4_1615478976526_667304_9733" body="&lt;para>Die eindeutige Identifizierungsnummer für einen Nachrichtentyp. Der konkret zu verwendende Datentyp für die Übermittlung des Schlüsselwertes wird durch den Fachstandard auf Schemaebene festgelegt.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1615478976531_147470_9740" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1615478976530_392700_9738" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1615478976527_691672_9734" name="erstellungszeitpunkt" visibility="private">
              <ownedComment xmi:id="_19_0_3_136d03d4_1615478976533_227442_9743" annotatedElement="_19_0_3_136d03d4_1615478976527_691672_9734" body="&lt;para>Der Zeitpunkt, an dem die Nachricht erstellt wurde.&lt;/para>&#xA;&lt;para>Dieses Feld wird durch das Fachverfahren beim Erstellen der Nachricht gefüllt. Hier ist explizit nicht der Sende- und Empfangszeitpunkt  festgehalten, denn die können in der Regel der Transportschicht entnommen werden.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191729703_367727_1061"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1615478976533_813268_9744" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1615478976532_388097_9742" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1615478976528_979620_9735" name="nachrichtenUUID" visibility="private" type="_16_5_4_1eeb04c1_1431421674715_699590_2654">
              <ownedComment xmi:id="_19_0_3_136d03d4_1615478976534_804742_9747" annotatedElement="_19_0_3_136d03d4_1615478976528_979620_9735" body="&lt;para>Hier wird der Universally Unique Identifier (UUID) der Nachricht mitgeteilt, der das primäre Identifikationsmerkmal einer Nachricht darstellt. Der UUID der Nachricht ist weltweit eindeutig. So wird es möglich, Nachrichten hersteller- und anwendungsübergreifend eindeutig zu identifizieren. &lt;/para>&#xA;&lt;para>Für jede Nachricht muss eine neue UUID erzeugt werden, um eine eindeutige Identifikation der Nachricht sicherzustellen. Insbesondere ist es nicht zulässig, in einer korrigierten Nachricht (bspw. nach Erhalt einer RTS-Nachricht) die UUID der ursprünglichen Nachricht wiederzuverwenden.&lt;/para>&#xA;&lt;para>Sofern eine einmal erzeugte Nachricht ein weiteres Mal gesendet werden soll (bspw. aufgrund von Problemen beim Nachrichtentransport), muss die UUID nicht angepasst werden.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1615478976534_182813_9748" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1615478976534_472174_9746" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1617016621104_44246_9389" name="Nachrichtenkopf.G2G">
            <ownedComment xmi:id="_19_0_3_136d03d4_1617017384818_422698_9421" annotatedElement="_19_0_3_136d03d4_1617016621104_44246_9389" body="&lt;para>Nachrichtenkopf für Nachrichten von Behörden (bzw. öffentlichen Stellen oder Diensten) an andere Behörden (bzw. öffentliche Stellen oder Dienste).&lt;/para>"/>
            <generalization xmi:id="_19_0_3_136d03d4_1617016880422_164917_9417" general="_16_5_4_1eeb04c1_1364384258088_829416_2134"/>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617016815724_215263_9390" name="identifikation.nachricht" visibility="private" type="_19_0_3_136d03d4_1615478976523_673762_9731" aggregation="composite">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617016815733_514481_9394" annotatedElement="_19_0_3_136d03d4_1617016815724_215263_9390" body="&lt;para>Hier werden die Identifkationsmerkmale zur vorliegenden Nachricht genannt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617016815733_940869_9395" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617016815732_176804_9393" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617016815730_248817_9391" name="leser" visibility="private" type="_16_5_4_1eeb04c1_1364313722451_850604_9366" aggregation="composite">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617016815735_852562_9398" annotatedElement="_19_0_3_136d03d4_1617016815730_248817_9391" body="&lt;para>Hier wird die Fachbehörde bzw. Organisation genannt, für die die vorliegende Nachricht bestimmt ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617016815735_634364_9399" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617016815735_513784_9397" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617016815731_950476_9392" name="autor" visibility="private" type="_16_5_4_1eeb04c1_1364382738190_314891_1582" aggregation="composite">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617016815736_45417_9402" annotatedElement="_19_0_3_136d03d4_1617016815731_950476_9392" body="&lt;para>Hier wird die Fachbehörde bzw. Organisation genannt, die die vorliegende Nachricht erstellt hat.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617016815736_561372_9403" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617016815736_555587_9401" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1617018517570_525675_9422" name="Nachricht.G2G">
            <ownedComment xmi:id="_19_0_3_136d03d4_1617018517572_747392_9423" annotatedElement="_19_0_3_136d03d4_1617018517570_525675_9422" body="&lt;para>Nachrichtenstruktur für die Kommunikation von Behörden (bzw. öffentlichen Stellen oder Diensten) mit anderen Behörden (bzw. öffentlichen Stellen oder Diensten).&lt;/para>"/>
            <generalization xmi:id="_19_0_3_136d03d4_1617018517577_487752_9431" general="_16_5_4_1eeb04c1_1364308813094_424263_1603"/>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617018517572_887187_9424" name="standard" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619" isReadOnly="true">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617018517578_239395_9434" annotatedElement="_19_0_3_136d03d4_1617018517572_887187_9424" body="&lt;para>In diesem Attribut wird der Name des Standards übermittelt, aus dem die Nachricht stammt. Der Name des Standards wird durch den Fachstandard als fixed-Value auf Schemaebene festgelegt (z. B. &lt;emphasis>XPersonenstand&lt;/emphasis>).&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617018517578_360878_9435" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617018517578_233068_9433" name="" value="1"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_19_0_3_c4f030d_1637573981904_513524_9668" name="" value="XBau-Kernmodul"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617018517573_632173_9425" name="version" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619" isReadOnly="true">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617018517580_469380_9438" annotatedElement="_19_0_3_136d03d4_1617018517573_632173_9425" body="&lt;para>In diesem Attribut wird die Version des Standards übermittelt, aus dem die Nachricht stammt. Die Versionsbezeichnung wird durch den Fachstandard als fixed-Value auf Schemaebene festgelegt (z. B. &lt;emphasis>1.5.0&lt;/emphasis>).&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617018517580_26992_9439" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617018517579_361103_9437" name="" value="1"/>
              <defaultValue xmi:type="uml:LiteralString" xmi:id="_19_0_3_c4f030d_1637574049241_530026_9669" name="" value="1.1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617018517574_560370_9426" name="produkt" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617018517581_187523_9442" annotatedElement="_19_0_3_136d03d4_1617018517574_560370_9426" body="&lt;para>In diesem Attribut ist der Name des Produktes (der Software) einzutragen, mit dem diese Nachricht erstellt worden ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617018517581_11871_9443" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617018517581_487471_9441" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617018517574_696333_9427" name="produkthersteller" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617018517582_642356_9446" annotatedElement="_19_0_3_136d03d4_1617018517574_696333_9427" body="&lt;para>In diesem Attribut ist der Name der Firma oder der Organisation einzutragen, die für das DV-Verfahren verantwortlich ist, mit dem diese Nachricht erstellt worden ist.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617018517583_808205_9447" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617018517582_922091_9445" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617018517575_48654_9428" name="produktversion" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617018517584_591224_9450" annotatedElement="_19_0_3_136d03d4_1617018517575_48654_9428" body="&lt;para>In diesem Attribut sollen ergänzende Hinweise zu dem Produkt, mit dem diese Nachricht erstellt worden ist, eingetragen werden. Dies sind Angaben, die für eine möglichst präzise Identifikation im Fehlerfall hilfreich sind, wie zum Beispiel Version und Patchlevel.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617018517584_412113_9451" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617018517583_452383_9449" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617018517576_517352_9429" name="test" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617018517584_528131_9454" annotatedElement="_19_0_3_136d03d4_1617018517576_517352_9429" body="&lt;para>Dieses Attribut ist optional. Ist es vorhanden, so sagt dies aus, dass es sich um eine Nachricht handelt, die (aus Sicht des Senders der Nachricht) nicht im normalen Produktivbetrieb behandelt werden soll. Über den Inhalt des Attributes wird nichts weiter ausgesagt, dies kann bilateral zwischen den Kommunikationspartnern vereinbart werden.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617018517585_463396_9455" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617018517584_664392_9453" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1617018517576_983893_9430" name="nachrichtenkopf" visibility="private" type="_19_0_3_136d03d4_1617016621104_44246_9389" aggregation="composite">
              <ownedComment xmi:id="_19_0_3_136d03d4_1617018517586_890521_9458" annotatedElement="_19_0_3_136d03d4_1617018517576_983893_9430" body="&lt;para>Dieses Element enthält die  Kopfinformationen zu Nachrichten des vorliegenden Typs.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1617018517586_260912_9459" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1617018517585_88665_9457" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1622230009808_308184_9453" name="Anonym_TextOderTextFormatiert">
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1622230030992_984691_9454" name="textUnformatiert" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
              <ownedComment xmi:id="_19_0_3_136d03d4_1622230110793_311068_9463" annotatedElement="_19_0_3_136d03d4_1622230030992_984691_9454" body="&lt;para>Hier wird der unformatierte Text übermittelt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1622230173886_182229_9465" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1622230173886_188218_9466" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1622230060145_801698_9455" name="textFormatiert" visibility="private" type="_18_0_2_940029b_1535726187446_656135_10650">
              <ownedComment xmi:id="_19_0_3_136d03d4_1622230121397_343168_9464" annotatedElement="_19_0_3_136d03d4_1622230060145_801698_9455" body="&lt;para>Hier wird der formatierte Text übermittelt.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1622230178973_694988_9467" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1622230178973_708819_9468" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
        </packagedElement>
        <packagedElement xmi:type="uml:Package" xmi:id="_19_0_3_136d03d4_1612479083484_262093_9335" name="Verortung" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_940029b_1589627283733_575112_12053" name="Anonym_Gemarkung">
            <ownedAttribute xmi:id="_19_0_3_940029b_1589627348453_384061_12061" name="nummer" visibility="private" aggregation="composite">
              <ownedComment xmi:id="_19_0_3_940029b_1589627348456_154304_12063" annotatedElement="_19_0_3_940029b_1589627348453_384061_12061" body="&lt;para>In dieses Element ist die Nummer der Gemarkung gemäß lokalem Liegenschaftskataster einzutragen (Gemarkungsnummer bestehend aus maximal 4 Stellen).&lt;/para>&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589627348457_910506_12064" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1589627348455_233611_12062" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589627283747_482664_12054" name="bezeichnung" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619" aggregation="composite">
              <ownedComment xmi:id="_19_0_3_940029b_1589627283752_243381_12056" annotatedElement="_19_0_3_940029b_1589627283747_482664_12054" body="&lt;para>Dieses Element steht für die deskriptive Bezeichnung der Gemarkung.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589627283753_895163_12057" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1589627283751_765478_12055" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1462299055656_708712_5047" name="Anonym_GeometriePolygon">
            <ownedAttribute xmi:id="_16_5_4_940029b_1465269124067_598733_5018" name="polygon" visibility="private" type="_18_0_2_8c5027b_1530287031672_844520_12582" aggregation="composite" association="_16_5_4_940029b_1465269124036_718978_5016">
              <ownedComment xmi:id="_16_5_4_940029b_1465270668196_604854_5535" annotatedElement="_16_5_4_940029b_1465269124067_598733_5018" body="&lt;para>Das Element (globales Element gml:Polygon) enthält die GML-Darstellung einer Grundfläche (es können Außenkanten und Innenkanten dargestellt werden).&lt;/para>&#xA;&lt;para>Aus der GML-Dokumentation: &quot;A Polygon is a special surface that is defined by a single surface patch. The boundary of this patch is coplanar and the polygon uses planar interpolation in its interior. The elements exterior and interior describe the surface boundary of the polygon.&quot; Quelle: &lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&quot;>http://www.datypic.com/sc/niem21/e-gml32_Polygon.html&lt;/link>  &lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465269124067_392495_5020" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465269124067_248877_5021" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1408964097602_950511_3483" name="Flurstueckskennzeichen">
            <ownedComment xmi:id="_16_5_4_8a30247_1408964140406_260187_3502" annotatedElement="_16_5_4_8a30247_1408964097602_950511_3483" body="&lt;para>Typ zur eindeutigen Identifikation eines Flurstücks.&lt;/para>&#xA;&lt;para>Ein Flurstück ist ein amtlich vermessener Teil der Erdoberfläche. Das Liegenschaftskataster ordnet jedem Flurstück des jeweiligen Nummerierungsbezirks (Flur oder Gemarkung) eine Flurstücksnummer zu.&#xA;&lt;/para>&#xA;&#xA;&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1408964599802_91559_3503" clientDependency="_16_5_4_8ae0277_1427194878441_42353_7435" name="bundesland" visibility="private" type="_16_5_4_8a30247_1423044461203_939066_6394">
              <ownedComment xmi:id="_16_5_4_8a30247_1410188461488_459574_3290" annotatedElement="_16_5_4_8a30247_1408964599802_91559_3503" body="&lt;para>Hier wird das Bundesland genannt, in dem sich das Flurstück befindet.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465375451399_94626_5521" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465375451399_21960_5522" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422969627950_52913_6195" name="kodierungFlurstueck" visibility="private" type="_18_0_2_940029b_1577646723035_837384_15544" association="_16_5_4_8ae0277_1427194978142_462923_7460">
              <ownedComment xmi:id="_16_5_4_940029b_1468227329223_484000_5573" annotatedElement="_16_5_4_8a30247_1422969627950_52913_6195" body="&lt;para>Hier sind die identifzierenden Angaben zum Flurstück gemäß Systematik des regionalen Liegenschaftskatasters einzutragen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465375445297_154803_5519" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465375445297_803876_5520" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1460651165974_293124_3777" name="GeoreferenzierteFlaeche">
            <ownedComment xmi:id="_16_5_4_940029b_1461160878182_666896_5884" annotatedElement="_16_5_4_940029b_1460651165974_293124_3777" body="&lt;para>In eine Instanz diesen Typs werden die Geodaten eines Vorhabens oder einer sonstigen Entität in Form von Flächen eingetragen.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_940029b_1465269351210_845309_5051" name="flaeche" visibility="private" type="_16_5_4_940029b_1462299055656_708712_5047" aggregation="composite" association="_16_5_4_940029b_1465269351210_133361_5050">
              <ownedComment xmi:id="_16_5_4_940029b_1465270497478_461035_5532" annotatedElement="_16_5_4_940029b_1465269351210_845309_5051" body="&lt;para>In diesem Element lassen sich georeferenzierte Daten zu Bauvorhaben, Baulasten oder sonstigen Objekten übermitteln, also zu Gegenständen, die im Zusammenhang von XBau-Prozessen näher bestimmt werden sollen. Es  lassen sich hier z. B. die äußeren Kanten eines geplanten Gebäudes (Bauvorhaben) georeferenziert abbilden.&lt;/para>&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1465375574948_447007_5525" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1465375574948_617106_5526" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460559782420_430828_3746" name="erlaeuterung" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_940029b_1461160888499_448047_5886" annotatedElement="_16_5_4_940029b_1460559782420_430828_3746" body="&lt;para>Hier können ergänzend Erläuterungen zur Lage des Bauvorhabens (Vorhabens) auf dem Baugrundstück gegeben werden  (z. B. &quot;Anbau an Nordseite&quot;).&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460560067276_796836_3774" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460560067276_69329_3775" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1577646723035_837384_15544" clientDependency="_18_0_2_940029b_1578181511276_378523_14636" name="KodierungFlurstueck">
            <ownedComment xmi:id="_18_0_2_940029b_1577646723071_147389_15566" annotatedElement="_18_0_2_940029b_1577646723035_837384_15544" body="&lt;para>Dieser Typ deckt Informationen zur Identifikation von Flurstücken (Liegenschaftskataster) ab.&lt;/para>"/>
            <ownedAttribute xmi:id="_18_0_2_940029b_1577646723072_898398_15569" name="gemarkung" visibility="private" type="_19_0_3_940029b_1589627283733_575112_12053">
              <ownedComment xmi:id="_18_0_2_940029b_1577646723074_515398_15581" annotatedElement="_18_0_2_940029b_1577646723072_898398_15569" body="&lt;para>Durch dieses Elements wird die Gemarkung bezeichnet. Sie ist entweder deskriptiv oder als Nummer dargestellt.&lt;/para>&#xA;&#xA;&lt;para>Eine Gemarkung ist eine zusammenhängende, aus mehreren Fluren bestehende Fläche des Liegenschaftskatasters.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1577646723074_569880_15582" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1578177328357_722589_14515" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1577646859247_92204_15654" clientDependency="_18_0_2_940029b_1577648241816_245193_16272" name="flur" visibility="private">
              <ownedComment xmi:id="_18_0_2_940029b_1577646859249_382638_15659" annotatedElement="_18_0_2_940029b_1577646859247_92204_15654" body="&lt;para>Mit diesem Element kann die Nummer der Flur (Flurnummer; maximal 3 Stellen) angegeben werden.&lt;/para> &#xA;&lt;para>Die Flur ist eine zusammenhängende, aus mehreren Flurstücken bestehende Fläche des Liegenschaftskatasters.&lt;/para> &#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1577646859249_872927_15660" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1577646859249_727845_15658" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1577646859248_358183_15655" clientDependency="_18_0_2_940029b_1577649919804_405032_16528" name="zaehler" visibility="private">
              <ownedComment xmi:id="_18_0_2_940029b_1577646859250_190473_15663" annotatedElement="_18_0_2_940029b_1577646859248_358183_15655" body="&lt;para>Dieses Element steht für den Zähler der Flurstücknummer (maximal 5 Stellen). Der Zähler ist der erste Teil der Flurstücksnummer und muss in jedem Fall angegeben werden.&lt;/para>  &#xA;&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1577646859250_85810_15664" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1577646859250_812646_15662" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1577646859248_144146_15656" clientDependency="_18_0_2_940029b_1577649930830_845966_16531" name="nenner" visibility="private">
              <ownedComment xmi:id="_18_0_2_940029b_1577646859250_485411_15667" annotatedElement="_18_0_2_940029b_1577646859248_144146_15656" body="&lt;para>Dieses Element steht für den ggf. anzuführenden Nenner der Flurstücknummer (maximal 4 Stellen). Der Nenner ist der zweite Teil der Flurstücksnummer, üblicherweise in einer Notation durch Schrägstrich vom Zähler getrennt. Die Angabe ist optional.&lt;/para>  &#xA;&#xA;"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1577646859250_241269_15668" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1577646859250_335472_15666" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_18_0_2_940029b_1577646859248_808671_15657" clientDependency="_18_0_2_940029b_1577649941781_529352_16534" name="folge" visibility="private">
              <ownedComment xmi:id="_18_0_2_940029b_1577646859251_248109_15671" annotatedElement="_18_0_2_940029b_1577646859248_808671_15657" body="&lt;para>Dieses Element bietet die Möglichkeit, im Rahmen der Flurstücksnummer auch eine  Flurstücksfolge anzugeben (maximal 2 Stellen). Die Folge ist eine weitere Präzisiserung einer Flurstücksnummer und kann ergänzend angegeben werden.&lt;/para>  "/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191873500_204582_1633"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_18_0_2_940029b_1577646859251_7797_15672" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_18_0_2_940029b_1577646859251_460238_15670" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_8ae0277_1427194978142_462923_7460" name="" memberEnd="_16_5_4_8ae0277_1427194978142_497560_7461 _16_5_4_8a30247_1422969627950_52913_6195">
            <ownedEnd xmi:id="_16_5_4_8ae0277_1427194978142_497560_7461" name="" visibility="private" type="_16_5_4_8a30247_1408964097602_950511_3483" association="_16_5_4_8ae0277_1427194978142_462923_7460"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465269124036_718978_5016" name="" memberEnd="_16_5_4_940029b_1465269124067_598733_5018 _16_5_4_940029b_1465269124067_795564_5017">
            <ownedComment xmi:id="_16_5_4_940029b_1465540439858_361794_5449" annotatedElement="_16_5_4_940029b_1465269124036_718978_5016" body="&lt;para>Doku an der Assoziation zum globalen Element Polygon.&lt;/para>"/>
            <ownedEnd xmi:id="_16_5_4_940029b_1465269124067_795564_5017" name="" visibility="private" type="_16_5_4_940029b_1462299055656_708712_5047" association="_16_5_4_940029b_1465269124036_718978_5016"/>
          </packagedElement>
          <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_940029b_1465269351210_133361_5050" name="" memberEnd="_16_5_4_940029b_1465269351210_845309_5051 _16_5_4_940029b_1465269351210_590067_5052">
