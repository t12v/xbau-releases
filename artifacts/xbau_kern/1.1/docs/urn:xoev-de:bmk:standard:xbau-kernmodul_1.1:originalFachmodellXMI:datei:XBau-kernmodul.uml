              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1592078031275_431909_14450" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1590490173044_649717_12520" name="gerichtSchluessel" visibility="private" type="_19_0_3_940029b_1590489969714_76848_12509">
              <ownedComment xmi:id="_19_0_3_940029b_1590490173067_284893_12547" annotatedElement="_19_0_3_940029b_1590490173044_649717_12520" body="&lt;para>Schlüssel des zuständigen Registergerichts.&lt;/para>"/>
