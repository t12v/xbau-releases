  <XOEVProfil:xoevBBIE xmi:id="_VFkjs5ZUEeyPL_M6Y8GWYA" MotivationDerAbweichung="Keine Abweichung gegen über dem Element name aus NameOrganisation. Die übrigen Elemente von NameOrganisation werden nicht benötigt. " base_Property="_16_5_4_1eeb04c1_1364313743191_46553_9404"/>
