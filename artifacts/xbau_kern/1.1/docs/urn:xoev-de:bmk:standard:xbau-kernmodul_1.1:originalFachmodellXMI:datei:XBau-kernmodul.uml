              <defaultValue xmi:type="uml:LiteralBoolean" xmi:id="_16_5_4_1eeb04c1_1431428226271_921757_3233" name="" value="true"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_1eeb04c1_1431428108514_93970_3186" name="TeilbekanntesDatumMitUnbekannt">
            <ownedComment xmi:id="_16_5_4_1eeb04c1_1431429234421_76217_3261" annotatedElement="_16_5_4_1eeb04c1_1431428108514_93970_3186" body="&lt;para>Mit diesem Datentyp kann entweder ein teilweise bekanntes Datum übermittelt oder angegeben werden, dass ein Tagesdatum vollständig unbekannt ist. Ist das Datum vollständig unbekannt, wird das Kindelement &lt;code>unbekannt&lt;/code> übermittelt, welches den Wert &lt;code>true&lt;/code> enthält.&lt;/para>"/>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1431428237233_221156_3234" name="teilbekanntesDatum" visibility="private" type="_16_5_4_1eeb04c1_1431427442898_519347_3056">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1431429943389_922670_3271" annotatedElement="_16_5_4_1eeb04c1_1431428237233_221156_3234" body="&lt;para>Das teilweise bekannte Datum&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1431428269651_222330_3236" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_1eeb04c1_1431428269651_160367_3237" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_1eeb04c1_1431428269708_384488_3238" name="unbekannt" visibility="private" isReadOnly="true">
              <ownedComment xmi:id="_16_5_4_1eeb04c1_1431429933269_948688_3270" annotatedElement="_16_5_4_1eeb04c1_1431428269708_384488_3238" body="&lt;para>Die Verwendung dieses Merkmals zeigt an, dass das Datum vollständig unbekannt ist.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_1eeb04c1_1431428278443_826162_3240" name="" value="1"/>
