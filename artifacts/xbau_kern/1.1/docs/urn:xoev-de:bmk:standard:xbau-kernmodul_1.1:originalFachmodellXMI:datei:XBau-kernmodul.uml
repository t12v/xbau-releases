        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_940029b_1483303261965_543138_5139" name="Code.XBau-MimeType">
          <ownedComment xmi:id="_16_5_4_940029b_1483303261996_271142_5145" annotatedElement="_16_5_4_940029b_1483303261965_543138_5139" body="&lt;para>Dieser Code-Typ steht für eine Benennung des MimeTypes einer über XBau bereitgestellten Ressource.&lt;/para>&#xA;&#xA;&lt;para>In diesen Typ  ist eine auszuwählende bzw. selbst zu definierende Codeliste einzubinden, die eine dafür passende Auflistung bietet. Im Anwendungskontext sind in die Attribute des vorliegenden Typs die Codelisten-URI und die Nummer der Version der ausgewählten Codeliste (in die XBau-Nachrichteninstanzen) einzutragen.&lt;/para>&#xA;&#xA;&lt;para>Als Muster wurde eine passende Codeliste definiert und als Angebot zur Einbindung für diesen Typ  bereitgestellt. Diese Codeliste kann auf Antrag erweitert bzw. geändert werden. Sie ist  im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter der Codelisten-URI &lt;emphasis role=&quot;italics&quot;>urn:xoev-de:xbau:codeliste:xbau-mimetypes&lt;/emphasis>  auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1423042064805_879401_5866" clientDependency="_19_0_3_136d03d4_1612313747966_653832_13270" name="Code.AmtlicherGemeindeschluessel">
          <ownedComment xmi:id="_16_5_4_8a30247_1423042064821_695502_5872" annotatedElement="_16_5_4_8a30247_1423042064805_879401_5866" body="&lt;para>Diese Codeliste stellt alle Gemeinden Deutschlands durch den Amtlichen Gemeindeschlüssel (AGS) dar, wie im Gemeindeverzeichnis des Statistischen Bundesamtes enthalten. &lt;/para>&#xA;&#xA;&lt;para>Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1591106653830_254650_13207" clientDependency="_19_0_3_136d03d4_1612313731618_963882_13269" name="Code.AmtlicherRegionalschluessel">
          <ownedComment xmi:id="_19_0_3_136d03d4_1591106653836_878077_13208" annotatedElement="_19_0_3_136d03d4_1591106653830_254650_13207" body="&lt;para>Diese Codeliste stellt alle Gemeinden Deutschlands durch den Amtlichen Regionalschlüssel (ARS) dar, wie im Gemeindeverzeichnis des Statistischen Bundesamtes enthalten. &lt;/para>&#xA;&#xA;&lt;para>Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1566915669224_70813_14791" clientDependency="_19_0_3_136d03d4_1612313714736_83434_13268" name="Code.Bezirk">
          <ownedComment xmi:id="_18_0_2_940029b_1566915669224_573255_14792" annotatedElement="_18_0_2_940029b_1566915669224_70813_14791" body="&lt;para>Diese Codeliste stellt alle Bezirke nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS). &lt;/para>&#xA;&#xA;&lt;para>Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1423044461203_939066_6394" clientDependency="_19_0_3_136d03d4_1612313695569_391490_13267" name="Code.Bundesland">
          <ownedComment xmi:id="_16_5_4_8a30247_1423044461203_734293_6400" annotatedElement="_16_5_4_8a30247_1423044461203_939066_6394" body="&lt;para>Diese Codeliste stellt die deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS). &lt;/para>&#xA;&#xA;&lt;para>Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1423044922195_172323_6450" clientDependency="_19_0_3_136d03d4_1612313676049_684572_13266" name="Code.Erreichbarkeit">
          <ownedComment xmi:id="_16_5_4_8a30247_1423044922198_351255_6456" annotatedElement="_16_5_4_8a30247_1423044922195_172323_6450" body="&lt;para>Die von der XÖV-Koordination bereitgestellte Codeliste beschreibt die gängigen Kanäle der Kommunikation wie z. B. Telefon und E-Mail, über die eine natürliche Person erreichbar sein kann.&lt;/para>&#xA;&#xA;&lt;para>Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1566915166057_468728_14664" name="Code.Gemeindeteil">
          <ownedComment xmi:id="_18_0_2_940029b_1566915166057_601124_14665" annotatedElement="_18_0_2_940029b_1566915166057_468728_14664" body="&lt;para>Diese Codeliste steht für lokal definierte Schlüssel, die die Gemeindeteile einer Gemeinde bezeichnen. Dieser Schlüssel ist, weil nur innerhalb eines Landes definiert, nicht Bestandteil des Amtlichen Gemeindeschlüssels (AGS). &lt;/para>&#xA;&#xA;&lt;para>In diesen Typ  ist eine auszuwählende bzw. selbst zu definierende Codeliste einzubinden, die eine solche Klassifikation bietet. Im Anwendungskontext sind in die Attribute des vorliegenden Typs die Codelisten-URI und die Nummer der Version der ausgewählten Codeliste (in die XBau-Nachrichteninstanzen) einzutragen.&lt;/para>&#xA;&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1566915051326_853293_14641" clientDependency="_19_0_3_136d03d4_1612313573418_68294_13263" name="Code.Kreis">
          <ownedComment xmi:id="_18_0_2_940029b_1566915051326_236946_14642" annotatedElement="_18_0_2_940029b_1566915051326_853293_14641" body="&lt;para>Diese Codeliste stellt die Landkreise nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS). &lt;/para>&#xA;&#xA;&lt;para>Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_940029b_1590489969714_76848_12509" clientDependency="_19_0_3_136d03d4_1612313536170_74915_13261" name="Code.Registergericht"/>
        <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1423043972175_271232_6283" clientDependency="_19_0_3_136d03d4_1612313497893_672951_13259" name="Code.Staat">
          <ownedComment xmi:id="_16_5_4_8a30247_1423043972191_96309_6289" annotatedElement="_16_5_4_8a30247_1423043972175_271232_6283" body="&lt;para>Codeliste Staatsgebiete aus der Staats- und Gebietssystematik des Statistischen Bundesamtes.Sie basiert auf dem &lt;quote>Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote> des Auswärtigen Amtes. &lt;/para>&#xA;&#xA;&lt;para>Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313747966_653832_13270" name="" client="_16_5_4_8a30247_1423042064805_879401_5866" supplier="_19_0_3_136d03d4_1612313332045_62531_9591"/>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313731618_963882_13269" name="" client="_19_0_3_136d03d4_1591106653830_254650_13207" supplier="_19_0_3_136d03d4_1612313332050_480442_9596"/>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313714736_83434_13268" name="" client="_18_0_2_940029b_1566915669224_70813_14791" supplier="_19_0_3_136d03d4_1612313332051_551267_9598"/>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313695569_391490_13267" name="" client="_16_5_4_8a30247_1423044461203_939066_6394" supplier="_19_0_3_136d03d4_1612313332051_117859_9599"/>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313676049_684572_13266" name="" client="_16_5_4_8a30247_1423044922195_172323_6450" supplier="_19_0_3_136d03d4_1612313332046_805113_9592"/>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313573418_68294_13263" name="" client="_18_0_2_940029b_1566915051326_853293_14641" supplier="_19_0_3_136d03d4_1612313332046_407020_9594"/>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313536170_74915_13261" name="" client="_19_0_3_940029b_1590489969714_76848_12509" supplier="_19_0_3_136d03d4_1612313332051_671210_9600"/>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313497893_672951_13259" name="" client="_16_5_4_8a30247_1423043972175_271232_6283" supplier="_19_0_3_136d03d4_1612313332050_732201_9597"/>
        <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1552127588117_500969_14828" name="Code.FormelleBefundeArt">
          <ownedComment xmi:id="_18_0_2_940029b_1552127588118_607405_14829" annotatedElement="_18_0_2_940029b_1552127588117_500969_14828" body="&lt;para>Arten von Befunden einer universell einsetzbaren Befundliste für die formelle Prüfung von Anträgen, Anzeigen und Erklärungen.&lt;/para>&#xA;&#xA;&lt;para>In diesen Typ  ist eine auszuwählende bzw. selbst zu definierende Codeliste einzubinden, die eine solche Klassifikation bietet. Im Anwendungskontext sind in die Attribute des vorliegenden Typs die Codelisten-URI und die Nummer der Version der ausgewählten Codeliste (in die XBau-Nachrichteninstanzen) einzutragen.&lt;/para>&#xA;&#xA;&lt;para>Als Muster wurde die Codeliste &lt;quote>Befunde einer formellen Prüfung&lt;/quote> (URI: &lt;emphasis role=&quot;italics&quot;>urn:xoev-de:xbau:codeliste:formellebefundeart&lt;/emphasis>) als Angebot zur Einbindung für diesen Typ  bereitgestellt. &lt;/para>&#xA;&#xA;&lt;para>Die angebotene Codeliste ist  im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter dem Stichwort &quot;XBau&quot; auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_18_0_2_940029b_1541261707920_683057_11719" clientDependency="_19_0_3_136d03d4_1612313438678_468904_13256" name="Code.XBau.Fehlerkennzahl">
          <ownedComment xmi:id="_18_0_2_940029b_1541261707936_656946_11721" annotatedElement="_18_0_2_940029b_1541261707920_683057_11719" body="&lt;para>Codeliste der Fehlerkennzahlen für die Klassifizierung von Fehlern. Die Einträge bestehen aus Fehlerkennzahl und deren Bedeutung. Die Liste wird durch XBau gepflegt. &lt;/para>&#xA;&#xA;&lt;para>Sie ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter der Codelisten-URI auffindbar. Ihre Versionen können von dort im XML-Format OASIS Genericode abgerufen werden.&lt;/para>&#xA;&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1612313438678_468904_13256" name="" client="_18_0_2_940029b_1541261707920_683057_11719" supplier="_19_0_3_136d03d4_1612313332043_678337_9586"/>
        <packagedElement xmi:type="uml:Dependency" xmi:id="_19_0_3_136d03d4_1615216900853_192151_9601" name="" client="_19_0_3_136d03d4_1615208012576_880185_9581" supplier="_16_5_4_5b501fb_1387625280030_115253_5005"/>
        <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1615476797907_523392_9724" clientDependency="_19_0_3_136d03d4_1615477029562_765218_9727" name="Code.XBau-KernmodulNachrichten">
          <ownedComment xmi:id="_19_0_3_136d03d4_1615476797909_632334_9725" annotatedElement="_19_0_3_136d03d4_1615476797907_523392_9724" body="&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Usage" xmi:id="_19_0_3_136d03d4_1615477029562_765218_9727" name="" client="_19_0_3_136d03d4_1615476797907_523392_9724" supplier="_19_0_3_136d03d4_1615465030210_782222_9407"/>
        <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_136d03d4_1629826627962_517090_9457" name="Code.Ablageort">
          <ownedComment xmi:id="_19_0_3_136d03d4_1629826627968_413480_9458" annotatedElement="_19_0_3_136d03d4_1629826627962_517090_9457" body="&lt;para>Diese Codeliste enthält Ablageorte des Projektraums, an dem ein Dokument abgelegt werden soll.&lt;/para>&#xA;&#xA;&lt;para>In diesen Typ  ist eine auszuwählende bzw. selbst zu definierende Codeliste einzubinden, die eine solche Klassifikation bietet. Im Anwendungskontext sind in die Attribute des vorliegenden Typs die Codelisten-URI und die Nummer der Version der ausgewählten Codeliste (in die XBau-Nachrichteninstanzen) einzutragen.&lt;/para>&#xA;&#xA;"/>
        </packagedElement>
        <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_940029b_1629982356132_732557_9504" name="Code.AnlageArt">
          <ownedComment xmi:id="_19_0_3_940029b_1629982356134_235994_9505" annotatedElement="_19_0_3_940029b_1629982356132_732557_9504" body="&lt;para>Dieser Code-Datentyp dient der Einbindung einer Codeliste, die Arten von Bauvorlagen oder sonstigen Anlagen unterscheidet, die einer XBau-Nachricht als Anlage beigefügt sein können. &lt;/para>&#xA;&#xA;&lt;para>In diesen Typ ist eine auszuwählende bzw. selbst zu definierende Codeliste einzubinden, die eine solche Klassifikation bietet. Im Anwendungskontext sind in die Attribute des vorliegenden Typs die Codelisten-URI und die Nummer der Version der ausgewählten Codeliste (in die XBau-Nachrichteninstanzen) einzutragen.&lt;/para>&#xA;&#xA;&lt;para>Codelisten, die im Rahmen des Betriebs XBau definiert und im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) bereitgestellt werden, und ggf. für den vorliegenden Zweck geeignet sein können:&lt;/para>&#xA;&#xA;&lt;itemizedlist>&#xA;  &lt;listitem>&#xA;    &lt;para>urn:xoev-de:xbau:codeliste:anlagen&lt;/para>&#xA;  &lt;/listitem>&#xA;&lt;/itemizedlist>"/>
        </packagedElement>
      </packagedElement>
      <packagedElement xmi:type="uml:Package" xmi:id="_19_0_3_136d03d4_1615207989277_776469_9579" clientDependency="_19_0_3_136d03d4_1615217099584_734726_9606 _19_0_3_136d03d4_1615217253369_255081_9608 _19_0_3_136d03d4_1615217056852_880776_9603 _19_0_3_136d03d4_1615217273002_824993_9609 _19_0_3_136d03d4_1615217285891_756200_9610 _19_0_3_136d03d4_1615221585090_709514_9335 _19_0_3_c4f030d_1631176837763_25257_9471" name="Datentypen" URI="">
        <packagedElement xmi:type="uml:Package" xmi:id="_19_0_3_136d03d4_1612479027755_244106_9332" name="fachuebergrBausteine" URI="">
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422955529766_893716_5914" name="AllgemeinerName">
            <ownedComment xmi:id="_16_5_4_8a30247_1422955529766_553979_5920" annotatedElement="_16_5_4_8a30247_1422955529766_893716_5914" body="&lt;para>Der AllgemeineName dient der Darstellung von Vor- und Nachnamen und fasst deren  gemeinsame Eigenschaften zusammen.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955529766_536500_5916" name="name" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955529797_194605_5964" annotatedElement="_16_5_4_8a30247_1422955529766_536500_5916" body="&lt;para>Die Komponente &quot;name&quot; ist der  Familien- oder Vorname als Zeichenkette.&lt;/para> &#xA;&lt;para>Nachnamen, z.B.  mit Adelstiteln bzw. ausländische Nachnamen werden als ein Name übermittelt und nicht in verschiedene Bestandteile aufgeteilt.&lt;/para> &#xA;&#xA;&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_512651_5963" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_737978_5965" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955529766_12705_5917" name="nichtVorhanden" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955529797_243429_5968" annotatedElement="_16_5_4_8a30247_1422955529766_12705_5917" body="&lt;para>Diese Komponente beinhaltet eine Feststellung (wahr oder falsch), ob zu Recht kein Name angegeben wurde. Ueber das Setzen auf TRUE, wird angezeigt, dass zurecht kein Name angegeben wurde.&lt;/para> "/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955529797_108430_5967" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422955529797_277543_5969" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422884384004_352244_4233" clientDependency="_16_5_4_8ae0277_1427193531907_193244_6959 _16_5_4_8ae0277_1427197248344_315701_9035" name="Anschrift">
            <ownedComment xmi:id="_16_5_4_8a30247_1422884384004_53636_4250" annotatedElement="_16_5_4_8a30247_1422884384004_352244_4233" body="&lt;para>Eine Anschrift beschreibt einen Ort mit den klassischen Ordnungsbegriffen wie Orts- und Straßennamen sowie ergänzenden Informationen wie Ortsteil und Postfach.&lt;/para>&#xA;&lt;para>Diese Klasse ist von der XÖV-Kernkomponente Anschrift abgeleitet. Sie verwendet ein ergänztes Element &lt;emphasis role=&quot;codebf&quot;>strasseHausnummer&lt;/emphasis>.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743609_24748_12229" name="strasse" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743635_651690_12240" annotatedElement="_19_0_3_940029b_1589655743609_24748_12229" body="&lt;para>Dieses Element bildet den Namen (die Bezeichnung) der Straße ab.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743637_163507_12241" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743634_165396_12239" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743616_508720_12230" name="hausnummer" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743640_144489_12244" annotatedElement="_19_0_3_940029b_1589655743616_508720_12230" body="&lt;para>Dieses Element nimmt die Hausnummer auf (einschließlich eines möglichen Buchstabens, der zur Hausnummer gehört, wie z.B. 39b).&lt;/para> &#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743641_263194_12245" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743639_821848_12243" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743618_296305_12231" clientDependency="_19_0_3_136d03d4_1590350634246_938655_12550 _19_0_3_136d03d4_1590350435511_254662_12548" name="strasseHausnummer" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743643_78153_12248" annotatedElement="_19_0_3_940029b_1589655743618_296305_12231" body="&lt;para>Element für die Erfassung von Straße und Hausnummer als undifferenzierte Zeichenkette (nur für bestimmte Kontexte: ersetzt dann die Verwendung der Elemente &lt;emphasis role=&quot;codebf&quot;>strasse&lt;/emphasis> und &lt;emphasis role=&quot;codebf&quot;>hausnummer&lt;/emphasis>).&lt;/para>&#xA;&lt;para>Falls sich in einem Kontext der Übernahme von Anschriftsdaten (z.B. bei Verwendung der eID-Funktion des maschinenlesbaren Personalausweises für die Erfassung der Daten des Antragstellers) die Bezeichnung der Straße und die Hausnummer nicht maschinell zuverlässig trennen lassen, können diese Informationen in das Element als eine gemeinsame Zeichenkette übernommen werden.&lt;/para> &#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743644_30841_12249" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1589655743642_791533_12247" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743621_451790_12232" name="postfach" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743647_844110_12252" annotatedElement="_19_0_3_940029b_1589655743621_451790_12232" body="&lt;para>Ein Postfach (oft Postfachnummer) ist ein Schlüssel zur Identifikation eines Postfaches in einer Postfiliale.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743647_399065_12253" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743646_563192_12251" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743623_997549_12233" name="postleitzahl" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743650_268619_12256" annotatedElement="_19_0_3_940029b_1589655743623_997549_12233" body="&lt;para>Eine Postleitzahl ist eine Angabe, um postalische Zustellgebiete unabhängig von Gebietskörperschaften (Gemeinde, Kreis) zu bezeichnen.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743650_840855_12257" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743649_804697_12255" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743624_940876_12234" name="ort" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743652_473661_12260" annotatedElement="_19_0_3_940029b_1589655743624_940876_12234" body="&lt;para>Dieses Element enthält den Namen des Ortes (Gemeinde, Ortschaft oder Stadt), zu der die Anschrift gehört.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743653_79725_12261" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743651_931506_12259" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743626_197976_12235" name="ortsteil" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743654_810752_12264" annotatedElement="_19_0_3_940029b_1589655743626_197976_12235" body="&lt;para>Der Ortsteil umfasst ein Teilgebiet des Ortes (der Gemeinde) und dient der Untergliederung.&lt;/para>&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743655_149031_12265" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743654_135179_12263" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743628_312805_12236" name="wohnungsgeber" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743657_164964_12268" annotatedElement="_19_0_3_940029b_1589655743628_312805_12236" body="&lt;para>Die Komponente &quot;wohnungsgeber&quot; enthält Angaben (Name/Bezeichnung) zum Hauptmieter oder Eigentümer einer Immobilie.&lt;/para>&#xA;&#xA;&lt;para>Die Angabe eines Wohnungsgebers im Kontext der Anschrift dient der genaueren oder leichteren Adressierung. Sie darf nicht genutzt werden um Mietverhältnisse oder ähnliche rechtliche Beziehungen zwischen Personen auszudrücken.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: bei Meyer&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743658_29645_12269" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743657_137734_12267" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743630_512110_12237" name="zusatz" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743659_587537_12272" annotatedElement="_19_0_3_940029b_1589655743630_512110_12237" body="&lt;para>Ein Anschriftenzusatz beinhaltet ggf. erforderliche weitere Präzisierungen zu einer Anschrift.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: Hinterhof, 3. Aufgang, Haus A, 3. Stock, Appartement 25a,  3. Stock - Appartement 25 a, #325a, Raum 77&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743659_14043_12273" name=""/>
              <upperValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743658_653450_12271" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1589655743631_394452_12238" name="staat" visibility="private" type="_16_5_4_940029b_1422888807308_342425_3010" aggregation="composite">
              <ownedComment xmi:id="_19_0_3_940029b_1589655743660_782892_12276" annotatedElement="_19_0_3_940029b_1589655743631_394452_12238" body="&lt;para>Der Staat, dem die Anschrift postalisch zugeordnet wird.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1589655743660_20148_12277" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1589655743660_911774_12275" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422894619924_503273_3379" clientDependency="_16_5_4_8ae0277_1427193463099_815271_6947 _16_5_4_8ae0277_1427196503513_568354_8735" name="Kommunikation">
            <ownedComment xmi:id="_16_5_4_8a30247_1422894619924_612939_3385" annotatedElement="_16_5_4_8a30247_1422894619924_503273_3379" body="&lt;para>&quot;Kommunikation&quot; fasst Angaben zur Erreichbarkeit über elektronische Kommunikationskanäle (z.B. Telefon, Fax, E-Mail) zusammen.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_583177_3381" clientDependency="_16_5_4_8ae0277_1427196509903_464243_8738" name="kanal" visibility="private" type="_16_5_4_8a30247_1423044922195_172323_6450">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_400513_3423" annotatedElement="_16_5_4_8a30247_1422894619924_583177_3381" body="&lt;para>Der &quot;kanal&quot; gibt an, über welchen Kommunikationskanal eine Erreichbarkeit besteht (Telefon, E-Mail usw.).&lt;/para>  &#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_949595_3422" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_536564_3424" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_870277_3382" clientDependency="_16_5_4_8ae0277_1427196516639_628708_8741" name="kennung" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_381305_3427" annotatedElement="_16_5_4_8a30247_1422894619924_870277_3382" body="&lt;para>Die &quot;kennung&quot; beinhaltet die konkreten Angaben zur Erreichbarkeit über einen Kommunikationskanal, d.h. die Telefonnummer, Faxnummer, E-Mail-Adresse oder dergleichen. Die Kennung soll strukturiert erfasst werden.&lt;/para>&#xA;&#xA;&lt;para>Beispiele: +49 30 12345-67 (internationale Rufnummer nach DIN 5008)&#xA;&#xA;030 12345-67 ( nationale Rufnummern nach DIN 5008)&#xA;&#xA;+49 89 1234567 (internationale Rufnummer nach E.123)&#xA;&#xA;(089) 123456) (nationale Rufnummer nach E.123)&#xA;&#xA;tel:+49-30-1234567 (Uniform Resource Identifier nach RFC 3966)&lt;/para>&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_907455_3426" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_970802_3428" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_202463_3383" name="istDienstlich" visibility="private">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_69296_3431" annotatedElement="_16_5_4_8a30247_1422894619924_202463_3383" body="&lt;para>Mit der Komponente &quot;istDienstlich&quot; kann angegeben werden, ob es sich um dienstliche oder private Kommunikationsdaten handelt.&lt;/para>"/>
              <type xmi:type="uml:Class" href="XOEV-Profil.profile.uml#_14_0_1_6370212_1218191716468_578747_1004"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_691580_3430" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619940_150044_3432" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422894619924_228031_3384" name="zusatz" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_8a30247_1422894619940_510860_3435" annotatedElement="_16_5_4_8a30247_1422894619924_228031_3384" body="&lt;para>Im &quot;zusatz&quot; können zusätzliche freie Angaben zur Erreichbarkeit über einen Kommunikationskanal gemacht werden.&lt;/para> &#xA;&#xA;&lt;para>Beispiel: erreichbar tagsüber zwischen 9 und 16 Uhr&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422894619940_525294_3434" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422894619955_829010_3436" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422955073653_603895_5103" clientDependency="_16_5_4_8ae0277_1427196365903_938927_8698" name="NameNatuerlichePerson">
            <ownedComment xmi:id="_16_5_4_8a30247_1422955073653_702979_5120" annotatedElement="_16_5_4_8a30247_1422955073653_603895_5103" body="&lt;para>Der Name einer Person ist eine Benennung dieser Person, die dazu dient, diese Person von anderen Personen zu unterscheiden.&lt;/para>&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_897530_5113" clientDependency="_16_5_4_8ae0277_1427196387606_122294_8701" name="titel" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_967723_5280" annotatedElement="_16_5_4_8a30247_1422955073653_897530_5113" body="&lt;para>Ein Titel wird häufig im Zusammenhang mit Namen verwendet, ist aber  kein orginärer Bestandteil des Namens. Im Unterschied dazu gehören Adelstitel zum Familiennamen und sind daher in diesem Verständnis kein Titel. Zu den Titeln zählen beispielsweise akademische Grade, Dienst- und Amtsbezeichnungen oder militärische Ränge. Es können auch Titel übermittelt werden, die keine Titel im Sinne des Meldewesens sind.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: Dr.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422955073794_566369_5279" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422955073794_777288_5281" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_433210_5114" name="anrede" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_891832_5284" annotatedElement="_16_5_4_8a30247_1422955073653_433210_5114" body="&lt;para>Die Anrede ist der Namenszusatz (auch eine Anrede ohne Namen nur mit Titel ist eine Anrede) bei der Anrede (mündlich oder schriftlich) oder bei einem Anruf (fernmündlich) an eine Person oder Personengruppe.&lt;/para>&#xA;&#xA;&lt;para>Anmerkung: Die komplette Anrede einer Person kann in einem Feld übermittelt werden.&lt;/para>&#xA;&#xA;&lt;para>Beispiel: Herr, Frau, Herr Staatssekretär, Frau Bundeskanzlerin, Herr Botschafter, Eure Eminenz&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621011095_467363_3910" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621011095_18399_3911" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_116526_5106" clientDependency="_16_5_4_8ae0277_1427196440753_243032_8707" name="familienname" visibility="private" type="_16_5_4_8a30247_1422955529766_893716_5914" aggregation="composite" association="_16_5_4_8ae0277_1427196276261_283770_8628">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_120326_5252" annotatedElement="_16_5_4_8a30247_1422955073653_116526_5106" body="&lt;para>Der Familienname ist der aktuelle Nachname einer Person und Ausdruck einer bestimmten Familienzugehörigkeit dieser Person.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621123614_669924_3912" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621123614_270154_3913" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422955073653_701701_5110" clientDependency="_16_5_4_8ae0277_1427196421259_460285_8704" name="vorname" visibility="private" type="_16_5_4_8a30247_1422955529766_893716_5914" aggregation="composite" association="_16_5_4_8ae0277_1427196267171_513183_8533">
              <ownedComment xmi:id="_16_5_4_8a30247_1422955073794_942027_5268" annotatedElement="_16_5_4_8a30247_1422955073653_701701_5110" body="&lt;para>Der Vorname ist der Name bzw. der Teil des Namens, der nicht die Zugehörigkeit zu einer Familie ausdrückt, sondern das Individuum innerhalb der Familie bezeichnet und dazu dient, es von anderen Familienmitgliedern zu unterscheiden.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460621132576_435657_3914" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460621132576_234_3915" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422957408723_400098_8364" clientDependency="_16_5_4_8ae0277_1427193489689_812796_6950" name="NameOrganisation">
            <ownedComment xmi:id="_16_5_4_8a30247_1422957408723_801794_8369" annotatedElement="_16_5_4_8a30247_1422957408723_400098_8364" body="&lt;para>&quot;NameOrganisation&quot; fasst die Angaben zum Namen einer Organisation zusammen.&lt;/para> "/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957408723_631641_8366" name="name" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957408770_89516_8412" annotatedElement="_16_5_4_8a30247_1422957408723_631641_8366" body="&lt;para>Offizieller Name einer Organisation. Entspricht bei registrierten Organisationen dem im Register eingetragenen Namen.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460623839986_414204_4726" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460623839986_120551_4727" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422957408723_203762_8367" name="kurzbezeichnung" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_16_5_4_8a30247_1422957408770_938031_8416" annotatedElement="_16_5_4_8a30247_1422957408723_203762_8367" body="&lt;para>Kurzbezeichnung des Namen einer Organisation.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422957408770_737842_8415" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422957408770_660999_8417" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_16_5_4_8a30247_1422977426041_172815_6757" clientDependency="_16_5_4_8ae0277_1427193498410_184944_6953" name="Organisation">
            <ownedComment xmi:id="_16_5_4_8a30247_1422977426056_688199_6771" annotatedElement="_16_5_4_8a30247_1422977426041_172815_6757" body="&lt;para>Eine Organisation ist eine  Vereinigung mehrerer natürlicher oder juristischer Personen bzw. eine rechtsfähige Personengesellschaft zu einem gemeinsamen Zweck, z.B.  im wirtschaftlichen, gemeinnützigen, religiösen, öffentlichen oder politischen Bereich.&lt;/para>&#xA;&#xA;"/>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426041_754458_6765" clientDependency="_16_5_4_8ae0277_1427193864249_936524_7178" name="name" visibility="private" type="_16_5_4_8a30247_1422957408723_400098_8364" aggregation="composite" association="_16_5_4_8ae0277_1427191914590_100076_5913">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_492509_6881" annotatedElement="_16_5_4_8a30247_1422977426041_754458_6765" body="&lt;para>Angaben zum offiziellen Namen der Organisation.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460623828363_397124_4724" name="" value="1"/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460623828363_231187_4725" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426056_110707_6767" name="anschrift" visibility="private" type="_16_5_4_8a30247_1422884384004_352244_4233" aggregation="composite" association="_16_5_4_8ae0277_1427192330303_284590_6843">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_843785_6889" annotatedElement="_16_5_4_8a30247_1422977426056_110707_6767" body="&lt;para>Angaben zur Anschrift der Organisation, die über den Typ der Anschrift auf deren Verwendung als Postanschrift, Niederlassungsanschrift oder Gründungsanschrift verweist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977426150_462413_6888" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977426150_706309_6890" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_8a30247_1422977426041_568786_6761" name="kommunikation" visibility="private" type="_16_5_4_8a30247_1422894619924_503273_3379" aggregation="composite" association="_16_5_4_8ae0277_1427191961941_338157_6253">
              <ownedComment xmi:id="_16_5_4_8a30247_1422977426150_701628_6865" annotatedElement="_16_5_4_8a30247_1422977426041_568786_6761" body="&lt;para>Unter &quot;kommunikation&quot; werden Angaben zur Erreichbarkeit einer Organisation über elektronische Kommunikationskanäle zusammengefasst.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_8a30247_1422977426150_839361_6864" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_8a30247_1422977426150_271056_6866" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_16_5_4_940029b_1460624135928_771822_4802" name="vertreter" visibility="private" type="_16_5_4_8a30247_1422955073653_603895_5103" association="_16_5_4_940029b_1460624135928_756920_4800">
              <ownedComment xmi:id="_16_5_4_940029b_1483458770760_264485_4562" annotatedElement="_16_5_4_940029b_1460624135928_771822_4802" body="&lt;para>Angaben zu Personen, die autorisiert sind, für die Organisation zu sprechen. Dies kann z. B. ein Mitglied der Geschäftsleitung sein.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_16_5_4_940029b_1460624135928_538610_4804" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_16_5_4_940029b_1460624135928_219294_4805" name="" value="*"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_136d03d4_1592308467398_364415_14476" name="ansprechpartner" visibility="private" type="_16_5_4_8a30247_1422955073653_603895_5103">
              <ownedComment xmi:id="_19_0_3_136d03d4_1592308467398_707031_14478" annotatedElement="_19_0_3_136d03d4_1592308467398_364415_14476" body="&lt;para>Angaben zu einer Person, die operativ für das Bauvorhaben zuständig ist.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_136d03d4_1592308467398_631101_14479" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_136d03d4_1592308467398_102450_14477" name="" value="1"/>
            </ownedAttribute>
            <ownedAttribute xmi:id="_19_0_3_940029b_1590490519004_446422_12575" name="registereintrag" visibility="private" type="_19_0_3_940029b_1590490173021_330823_12511">
              <ownedComment xmi:id="_19_0_3_136d03d4_1590982087098_721806_13557" annotatedElement="_19_0_3_940029b_1590490519004_446422_12575" body="&lt;para>Angaben zum Registereintrag einer natürlichen oder juristischen Person oder&#xA;Personengesellschaft.&lt;/para>"/>
              <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_940029b_1590490545609_180712_12577" name=""/>
              <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_940029b_1590490545610_876893_12578" name="" value="1"/>
            </ownedAttribute>
          </packagedElement>
          <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_940029b_1590490173021_330823_12511" name="Registereintrag">
            <ownedComment xmi:id="_19_0_3_940029b_1590490173030_987535_12514" annotatedElement="_19_0_3_940029b_1590490173021_330823_12511" body="&lt;para>Mit diesem Typ werden Angaben zum Registereintrag einer natürlichen oder juristischen Person oder Personengesellschaft übermittelt.&lt;/para>"/>
            <ownedAttribute xmi:id="_19_0_3_940029b_1590490173040_351132_12517" name="eintragungNr" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
              <ownedComment xmi:id="_19_0_3_940029b_1590490173060_721982_12535" annotatedElement="_19_0_3_940029b_1590490173040_351132_12517" body="&lt;para>Nummer der Eintragung im Handels-, Genossenschafts- oder Vereinsregister.&lt;/para>"/>
