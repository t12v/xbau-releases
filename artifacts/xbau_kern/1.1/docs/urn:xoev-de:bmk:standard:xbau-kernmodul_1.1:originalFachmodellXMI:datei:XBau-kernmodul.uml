  <XOEVProfil:xoevVersionCodeliste xmi:id="_VFo1KJZUEeyPL_M6Y8GWYA" version="3" datumGueltigkeitAb="2018-05-03" aenderungZurVorversion="Der Code 09 mit der Beschreibung &quot;Web&quot; wurde hinzugefügt. Die Beschreibung der Codeliste wurde angepasst, da die Codeliste auch zur Bestimmung der Erreichbarkeit von Institutionen genutzt werden kann." base_Class="_19_0_3_136d03d4_1612313332079_508672_9708" versionCodelistenHandbuch="1.0"/>
  <XOEVProfil:xoevVersionCodeliste xmi:id="_VFo1KZZUEeyPL_M6Y8GWYA" version="1.0" base_Class="_19_0_3_136d03d4_1615465030210_782222_9407" versionCodelistenHandbuch="1.1"/>
  <XOEVProfil:xoevVersionStandard xmi:id="_VFo1KpZUEeyPL_M6Y8GWYA" base_Model="_16_5_4_b7102e0_1292419822540_950613_464" version="9" versionXOEVHandbuch="2.3" versionXGenerator="3.0.1" versionModellierungswerkzeug="19.0 SP4"/>
  <XOEVProfil:xoevVersionStandard xmi:id="_VFqDQJZUEeyPL_M6Y8GWYA" base_Model="_16_5_4_1d100e5_1384794823532_59933_328" version="1.1" beschreibung="Das XBau-Kernmodul wurde in dieser Version ergänzt um weitere generische Prozessnachrichten, beispielsweise zum Einstellen von Dokumenten in einen Projektraum des Antragsportals. Oder zur informellen Kommunikation der an einem Vorgang Beteiligten (was in der Praxis bisher als E-Mail-Kommunikation ablief). Die Datentypen zu Metadaten von Bauvorlagen (und sonstigen Anlagen zu XBau-Nachrichten) wurden konsolidiert. Jetzt muss ein Dokument entweder als Anhang (Attachment) mit einer XBau-Nachricht versendet werden oder per Link (z.B. auf eine Ressource in einem DMS) referenziert werden, der in der XBau-Nachricht enthalten ist (keine base64-Kodierung mehr innerhalb der XBau-Fachnachricht). Außerdem sind jetzt auch im XBau-Kernmodul Definitionen für DVDV-Dienste mit den passenden WSDL-Vorlagedateien enthalten." versionXOEVHandbuch="2.3" versionXGenerator="3.0.1" versionModellierungswerkzeug="19.0"/>
  <XOEVProfil:xoevVersionStandard xmi:id="_VFqDQZZUEeyPL_M6Y8GWYA" base_Model="_18_0_2_8c5027b_1530282394636_112672_9470"/>
  <XOEVProfil:xoevBibliothek xmi:id="_VFqDQpZUEeyPL_M6Y8GWYA" nameLang="XÖV-Bibliothek: Spezifikation der XÖV-Datentypen und XÖV-Kernkomponenten" nameKurz="XÖV-Bibliothek" nameTechnisch="XOEV-Bibliothek" kennung="urn:xoev-de:kosit:xoev:bibliothek:xoevbibliothek" beschreibung="Die XÖV-Bibliothek ist der zentrale Ort zur Verwaltung und Bereitstellung aller XÖV-spezifischer, zur Wiederverwendung vorgesehener XÖV-Bausteine.&#xA;&#xA;Ausnahme bilden die Bausteine der Art &quot;Codeliste&quot;, die ausschließlich über das XRepository bereitgestellt werden." herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT" externeWebsite="http://www.xoev.de/de/bibliothek" statusVerwendung="AKTUELL" base_Model="_16_5_4_5b501fb_1375258090807_886576_2132"/>
