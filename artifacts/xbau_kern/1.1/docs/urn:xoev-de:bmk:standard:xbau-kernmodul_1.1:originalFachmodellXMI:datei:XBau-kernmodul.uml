  <XOEVProfil:xoevABIE xmi:id="_VFhgaJZUEeyPL_M6Y8GWYA" base_Class="_18_0_2_940029b_1577646723035_837384_15544" Abweichung="Abweichende Bezeichnung der Klasse" MotivationDerAbweichung="Es werden von der Kernkomponente Geokodierung nur die Eigenschaften verwendet, die sich auf das Liegenschaftskataster beziehen."/>
  <XOEVProfil:xoevABIE xmi:id="_VFhgaZZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_8a30247_1408964097602_950511_3483"/>
  <XOEVProfil:xoevABIE xmi:id="_VFhgapZUEeyPL_M6Y8GWYA" base_Class="_18_0_2_940029b_1566914340130_207583_14410" Abweichung="Reihenfolge wurde umgestellt, so dass die Sequenz dem Aufbau des AGS entspricht (Land, Bezirk, Kreis, Gemeinde)" MotivationDerAbweichung="Verbesserung von Nachvollziehbarkeit und Konsistenz"/>
  <XOEVProfil:xoevABIE xmi:id="_VFhga5ZUEeyPL_M6Y8GWYA" base_Class="_16_5_4_940029b_1422888807308_342425_3010"/>
