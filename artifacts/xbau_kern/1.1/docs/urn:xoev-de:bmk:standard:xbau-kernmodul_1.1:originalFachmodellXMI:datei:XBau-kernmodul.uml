  <XOEVProfil:xoevKernkomponentenkatalog xmi:id="_VFnnDpZUEeyPL_M6Y8GWYA" base_Element="_16_5_4_5b501fb_1377673897130_313564_2218"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFnnD5ZUEeyPL_M6Y8GWYA" nameLang="Gemeinden, dargestellt durch den Amtlichen Gemeindeschlüssel (AGS) des Statistischen Bundesamtes" nameKurz="AGS" nameTechnisch="AGS" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:ags" beschreibung="Diese Codeliste stellt alle Gemeinden Deutschlands durch den Amtlichen Gemeindeschlüssel (AGS) dar, wie im Gemeindeverzeichnis des Statistischen Bundesamtes enthalten. Darüber hinaus enthält die Codeliste für die Stadtstaaten Hamburg, Bremen und Berlin Einträge für Stadt-/Ortsteile bzw. Stadtbezirke. Diese Einträge sind mit einem entsprechenden Hinweis versehen." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis" base_Class="_19_0_3_41901a4_1602870438209_953294_7747"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFnnEJZUEeyPL_M6Y8GWYA" nameLang="Codeliste Staat aus der Staats- und Gebietssystematik des Statistischen Bundesamtes" nameKurz="DESTATIS Staatenliste" nameTechnisch="Staat" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:staat" beschreibung="Die Codeliste Staat (eigenständige, von Deutschland diplomatisch anerkannte derzeitige Staaten). Tabelle von Staaten und Staatsangehörigkeiten. Enthalten sind alle Staaten im vollen politischen Sinne. Entspricht inhaltlich dem &quot;Verzeichnis der Staatennamen für den amtlichen Gebrauch&quot; des Auswärtigen Amtes. Enthalten sind z.B. Einträge für: Frankreich, Italien, Vereinigtes Königreich; nicht aber für: Französisch-Guayana, die britischen Jungferninseln oder Jersey. Neben den amtlichen Bezeichnungen (Kurzform und Vollform) und der Staatsangehörigkeit als Adjektiv/Adverb ist auch der jeweilige Suchbegriff aus dem Länderverzeichnis des Auswärtigen Amtes aufgeführt (der Suchbegriff ist eine griffige Bezeichnung des Staates). Die Angaben umfassen zudem den numerischen Destatis-Code, den 2- und 3-stelligen alphabetischen ISO 3166-1 Code sowie ggf. das Datum der Selbständigkeit bzw. Gründung nach den Angaben des Auswärtigen Amtes." herausgebernameLang="Statistisches Bundesamt" herausgebernameKurz="DESTATIS" base_Class="_19_0_3_41901a4_1602870438209_555654_7748"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFnnEZZUEeyPL_M6Y8GWYA" nameLang="Fehlercodes in XInneres" nameKurz="Fehlercodes in XInneres" nameTechnisch="fehlercodes" kennung="urn:de:xinneres:codeliste:fehlercodes" beschreibung="Diese Tabelle führt mögliche Gründe für eine Rücksendung einer Nachricht an den Absender auf. Mit dem Präfix des jeweiligen Schlüssels wird folgende Systematik festgelegt: T (Transportproblem), X (formales Problem mit XML), V (Versionsproblem), S (nicht spezifikationskonform)." herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT" base_Class="_19_0_3_41901a4_1602870438162_638558_7667"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOEJZUEeyPL_M6Y8GWYA" nameLang="Kommunikationskanal/Erreichbarkeit" nameKurz="Erreichbarkeit" nameTechnisch="Erreichbarkeit" kennung="urn:de:xoev:codeliste:erreichbarkeit" beschreibung="Eine Liste der Kommunikationsmedien und -kanäle, über die man eine Person oder Institution erreichen kann." herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT" base_Class="_19_0_3_41901a4_1602870438177_918420_7677"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOEZZUEeyPL_M6Y8GWYA" nameLang="Präfixe im DVDV" nameKurz="DVDV.Praefixe" nameTechnisch="dvdv.praefix" kennung="urn:xoev-de:bund:bmi:bit:codeliste:dvdv.praefix" beschreibung="Diese Codeliste enthält alle Präfixe, welche im DVDV zum Einsatz kommen." herausgebernameLang="Informationstechnikzentrum Bund" herausgebernameKurz="BMI/ITZBund" base_Class="_19_0_3_41901a4_1602870438209_998758_7750"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOEpZUEeyPL_M6Y8GWYA" nameLang="DVDV Behördenschlüssel der Bundesbehörden" nameKurz="DVDV.Behoerdenschluessel.Bundesbehoerden" nameTechnisch="dvdv.behoerdenschluessel" kennung="urn:xoev-de:bund:bmi:bit:codeliste:dvdv.behoerdenschluessel" beschreibung="Diese Codeliste enthält die Behördenschlüssel zur Präfix dbs, welches unter anderem für Bundes- und Landesbehörden von der Koordinierenden Stelle DVDV vergeben wird." herausgebernameLang="Informationstechnikzentrum Bund" herausgebernameKurz="BMI/ITZBund" base_Class="_19_0_3_41901a4_1602870438209_354806_7749"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOE5ZUEeyPL_M6Y8GWYA" nameLang="Quittungsrelevanter Sachverhalt" nameKurz="Quittungsrelevanter Sachverhalt" nameTechnisch="quittungsrelevanter-sachverhalt" kennung="urn:xoev-de:xinneres:codeliste:quittungsrelevanter-sachverhalt" beschreibung="Diese Codeliste umfasst die quittungsrelevanten Sachverhalte für XInneres." herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT" base_Class="_19_0_3_41901a4_1602870438177_457039_7671"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOFJZUEeyPL_M6Y8GWYA" nameLang="Nachrichtentypen in XInneres" nameKurz="Nachrichtentypen in XInneres" nameTechnisch="nachrichtentyp" kennung="urn:de:xinneres:codeliste:nachrichtentyp" beschreibung="Die Liste von eindeutigen Bezeichner für Nachrichtentypen im XInneres-Basismodul." herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT" base_Class="_19_0_3_41901a4_1602870438177_776537_7669"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOFZZUEeyPL_M6Y8GWYA" nameLang="Registergerichte" nameKurz="Registergerichte" nameTechnisch="registergerichte" kennung="urn:xoev-de:xgewerbeanzeige:codeliste:registergerichte" beschreibung="Enthält alle Registergerichte. Als Schlüssel für die Datenübermittlung ist die Spalte XJustiz_Id zu verwenden." herausgebernameLang="Betreiber XGewerbeanzeige (KoSIT und IT.NRW im Auftrag des Bundesministeriums für Wirtschaft und Energie)" herausgebernameKurz="XGewerbeanzeige" base_Class="_19_0_3_136d03d4_1612313332051_671210_9600"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOFpZUEeyPL_M6Y8GWYA" nameLang="Länder der Bundesrepublik Deutschland" nameKurz="Destatis Bundesland" nameTechnisch="bundesland" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:bundesland" beschreibung="Die Bundesrepublik Deutschland ist ein Zusammenschluss von Ländern. Die meisten Bundesländer umfassen mehrere Kreise und Bezirke. Diese Codeliste stellt die deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS)." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis" base_Class="_19_0_3_136d03d4_1612313332051_117859_9599"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOF5ZUEeyPL_M6Y8GWYA" nameLang="Bezirke bzw. Regierungsbezirke der deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes" nameKurz="Destatis Bezirk" nameTechnisch="Bezirk" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:bezirk" beschreibung="Die Bundesrepublik Deutschland ist ein Zusammenschluss von Bundesländern. Die meisten Bundesländer umfassen mehrere Kreise und Bezirke bzw. Regierungsbezirke. Diese Codeliste stellt alle Bezirke nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS)." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis" base_Class="_19_0_3_136d03d4_1612313332051_551267_9598"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOGJZUEeyPL_M6Y8GWYA" nameLang="Staatsgebiete gemäß der Staats- und Gebietssystematik des Statistischen Bundesamts" nameKurz="Destatis Staatsgebiete" nameTechnisch="staatsgebiete" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:staatsgebiete" beschreibung="Codeliste Staatsgebiete aus der Staats- und Gebietssystematik des Statistischen Bundesamtes.Sie basiert auf dem &lt;quote>Verzeichnis der Staatennamen für den amtlichen Gebrauch&lt;/quote> des Auswärtigen Amtes.&#xA;&#xA;Die Codeliste ist im XRepository (&lt;link xmlns:xlink=&quot;http://www.w3.org/1999/xlink&quot; xlink:href=&quot;www.xrepository.de&quot;>www.xrepository.de&lt;/link>) unter Nennung ihrer Codelisten-URI auffindbar und kann von dort im XML-Format OASIS Genericode abgerufen werden." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis" base_Class="_19_0_3_136d03d4_1612313332050_732201_9597"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOGZZUEeyPL_M6Y8GWYA" nameLang="Gemeinden gemäß Amtlicher Regionalschlüssel (ARS)" nameKurz="Destatis ARS" nameTechnisch="rs" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:rs" beschreibung="Diese Codeliste stellt alle Gemeinden Deutschlands durch den Amtlichen Regionalschlüssel (ARS) dar, wie im Gemeindeverzeichnis des Statistischen Bundesamtes enthalten. Darüber hinaus enthält die Codeliste für die Stadtstaaten Hamburg, Bremen und Berlin Einträge für Stadt-/Ortsteile bzw. Stadtbezirke. Diese Einträge sind mit einem entsprechenden Hinweis versehen." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis" base_Class="_19_0_3_136d03d4_1612313332050_480442_9596"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOGpZUEeyPL_M6Y8GWYA" nameLang="XBau-Kernmodul-Nachrichten" nameKurz="XBau-Kernmodul-Nachrichten" nameTechnisch="xbau-kernmodul-nachrichten" kennung="urn:xoev-de:xbau-kernmodul:codeliste:xbau-kernmodul-nachrichten" beschreibung="Codeliste der Bezeichnungen aller XBau-Kernmodul-Nachrichten." herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK" base_Class="_19_0_3_136d03d4_1615465030190_41867_9336"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOG5ZUEeyPL_M6Y8GWYA" nameLang="Die Kreise der deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes" nameKurz="Destatis Kreis" nameTechnisch="Kreis" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:kreis" beschreibung="Die Bundesrepublik Deutschland ist ein Zusammenschluss von Bundesländern. Die meisten Bundesländer umfassen mehrere Kreise und Bezirke. Diese Codeliste stellt die Kreise der deutschen Bundesländer nach dem Gemeindeverzeichnis des Statistischen Bundesamtes dar. Dieser Code ist auch Bestandteil des Amtlichen Gemeindeschlüssels (AGS)." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis" base_Class="_19_0_3_136d03d4_1612313332046_407020_9594"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOHJZUEeyPL_M6Y8GWYA" nameLang="Erreichbarkeit" nameKurz="Erreichbarkeit" nameTechnisch="erreichbarkeit" kennung="urn:de:xoev:codeliste:erreichbarkeit" beschreibung="Eine Liste der Kommunikationsmedien und -kanäle, über die man eine Person oder Institution erreichen kann." herausgebernameLang="Koordinierungsstelle für IT-Standards" herausgebernameKurz="KoSIT" base_Class="_19_0_3_136d03d4_1612313332046_805113_9592"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOHZZUEeyPL_M6Y8GWYA" nameLang="Gemeinden gemäß Amtlicher Gemeindeschlüssel (AGS)" nameKurz="Destatis AGS" nameTechnisch="ags" kennung="urn:de:bund:destatis:bevoelkerungsstatistik:schluessel:ags" beschreibung="Diese Codeliste stellt alle Gemeinden Deutschlands durch den Amtlichen Gemeindeschlüssel (AGS) dar, wie im Gemeindeverzeichnis des Statistischen Bundesamtes enthalten." herausgebernameLang="Statistisches Bundesamt, Wiesbaden" herausgebernameKurz="Destatis" base_Class="_19_0_3_136d03d4_1612313332045_62531_9591"/>
  <XOEVProfil:xoevCodeliste xmi:id="_VFoOHpZUEeyPL_M6Y8GWYA" nameLang="XBau Fehlerkennzahlen" nameKurz="XBau Fehlerkennzahlen" nameTechnisch="xbau-fehlerkennzahlen" kennung="urn:xoev-de:xbau-kernmodul:codeliste:xbau-fehlerkennzahlen" beschreibung="Codeliste der Fehlerkennzahlen für die Klassifikation von Fehlern, die in XBau-Nachrichteninstanzen angetroffen werden. Die Einträge bestehen aus Fehlerkennzahl und der Angabe deren Bedeutung. Gruppen von Codes: X - formales Problem mit XML oder mit (Inhalten von) Codelisten, V - Versionsproblem, S - nicht spezifikationskonform, A - Problem mit Anlagen zur empfangenen Nachricht.&#xA;" herausgebernameLang="Bauministerkonferenz" herausgebernameKurz="BMK" base_Class="_19_0_3_136d03d4_1612313332043_678337_9586"/>
  <XOEVProfil:xoevStandard xmi:id="_VFo1IJZUEeyPL_M6Y8GWYA" base_Model="_16_5_4_b7102e0_1292419822540_950613_464" nameLang="XInneres-Basismodul" nameKurz="XInneres-Basismodul" nameTechnisch="xinneres.basismodul" kennung="urn:xoev-de:kosit:standard:xinneres.basismodul" beschreibung="Im Auftrag des AK I hat die PG Standard bisher unter anderem die fachlichen Vorgaben und die Struktur der Meldeanschrift für die Bereiche Ausländer-, Melde- und Personenstandswesen harmonisiert. Der vorliegende Standard XInneres bildet auf technischer Ebene eine Klammer vor den Standards der Innenverwaltung. An dieser Stelle können gemeinsam genutzte Komponenten definiert werden. In der ersten Version von XInneres definiert der Standard die Datentypen für die Darstellung der Meldeanschrift."/>
  <XOEVProfil:xoevStandard xmi:id="_VFo1IZZUEeyPL_M6Y8GWYA" base_Model="_16_5_4_1d100e5_1384794823532_59933_328" nameLang="XBau-Kernmodul" nameKurz="XBau-Kernmodul" nameTechnisch="xbau-kernmodul" kennung="urn:xoev-de:bmk:standard:xbau-kernmodul" beschreibung="Das XBau-Kernmodul umfasst die von den XBau-Fachmodulen gemeinsam verwendeten Daten- und Nachrichtentypen."/>
