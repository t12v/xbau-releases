          <packagedElement xmi:type="uml:Package" xmi:id="_19_0_3_129a03b9_1694598356258_185770_8876" name="Gebuehrenbescheid" URI="">
            <packagedElement xmi:type="uml:Class" xmi:id="_19_0_3_129a03b9_1694598367137_540587_8877" name="Gebuehrenbescheid">
              <ownedComment xmi:id="_19_0_3_129a03b9_1694598367137_250944_8878" annotatedElement="_19_0_3_129a03b9_1694598367137_540587_8877" body="&lt;para>Dieser Typ beinhaltet die Parameter eines Gebührenbescheids der Fachbehörde. Es sind die Daten zu Gegenstand, Herleitung, Betrag und Bezahlung der Gebühren enthalten.&lt;/para>"/>
              <ownedAttribute xmi:id="_19_0_3_129a03b9_1694598367137_657904_8879" name="istVorauszahlungsbescheid" visibility="private" type="_14_0_1_6370212_1218191716468_578747_1004">
                <ownedComment xmi:id="_19_0_3_129a03b9_1694598367147_765710_8888" annotatedElement="_19_0_3_129a03b9_1694598367137_657904_8879" body="&lt;para>Falls es sich nicht um den abschließenden Gebührenbescheid, sondern um einen Vorauszahlungsbescheid handelt, ist hier true einzutragen. Dann weiß der Empfänger, dass weitere Gebührenbescheide zum angegebenen Vorgang zu erwarten sind.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_129a03b9_1694598367147_31228_8889" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_129a03b9_1694598367145_888361_8887" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_19_0_3_129a03b9_1694598367137_167267_8880" name="begruendung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
                <ownedComment xmi:id="_19_0_3_129a03b9_1694598367147_767911_8892" annotatedElement="_19_0_3_129a03b9_1694598367137_167267_8880" body="&lt;para>Hier ist die Rechtsgrundlage für die Gebühr bzw. eine sonstige Begründung einzutragen.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_129a03b9_1694598367147_923548_8893" name="" value="1"/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_129a03b9_1694598367147_404372_8891" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_19_0_3_129a03b9_1694598367137_819782_8881" name="kostenberechnung" visibility="private" type="_19_0_3_129a03b9_1694598444342_688874_8929">
                <ownedComment xmi:id="_19_0_3_129a03b9_1694598367147_134795_8896" annotatedElement="_19_0_3_129a03b9_1694598367137_819782_8881" body="&lt;para>Dieses Objekt enthält alle Informationen zu den Positionen des Gebührenbescheids und deren Summierung zu einem Geldbetrag.&lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_129a03b9_1694598367147_674202_8897" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_129a03b9_1694598367147_508864_8895" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_19_0_3_129a03b9_1694598367145_783195_8882" name="zahlungsdaten" visibility="private" type="_19_0_3_129a03b9_1694598818396_360789_9002">
                <ownedComment xmi:id="_19_0_3_129a03b9_1694598367147_529832_8900" annotatedElement="_19_0_3_129a03b9_1694598367145_783195_8882" body="&lt;para>Dieses Element enthält die Angaben, die der Anwender zur Veranlassung einer bargeldlosen Bezahlung gemäß SEPA benötigt. &lt;/para>&#xA;"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_129a03b9_1694598367147_948131_8901" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_129a03b9_1694598367147_968021_8899" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_19_0_3_129a03b9_1694598367145_235940_8883" name="informationVerspaetungszuschlag" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
                <ownedComment xmi:id="_19_0_3_129a03b9_1694598367147_80180_8904" annotatedElement="_19_0_3_129a03b9_1694598367145_235940_8883" body="&lt;para>Hier werden Angaben zu Zuschlägen bei Fristversäumnis eingetragen.&lt;/para>"/>
                <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_3_129a03b9_1694598367147_337123_8905" name=""/>
                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_129a03b9_1694598367147_413320_8903" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_19_0_3_129a03b9_1694598367145_783691_8884" name="rechtshelfsbelehrung" visibility="private" type="_18_0_2_940029b_1535727067041_864259_10734">
                <ownedComment xmi:id="_19_0_3_129a03b9_1694598367147_753179_8908" annotatedElement="_19_0_3_129a03b9_1694598367145_783691_8884" body="&lt;para>Hier werden die Rechtshelfsbelehrungen zum Bescheid gegeben.&lt;/para>&#xA;"/>
