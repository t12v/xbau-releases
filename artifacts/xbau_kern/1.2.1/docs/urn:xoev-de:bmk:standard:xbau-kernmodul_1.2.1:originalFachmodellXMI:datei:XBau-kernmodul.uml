                <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_3_129a03b9_1694598367147_128095_8907" name="" value="1"/>
              </ownedAttribute>
              <ownedAttribute xmi:id="_19_0_3_129a03b9_1694598367145_885575_8885" name="anlage" visibility="private" type="_16_5_4_940029b_1460560241523_867175_3826">
