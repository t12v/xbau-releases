                  <packagedElement xmi:type="uml:Association" xmi:id="_19_0_4_41901a4_1650872920828_971045_6387" name="" memberEnd="_19_0_4_41901a4_1650872920828_251177_6388 _19_0_4_41901a4_1650865262808_744857_6520">
                    <ownedEnd xmi:id="_19_0_4_41901a4_1650872920828_251177_6388" name="" visibility="private" type="_19_0_4_41901a4_1650865152317_653500_6428" association="_19_0_4_41901a4_1650872920828_971045_6387"/>
