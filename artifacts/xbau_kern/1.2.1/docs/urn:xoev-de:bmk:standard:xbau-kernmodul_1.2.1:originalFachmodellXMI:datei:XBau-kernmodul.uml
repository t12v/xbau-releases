  <XOEVProfil:xoevVersionCodeliste xmi:id="_3ntmAa2XEe6KvPAEqpag8w" version="1.0" base_Class="_19_0_3_136d03d4_1615465030210_782222_9407" versionCodelistenHandbuch="1.1"/>
  <XOEVProfil:xoevVersionStandard xmi:id="_3ntmAq2XEe6KvPAEqpag8w" base_Model="_16_5_4_1d100e5_1384794823532_59933_328" version="1.2.1" beschreibung="Für diese Version des XBau-Kernmoduls ist  umgesetzt worden: Die Anpassung an die neue Nachrichtenarchitektur gemäß XÖV-Bibliothek. Eine neue generische Nachricht zur Übermittlung eines Gebührenbescheids (prozessfrei innerhalb eines Vorgangs). Die bisher in XBau verwendeten Datentypen des XInneres-Basismoduls sind ersetzt durch Datentypen der XÖV-Basisnachricht und durch im Kernmodul neu definierte Datentypen für 'Jahr' und 'JahrMonat'. Diese und weitere Änderungen sind im Detail in der Versionshistorie des Spezifikationsdokuments beschrieben." versionXOEVHandbuch="3.0.1" versionXGenerator="3.1.1" versionModellierungswerkzeug="19.0"/>
  <XOEVProfil:xoevVersionStandard xmi:id="_3ntmA62XEe6KvPAEqpag8w" base_Model="_18_0_2_8c5027b_1530282394636_112672_9470"/>
