  <XOEVProfil:xoevVersionCodeliste xmi:id="_3ns--a2XEe6KvPAEqpag8w" version="2019-07-31" datumGueltigkeitAb="2019-07-31" base_Class="_19_0_3_136d03d4_1612313333074_600910_10229" versionCodelistenHandbuch="1.0">
