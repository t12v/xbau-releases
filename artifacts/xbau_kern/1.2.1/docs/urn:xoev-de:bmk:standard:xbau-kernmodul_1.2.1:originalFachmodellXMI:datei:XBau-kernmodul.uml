                    <ownedAttribute xmi:id="_19_0_4_41901a4_1650874580046_823444_6490" name="verzeichnisdienst" visibility="private" type="_19_0_4_41901a4_1650972069891_946702_6728" aggregation="composite" association="_19_0_4_41901a4_1650972099581_986582_6775">
                      <ownedComment xmi:id="_19_0_4_41901a4_1651214635335_64174_6565" annotatedElement="_19_0_4_41901a4_1650874580046_823444_6490" body="&lt;para>Angabe des Verzeichnisdienstes (bspw. DVDV), in welchem die Behörde / öffentliche Stelle unter der nachfolgend angegebenen Kennung eingetragen ist.&lt;/para>"/>
                      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_4_41901a4_1650874642389_853268_6527" name="" value="1"/>
                      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_4_41901a4_1650874642404_30559_6528" name="" value="1"/>
                    </ownedAttribute>
                    <ownedAttribute xmi:id="_19_0_4_41901a4_1650874884316_501608_6548" name="kennung" visibility="private" type="_18_0_6_5b501fb_1565874046564_914647_6619">
                      <ownedComment xmi:id="_19_0_4_41901a4_1650875708283_741513_6600" annotatedElement="_19_0_4_41901a4_1650874884316_501608_6548" body="&lt;para>Dieses Element enthält die eindeutige Kennzeichnung der Behörde / öffentlichen Stelle innerhalb des angegebenen Verzeichnisdienstes.&lt;/para>&#xA;&lt;para>Für den Verzeichnisdienst „DVDV“ enthält die Kennzeichnung das „Präfix“ und die „Kennung“ getrennt durch das Zeichen ':', also bspw. 'psw:01003110'.&lt;/para>"/>
                      <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_19_0_4_41901a4_1650874891739_438284_6550" name="" value="1"/>
                      <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_19_0_4_41901a4_1650874891739_74972_6551" name="" value="1"/>
                    </ownedAttribute>
