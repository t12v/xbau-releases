                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_523538_6093" annotatedElement="_16_5_4_5b501fb_1387625291120_827601_5220" body="Angaben zum Gültigkeitszeitraum für den Namen der Organisation."/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291320_257455_6094" name="" visibility="private" type="_16_5_4_5b501fb_1387625291111_535429_5174" association="_16_5_4_5b501fb_1387625291120_827601_5220"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291121_679275_5221" name="" memberEnd="_16_5_4_5b501fb_1387625291146_812125_5332 _16_5_4_5b501fb_1387625291320_143270_6097">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_894398_6096" annotatedElement="_16_5_4_5b501fb_1387625291121_679275_5221" body="Behörde, die den Familienstand amtlich gemacht hat."/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291320_143270_6097" name="" visibility="private" type="_16_5_4_5b501fb_1387625291098_333760_5159" association="_16_5_4_5b501fb_1387625291121_679275_5221"/>
              </packagedElement>
              <packagedElement xmi:type="uml:Association" xmi:id="_16_5_4_5b501fb_1387625291121_732691_5222" name="" memberEnd="_16_5_4_5b501fb_1387625291307_702202_5955 _16_5_4_5b501fb_1387625291320_855901_6100">
                <ownedComment xmi:id="_16_5_4_5b501fb_1387625291320_646399_6099" annotatedElement="_16_5_4_5b501fb_1387625291121_732691_5222" body="Ein weiterer Name ist ein Name, der nicht Bestandteil des Vor- oder Nachnamens einer Person und weder Künstlername noch Ordensname ist. "/>
                <ownedEnd xmi:id="_16_5_4_5b501fb_1387625291320_855901_6100" name="" visibility="private" type="_16_5_4_5b501fb_1387625291116_769920_5181" association="_16_5_4_5b501fb_1387625291121_732691_5222"/>
              </packagedElement>
