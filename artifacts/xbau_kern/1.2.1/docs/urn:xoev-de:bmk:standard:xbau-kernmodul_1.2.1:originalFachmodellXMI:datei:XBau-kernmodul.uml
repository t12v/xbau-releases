            <packagedElement xmi:type="uml:Package" xmi:id="_19_0_4_41901a4_1616508925091_241054_6308" name="XML namespace" URI="">
              <packagedElement xmi:type="uml:Package" xmi:id="_19_0_4_41901a4_1616508938452_940035_6309" name="2009/01" URI="">
                <packagedElement xmi:type="uml:Class" xmi:id="_19_0_4_41901a4_1616508950272_846012_6310" name="lang"/>
                <packagedElement xmi:type="uml:Class" xmi:id="_19_0_4_41901a4_1616508963182_840543_6311" name="space"/>
