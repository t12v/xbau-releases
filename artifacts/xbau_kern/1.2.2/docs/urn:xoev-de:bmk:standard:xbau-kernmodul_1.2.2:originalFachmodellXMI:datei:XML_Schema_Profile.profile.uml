            <details xmi:id="_PcPg5K50Ee-kZ_Tkwdi3Ng" key="documentation" value="(not type.oclIsUndefined()) implies (type.oclIsKindOf(XSDsimpleType) or type.oclIsKindOf(XSDcomplexType) or (type.oclIsKindOf(XSDcomponent) and type.name='anyType'))&#xD;&#xA;(not type.oclIsUndefined()) implies type.oclIsKindOf(XSDsimpleType) or type.oclIsKindOf(XSDcomplexType) or (type.oclIsKindOf(XSDcomponent) and name='anyType')&#xD;&#xA;not owner.appliedStereotypeInstance.oclIsUndefined() and&#xA;owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') ->size()=0&#xD;&#xA;not owner.appliedStereotypeInstance.oclIsUndefined() and&#xA;owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') -> size()=0&#xD;&#xA;not owner.appliedStereotypeInstance.oclIsUndefined() and owner.appliedStereotypeInstance.classifier -> select (name='XSDsimpleContent') ->asSet()->size()=0&#xD;&#xA;not specific.appliedStereotypeInstance.oclIsUndefined() and specific.appliedStereotypeInstance.classifier -> select (name='XSDsimpleType') ->size()=0&#xD;&#xA;not appliedStereotypeInstance.oclIsUndefined() and&#xA;appliedStereotypeInstance.classifier->select (name='XSDsimpleType' or name='XSDcomplexType') ->size()=0&#xD;&#xA;not appliedStereotypeInstance.oclIsUndefined() and&#xA;appliedStereotypeInstance.classifier->select (name='XSDsimpleType' or name='XSDcomplexType') ->size()=0&#xD;&#xA;not targetNamespace.oclIsUndefined()&#xD;&#xA;let owners : Set(UML2_Metamodel::ElementImport)=ownedElement->select(oclIsKindOf(xmlns))->collect(oclAsType(UML2_Metamodel&#xA;::ElementImport))->asSet() in owners.importedElement.name -> exists (n|n='http://www.w3.org/2001/XMLSchema')"/>
          </eAnnotations>
        </eSubpackages>
      </contents>
