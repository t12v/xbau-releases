							</xmi:Extension>
						</general>
					</generalization>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_129a03b9_1684499158982_410199_8747' name='Jahr'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1684499158998_117003_8748' body='&lt;para&gt;Mit diesem Datentyp wird ein teilweise bekanntes Datum übermittelt. Vom Datum ist nur das Jahr bekannt.&lt;/para&gt;'>
