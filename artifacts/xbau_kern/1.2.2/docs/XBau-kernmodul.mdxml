					<packagedElement xmi:type='uml:Class' xmi:id='_18_0_2_940029b_1541322508385_460887_11132' name='prozessnachrichten.eingangsbestaetigung.1120'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1541322508385_41284_11133' body='&lt;para&gt;Diese Nachricht wird durch die Fachbehörde verwendet, um als Reaktion auf einen Antrag (modifizierten Antrag, Rücknahme eines Antrags, Anzeige) zu informieren, dass das Anliegen eingegangen ist und sich in Bearbeitung befindet. &lt;/para&gt;&#10;&#10;&lt;para&gt;Sie enthält die nötigen Informationen, um den Bezug auf die Nachricht, deren Eingang sie bestätigt, herzustellen.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_18_0_2_940029b_1541322508385_460887_11132'/>
						</ownedComment>
