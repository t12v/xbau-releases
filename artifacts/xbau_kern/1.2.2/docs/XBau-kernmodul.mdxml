								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728550570093_727548_8983' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728550570087_376823_8961' name='hinweise' visibility='private' type='_18_0_2_940029b_1535726187446_656135_10650'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728550570093_673155_8988' body='&lt;para&gt;Hier werden ggf. ergänzende Hinweise zum Bescheid gegeben. Diese können unter anderem Nebenbestimmungen oder Abweichungen enthalten.&lt;/para&gt;'>
