						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1617018517574_696333_9427' name='produkthersteller' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
