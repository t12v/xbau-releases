			<packagedElement xmi:type='uml:Package' xmi:id='_19_0_3_136d03d4_1612479012595_942167_9330' name='Basisdatentypen'>
				<packagedElement xmi:type='uml:Class' xmi:id='_18_0_6_8c5027b_1571829426918_186531_14360' name='Dezimal.XBau'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_8c5027b_1571830849953_904265_14454' body='&lt;para&gt;Dieser Datentyp stellt numerische Werte mit zwei Nachkommastellen dar. Er kann für Zahlen genutzt werden, die mit dieser Präzision sinnvoll sind. Darum erlaubt der Datentyp Dezimal.XBau zum Beispiel bei der Übertragung der Einheit Meter (m) eine Präzision von einem Zentimeter.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_18_0_6_8c5027b_1571829426918_186531_14360'/>
					</ownedComment>
