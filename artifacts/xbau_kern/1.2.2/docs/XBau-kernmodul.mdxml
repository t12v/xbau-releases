									<xmi:Extension extender='MagicDraw UML 19.0'>
										<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
									</xmi:Extension>
								</type>
								<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1694598818396_862454_9017' body='&lt;para&gt;Hier ist das Kassenzeichen einzutragen, unter dem die Sollstellung durch die Behörde bei der lokalen Finanzverwaltung veranlasst wurde. Ist vom Gebührenzahler bei der Zahlung im Überweisungsformular in das Feld &quot;Verwendungszweck&quot; einzutragen.&lt;/para&gt;'>
									<annotatedElement xmi:idref='_19_0_3_129a03b9_1694598818396_349596_9006'/>
								</ownedComment>
