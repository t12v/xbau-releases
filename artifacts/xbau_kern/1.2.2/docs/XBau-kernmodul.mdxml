						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_4_78d0259_1728568070449_749955_10327' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567100077_870119_10015' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567100086_298737_10027' body='&lt;para&gt;Unterhalb dieses Elements werden Eintragungen vorgenommen, um auf den laufenden Vorgang zum Antrag Bezug zu nehmen; außerdem ggf. auf die Nachricht universellerAntrag.antrag.1200, die den Vorgang ausgelöst hat. &lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567100077_870119_10015'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567100087_64551_10028' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567100086_81926_10026' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567100079_378803_10016' name='aufforderungZurStellungnahme' visibility='private' aggregation='composite' type='_18_0_2_940029b_1535727067041_864259_10734'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567100088_272224_10031' body='&lt;para&gt;Hier ist die Aufforderung zu Stellungnahme in Form eines Anschreibens formuliert.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567100079_378803_10016'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567100088_73155_10032' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567100087_143166_10030' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567100080_625314_10017' name='bescheidlage' visibility='private' type='_19_0_4_78d0259_1728567443349_699489_10152'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567100089_961684_10035' body='&lt;para&gt;Hier können die Gründe, die nach aktueller Lage zur Ablehnung des Antrags durch die zuständige Behörde führen können, in Form einer strukturierten Liste angegeben werden. Es handelt sich um eine Liste von Abweichungen von den öffentlich-rechtlichen Vorschriften, die sich aus der laufenden Prüfung des Antrags ergeben hat. Zu jedem Eintrag der Liste fordert die Nachricht zu einer Stellungnahme bzw. Nachbesserung auf.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567100080_625314_10017'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567100089_38430_10036'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567100088_493114_10034' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567100081_230437_10019' name='frist' visibility='private' aggregation='composite'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191726109_379108_1042'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='W3C Data Types::date' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567100090_80401_10043' body='&lt;para&gt;Hier kann eine durch die Behörde gesetzte Frist angegeben werden, innerhalb derer eine Stellungnahme des Antragstellers vorliegen muss, damit sie berücksichtigt werden kann.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567100081_230437_10019'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567100090_198554_10044'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567100090_242867_10042' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567100082_658230_10020' name='angebotFuerAntwortLeser' visibility='private' aggregation='composite' type='_19_0_3_136d03d4_1611781855355_662927_10055'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567100091_430612_10047' body='&lt;para&gt;Dieses Element kann verwendet werden, um Webressourcen für ggf. nötige Reaktionen des Lesers auf die vorliegende Nachricht anzugeben . &lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567100082_658230_10020'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567100091_100353_10048'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567100091_352589_10046' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567100082_543095_10021' name='anlagen' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567100091_553819_10051' body='&lt;para&gt;Für die Aufforderung zur Stellungnahme ggf. notwendige Anhänge können hier der Nachricht als Anlage beigefügt werden.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567100082_543095_10021'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567100092_19376_10052'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567100091_220322_10050' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_4_78d0259_1728567750287_994975_10188' name='universellerAntrag.stellungnahme.1204'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567750312_484629_10218' body='&lt;para&gt;Diese Nachricht bezieht sich auf einen bereits gestellten Antrag und auf eine zu diesem&#10;vorliegende Anhörungsnachricht. Sie enthält Stellungnahmen  zu den Eigenschaften des Vorhabens bzw. des Antrags, die von der zuständigen Behörden beanstandet wurden. Sie enthält ggf. außerdem den nachgebesserten Antrag bzw. nachgebesserte Vorlagen.&lt;/para&gt;&#10;&#10;'>
							<annotatedElement xmi:idref='_19_0_4_78d0259_1728567750287_994975_10188'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_4_78d0259_1728568048126_744103_10326' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567750313_491218_10219' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567750315_890799_10227' body='&lt;para&gt;Unterhalb dieses Elements werden Eintragungen vorgenommen, um auf den laufenden Vorgang zum Bauantrag Bezug zu nehmen und außerdem auf die Nachricht universellerAntrag.materiellePruefungBefundliste.1203, auf deren Inhalt sich die vorliegende Nachricht bezieht.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567750313_491218_10219'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567750315_169251_10228' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567750315_698049_10226' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567750313_765728_10220' name='stellungnahmeBelastenderVerwaltungsakt' visibility='private' aggregation='composite' type='_19_0_4_78d0259_1728568308217_499205_10331'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567750315_428900_10231' body='&lt;para&gt;Hier ist die Reaktion auf die in der Anhörungsnachricht enthaltenen Punkte einzutragen. Dies kann eine Verteidigung der ursprünglichen Konzeption sein, dies kann aber auch eine geänderte Antragsunterlage sein, welche in diesem Fall in den Anlagen dokumentiert ist.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567750313_765728_10220'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567750315_693105_10232' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567750315_676447_10230' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567750314_920150_10222' name='anlagen' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567750316_407968_10239' body='&lt;para&gt;Hier sind ggf. überarbeitete oder nachgereichte Anlagen bzw. Verweise auf überarbeitete oder nachgereichte Anlagen enthalten, passend zur weiter oben gegebenen Stellungnahme bzw. Erläuterung der Anpassung. &lt;/para&gt;&#10;&lt;para&gt;Geänderte oder ergänzte Daten werden als Brutto-Datensatz geschickt. Es werden mit diesem Element also die bereinigten und ggf. ergänzten Daten vollständig gesendet, so dass der Empfänger einen &#39;Datensatz nach Änderung&#39; erhält.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567750314_920150_10222'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567750316_362109_10240'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567750316_717288_10238' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_4_78d0259_1728550330695_124171_8940' name='universellerAntrag.bescheid.1205'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728573045845_139709_8900' body='&lt;para&gt;Diese Nachricht stellt den Bescheid dar, in den die zuständige Behörde die Ergebnisse ihrer materiellen&#10;Prüfung einträgt. Der Antrag ist entweder genehmigt, genehmigt mit Nebenbestimmungen&#10;(zum Beispiel unter Auflagen) oder abgelehnt. Das Absenden dieser Nachricht stellt das Erteilen des&#10;Bescheids dar.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_4_78d0259_1728550330695_124171_8940'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_4_78d0259_1728568089857_686666_10328' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728550484095_359632_8946' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728550484103_957747_8948' body='&lt;para&gt;Dieses Objekt enthält die Eintragungen, die auf den Vorgang bzw. die Nachricht universellerAntrag.antrag.1200 mit dem Antrag Bezug nehmen, zu dem die vorliegende Nachricht den Bescheid enthält.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728550484095_359632_8946'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728550484104_236086_8949' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728550484101_500105_8947' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728550585578_893908_9005' name='anlagen' visibility='private' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728550585579_793006_9007' body='&lt;para&gt;Hier sind die Anlagen zum Bescheid bzw. Verweise auf diese Anlagen enthalten.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728550585578_893908_9005'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728550585579_252674_9008'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728550585579_655412_9006' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728550591652_134872_9012' name='bescheid' visibility='private' type='_19_0_4_78d0259_1728550570080_667657_8953'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728550684137_172176_9018' body='&lt;para&gt;In diesem Objekt sind die verschiedenen Komponenten des Bescheides enthalten.&lt;/para&gt;&#10;&lt;para&gt;Ein Bescheid mit positivem Tenor kann zugelassene oder auch nicht zugelassene Abweichungen (Element abweichung) enthalten. Ein Bescheid mit negativem Tenor kann nur nicht zugelassene Abweichungen enthalten. Die Abweichungen sind in den Hinweisen anzugeben.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728550591652_134872_9012'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728550607736_857894_9013' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728550607738_640736_9014' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
				</packagedElement>
			</packagedElement>
			<packagedElement xmi:type='uml:Package' xmi:id='_19_0_3_136d03d4_1612479039044_716623_9333' name='Prozesse'>
				<packagedElement xmi:type='uml:Package' xmi:id='_18_0_2_940029b_1541265512624_204597_12556' name='Prozessmuster'>
