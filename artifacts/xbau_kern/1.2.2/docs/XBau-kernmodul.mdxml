			<packagedElement xmi:type='uml:Dependency' xmi:id='_16_5_4_5b501fb_1398421542326_660552_1933'>
				<client xmi:idref='_16_5_4_1d100e5_1384794823532_59933_328'/>
				<supplier href='XOEV-Bibliothek.mdxml#_16_5_4_5b501fb_1375258090807_886576_2132'>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek' referentType='Model'/>
					</xmi:Extension>
				</supplier>
			</packagedElement>
			<packagedElement xmi:type='uml:Package' xmi:id='_19_0_3_136d03d4_1614869261849_45392_9315' name='Dienste'>
				<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_129a03b9_1686153217981_727178_8802' name='anBauportal'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1686153217983_331430_8803' body='&lt;head&gt;&lt;title&gt;Datenübermittlungen allgemeiner Prozessnachrichten an die Online-Bauportale&lt;/title&gt;&lt;/head&gt;&#10;&lt;body&gt;&lt;p&gt;Folgende Nachrichten des XBau-Schemas sind als Input der Operation &lt;i&gt;sendeAnBauportal&lt;/i&gt;zulässig:&#10;&lt;ul&gt;&amp;servicelist;&lt;/ul&gt;&lt;/p&gt;&#10;&lt;p&gt;Organisationsschlüssel für &lt;i&gt;find.servicedescription&lt;/i&gt;-Anfragen sind die 12-stelligen Schlüssel für die Bauportale; der zu verwendende Präfix lautet &quot;&lt;b&gt;bap&lt;/b&gt;&quot;.&lt;/p&gt;&#10;&lt;p&gt;Zulässige Dienstanbieter sind ausschließlich Organisationen der DVDV-Organisationskategorie &quot;&lt;b&gt;Bauportal&lt;/b&gt;&quot;. &#10;Zulässige Dienstnutzer sind Organisationen der DVDV-Organisationskategorien &quot;&lt;b&gt;Bauaufsichtsbehörde&lt;/b&gt;&quot;, &quot;&lt;b&gt;Straßenbaubehörde&lt;/b&gt;&quot;, &quot;&lt;b&gt;Straßenverkehrsbehörde&lt;/b&gt;&quot;.&lt;/p&gt;&lt;/body&gt;'>
						<annotatedElement xmi:idref='_19_0_3_129a03b9_1686153217981_727178_8802'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_19_0_3_129a03b9_1686155496725_788834_8894' general='_19_0_3_129a03b9_1686153299885_829486_8830'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_129a03b9_1686153260902_931193_8816' name='anFachbehoerde'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1686153260905_271678_8817' body='&lt;head&gt;&lt;title&gt;Datenübermittlungen allgemeiner Prozessnachrichten an die Fachbehörden&lt;/title&gt;&lt;/head&gt;&#10;&lt;body&gt;&lt;p&gt; Folgende Nachrichten des XBau-Schemas sind als Input der Operation &lt;i&gt;sendeAnFachbehoerde&lt;/i&gt; zulässig:&#10;&lt;ul&gt;&amp;servicelist;&lt;/ul&gt;&lt;/p&gt;&#10;&lt;p&gt;Organisationsschlüssel für &lt;i&gt;find.servicedescription&lt;/i&gt;-Anfragen sind die Fachbehörden von XBau/XBreitband; die zu verwendende Präfixe lauten &#10;&quot;&lt;b&gt;dbs&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;bab&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;gba&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;aik&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;bet&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;pin&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;sbb&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;svb&lt;/b&gt;&quot;.&#10;Zulässige Dienstanbieter sind Organisationen der DVDV-Organisationskategorie &#10;&quot;&lt;b&gt;Bundesbehörde&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;Bauaufsichtsbehörde&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;Gemeindebauamt&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;Architekten- und Ingenieurkammer&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;Amtsgericht&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;Baubeteiligte Stelle&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;Prüfingenieur&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;Straßenbaubehörde&lt;/b&gt;&quot;,&#10;&quot;&lt;b&gt;Straßenverkehrsbehörde&lt;/b&gt;&quot;. &#10;Zulässige Dienstnutzer sind ausschließlich Organisationen in der DVDV-Organisationskategorie &quot;&lt;b&gt;Bauportal&lt;/b&gt;&quot;.&lt;/p&gt;&lt;/body&gt;'>
						<annotatedElement xmi:idref='_19_0_3_129a03b9_1686153260902_931193_8816'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_19_0_3_129a03b9_1686155544140_39792_8895' general='_19_0_3_129a03b9_1686153299885_829486_8830'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_129a03b9_1686153299885_829486_8830' name='Asynchron'/>
				<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_129a03b9_1686153346668_278102_8844' name='FachlicheKommunikation'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1686153346669_566917_8845' body='&lt;head&gt;&lt;title&gt;Nachricht für die verfahrensbegleitende fachliche Kommunikation.&lt;/title&gt;&lt;/head&gt;&#10;                  &lt;body&gt;&lt;p&gt;&#10;                     Folgende Nachrichten des XBau-Kernmoduls sind als Input der Operation &lt;i&gt;sendeRueckweisung&lt;/i&gt; zulässig:&#10;                     &lt;ul&gt;&amp;servicelist;&lt;/ul&gt;&#10;                  &lt;/p&gt;&#10;                  &lt;p&gt;&#10;                     Zulässige Dienstanbieter und Dienstnutzer sind alle Kommunikationspartner von XBau/XBreitband.&#10;                  &lt;/p&gt;&lt;/body&gt;'>
						<annotatedElement xmi:idref='_19_0_3_129a03b9_1686153346668_278102_8844'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_19_0_3_129a03b9_1686155562398_916077_8896' general='_19_0_3_129a03b9_1686153299885_829486_8830'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_129a03b9_1686153386257_974924_8858' name='Rueckweisung'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1686153386258_10639_8859' body='&lt;head&gt;&lt;title&gt;Ein Kommunikationspartner bei XBau/XBreitband weist eine nicht spezifikationskonforme Nachricht ab.&lt;/title&gt;&lt;/head&gt;&#10;         &lt;body&gt;&lt;p&gt;&#10;            Folgende Nachrichten des XBau-Kernmoduls sind als Input der Operation &lt;i&gt;sendeRueckweisung&lt;/i&gt; zulässig:&#10;            &lt;ul&gt;&amp;servicelist;&lt;/ul&gt;&#10;         &lt;/p&gt;&#10;         &lt;p&gt;&#10;            Zulässige Dienstanbieter und Dienstnutzer sind alle Kommunikationspartner von XBau/XBreitband.&#10;         &lt;/p&gt;&lt;/body&gt;'>
						<annotatedElement xmi:idref='_19_0_3_129a03b9_1686153386257_974924_8858'/>
					</ownedComment>
					<generalization xmi:type='uml:Generalization' xmi:id='_19_0_3_129a03b9_1686155573795_188781_8897' general='_19_0_3_129a03b9_1686153299885_829486_8830'/>
				</packagedElement>
