					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_4_78d0259_1728549533150_161612_8912' name='universellerAntrag.angepassterAntrag.1202'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728549828610_32079_8937' body='&lt;para&gt;Diese Nachricht enthält geänderte oder ergänzte Daten des Antrags bzw. geänderte oder ergänzte&#10;Vorlagen. Sie bezieht sich auf einen bereits gestellten Antrag, zu dem noch kein Bescheid erteilt&#10;wurde.&lt;/para&gt;&#10;&lt;para&gt;Entweder ist sie eine Reaktion auf eine zum Antrag vorliegende Mängelliste der zuständigen Behörde,&#10;oder der Antragsteller reicht aus anderen Gründen eine modifizierte Planung im laufenden Verfahren&#10;nach.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_4_78d0259_1728549533150_161612_8912'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_4_78d0259_1728568128324_737248_10330' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728549687069_514804_8916' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728549687081_455598_8918' body='&lt;para&gt;Unterhalb dieses Elements werden Eintragungen vorgenommen, um auf den laufenden Vorgang zum Antrag Bezug zu nehmen; außerdem ggf. auf die Nachrichten prozessnachrichten.formellePruefungBefundliste.1140 oder prozessnachrichten.fachlicheKommunikation.1142, wenn diese den Vorgang ausgelöst haben.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728549687069_514804_8916'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728549687081_332821_8919' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728549687077_683160_8917' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728549689328_831698_8923' name='anlagen' visibility='private' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728549689331_439698_8925' body='&lt;para&gt;Hier sind ggf. überarbeitete oder nachgereichte Anlagen bzw. Verweise auf überarbeitete oder nachgereichte Anlagen enthalten.&lt;/para&gt;&#10;&lt;para&gt;Nachgereichte Anlagen: Aus der Beschreibung bzw. Bezeichnung der Anlage muss (wie immer) der Charakter der nachgereichten Unterlage hervorgehen. Ein gesonderter Bezug auf den Befund der Befundliste (z.B. Befund-Nr.), der ggf. zur Übermittlung dieser Unterlage führte, ist nicht erforderlich.&lt;/para&gt;&#10;&lt;para&gt;Geänderte Anlagen: In diesem Fall wird eine neue Version (jüngeres Erstellungsdatum) einer bereits vorher gelieferten Anlagen übermittelt.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728549689328_831698_8923'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728549689331_752942_8926' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728549689330_781644_8924' value='*'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_4_78d0259_1728544218826_934068_8756' name='universellerAntrag.antrag.1200'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728547146661_145488_8909' body='&lt;para&gt;Diese Nachricht stellt einen Antrag dar, d.h. durch das Senden dieser Nachricht an die zuständigen Behörden beantragt der Absender die Genehmigung zu dem in der Nachricht dokumentierten Vorhaben. Die Nachricht enthält die Daten des Antrags und als Anlage die dazugehörigen Vorlagen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_4_78d0259_1728544218826_934068_8756'/>
						</ownedComment>
