					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_4_b6602da_1727331693524_595912_8289' name='prozessnachrichten.statusFuerAntragsportal.1170'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_b6602da_1727331693545_544417_8290' body='&lt;para&gt;Diese Nachricht kann durch eine Aufsichtsbehörde verwendet werden, um das Antragsportal über eine Statusänderung im Rahmen eines Vorgangs, der durch die Aufsichtsbehörde geführt wird, zu informieren. Das Antragsportal verwendet diese Information, um den im Antragsportal geführten Status zu diesem Vorgang anzupassen.&lt;/para&gt;&#10;&lt;para&gt;Hinweis: Bei vorhandenen spezifischen Nachrichten darf diese generische Nachricht nicht&#10;genutzt werden.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_4_b6602da_1727331693524_595912_8289'/>
						</ownedComment>
