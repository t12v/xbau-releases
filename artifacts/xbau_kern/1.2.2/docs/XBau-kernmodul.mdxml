						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_4_78d0259_1728568108748_446052_10329' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728544651989_725055_8762' name='referenzAntragsservice' visibility='private' type='_18_0_2_940029b_1546716878558_771130_12819'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728544770273_847908_8764' body='&lt;para&gt;Eine vom Antragsservice vergebene eindeutige Kennung des Antragsvorgangs. Sofern die zuständige Behörde auf die Antragstellung reagiert, bezieht sie sich in ihren Reaktionsnachrichten auf diese Kennung.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728544651989_725055_8762'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728546167210_65040_8801' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728546167210_24813_8802' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728908662355_100884_9148' name='artDesAntrags' visibility='private' type='_18_0_2_940029b_1535727067041_864259_10734'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728908700086_791945_9150' body='&lt;para&gt;In dieses Element wird die Art des Antrags eingetragen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728908662355_100884_9148'/>
							</ownedComment>
