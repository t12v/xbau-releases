						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728550570087_626447_8960' name='rechtshelfsbelehrung' visibility='private' type='_18_0_2_940029b_1535727067041_864259_10734'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728550570093_699835_8984' body='&lt;para&gt;Falls anwendbar,  werden hier die Rechtshelfsbelehrungen zum Bescheid gegeben.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728550570087_626447_8960'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
