								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728550570093_243345_8987' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_4_78d0259_1728567443349_699489_10152' name='BefundlisteMateriell'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567443349_67279_10153' body='&lt;para&gt;Eine Instanz diesen Typs steht für eine Befundliste der materiellen Prüfung eines Antrags. Jeder Befund beinhaltet die Parameter, die einen  belastenden Verwaltungsakt im Kontext eines Vorgangs definieren. &lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_4_78d0259_1728567443349_699489_10152'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728567443349_205359_10154' name='befund' visibility='private' aggregation='composite' type='_19_0_4_78d0259_1728569368403_469737_8874'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567443351_712664_10157' body='&lt;para&gt;Jedes Element steht für einen  belastenden Verwaltungsakt, im Kontext des aktuellen Antragsvorgangs, zu dem der Adressat der Nachricht zu einer Stellungnahme aufgefordert ist.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728567443349_205359_10154'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728567443351_81038_10158' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728567443350_79704_10156' value='*'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_4_78d0259_1728569368403_469737_8874' name='Anonym_BefundMateriell'>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728569878472_880070_8878' name='rechtsbereich' visibility='private' aggregation='composite' type='_19_0_4_78d0259_1728567535312_938846_10185'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728569878475_395797_8882' body='&lt;para&gt;Dieses Element nennt den  Rechtsbereich, innerhalb dessen der belastende Verwaltungsakt liegt. &lt;/para&gt;'>
