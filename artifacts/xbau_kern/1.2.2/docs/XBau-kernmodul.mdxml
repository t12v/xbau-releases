						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_940029b_1546778584008_912671_11944' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1546778584008_501771_11950' body='&lt;para&gt;In dieses Element sind die Referenzen von Antragsteller und ggf. Behörde einzutragen.&lt;/para&gt;&#10;&#10;&lt;para&gt;Hier müssen Eintragungen vorgenommen werden, so dass sich die Nachricht einem vorhandenen Vorgang eindeutig zuordnen lässt. Dafür ist in das Element referenz die UUID der Antragsnachricht (Element referenzAntragsservice) einzutragen, auf die sich die Rücknahme bezieht.&lt;/para&gt;&#10;&#10;&lt;para&gt;Es ist die Nachricht des Antragstellers zu referenzieren, mittels derer er über seine Absicht informiert hat, den Antrag zurückzunehmen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_18_0_2_940029b_1546778584008_912671_11944'/>
							</ownedComment>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_b6602da_1727789053452_101212_8785'>
								<annotatedElement xmi:idref='_18_0_2_940029b_1546778584008_912671_11944'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_2_940029b_1546778584008_334154_11951' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_2_940029b_1546778584008_517372_11949' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_940029b_1546780686209_577757_12204' name='ruecknahmeAkzeptiert' visibility='private' aggregation='composite'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191716468_578747_1004'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='W3C Data Types::boolean' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1546780686225_95989_12206' body='&lt;para&gt;Falls die Rücknahme des Antrags durch die Fachbehörde akzeptiert wurde, wird in diesem Element &quot;true&quot; übermittelt. &lt;/para&gt;&#10;&lt;para&gt;Andernfalls wird &quot;false&quot; übermittelt. Dann ist eine Rücknahme des Antrags nicht mehr möglich, weil bereits ein Bescheid erteilt wurde, der dem Antragsteller auf dem vorgesehenen Wege zugehen wird oder bereits zugegangen ist.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_18_0_2_940029b_1546780686209_577757_12204'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_2_940029b_1546780686225_370147_12207' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_2_940029b_1546780686225_440054_12205' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_940029b_1546778584008_302817_11945' name='information' visibility='private' aggregation='composite' type='_18_0_2_940029b_1535727067041_864259_10734'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1546778584008_690799_11954' body='&lt;para&gt;Hier kann optional eine Begründung oder Erläuterung der Fachbehörde eingetragen werden.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_18_0_2_940029b_1546778584008_302817_11945'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_2_940029b_1546778584008_365051_11955'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_2_940029b_1546778584008_703346_11953' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_18_0_2_940029b_1552126388478_40002_14677' name='prozessnachrichten.formellePruefungBefundliste.1140'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1552126388479_448931_14678' body='&lt;para&gt;Diese Nachricht bezieht sich auf einen gestellten Antrag oder eine übermittelte Anzeige oder Erklärung. Enthalten sind die Ergebnisse einer formellen Prüfung (Befunde) sowie ggf. eine Frist, innerhalb derer Antrag bzw. Anzeige anzupassen ist (bei einer Anpassung kann es sich um Korrekturen oder um eine Vervollständigung handeln).&lt;/para&gt;'>
							<annotatedElement xmi:idref='_18_0_2_940029b_1552126388478_40002_14677'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_3_136d03d4_1617019729277_465605_9467' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_940029b_1552126388479_186666_14679' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1552126388480_952886_14685' body='&lt;para&gt;Hier müssen Eintragungen vorgenommen werden, so dass sich die Nachricht einem vorhandenen Vorgang eindeutig zuordnen lässt. Dafür ist in das Element referenz die UUID der Antragsnachricht (Element referenzAntragsservice) einzutragen, auf die sich die formelle Prüfung bezieht.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_18_0_2_940029b_1552126388479_186666_14679'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_2_940029b_1552126388480_450655_14686' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_2_940029b_1552126388480_602088_14684' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_940029b_1552126388479_582729_14680' name='befundliste' visibility='private' aggregation='composite' type='_18_0_2_940029b_1552127281868_654162_14786'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1552126388480_701304_14689' body='&lt;para&gt;In diesem Element sind die Ergebnisse der formellen Prüfung enthalten. Sie haben die Form einer Liste von Mängeln des geprüften Gegenstandes.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_18_0_2_940029b_1552126388479_582729_14680'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_2_940029b_1552126388481_679365_14690' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_2_940029b_1552126388480_361408_14688' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_940029b_1552126388479_960148_14681' name='frist' visibility='private' aggregation='composite'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191726109_379108_1042'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='W3C Data Types::date' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1552126388481_253963_14693' body='&lt;para&gt;Im Falle einer Unvollständigkeit der Dokumente kann in dieses Element wird - falls im entsprechenden Vorgang vorgesehen - eine durch die Behörde gesetzte Frist eingetragen, innerhalb derer die genannten Mängel zu beseitigen und die Unterlagen erneut einzureichen sind.&lt;/para&gt;&#10;&lt;para&gt;Falls im Rahmen der formellen Prüfung alle Merkmale positiv bewertet wurden (Dokumentation vollständig), sind die Angaben zur Genehmigungsfrist und zu den eingereichten Unterlagen hier zu machen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_18_0_2_940029b_1552126388479_960148_14681'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_2_940029b_1552126388481_818106_14694'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_2_940029b_1552126388481_683596_14692' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1730730218005_921399_8892' name='dokumentationVollstaendig' visibility='private'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191716468_578747_1004'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='W3C Data Types::boolean' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1730730356835_871450_8896' body='&lt;para&gt;Mit diesem Element wird angegeben, ob die Dokumentation zu dem Vorgang vollständig oder nicht vollständig ist.Im Falle der Vollständigkeit, ist true einzutragen, andernfalls false.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1730730218005_921399_8892'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1730730299760_377675_8894' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1730730299765_196881_8895' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_940029b_1594568645475_790674_14704' name='prozessnachrichten.zustellungSchreiben.1141'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1594568645482_334449_14705' body='&lt;para&gt;Mittels dieser Nachricht kann die Fachbehörde einem Antragsteller oder sonstigem Beteiligten am Bauvorhaben eine Nachricht (Anschreiben mit Anlagen) zustellen. &lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_3_940029b_1594568645475_790674_14704'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_3_136d03d4_1617019925545_631167_9470' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1594568645483_204126_14706' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1594568645498_719889_14712' body='&lt;para&gt;Bezug auf Vorgang und Nachricht, auf die sich die Inhalte der vorliegenden Nachricht beziehen. Oder Angabe einer Vorgangsnummer für zukünftige Bezugnahme auf diese Nachricht.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1594568645483_204126_14706'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1594568645500_752083_14713' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_940029b_1594568645496_847085_14711' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1594568645486_545150_14707' name='anschreiben' visibility='private' aggregation='composite' type='_18_0_2_940029b_1535727067041_864259_10734'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1594568645506_942495_14716' body='&lt;para&gt;In dieses Element ist der Anschreibentext der Nachricht einzutragen.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1594568645486_545150_14707'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1594568645508_616119_14717' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_940029b_1594568645504_949972_14715' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1594568645489_23350_14708' name='angebotFuerAntwortLeser' visibility='private' aggregation='composite' type='_19_0_3_136d03d4_1611781855355_662927_10055'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1594568645516_963848_14720' body='&lt;para&gt;Dieses Element kann verwendet werden, um Webressourcen für ggf. nötige Reaktionen des Lesers auf die vorliegende Nachricht anzugeben . &lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1594568645489_23350_14708'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1594568645517_394996_14721'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_940029b_1594568645513_203653_14719' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1594569105972_656913_14738' name='anlagen' visibility='private' aggregation='composite' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1594569105977_649827_14740' body='&lt;para&gt;Dieses Element ist für Anlagen zur Nachricht zu verwenden.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1594569105972_656913_14738'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1594569105978_295185_14741'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_940029b_1594569105976_786267_14739' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_136d03d4_1622229844837_678922_9419' name='prozessnachrichten.fachlicheKommunikation.1142'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1622229844837_380491_9420' body='&lt;para&gt;Diese Nachricht dient der informellen, fachlichen Kommunikation innerhalb eines Verfahrens. Sie wird zum einem für Rückfragen eines Beteiligten des Verfahrens (Anschreiben ohne Anlagen) und zum anderem für die zugehörige Antwort der Fachbehörde verwendet.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_3_136d03d4_1622229844837_678922_9419'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_3_136d03d4_1622229844852_197825_9425' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1622229844837_565061_9421' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1622229844852_309835_9428' body='&lt;para&gt;Hier müssen Eintragungen vorgenommen werden, so dass sich die Nachricht einem vorhandenen Vorgang eindeutig zuordnen lässt. Dafür ist in das Element referenz entweder die UUID (Element referenzAntragsservice) der Antragsnachricht, die Vorgangsnummer oder das Aktenzeichen (Element vorgang) einzutragen, auf die sich die fachliche Kommunikation bezieht.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_136d03d4_1622229844837_565061_9421'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_136d03d4_1622229844852_898721_9429' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_136d03d4_1622229844852_741815_9427' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1622229844852_398538_9422' name='anschreiben' visibility='private' aggregation='composite' type='_19_0_3_136d03d4_1622230009808_308184_9453'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1622229844852_465632_9432' body='&lt;para&gt;In dieses Element ist der Anschreibentext der Nachricht (Rückfrage des Beteiligten oder Antwort der Behörde) einzutragen. Der Anschreibentext kann unformatiert oder formatiert übermittelt werden.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_136d03d4_1622229844852_398538_9422'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_136d03d4_1622229844852_165353_9433' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_136d03d4_1622229844852_777876_9431' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1624867753204_323298_9455' name='anlagen' visibility='private' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1624867815721_146060_9459' body='&lt;para&gt;Mit diesem Element können Metadaten zu Anlagen übermittelt werden.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_136d03d4_1624867753204_323298_9455'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_136d03d4_1624867973148_256005_9460'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_136d03d4_1624867973149_239875_9461' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_136d03d4_1622232026922_749916_9485' name='prozessnachrichten.einstellenDokumente.1150'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1622232026923_66704_9486' body='&lt;para&gt;Mit dieser Nachricht kann die Aufsichtsbehörde Dokumente in einen Projektraum einstellen, z. B. ergänzende Dokumentation zum Antrag, zur Prüfung des Antrags oder zur Ämterbeteiligung; auch z. B. einen digitalisierten Papierantrag mit Anlagen.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_3_136d03d4_1622232026922_749916_9485'/>
						</ownedComment>
						<generalization xmi:type='uml:Generalization' xmi:id='_19_0_3_136d03d4_1622232026925_333773_9489' general='_19_0_3_136d03d4_1617018517570_525675_9422'/>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1622232026924_422768_9487' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1622232026925_792077_9492' body='&lt;para&gt;Hier müssen Eintragungen vorgenommen werden, so dass sich die Nachricht einem vorhandenen Vorgang oder Projektraum eindeutig zuordnen lässt. Dafür ist in das Element referenz die UUID der Antragsnachricht (Element referenzAntragsservice) einzutragen, auf die sich das Einstellen der Dokumente bezieht.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_136d03d4_1622232026924_422768_9487'/>
							</ownedComment>
