							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743635_651690_12240' body='&lt;para&gt;Dieses Element bildet den Namen (die Bezeichnung) der Straße ab.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743609_24748_12229'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743637_163507_12241'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743634_165396_12239' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743616_508720_12230' name='hausnummer' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743640_144489_12244' body='&lt;para&gt;Dieses Element nimmt die Hausnummer auf (einschließlich eines möglichen Buchstabens, der zur Hausnummer gehört, wie z.B. 39b).&lt;/para&gt; &#10;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743616_508720_12230'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743641_263194_12245'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743639_821848_12243' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743618_296305_12231' name='strasseHausnummer' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743643_78153_12248' body='&lt;para&gt;Element für die Erfassung von Straße und Hausnummer als undifferenzierte Zeichenkette (nur für bestimmte Kontexte: ersetzt dann die Verwendung der Elemente &lt;emphasis role=&quot;codebf&quot;&gt;strasse&lt;/emphasis&gt; und &lt;emphasis role=&quot;codebf&quot;&gt;hausnummer&lt;/emphasis&gt;).&lt;/para&gt;&#10;&lt;para&gt;Falls sich in einem Kontext der Übernahme von Anschriftsdaten (z.B. bei Verwendung der eID-Funktion des maschinenlesbaren Personalausweises für die Erfassung der Daten des Antragstellers) die Bezeichnung der Straße und die Hausnummer nicht maschinell zuverlässig trennen lassen, können diese Informationen in das Element als eine gemeinsame Zeichenkette übernommen werden.&lt;/para&gt; &#10;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743618_296305_12231'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743644_30841_12249'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_940029b_1589655743642_791533_12247' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743621_451790_12232' name='postfach' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743647_844110_12252' body='&lt;para&gt;Ein Postfach (oft Postfachnummer) ist ein Schlüssel zur Identifikation eines Postfaches in einer Postfiliale.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743621_451790_12232'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743647_399065_12253'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743646_563192_12251' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743623_997549_12233' name='postleitzahl' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743650_268619_12256' body='&lt;para&gt;Eine Postleitzahl ist eine Angabe, um postalische Zustellgebiete unabhängig von Gebietskörperschaften (Gemeinde, Kreis) zu bezeichnen.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743623_997549_12233'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743650_840855_12257'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743649_804697_12255' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743624_940876_12234' name='ort' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743652_473661_12260' body='&lt;para&gt;Dieses Element enthält den Namen des Ortes (Gemeinde, Ortschaft oder Stadt), zu der die Anschrift gehört.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743624_940876_12234'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743653_79725_12261'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743651_931506_12259' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743626_197976_12235' name='ortsteil' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743654_810752_12264' body='&lt;para&gt;Der Ortsteil umfasst ein Teilgebiet des Ortes (der Gemeinde) und dient der Untergliederung.&lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743626_197976_12235'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743655_149031_12265'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743654_135179_12263' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743628_312805_12236' name='wohnungsgeber' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743657_164964_12268' body='&lt;para&gt;Die Komponente &quot;wohnungsgeber&quot; enthält Angaben (Name/Bezeichnung) zum Hauptmieter oder Eigentümer einer Immobilie.&lt;/para&gt;&#10;&#10;&lt;para&gt;Die Angabe eines Wohnungsgebers im Kontext der Anschrift dient der genaueren oder leichteren Adressierung. Sie darf nicht genutzt werden um Mietverhältnisse oder ähnliche rechtliche Beziehungen zwischen Personen auszudrücken.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiel: bei Meyer&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743628_312805_12236'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743658_29645_12269'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743657_137734_12267' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743630_512110_12237' name='zusatz' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743659_587537_12272' body='&lt;para&gt;Ein Anschriftenzusatz beinhaltet ggf. erforderliche weitere Präzisierungen zu einer Anschrift.&lt;/para&gt;&#10;&#10;&lt;para&gt;Beispiele: Hinterhof, 3. Aufgang, Haus A, 3. Stock, Appartement 25a,  3. Stock - Appartement 25 a, #325a, Raum 77&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743630_512110_12237'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743659_14043_12273'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743658_653450_12271' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_940029b_1589655743631_394452_12238' name='staat' visibility='private' aggregation='composite' type='_16_5_4_940029b_1422888807308_342425_3010'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_940029b_1589655743660_782892_12276' body='&lt;para&gt;Der Staat, dem die Anschrift postalisch zugeordnet wird.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_940029b_1589655743631_394452_12238'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_940029b_1589655743660_20148_12277'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_940029b_1589655743660_911774_12275' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_8a30247_1422894619924_503273_3379' name='Kommunikation'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8a30247_1422894619924_612939_3385' body='&lt;para&gt;&quot;Kommunikation&quot; fasst Angaben zur Erreichbarkeit über elektronische Kommunikationskanäle (z.B. Telefon, Fax, E-Mail) zusammen.&lt;/para&gt;&#10;'>
							<annotatedElement xmi:idref='_16_5_4_8a30247_1422894619924_503273_3379'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<modelExtension>
								<ownedDiagram xmi:type='uml:Diagram' xmi:id='_16_5_4_8a30247_1422894619940_386478_3400' name='Kommunikation' visibility='public' ownerOfDiagram='_16_5_4_8a30247_1422894619924_503273_3379'>
