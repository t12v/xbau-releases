					<packagedElement xmi:type='uml:Dependency' xmi:id='_19_0_4_78d0259_1728657130776_914869_10047'>
						<client xmi:idref='_19_0_4_78d0259_1728657130758_501592_10029'/>
						<supplier href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_354848_6727'>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08' referentType='Package'/>
