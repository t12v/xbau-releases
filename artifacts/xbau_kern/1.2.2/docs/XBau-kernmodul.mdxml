								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_b6602da_1727331980442_982540_8318' name='statusAntragsportal' visibility='private' type='_19_0_4_b6602da_1727331549013_612647_8287'>
