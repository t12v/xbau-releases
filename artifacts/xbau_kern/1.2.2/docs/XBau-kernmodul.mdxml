								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_136d03d4_1611781871673_705551_10079' name='Anonym_LinkListe'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1611781871674_8741_10080'>
							<annotatedElement xmi:idref='_19_0_3_136d03d4_1611781871673_705551_10079'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1611781871674_544000_10081' name='link' visibility='private' type='_19_0_3_136d03d4_1611781889004_410228_10088'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1611781871675_452931_10083' body='&lt;para&gt;Jedes instanziierte Element steht für einen Link auf eine Webseite oder Ressource.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_19_0_3_136d03d4_1611781871674_544000_10081'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_136d03d4_1611781871675_959785_10084' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_136d03d4_1611781871674_855158_10082' value='*'/>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_16_5_4_940029b_1465368877212_444325_5428' name='Bezug'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465369587050_970021_5510' body='&lt;para&gt;Dieser Typ gestattet Eintragungen, um auf einen Antrag, einen Vorgang und ggf. auf eine Nachricht, die im Rahmen dieses Vorgangs gesendet worden ist, Bezug zu nehmen. &lt;/para&gt;'>
							<annotatedElement xmi:idref='_16_5_4_940029b_1465368877212_444325_5428'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_2_940029b_1546720734944_199093_13359' name='referenz' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1664881730540_81040_6897'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Basisnachricht::qualified::G2G::1.1::UUID' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1546720734959_14595_13361' body='&lt;para&gt;Hier ist der Identifier des Antragsservice (der mit dem Antrag bzw. der Anzeige bei der Fachbehörde eingegangen ist) oder der Abfrage (auf die die vorliegende Nachricht eine Antwort ist) anzugeben.&lt;/para&gt;&#10;&lt;para&gt;Falls die vorliegende Nachricht an ein Online-Portal gerichtet ist, kann so der Projektraum bzw. Postkorb angesteuert werden.&lt;/para&gt;&#10;&#10;'>
								<annotatedElement xmi:idref='_18_0_2_940029b_1546720734944_199093_13359'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_2_940029b_1546720734959_437875_13362'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_2_940029b_1546720734959_220578_13360' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_940029b_1465369045932_696516_5487' name='vorgang' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1659506109571_319729_6731'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Teilmengen der in Unicode enthaltenen Zeichen::DIN 91379::2022-08::datatypeC' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_940029b_1465369445636_190258_5508' body='&lt;para&gt;Eine Instanz dieses Elements enthält, falls ein solches vergeben wurde, das Zeichen (Aktenzeichen) des von der Fachbehörde geführten Vorgangs, innerhalb dessen diese Nachricht übermittelt wird. &lt;/para&gt;&#10;'>
								<annotatedElement xmi:idref='_16_5_4_940029b_1465369045932_696516_5487'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_940029b_1465369058452_265785_5489'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_940029b_1465369058452_98569_5490' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1612387491891_70335_9576' name='bezugNachricht' visibility='private'>
							<type href='XOEV-Bibliothek.mdxml#_19_0_4_41901a4_1664881730540_634830_6898'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='Externe Modelle::XOEV-Bibliothek::XOEV-Datentypen::Basisnachricht::qualified::G2G::1.1::Identifikation.NachrichtType' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1612387592075_194225_9582' body='&lt;para&gt;Falls ein solcher Zusammenhang vorliegt, sind hier die Kennungen der Nachricht einzutragen, auf die sich diese Nachricht bezieht.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_136d03d4_1612387491891_70335_9576'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_136d03d4_1612387564308_84214_9580'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_136d03d4_1612387564308_525826_9581' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_136d03d4_1601245573232_871949_15379' name='Nachweisdaten'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1601245610915_709820_15381' body='&lt;para&gt;Dieser Typ bildet Nachweisdaten zu behördlichen Vorgängen ab.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_3_136d03d4_1601245573232_871949_15379'/>
						</ownedComment>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1601245613095_453060_15382' name='behoerde' visibility='private'>
