								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728544794087_164621_8765' name='bezug' visibility='private' type='_19_0_3_129a03b9_1668162628374_570793_9692'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728544794095_618664_8767' body='&lt;para&gt;Sofern anwendbar, kann hier ein Bezug zu einem anderen Vorgang angegeben werden.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728544794087_164621_8765'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728544794098_535642_8768'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728544794094_790282_8766' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728544935002_18201_8772' name='antragsteller' visibility='private' type='_16_5_4_8a30247_1408703057450_27821_3423'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728572879817_802499_8899' body='&lt;para&gt;In dieses Element sind die Daten des Antragstellers bzw. der Antragsteller einzutragen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728544935002_18201_8772'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728546158998_510562_8799' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728546158998_306108_8800' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728546018193_46867_8788' name='grundstueck' visibility='private' type='_19_0_4_78d0259_1728545175832_300303_8774'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728546089486_934077_8792' body='&lt;para&gt;In diesem Element sind Daten enthalten, die das Baugrundstück (ein Grundstück, auf dem das Vorhaben stattfinden soll bzw. auf dem es durchgeführt wurde) identifizieren. Ein Baugrundstück kann mehrere Grundstücke umfassen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728546018193_46867_8788'/>
							</ownedComment>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728546038585_676860_8789' value='1'/>
								</modelExtension>
							</xmi:Extension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728546038585_599291_8790' value='*'/>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_4_78d0259_1728549721978_622334_8930' name='anlagen' visibility='private' type='_16_5_4_940029b_1460560241523_867175_3826'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728549721978_151081_8932' body='&lt;para&gt;Die für die Planung des Vorhabens notwendigen Vorlagen sind dem Antrag als Anlage  bzw. Verweise auf diese Anlagen beizufügen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_4_78d0259_1728549721978_622334_8930'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_4_78d0259_1728549721978_468604_8933'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_4_78d0259_1728549721978_469421_8931' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_19_0_4_78d0259_1728567100074_911563_10014' name='universellerAntrag.materiellePruefungBefundliste.1203'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_4_78d0259_1728567100085_381424_10023' body='&lt;para&gt;Diese Nachricht fordert den Antragsteller zur Stellungnahme auf, nachdem die materielle Prüfung des Antrags ergeben hat, dass Gründe vorliegen, die zu seiner Ablehnung durch die zuständige Behörde führen können. Es sind die Befunde enthalten, die das Ergebnis der materiellen Prüfung sind. Diese werden hier aufgelistet bzw. im Anhang der Nachricht dokumentiert mit dem Hinweis, dass Gelegenheit zu Stellungnahme bzw. Nachbesserung  besteht.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_19_0_4_78d0259_1728567100074_911563_10014'/>
						</ownedComment>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<modelExtension>
