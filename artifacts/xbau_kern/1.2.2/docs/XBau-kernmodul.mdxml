					<packagedElement xmi:type='uml:Package' xmi:id='_19_0_3_129a03b9_1694598356258_185770_8876' name='Gebuehrenbescheid'>
						<packagedElement xmi:type='uml:Class' xmi:id='_19_0_3_129a03b9_1694598367137_540587_8877' name='Gebuehrenbescheid'>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1694598367137_250944_8878' body='&lt;para&gt;Dieser Typ beinhaltet die Parameter eines Gebührenbescheids der Fachbehörde. Es sind die Daten zu Gegenstand, Herleitung, Betrag und Bezahlung der Gebühren enthalten.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_129a03b9_1694598367137_540587_8877'/>
							</ownedComment>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_129a03b9_1694598367137_657904_8879' name='istVorauszahlungsbescheid' visibility='private'>
								<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191716468_578747_1004'>
									<xmi:Extension extender='MagicDraw UML 19.0'>
										<referenceExtension referentPath='W3C Data Types::boolean' referentType='Class'/>
									</xmi:Extension>
								</type>
								<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1694598367147_765710_8888' body='&lt;para&gt;Falls es sich nicht um den abschließenden Gebührenbescheid, sondern um einen Vorauszahlungsbescheid handelt, ist hier true einzutragen. Dann weiß der Empfänger, dass weitere Gebührenbescheide zum angegebenen Vorgang zu erwarten sind.&lt;/para&gt;&#10;'>
									<annotatedElement xmi:idref='_19_0_3_129a03b9_1694598367137_657904_8879'/>
								</ownedComment>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<modelExtension>
										<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_129a03b9_1694598367147_31228_8889' value='1'/>
									</modelExtension>
								</xmi:Extension>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<modelExtension>
										<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_129a03b9_1694598367145_888361_8887' value='1'/>
									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_129a03b9_1694598367137_167267_8880' name='begruendung' visibility='private' type='_18_0_2_940029b_1535727067041_864259_10734'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1694598367147_767911_8892' body='&lt;para&gt;Hier ist die Rechtsgrundlage für die Gebühr bzw. eine sonstige Begründung einzutragen.&lt;/para&gt;&#10;'>
									<annotatedElement xmi:idref='_19_0_3_129a03b9_1694598367137_167267_8880'/>
								</ownedComment>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<modelExtension>
										<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_129a03b9_1694598367147_923548_8893' value='1'/>
									</modelExtension>
								</xmi:Extension>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<modelExtension>
										<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_129a03b9_1694598367147_404372_8891' value='1'/>
									</modelExtension>
								</xmi:Extension>
							</ownedAttribute>
							<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_129a03b9_1694598367137_819782_8881' name='kostenberechnung' visibility='private' type='_19_0_3_129a03b9_1694598444342_688874_8929'>
								<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_129a03b9_1694598367147_134795_8896' body='&lt;para&gt;Dieses Objekt enthält alle Informationen zu den Positionen des Gebührenbescheids und deren Summierung zu einem Geldbetrag.&lt;/para&gt;&#10;'>
									<annotatedElement xmi:idref='_19_0_3_129a03b9_1694598367137_819782_8881'/>
								</ownedComment>
								<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_129a03b9_1694598367147_674202_8897'/>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<modelExtension>
