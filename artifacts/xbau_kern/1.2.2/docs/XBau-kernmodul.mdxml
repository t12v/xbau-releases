	<XOEV_Profil:xsdXModel xmi:id='_16_5_4_1d100e5_1384795021953_565292_401' base_Model='_16_5_4_1d100e5_1384794823532_59933_328' schemaLocationBase='https://xleitstelle.de/xbau/schema/kernmodul/1/2/2/' namespace='http://www.xleitstelle.de/xbau/kernmodul/1/2/2' fassungVom='2024-11-07' prefix='xbauk' deployment='true' elementFormDefault='unqualified' automatischeImportErmittlung='false' automatischeIncludeErmittlung='false' ermittlungElementreihenfolge='Stereotyp' standardeinstellungEigenschaften='keine' xsdNamedTypeNameSuffix=''/>
