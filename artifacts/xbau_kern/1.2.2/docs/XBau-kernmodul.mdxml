					<supplier xmi:idref='_19_0_3_136d03d4_1612313332051_551267_9598'/>
				</packagedElement>
				<packagedElement xmi:type='uml:Usage' xmi:id='_19_0_3_136d03d4_1612313695569_391490_13267'>
