								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_136d03d4_1605090083293_537380_15288' value='1'/>
								</modelExtension>
							</xmi:Extension>
						</ownedAttribute>
						<ownedAttribute xmi:type='uml:Property' xmi:id='_19_0_3_136d03d4_1601245635439_872357_15384' name='aktenzeichen' visibility='private'>
							<type href='XOEV-Profil.mdxml#_14_0_1_6370212_1218191873500_204582_1633'>
								<xmi:Extension extender='MagicDraw UML 19.0'>
									<referenceExtension referentPath='W3C Data Types::token' referentType='Class'/>
								</xmi:Extension>
							</type>
							<ownedComment xmi:type='uml:Comment' xmi:id='_19_0_3_136d03d4_1601245728038_658552_15396' body='&lt;para&gt;In dieses Element ist das Aktenzeichen einzutragen.&lt;/para&gt;'>
								<annotatedElement xmi:idref='_19_0_3_136d03d4_1601245635439_872357_15384'/>
							</ownedComment>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_19_0_3_136d03d4_1605090098128_900802_15289'/>
							<xmi:Extension extender='MagicDraw UML 19.0'>
								<modelExtension>
									<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_19_0_3_136d03d4_1605090098128_213687_15290' value='1'/>
								</modelExtension>
