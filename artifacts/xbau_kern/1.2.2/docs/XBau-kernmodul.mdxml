						</ownedAttribute>
					</packagedElement>
					<packagedElement xmi:type='uml:Class' xmi:id='_18_0_2_940029b_1546778584008_952063_11942' name='prozessnachrichten.quittierungRuecknahme.1131'>
						<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_2_940029b_1546778584008_602047_11943' body='&lt;para&gt;Diese Nachricht wird von der Fachbehörde verwendet, um  die Rücknahme des Antrags durch den Antragsteller zu quittieren, also zu bestätigen, dass die Rücknahme durch die Behörde akzeptiert wurde (mit gegebenen Konsequenzen für den Antragsteller). Ggf. kann sie aber auch die Information enthalten, dass der Antrag nicht mehr zurückgenommen werden kann.&lt;/para&gt;'>
							<annotatedElement xmi:idref='_18_0_2_940029b_1546778584008_952063_11942'/>
						</ownedComment>
