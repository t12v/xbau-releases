    <packagedElement xmi:type="uml:Package" xmi:id="_12_0_8f90291_1163703146375_8469_2064" name="XML Schema constraints" visibility="public" URI="">
      <ownedRule xmi:id="_12_0_8f90291_1163575123937_950942_1219" name="Not XML Schema Types for XSDattribute" visibility="public" constrainedElement="magicdraw_1046682040730_843189_181">
        <ownedComment xmi:id="_12_0_8f90291_1163575454812_25968_1228" annotatedElement="_12_0_8f90291_1163575123937_950942_1219" body="XML Schema – specific types, not simple UML types should be used."/>
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_12_0_8f90291_1163575353828_963914_1220" name="" visibility="public">
          <language>OCL2.0</language>
          <body>(not type.oclIsUndefined()) implies (type.oclIsKindOf(XSDsimpleType) or type.oclIsKindOf(XSDcomplexType) or (type.oclIsKindOf(XSDcomponent) and type.name='anyType'))</body>
        </specification>
      </ownedRule>
      <ownedRule xmi:id="_12_0_8f90291_1163575564875_903163_1229" name="Not XML Schema Types for XSDelement" visibility="public" constrainedElement="magicdraw_1046682074970_241068_216">
