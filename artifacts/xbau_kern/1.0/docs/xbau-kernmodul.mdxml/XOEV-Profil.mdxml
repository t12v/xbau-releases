						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1499768519879_287470_4011' name='nameKurz' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499768519879_431495_4021' body='Der Name (kurz) ist die &quot;sprechende&quot; Kurzbezeichnung einer Codeliste. Dieser Name wird beispielsweise im XRepository in Listendarstellungen von Inhalten verwendet oder kann zur Bezeichnung der Codeliste in Texten (Spezifikationsdokument) verwendet werden.'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1499768519879_287470_4011'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1499768519879_311664_4022' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1499768519879_53868_4020' value='1'/>
						</modelExtension>
