			<packagedElement xmi:type='uml:Stereotype' xmi:id='_18_0_6_5b501fb_1499769818144_431335_4474' name='xoevKernkomponente'>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1499769818144_370855_4481' name='nameLang' visibility='private'>
