				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1499769818159_477542_4482' name='nameKurz' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499769818159_854866_4512' body='Der Name (kurz) ist die &quot;sprechende&quot; Kurzbezeichnung einer Kernkomponente. Dieser Name wird beispielsweise im XRepository in Listendarstellungen von Inhalten verwendet oder kann zur Bezeichnung der Kernkomponente in Texten (Spezifikationsdokument) verwendet werden.'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1499769818159_477542_4482'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1499769818159_753958_4513' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1499769818159_350706_4511' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1499769818159_982633_4483' name='nameTechnisch' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499769818159_535596_4515' body='Neben den Namen (lang) und Namen (kurz) besitzt eine Kernkomponente einen technischen Namen. Dieser Name soll &quot;sprechend&quot; und gleichzeitig zur technischen Verarbeitung optimiert sein. In der Regel ist der technische Name vom Namen (kurz) abgeleitet.&#10;&#10;Die Regeln zur Bildung des technischen Namens sind im XÖV-Handbuch detailliert dargestellt.'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1499769818159_982633_4483'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1499769818159_784282_4516' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1499769818159_692286_4514' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1499769818159_988178_4484' name='kennung' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499769818159_563196_4518' body='Mittels einer Kennung wird eine Kernkomponente versionsübergreifend eindeutig identifiziert.&#10;&#10;Die Regeln zur Bildung von Kennungen sind im XÖV-Handbuch detailliert dargestellt.'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1499769818159_988178_4484'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1499769818159_804997_4519' value='1'/>
						</modelExtension>
