					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_14_0_1_6370212_1213859900312_479266_957'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_14_0_1_6370212_1213859900312_941739_958' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_12_1_8b00279_1240305834261_832017_144'>
				<memberEnd xmi:idref='_12_1_8b00279_1240305834261_735373_145'/>
				<memberEnd xmi:idref='_12_1_8b00279_1240305834261_608391_146'/>
				<navigableOwnedEnd xmi:idref='_12_1_8b00279_1240305834261_608391_146'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_12_1_8b00279_1240305834261_608391_146' name='extension_xsdCode' visibility='private' aggregation='composite' type='_12_1_8b00279_1240305730667_765894_120' association='_12_1_8b00279_1240305834261_832017_144'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240305834261_493285_147'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240305834261_810502_148' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_12_1_8b00279_1240306518157_731879_204'>
				<memberEnd xmi:idref='_12_1_8b00279_1240306518157_213767_205'/>
				<memberEnd xmi:idref='_12_1_8b00279_1240306518157_514542_206'/>
				<navigableOwnedEnd xmi:idref='_12_1_8b00279_1240306518157_514542_206'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_12_1_8b00279_1240306518157_514542_206' name='extension_xsdCodeList' visibility='private' aggregation='composite' type='_12_1_8b00279_1240306417404_766333_161' association='_12_1_8b00279_1240306518157_731879_204'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240306518157_363360_207'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240306518157_953835_208' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1181826329822_66722_3772' name='xsdTitled'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1207143051046_441558_3' body='&lt;para&gt;Ein mit diesem Stereotyp gekennzeichnetes UML-Element (z.B. eine UML-Klasse) erhält in der Dokumentation des XÖV-Standards einen anderen Titel als seinen Namen im UML-Modell (z.B. den UML-Klassennamen). Dies ist insbesondere dann sinnvoll, wenn der Titel in der Dokumentation beispielsweise Leerzeichen oder Umlaute enthalten soll.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1181826329822_66722_3772'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1181826329822_358801_3774' name='base_Element' visibility='private' association='_11_5_6370212_1181826329822_317572_3773'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Element'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Element' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1170240822453_184342_1' name='title' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1179674937750_328255_11' body='&lt;para&gt;Der Prosa-Titel in der Dokumentation.&lt;/para&gt;&#10;&lt;para&gt;Im XML-Schema wird die Eigenschaft in xs:annotation des jeweiligen XML-Schema-Bestandteils abgebildet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1170240822453_184342_1'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_14_0_5b501fb_1239108443131_132845_1103' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_14_0_5b501fb_1239108443131_719273_1104' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1181825895666_44096_93' name='xsdWithImplementationHint'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1207143171921_571560_4' body='&lt;para&gt;Ein mit diesem Stereotyp gekennzeichnetes UML-Element erhält in der Dokumentation neben der normalen Beschreibung einen Abschnitt mit Implementierungshinweisen.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1181825895666_44096_93'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1181826014072_327233_113' name='base_Element' visibility='private' association='_11_5_6370212_1181826014072_287792_112'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Element'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Element' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1181827583119_960162_4154' name='implementationHint' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240319752226_284628_285' body='&lt;para&gt;Der Implementierungshinweis zu dem XML-Bestandteil.&lt;/para&gt;&#10;&lt;para&gt;Im XML-Schema wird die Eigenschaft in xs:annotation des jeweiligen XML-Schema-Bestandteils abgebildet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1181827583119_960162_4154'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_14_0_5b501fb_1239108495983_830996_1106' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_14_0_5b501fb_1239108495983_28614_1107' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1197040199062_390349_11' name='xoevCodelisteneintrag'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1207142970046_935815_2' body='&lt;para&gt;Mit diesem Stereotyp werden Literale einer  UML-Enumeration als Wert einer &amp;clst; (UML-Enumeration mit dem Stereotyp &quot;xsdCodeList&quot;)  gekennzeichnet.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung des Stereotyps im XML-Schema erfolgt als xs:enumeration&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1197040199062_390349_11'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1197040223296_174154_31' name='base_EnumerationLiteral' visibility='private' association='_11_5_6370212_1197040223296_689223_30'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#EnumerationLiteral'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::EnumerationLiteral' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1197040232437_934738_35' name='wertErsteBeschreibungsspalte' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240306708182_393937_212'>
						<annotatedElement xmi:idref='_11_5_6370212_1197040232437_934738_35'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1241704661212_722338_514' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1241704661212_729451_515' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1500890405977_823523_4113' name='wertZweiteBeschreibungsspalte' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1500890405977_232079_4115'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1500890405977_823523_4113'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1500890405977_422192_4116'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1500890405977_221679_4114' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1322499063960_322188_432' name='obsolet' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#Boolean'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1322501557543_392565_366' body='&lt;para&gt;Mit diesem Schalter können veraltete, nicht mehr zu übermittelnde Codes gekennzeichnet werden (obsolete = true). Deartig gekennzeichnete Codes, d. h. Literale einer Enumeration, werden im Kontext einer Standard-Codeliste nicht mehr in das Schema herausgeschrieben. Auf diese Weise kann die (unbemerkte) Wiederverwendung alter Codes für neue Zwecke, d. h. mit neuer Bedeutung, vermieden werden, da doppelte Codes in einer Enumeration in UML nicht zugelassen werden.&lt;/para&gt; &lt;para&gt;Der Default-Wert der Eigenschaft &quot;obsolete&quot; ist &quot;false&quot;.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1322499063960_322188_432'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1322499081816_700799_435'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1322499081816_852808_436' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='_16_5_4_5b501fb_1322499094610_756063_440'/>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_12_1_8b00279_1240305730667_765894_120' name='xsdCode'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240305907173_196075_157' body='&lt;para&gt;Eine UML-Klasse, die mit dem Stereotypen &quot;xsdCode&quot; versehen ist, stellt einen Code-Datentyp dar, der eine einzusetzende &amp;clst; näher beschreibt.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung der so stereotypisierten UML-Klasse im XML-Schema erfolgt als xs:complexType&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; mit xs:complexContent&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#declare-type&quot;&gt;http://www.w3.org/TR/xmlschema-1/#declare-type&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; im XML-Schema.&lt;/para&gt;&#10;&lt;para&gt;In Abhängigkeit von der zusätzlichen Vergabe des Stereotypen &quot;xsdNamedType&quot; wird der Code-Datentyp als benannter Typ im XML-Schema umgesetzt, ansonsten als anonymer Typ.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_12_1_8b00279_1240305730667_765894_120'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240305834261_735373_145' name='base_Class' visibility='private' association='_12_1_8b00279_1240305834261_832017_144'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_12_1_8b00279_1240306417404_766333_161' name='xsdCodeList'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240306628661_568772_211' body='&lt;para&gt;Die Umsetzung des Stereotyps im XML-Schema erfolgt als xs:simpleType&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; mit dem durch xs:enumeration&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-enumeration&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; eingeschränkten Basistyp &quot;xs:token&quot;&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#token&quot;&gt;http://www.w3.org/TR/xmlschema-2/#token&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;, es sei denn die Eigenschaft &lt;emphasis&gt;base&lt;/emphasis&gt; definiert einen anderen Basistypen. Wird die Codeliste in einem Code Datentyp verwendet, muss der Basistyp vom Typ xs:token oder einer Unterklasse sein.&lt;/para&gt;&#10;&lt;para&gt;In Abhängigkeit von der zusätzlichen Vergabe des Stereotypen &quot;xsdNamedType&quot; wird die &amp;clst; als benannter Typ im XML-Schema umgesetzt, ansonsten als anonymer Typ.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_12_1_8b00279_1240306417404_766333_161'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240306518157_213767_205' name='base_Enumeration' visibility='private' association='_12_1_8b00279_1240306518157_731879_204'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Enumeration'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Enumeration' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310464347811_201332_328' name='base' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1316429565493_495332_461' body='&lt;para&gt;Bestimmt den Obertypen der Enumeration. Dieser muss ein einfacher Typ sein. Bei der Verwendung innerhalb eines XÖV-Codes muss er zusätzlich vom Typ xs:token order ein davon abgeleiteter Typ sein.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1310464347811_201332_328'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310464635387_157256_328'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310464635388_364329_329' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_8b00279_1264582309240_225915_526' name='xsdLocalStructure'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8b00279_1264582638551_280009_554' body='&lt;para&gt;Eine UML-Eigenschaft, die mit &quot;xsdLocalStructure&quot; versehen ist, kennzeichnet, dass die Strukturen der anonymen referenzierten UML-Klasse, die einen Typ mit komplexen Inhalt darstellt, im XML-Schema direkt, ohne Angabe von &quot;xs:complexType&quot;&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; in die darüberliegende Struktur eingebunden werden.&lt;/para&gt;&#10;&lt;para&gt;Verwendung ohne &quot;xsdLocalStructure&quot;:&lt;/para&gt;&#10;&lt;programlisting&gt;&lt;![CDATA[&lt;xs:complexType name=&quot;Beispiel&quot;&gt;&#10;  &lt;xs:sequence&gt;&#10;    &lt;xs:element name=&quot;ergebnis&quot;&gt;&#10;      &lt;xs:complexType&gt;&#10;        &lt;xs:choice&gt;&#10;          &lt;xs:element name=&quot;grundFuerAusfallDesWettbewerbs&quot; type=&quot;xs:string&quot;/&gt;&#10;          &lt;xs:element name=&quot;teilnehmer&quot; type=&quot;xhz:Teilnehmer&quot; maxOccurs=&quot;unbounded&quot;/&gt;&#10;       &lt;/xs:choice&gt;&#10;     &lt;/xs:complexType&gt;&#10;   &lt;/xs:element&gt;&#10;   ...&#10;  &lt;/xs:sequence&gt;&#10;&lt;/xs:complexType&gt;]]&gt;&lt;/programlisting&gt;&lt;para&gt;&lt;/para&gt;&#10;&lt;para&gt;Verwendung mit &quot;xsdLocalStructure&quot;:&lt;/para&gt;&#10;&lt;programlisting&gt;&lt;![CDATA[&lt;xs:complexType name=&quot;Beispiel&quot;&gt;&#10;  &lt;xs:sequence&gt;&#10;    &lt;xs:choice&gt;&#10;      &lt;xs:element name=&quot;grundFuerAusfallDesWettbewerbs&quot; type=&quot;xs:string&quot;/&gt;&#10;      &lt;xs:element name=&quot;teilnehmer&quot; type=&quot;xhz:Teilnehmer&quot; maxOccurs=&quot;unbounded&quot;/&gt;&#10;     &lt;/xs:choice&gt;&#10;     ...&#10;  &lt;/xs:sequence&gt;&#10;&lt;/xs:complexType&gt;]]&gt;&lt;/programlisting&gt;'>
					<annotatedElement xmi:idref='_16_5_4_8b00279_1264582309240_225915_526'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8b00279_1264582391052_265825_550' name='base_Property' visibility='private' association='_16_5_4_8b00279_1264582391052_582065_549'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Property'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Property' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1270208088006_335639_526' name='position' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#Integer'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::Integer' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1270208104074_432819_528' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1270208104074_120801_529' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_8b00279_1264582391052_582065_549'>
				<memberEnd xmi:idref='_16_5_4_8b00279_1264582391052_265825_550'/>
				<memberEnd xmi:idref='_16_5_4_8b00279_1264582391052_609645_551'/>
				<navigableOwnedEnd xmi:idref='_16_5_4_8b00279_1264582391052_609645_551'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_8b00279_1264582391052_609645_551' name='extension_xsdLocalStructure' visibility='private' aggregation='composite' type='_16_5_4_8b00279_1264582309240_225915_526' association='_16_5_4_8b00279_1264582391052_582065_549'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8b00279_1264582391052_729212_552'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8b00279_1264582391052_196587_553' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_5b501fb_1276693051258_429282_547' name='xsdDeprecated'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1276693182429_121388_577' body='&lt;para&gt;Dieser Stereotyp kann bei der Dokumentationsgenerierung berücksichtigt werden, um bestimmte Teile eines Standards abzukündigen.&lt;/para&gt;&#10;&lt;para&gt;Der Stereotyp hat keine Auswirkungen auf die generierten XML-Schemata.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_5b501fb_1276693051258_429282_547'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1276693051260_841685_549' name='base_Element' visibility='private' association='_16_5_4_5b501fb_1276693051260_225562_548'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Element'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Element' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1276693121229_470354_570' name='deprecatedContext' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1276693194740_950700_578' body='&lt;para&gt;Diese Eigenschaft kann dazu genutzt werden, um mehrere abgekündigte Bestandteile zu gruppieren, da diese z. B. durch einen einzigen Änderungeantrag wegfallen. Innerhalb der generierten Dokumentation kann dann auf einen beschreibenden Abschnitt verwiesen werden.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1276693121229_470354_570'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1276693167382_532928_575' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1276693167382_120464_576' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_5b501fb_1276693051260_225562_548'>
				<memberEnd xmi:idref='_16_5_4_5b501fb_1276693051260_841685_549'/>
				<memberEnd xmi:idref='_16_5_4_5b501fb_1276693051260_440941_550'/>
				<navigableOwnedEnd xmi:idref='_16_5_4_5b501fb_1276693051260_440941_550'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_5b501fb_1276693051260_440941_550' name='extension_unbenannt1' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1276693051258_429282_547' association='_16_5_4_5b501fb_1276693051260_225562_548'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1276693051260_752970_551'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1276693051260_858826_552' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_b7102e0_1282131963663_958424_532' name='xsdXModelImport'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1282131963670_843674_534' body='&lt;para&gt;Dieser Stereotyp wird für die Dokumentation von Datentypen aus eingebundenen externen Modellen benötigt. Bei der Verwendung eines externen Datentyps kann die Dokumentation auf die hier definierten Daten zurückgreifen und so einen Verweis auf ein externes Dokument erzeugen.&lt;/para&gt;&#10;&lt;para&gt;Der Stereotyp hat keine Auswirkungen auf die generierten XML-Schemata.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_b7102e0_1282131963663_958424_532'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1282131963681_712136_539' name='base_Dependency' visibility='private' association='_16_5_4_b7102e0_1282131963681_472501_538'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Dependency'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Dependency' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1282131963669_347065_533' name='bezeichnung' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1282131963670_561191_536' body='&lt;para&gt;Bei Verweisen verwendeter Bezeichner. Beispiel: [XOEV-Basisdatentypen]&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1282131963669_347065_533'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1282131963670_531828_535' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1282131963670_187054_537' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_b7102e0_1282131963681_472501_538'>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1282131963681_712136_539'/>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1282131963681_229370_540'/>
				<navigableOwnedEnd xmi:idref='_16_5_4_b7102e0_1282131963681_229370_540'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_b7102e0_1282131963681_229370_540' name='extension_xsdXModelImport' visibility='private' aggregation='composite' type='_16_5_4_b7102e0_1282131963663_958424_532' association='_16_5_4_b7102e0_1282131963681_472501_538'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1282131963681_710655_541'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1282131963681_788166_542' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_b7102e0_1310393084388_456884_533' name='xsdGroup'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314793033333_842787_619' body='&lt;para&gt;Eine UML-Klasse, die mit diesem Stereotyp versehen ist, wird im XML-Schema durch ein xs:group&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cModel_Group_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cModel_Group_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;- oder xs:attributeGroup&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cAttribute_Group_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cAttribute_Group_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;-Elementmodell umgesetzt (anstelle von xs:complexType). Die Gruppe enthält alle Eigenschaften der mit &lt;emphasis&gt;xsdGroup&lt;/emphasis&gt; gekennzeichneten Klasse, die mit &lt;emphasis&gt;xsdElement&lt;/emphasis&gt; bzw. &lt;emphasis&gt;xsdAttribute&lt;/emphasis&gt; gekennzeichnet sind.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_b7102e0_1310393084388_456884_533'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310393119067_490352_540' name='base_Class' visibility='private' association='_16_5_4_b7102e0_1310393119067_145127_539'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_b7102e0_1310393119067_145127_539'>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310393119067_490352_540'/>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310393119067_217681_541'/>
				<navigableOwnedEnd xmi:idref='_16_5_4_b7102e0_1310393119067_217681_541'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_b7102e0_1310393119067_217681_541' name='extension_xsdGroup' visibility='private' aggregation='composite' type='_16_5_4_b7102e0_1310393084388_456884_533' association='_16_5_4_b7102e0_1310393119067_145127_539'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310393119067_622256_542'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310393119067_424107_543' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_b7102e0_1310551667488_613356_328' name='xsdGlobalElementType'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314792541184_758204_618' body='&lt;para&gt;Eine UML-Abhängigkeit zwischen einer als &lt;emphasis&gt;xsdGlobalElement&lt;/emphasis&gt; ausgezeichneten UML-Klasse und einer als &lt;emphasis&gt;xsdNamedType&lt;/emphasis&gt; ausgezeichneten UML-Klasse, die mit dem Stereotyp &lt;emphasis&gt;xsdGlobalElementType&lt;/emphasis&gt; versehen ist bewirkt, dass im XML-Schema als Datentyp des globalen Elements der bebannte Typ der als Ziel der Abhängigkteit angegeben ist festgelegt wird&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;&#10;&lt;para&gt;Der Stereotyp muss im Zusammenspiel mit den Stereotypen &lt;emphasis&gt;xsdGlobalElement&lt;/emphasis&gt; und &lt;emphasis&gt;xsdNamedType&lt;/emphasis&gt; verwendet werden.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_b7102e0_1310551667488_613356_328'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310551689818_544499_335' name='base_Dependency' visibility='private' association='_16_5_4_b7102e0_1310551689818_138115_334'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Dependency'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Dependency' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_b7102e0_1310551689818_138115_334'>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310551689818_544499_335'/>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310551689818_91508_336'/>
				<navigableOwnedEnd xmi:idref='_16_5_4_b7102e0_1310551689818_91508_336'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_b7102e0_1310551689818_91508_336' name='extension_xsdGlobalElementType' visibility='private' aggregation='composite' type='_16_5_4_b7102e0_1310551667488_613356_328' association='_16_5_4_b7102e0_1310551689818_138115_334'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310551689818_999397_337'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310551689818_614624_338' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_b7102e0_1310654548871_451816_514' name='xsdUnion'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314793735035_598605_620' body='&lt;para&gt;Angewendet auf eine UML-Klasse bewirkt dieser Stereotyp, dass eine xs:union&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; als Inhaltsmodell des simple Types festgelegt wird. Die Mitglieder der Union werden über Abhängigkeiten die mit dem Stereotyp &quot;xsdUnionMember&quot; annotiert sind modelliert.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_b7102e0_1310654548871_451816_514'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310654564840_14479_521' name='base_Class' visibility='private' association='_16_5_4_b7102e0_1310654564840_795792_520'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_b7102e0_1310654564840_795792_520'>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310654564840_14479_521'/>
				<memberEnd xmi:idref='_16_5_4_b7102e0_1310654564840_381530_522'/>
				<navigableOwnedEnd xmi:idref='_16_5_4_b7102e0_1310654564840_381530_522'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_b7102e0_1310654564840_381530_522' name='extension_xsdUnion' visibility='private' aggregation='composite' type='_16_5_4_b7102e0_1310654548871_451816_514' association='_16_5_4_b7102e0_1310654564840_795792_520'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310654564840_715038_523'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310654564840_70422_524' value='1'/>
						</modelExtension>
					</xmi:Extension>
