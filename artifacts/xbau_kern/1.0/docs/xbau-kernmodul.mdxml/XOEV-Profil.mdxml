						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1499769708695_608979_4445' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1499769708695_901839_4416' name='externeWebsite' visibility='private'>
