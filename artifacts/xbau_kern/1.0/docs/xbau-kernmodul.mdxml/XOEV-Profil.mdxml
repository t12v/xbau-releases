			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124197329781_449768_111' name='xsdSchema'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_10_5_6370212_1135691576835_19599_1' body='&lt;para&gt;Das so annotierte UML-Paket wird in ein XML-Schema übersetzt. Es besteht eine direkte Beziehung zwischen einer erzeugten XML-Schema-Datei und einem &quot;xsdSchema&quot;-Paket.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung erfolgt als xs:schema&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; in einer XML-Schema-Datei.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124197329781_449768_111'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_9_5_6370212_1124197424367_992585_161' name='namespace' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_10_5_6370212_1135691604635_111594_2' body='&lt;para&gt;Der Namensraum für dieses Schema.&lt;/para&gt;&#10;&lt;para&gt;Bei der Erzeugung des XML-Schemas wird dieser Wert für das &quot;targetNamespace&quot;-Attribut des xs:schema-Elements&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; verwendet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_9_5_6370212_1124197424367_992585_161'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_14_0_5b501fb_1239108404255_219355_1100'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_14_0_5b501fb_1239108404255_820812_1101' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_9_5_6370212_1131634883583_925466_152' name='prefix' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806720875_602408_123' body='&lt;para&gt;Bei der Angabe der Eigenschaft wird dessen Wert für den XML-Namensraum dieses xs:schema-Elements&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; als XML-Präfix verwendet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_9_5_6370212_1131634883583_925466_152'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169812652984_776307_115'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169812652984_336182_116' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1169812627687_672667_56' name='base_Package' visibility='private' association='_11_5_6370212_1169812627687_377217_55'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Package'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Package' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1241763404546_398541_253' name='schemaFile' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1241763570859_987315_257' body='&lt;para&gt;Der physische Dateiname des XML-Schemas ohne eine Pfadangabe, der zur Benennung des XML-Schemas auf Dateiebene herangezogen wird.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_12_1_8b00279_1241763404546_398541_253'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1241763421515_183573_255' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1241763421515_491351_256' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_9_5_6370212_1131634883583_726833_151' name='schemaLocation' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806733453_497600_124' body='&lt;para&gt;Der physische Speicherort (URL inklusive Dateiname), an dem das Schema später gefunden werden kann. Dieses Schema-Attribut wird auf xs:import&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;&gt;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; und xs:include&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;&gt;http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; abgebildet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_9_5_6370212_1131634883583_726833_151'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1241758916656_596700_254'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1241758916656_234261_255' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_9_5_6370212_1124197424367_6512_162' name='version' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806811343_493601_125' body='&lt;para&gt;Die Version des XML-Schemas.&lt;/para&gt;&#10;&lt;para&gt;Dieser Wert wird auf das Attribut &quot;version&quot; des xs:schema-Elements&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; abgebildet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_9_5_6370212_1124197424367_6512_162'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169812645078_146804_109'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169812645078_883049_110' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1431011091489_223136_576' name='elementFormDefault' visibility='private' type='_16_5_4_1d100e5_1382428090839_769482_556'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1431015606873_632467_718' body='&lt;para&gt;Mittels dieser Eigenschaft kann die standardmäßige Qualifizierung der XML-Elemente in der ausgezeichneten XML Schema-Definition vorgegeben werden, also der Wert für das XML Schema-Attribut elementFormDefault.&#10;&#10;Falls der Eigenschaft kein Wert oder der Wert &#39;default&#39; zugewiesen ist, wird die Vorgabe aus der gleichnamigen Eigenschaft des Stereotyps xsdXModel übernommen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1431011091489_223136_576'/>
					</ownedComment>
					<defaultValue xmi:type='uml:InstanceValue' xmi:id='_16_5_4_5b501fb_1431015046783_564763_717' instance='_16_5_4_5b501fb_1431014209419_453152_578'/>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638865_811303_3'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124266425909_961504_7' name='xsdInclude'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1179674885531_662107_8' body='&lt;para&gt;Die mit dem Stereotyp gekennzeichnete UML-Abhängigkeit bildet eine Beziehung zwischen zwei &quot;xsdSchema&quot;-Paketen ab, wobei das eine Paket von dem anderen eingebunden wird.&lt;/para&gt;&#10;&lt;para&gt;Das XML-Schema des Anbieter-Pakets wird durch ein xs:include&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;&gt;http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; in das XML-Schema des abhängigen Pakets eingebunden.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124266425909_961504_7'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_10_5_6370212_1135160639787_614481_63' name='base_Dependency' visibility='private' association='_10_5_6370212_1135160639787_431082_62'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Dependency'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Dependency' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638885_128560_12'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124265352966_791641_19' name='xsdGlobalElement'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806339578_782293_118' body='&lt;para&gt;Eine UML-Klasse oder -Enumeration, die mit dem Stereotyp &quot;xsdGlobalElement&quot; versehen ist, wird im XML-Schema als globales Element, d.h. als mögliches Wurzelelement-xs:element&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; (&#39;document root&#39;) umgesetzt.&lt;/para&gt;&#10;&lt;para&gt;Der Stereotyp kann in Zusammenspiel mit dem Stereotypen &quot;xsdMessage&quot; zur Kennzeichnung von XÖV-Nachrichten verwendet werden.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124265352966_791641_19'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1315386820199_794796_329' name='base_Classifier' visibility='private' association='_16_5_4_b7102e0_1315386820198_165407_328'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Classifier'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classifier' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638885_184292_14'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124196478227_708100_1' name='xsdAttribute'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806433375_745396_120' body='&lt;para&gt;Eine mit diesem Stereotyp gekennzeichnete UML-Eigenschaft (UML-Attribut oder -Assozationsende) wird als xs:attribute&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cAttribute_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cAttribute_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; umgesetzt. UML-Klassenattribute, die mit diesem Stereotyp gekennzeichnet sind, dürfen als Multiplizität nur 1 (dies ist der Standard-Wert) oder 0..1 besitzen, d.h. sie sind somit entweder obligatorisch oder optional.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124196478227_708100_1'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_10_5_6370212_1135160639847_389881_108' name='base_Property' visibility='private' association='_10_5_6370212_1135160639847_299101_107'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Property'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Property' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1311680132156_358790_346' name='isRef' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#Boolean'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314795487558_406109_625' body='&lt;para&gt;Falls die als xsdAttribute markierte Eigenschaft auf eine globale Attributgruppe verweisen soll, muss für diese Eigenschaft der Wert true angegeben werden. Andernfalls wird ein lokales Attribut erzeugt.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1311680132156_358790_346'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1311680143226_814268_348'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1311680143226_334547_349' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638865_164754_1'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124265313409_433757_5' name='xsdChoice'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806589437_828417_121' body='&lt;para&gt;Eine UML-Klasse, die mit diesem Stereotyp versehen ist, wird im XML-Schema durch ein xs:choice&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Model_Groups&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Model_Groups&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;-Elementmodell umgesetzt (anstelle von xs:sequence&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Model_Groups&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Model_Groups&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;). Der &quot;choice&quot; erstreckt sich über alle Eigenschaften der mit &quot;xsdChoice&quot; gekennzeichneten UML-Klasse, die mit &quot;xsdElement&quot; gekennzeichnet sind.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124265313409_433757_5'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1169814699046_210081_649' name='base_Class' visibility='private' association='_11_5_6370212_1169814699046_370226_648'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638885_409632_13'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124197274712_758074_19' name='xsdNamedType'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169805981640_797237_117' body='&lt;para&gt;Eine UML-Klasse, die mit &quot;xsdNamedType&quot; versehen ist, wird im XML-Schema als benannter Typ (xs:complexType&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; oder xs:simpleType&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Simple_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;) umgesetzt.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124197274712_758074_19'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1170922896187_582585_20' name='base_Classifier' visibility='private' association='_11_5_6370212_1170922896171_36314_18'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Classifier'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Classifier' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638865_245295_2'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124265621682_674591_142' name='xsdElement'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806396828_772109_119' body='&lt;para&gt;Eine mit diesem Stereotyp gekennzeichnete UML-Eigenschaft (UML-Attribut oder -Assoziationsende einer Aggregation) legt fest, dass sie als xs:element&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; umgesetzt wird.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124265621682_674591_142'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1157021169533_511715_2' name='nillable' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#Boolean'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169809067203_692248_1' body='&lt;para&gt;Wenn diese Eigenschaft mit &quot;true&quot; angegeben wird, wird dieses Element im entsprechenden xs:complexType&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; als &quot;nillable=&#39;true&#39;&quot;&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#xsi_nil&quot;&gt;http://www.w3.org/TR/xmlschema-1/#xsi_nil&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; deklariert.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1157021169533_511715_2'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1239983029031_47950_270'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1239983029031_85648_271' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_10_5_6370212_1135160639837_429169_98' name='base_Property' visibility='private' association='_10_5_6370212_1135160639837_352518_97'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Property'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Property' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_9_5_6370212_1124265642542_581447_156' name='position' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#Integer'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::Integer' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806848765_985885_126' body='&lt;para&gt;Die Eigenschaft bestimmt die Position einer als xs:element&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; umgesetzten UML-Eigenschaft innerhalb der Elementsequenz xs:sequence&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Model_Groups&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Model_Groups&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; im entsprechenden xs:complexType&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Complex_Type_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;&#10;&lt;para&gt;Die Nummierung der Eigenschaft position muss für alle &quot;xsdElement&quot;-Eigenschaften einer UML-Klasse eindeutig und als positiver ganzzahliger Wert hinterlegt sein.&lt;/para&gt;&#10;&lt;para&gt;Die Nummern werden nicht in der Dokumentation des jeweiligen xs:element&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; ausgegeben. Sie dient zur Bildung der xs:element&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;-Reihenfolge.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_9_5_6370212_1124265642542_581447_156'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169814723375_635684_662' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169814723375_97767_663' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8b00279_1259845446213_525900_763' name='form' visibility='private' type='_16_5_4_1d100e5_1382428090839_769482_556'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8b00279_1259845566578_581339_768' body='&lt;para&gt;Mittels dieser Eigenschaft kann die Qualifizierung des ausgezeichneten XML-Elements bestimmt werden. Standardmäßig (form = default) gilt für das Element die Vorgabe der zugrundeliegenden XML Schema-Definition, gesteuert über das XML Schema-Attribut elementFormDefault (siehe die Eigenschaft elementFormDefault des Stereotyps xsdSchema bzw. xsdXModel). Die Qualifizierung des Elements kann jedoch über die Werte &#39;qualified&#39; und &#39;unqualified&#39; auch explizit festgelegt werden.&lt;/para&gt;&#10;&#10;&lt;para&gt;Unqualifizierte Elemente werden bei der Ableitung (XML-Restriktion) eines Basistyps benötigt, der sich in einem fremden Namensraum befindet.&lt;/para&gt;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_8b00279_1259845446213_525900_763'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8b00279_1259845549267_89032_766'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8b00279_1259845549267_423589_767' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:InstanceValue' xmi:id='_16_5_4_1d100e5_1382428184415_369572_579' instance='_16_5_4_5b501fb_1431014209419_453152_578'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310635978408_761139_343' name='isRef' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#Boolean'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314795439719_195684_624' body='&lt;para&gt;Falls die als xsdElement markierte Eigenschaft auf ein globales Element oder eine Elementgruppe verweisen soll, muss für diese Eigenschaft der Wert true angegeben werden. Andernfalls wird ein lokales Element erzeugt.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1310635978408_761139_343'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310636580794_288910_502'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310636580794_674516_503' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638885_150077_18'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124307083424_342810_23' name='xsdRestriction'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1179674571562_832490_4' body='&lt;para&gt;Wird eine UML-Generalisierung mit diesem Stereotyp gekennzeichnet, wird ein Hinzufügen von Informationen in der Unterklasse verboten. Die Instanzen der Unterklasse dürfen nur noch die Eigenschaften der Oberklasse verwenden, die explizit noch einmal in der Unterklasse aufgezählt werden. Die Vererbung wird hiermit eingeschränkt. Die Multiplizitäten (d. h. Häufigkeiten) der wiederverwendeten Eigenschaften dürfen zwar verändert, aber lediglich verschärft werden (z.B. von 0..1 zu 1 oder von 0..* zu 1..*).&lt;/para&gt;&#10;&lt;para&gt;Für Typen mit einfachem Inhalt können die als Eigenschaften abgebildeten Facetten&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-facets&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-facets&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; zur Einschränkung genutzt werden. Sie werden direkt im XML-Schema abgebildet.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124307083424_342810_23'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240232113886_828286_638' name='fractionDigits' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240232281433_104033_642' body='&lt;para&gt;xs:fractionDigits&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-fractionDigits&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-fractionDigits&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; definiert die maximal mögliche Anzahl von Ziffern nach dem Dezimalpunkt.&lt;/para&gt;&#10;&lt;para&gt;Zulässig ist die Angabe einer solchen Facette im XML-Schema nur für  xs:decimal&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#decimal&quot;&gt;http://www.w3.org/TR/xmlschema-2/#decimal&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_12_1_8b00279_1240232113886_828286_638'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240232155984_418178_640'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240232155984_700339_641' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_10_5_6370212_1135160639776_620610_58' name='base_Generalization' visibility='private' association='_10_5_6370212_1135160639776_697561_57'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Generalization'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Generalization' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240223313517_317525_592' name='length' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240223572023_630231_596' body='&lt;para&gt;xs:length&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-length&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-length&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; definiert eine feste Länge von Zeichen (allgemein) oder Bytes (xs:base64Binary bzw. xs:hexBinary).&lt;/para&gt;&#10;&lt;para&gt;Zulässig ist die Angabe einer solchen Facette im XML-Schema für die folgenden W3C-Datentypen&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&quot;&gt;http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&lt;/ulink&gt; und &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-derived&quot;&gt;http://www.w3.org/TR/xmlschema-2/#built-in-derived&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;: xs:anyURI, xs:base64Binary, xs:ENTITY, xs:hexBinary, xs:ID, xs:IDREF, xs:language, xs:Name, xs:NCName, xs:NMTOKEN,  xs:normalizedString, xs:NOTATION, xs:QName, xs:string, &#10;xs:token.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_12_1_8b00279_1240223313517_317525_592'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240223379358_373153_594'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240223379358_56749_595' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1240230311912_525273_613' name='maxExclusive' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
