						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169817195750_360131_145' body='&lt;para&gt;Die Pfadausdrücke für die xs:field-Elemente&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;'>
