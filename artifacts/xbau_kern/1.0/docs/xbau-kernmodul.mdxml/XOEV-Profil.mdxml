					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1269956481660_115225_14307' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638895_265466_28'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1157547867034_698291_2' name='xsdMessage'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169816674250_883090_17' body='&lt;para&gt;Der Stereotyp &quot;xsdMessage&quot; kennzeichnet die Instanzen dieser UML-Klasse als Nachrichten im XÖV-Sinne, also einer elektronischen Datenübermittlung innerhalb und mit der Verwaltung.&lt;/para&gt;&#10;&lt;para&gt;Da XÖV-Nachrichten XML-Instanzen darstellen, sind diese mittels des Stereotyps &quot;xsdGlobalElement&quot; immer als globale XML-Elemente zu definieren.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1157547867034_698291_2'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1157547876320_334985_5' name='base_Class' visibility='private' association='_11_5_6370212_1157547876320_487443_4'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1169816586562_669702_7' name='leser' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169816736546_935010_19'>
						<annotatedElement xmi:idref='_11_5_6370212_1169816586562_669702_7'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169816595859_581097_11'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1590752516126_234356_4232' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1169816597703_721827_13' name='rechtsgrundlagen' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169816707703_160789_18' body='&lt;para&gt;Die Rechtsgrundlage(n) wie beispielsweise  Gesetze, Verordnungen oder Satzungen zu dieser Nachricht.&lt;/para&gt;&#10;&lt;para&gt;Die Information dient nur zu Dokumentationszwecken und hat keine Auswirkung auf die Struktur des XML-Schemas: Es erfolgt eine Ausgabe in der Dokumentation des jeweiligen xs:element&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cElement_Declarations&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;-Eintrags im XML-Schema.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1169816597703_721827_13'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240219392990_920357_586'/>
					<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240219392990_283329_587' value='*'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1169816557656_753260_1' name='autor' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169816772343_218412_20'>
						<annotatedElement xmi:idref='_11_5_6370212_1169816557656_753260_1'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169816580687_120891_5'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1590752520812_763553_4233' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1326204703881_778395_389' name='wsdlVorlagedatei' visibility='private' type='_18_0_6_5b501fb_1590767326933_253997_4232'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1590767420540_678049_4236'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1590767420540_55174_4237' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:InstanceValue' xmi:id='_18_0_6_5b501fb_1590767430014_781313_4238' instance='_18_0_6_5b501fb_1590767382572_405930_4233'/>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124307426007_721881_130' name='xsdImport'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1179674784156_14714_6' body='&lt;para&gt;Die mit dem Stereotyp gekennzeichnete UML-Abhängigkeit bildet eine Import-Beziehung zwischen zwei &quot;xsdSchema&quot;-UML-Paketen ab.&lt;/para&gt;&#10;&lt;para&gt;Das XML-Schema des Anbieter-Pakets (Ende mit Pfeilspitze) wird durch ein xs:import&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;&gt;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; in das XML-Schema des abhängigen Pakets eingebunden.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124307426007_721881_130'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_9_5_6370212_1124307488998_373216_144' name='prefix' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1179674808890_881389_7' body='&lt;para&gt;Das XML-Präfix, mit dem der Namensraum des importierten Schemas angesprochen werden soll.&lt;/para&gt;&#10;&lt;para&gt;Der Wert wird direkt in das XML-Schema übernommen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_9_5_6370212_1124307488998_373216_144'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169814309640_74715_388'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169814309640_177159_389' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_10_5_6370212_1135160639817_719288_78' name='base_Dependency' visibility='private' association='_10_5_6370212_1135160639817_199799_77'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Dependency'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Dependency' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1360231538062_197764_414' name='schemaLocationDeployment' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1360231703547_510180_415' body='Mit dieser Eigenschaft kann die SchemaLocation für ein importiertes Schema angegeben werden, die bei einem Release (deployment=true) ausgegeben wird.&#10;Die Eigenschaft ist vor allem für eingebundene XÖV-kompatible Modelle gedacht bei denen nur das komplette Schema vorliegt.'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1360231538062_197764_414'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1360231722513_617741_416'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1360231722513_115052_417' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1360231736150_325481_418' name='schemaLocationLocal' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1360231822857_189671_419' body='Mit dieser Eigenschaft kann die SchemaLocation für ein importiertes Schema angegeben werden, die bei einem Arbeitsbuild (deployment=false) ausgegeben wird.&#10;Die Eigenschaft ist vor allem für eingebundene XÖV-kompatible Modelle gedacht bei denen nur das komplette Schema vorliegt und die Validierung des resultierenden Schemas nicht mit den vom XGenerator erzeugten Fragmenten funktionieren würde.'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1360231736150_325481_418'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1360231848051_636417_420'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1360231848051_74401_421' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638885_199327_21'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_6370212_1124265393034_976238_33' name='xsdAnyContents'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169806628859_282358_122' body='&lt;para&gt;Eine mit diesem Stereotyp versehene UML-Klasse wird im XML-Schema als Typ umgesetzt, der beliebige XML-Elemente enthalten kann.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung des Stereotyps wird im XML-Schema durch xs:any&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Wildcards&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Wildcards&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; realisiert.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_9_5_6370212_1124265393034_976238_33'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1169814709562_250547_654' name='base_Class' visibility='private' association='_11_5_6370212_1169814709562_7309_653'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310993138097_235326_352' name='maxOccurs' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314795253830_668437_623' body='&lt;para&gt;Mit dieser Eigenschaft wird die maximale Anzahl der Elemente aus dem in der Eigenschaft &quot;namespace&quot; definierten Namensraum festgelegt.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1310993138097_235326_352'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310993186798_556223_354'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310993186798_505412_355' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralString' xmi:id='_16_5_4_b7102e0_1310993186798_396431_356' value='unbounded'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_b7102e0_1310992868923_31184_344' name='minOccurs' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_b7102e0_1314795216218_759617_622' body='&lt;para&gt;Mit dieser Eigenschaft wird die minimale Anzahl der Elemente aus dem in der Eigenschaft &quot;namespace&quot; definierten Namensraum festgelegt.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_b7102e0_1310992868923_31184_344'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_b7102e0_1310993133509_42252_349'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_b7102e0_1310993133509_10323_350' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralString' xmi:id='_16_5_4_b7102e0_1310993133510_677074_351' value='0'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_9_5_6370212_1124265422386_530314_47' name='namespace' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1179674140843_551404_2' body='&lt;para&gt;Die Eigenschaft legt den XML-Namensraum fest, aus dem die Inhalte kommen dürfen. Standardwert ist der Namensraum &lt;quote&gt;##any&lt;/quote&gt;.&lt;/para&gt;&#10;  &lt;para&gt;Der Wert wird direkt in das XML-Schema übernommen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_9_5_6370212_1124265422386_530314_47'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1248762679031_229268_204'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1248762679031_575587_205' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralString' xmi:id='_16_5_4_5b501fb_1280399424738_398872_921' value='##any'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1280399248925_4946_530' name='processContents' visibility='private' type='_16_5_4_b7102e0_1316421278144_216181_537'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1280399669190_271673_922' body='&lt;para&gt;Mit dieser Eigenschaft kann der Wert des Attributs processContents definiert werden, der standardmäßig auf &lt;quote&gt;strict&lt;/quote&gt; (Namensraum muss verfügbar sein und Validierung findet statt) eingestellt ist. Mögliche Werte sind ausserdem &lt;quote&gt;lax&lt;/quote&gt; (Validierung nur wenn der Namensraum verfügbar ist) und &lt;quote&gt;skip&lt;/quote&gt; (keine Validierung).&lt;/para&gt;&#10;&lt;para&gt;Der Wert wird direkt in das XML-Schema übernommen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1280399248925_4946_530'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1280400428684_880553_923'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1280400428684_505762_924' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralString' xmi:id='_16_5_4_5b501fb_1280400428686_180432_925' value='strict'/>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_10_5_6370212_1135160638885_804587_15'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1161246056421_346423_2' name='xsdUnique'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169817055265_31879_138' body='&lt;para&gt;Eine mit diesem Stereotyp gekennzeichnete UML-Abhängigkeit modelliert ein xs:unique-Constraint&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; in XML. Der Name der UML-Abhängigkeit wird als Name des xs:unique&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; verwendet.&lt;/para&gt;&#10;&lt;para&gt;Die Anwendung auf eine UML-Abhängigkeit im UML-Modell erfolgt analog zum Stereotyp &quot;xsdKey&quot;.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1161246056421_346423_2'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1161246159625_177555_26' name='fields' visibility='private' isOrdered='true'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169817186937_272180_144' body='&lt;para&gt;Die Pfadausdrücke für die xs:field-Elemente&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1161246159625_177555_26'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1161951520376_248301_2'/>
					<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_14_0_5b501fb_1208802571735_164011_103' value='*'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1161345127734_606639_1' name='selector' visibility='private'>
