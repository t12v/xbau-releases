			<packagedElement xmi:type='uml:Stereotype' xmi:id='_18_0_6_5b501fb_1563113608422_755298_12224' name='xsdWithAnyAttribute'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1563113608422_811068_12226' body='&lt;para&gt;Eine mit diesem Stereotyp versehene UML-Klasse wird im XML-Schema als Typ umgesetzt, der beliebige XML-Elemente enthalten kann.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung des Stereotyps wird im XML-Schema durch xs:any&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Wildcards&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Wildcards&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; realisiert.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_18_0_6_5b501fb_1563113608422_755298_12224'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1563113608422_816733_12248' name='base_Class' visibility='private' association='_18_0_6_5b501fb_1563113608422_500696_12247'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1563113608422_317263_12229' name='namespace' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1563113608422_585203_12240' body='&lt;para&gt;Die Eigenschaft legt den XML-Namensraum fest, aus dem die Inhalte kommen dürfen. Standardwert ist der Namensraum &lt;quote&gt;##any&lt;/quote&gt;.&lt;/para&gt;&#10;  &lt;para&gt;Der Wert wird direkt in das XML-Schema übernommen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1563113608422_317263_12229'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1563113608422_911258_12241'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1563113608422_861400_12239' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralString' xmi:id='_18_0_6_5b501fb_1563113608422_829184_12242' value='##any'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1563113608422_62626_12230' name='processContents' visibility='private' type='_16_5_4_b7102e0_1316421278144_216181_537'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1563113608422_248168_12244' body='&lt;para&gt;Mit dieser Eigenschaft kann der Wert des Attributs processContents definiert werden, der standardmäßig auf &lt;quote&gt;strict&lt;/quote&gt; (Namensraum muss verfügbar sein und Validierung findet statt) eingestellt ist. Mögliche Werte sind ausserdem &lt;quote&gt;lax&lt;/quote&gt; (Validierung nur wenn der Namensraum verfügbar ist) und &lt;quote&gt;skip&lt;/quote&gt; (keine Validierung).&lt;/para&gt;&#10;&lt;para&gt;Der Wert wird direkt in das XML-Schema übernommen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1563113608422_62626_12230'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1563113608422_544346_12245'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_18_0_6_5b501fb_1563113608422_744264_12243' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralString' xmi:id='_18_0_6_5b501fb_1563113608422_397254_12246' value='strict'/>
				</ownedAttribute>
				<icon xmi:type='uml:Image' xmi:id='_18_0_6_5b501fb_1563113608422_172671_12225'/>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_18_0_6_5b501fb_1563113608422_500696_12247'>
