				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1169739604296_404318_1' name='refer' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1179674976093_318592_129' body='&lt;para&gt;Der Name des xs:key- oder xs:unique-Constraints&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;, auf das sich dieses xs:keyref-Constraint&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; bezieht.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung erfolgt als Attribut &quot;refer&quot; des xs:keyref-Elements&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1169739604296_404318_1'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169739617281_781037_3' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1169739617281_573413_4' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1162384324471_388832_105' name='selector' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169817142828_451375_142' body='&lt;para&gt;Der Pfadausdruck für das &#39;refer&#39;-Attribut im xs:keyref&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;. Es muss ein xs:key- oder xs:unique-Constraint&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; mit diesem Namen im Modell geben.&lt;/para&gt;&#10;&lt;para&gt;Die Umsetzung erfolgt als xs:selector&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_11_5_6370212_1162384324471_388832_105'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1162384324473_975223_109' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralInteger' xmi:id='_11_5_6370212_1162384324473_260669_108' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
			</packagedElement>
