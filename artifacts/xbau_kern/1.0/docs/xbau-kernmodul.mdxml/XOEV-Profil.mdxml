			<packagedElement xmi:type='uml:Stereotype' xmi:id='_18_0_6_5b501fb_1499768519864_957106_4009' name='xoevCodeliste'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1501330831621_171704_4113' body='Mittels dieses Stereotyps wird die UML-Enumeration einer Codeliste annotiert. Er erlaubt die Angabe der versionsunabhängigen Metadaten der Codeliste.'>
					<annotatedElement xmi:idref='_18_0_6_5b501fb_1499768519864_957106_4009'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1499768519879_82614_4039' name='base_Enumeration' visibility='private' association='_18_0_6_5b501fb_1499768519879_512125_4038'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Enumeration'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Enumeration' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_18_0_6_5b501fb_1499768519879_819739_4010' name='nameLang' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499768519879_871015_4018' body='Der Name (lang) ist die &quot;sprechende&quot; Bezeichnung einer Codeliste.'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1499768519879_819739_4010'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_18_0_6_5b501fb_1499768519879_314747_4019' value='1'/>
