					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499769708695_301320_4458' body='Zu einem Datentyp kann ein URL zu einer externen Webseite angegeben werden, auf der weitere Informationen zum Datentyp zur Verfügung stehen.'>
