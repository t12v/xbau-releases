						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499769818159_405927_4509' body='Der Name (lang) ist die &quot;sprechende&quot; Bezeichnung einer Kernkomponente.'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1499769818144_370855_4481'/>
					</ownedComment>
