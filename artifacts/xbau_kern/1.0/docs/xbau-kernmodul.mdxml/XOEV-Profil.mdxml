						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499769818159_287335_4530' body='Zu einer Kernkomponente kann ein URL zu einer externen Webseite angegeben werden, auf der weitere Informationen zur Kernkomponente zur Verfügung stehen.'>
