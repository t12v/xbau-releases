					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499769708695_913133_4437' body='Der Name (lang) ist die &quot;sprechende&quot; Bezeichnung eines Datentyps.'>
						<annotatedElement xmi:idref='_18_0_6_5b501fb_1499769708695_26575_4409'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
