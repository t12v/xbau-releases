			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1162384324470_855386_103' name='xsdKeyref'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169817067500_277666_139' body='&lt;para&gt;Die mit diesem Stereotyp gekennzeichnete UML-Abhängigkeit modelliert ein xs:keyref&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;-Constraint in XML. Der Name der UML-Abhängigkeit wird als Name des xs:keyref&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; verwendet.&lt;/para&gt;&#10;&lt;para&gt;Da sich die Key-Constraints in XML-Schema immer auf ein XML-Element (und nicht auf einen XML-Typen) beziehen, werden sie auch in UML entsprechend an eine mit &quot;xsdElement&quot; versehene Klasseneigenschaft (UML-Attribut oder -Kompositition) annotiert.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_11_5_6370212_1162384324470_855386_103'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_11_5_6370212_1162384324474_206626_111' name='base_Dependency' visibility='private' association='_11_5_6370212_1162384324473_942719_110'>
