					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240231816641_117760_637' body='&lt;para&gt;xs:totalDigits&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#rf-totalDigits&quot;&gt;http://www.w3.org/TR/xmlschema-2/#rf-totalDigits&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; definiert die maximale Anzahl von Dezimalziffern.&lt;/para&gt;&#10;&lt;para&gt;Zulässig ist die Angabe einer solchen Facette im XML-Schema für die folgenden W3C-Datentypen&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&quot;&gt;http://www.w3.org/TR/xmlschema-2/#built-in-primitive-datatypes&lt;/ulink&gt; und &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-2/#built-in-derived&quot;&gt;http://www.w3.org/TR/xmlschema-2/#built-in-derived&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt;: xs:byte, xs:decimal, xs:int, xs:integer, xs:long, xs:negativeInteger, xs:nonNegativeInteger, xs:nonPositiveInteger, xs:positiveInteger, xs:short, xs:unsignedByte, xs:unsignedInt, xs:unsignedLong, xs:unsignedShort.&lt;/para&gt;'>
