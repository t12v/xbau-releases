			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_14_0_1_6370212_1213859870390_667705_948' name='xsdXModel'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1240237192966_510870_653' body='&lt;para&gt;Das mit diesem Stereotyp annotierte UML-Modell stellt den &amp;xoevstd; dar und enthält alle &quot;xsdSchema&quot;-Pakete des &amp;xoevstds; sowie weitere relevante Informationen (z.B. xsdImport, xsdInclude).&lt;/para&gt;'>
					<annotatedElement xmi:idref='_14_0_1_6370212_1213859870390_667705_948'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_1_6370212_1213859900312_713314_955' name='base_Model' visibility='private' association='_14_0_1_6370212_1213859900312_197952_954'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Model'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Model' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_8b00279_1263994461162_348485_883' name='deployment' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#Boolean'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::Boolean' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_8b00279_1263995069209_607048_889' body='&lt;para&gt;Der Schalter zur Angabe, ob der Standard sich noch in der lokalen Entwicklung befindet (false) oder das Deployment mit der Veröffentlichung des Standards (true) bevorsteht und somit auch die XML-Schemata über öffentlich zugängliche URLs angesprochen werden können.&lt;/para&gt;&#10;&lt;para&gt;Bei Angabe des Wertes &quot;true&quot; wird im Normalfall für das Attribut &quot;schemaLocation&quot; für xs:import&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;&gt;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; und xs:include&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;&gt;http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; der Wert der Eigenschaft &quot;schemaLocation&quot; im Stereotyp &quot;xsdSchema&quot; verwendet. Ist &quot;schemaLocation&quot; für das &quot;xsdSchema&quot;-Paket nicht angegeben so wird eine Kombination der Eigenschaftswerte aus &quot;schemaFile&quot; (&quot;xsdSchema&quot;-Paket) und &quot;schemaLocationBase&quot; (&quot;xsdXModel&quot;-Modell) gebildet.&lt;/para&gt;&#10;&lt;para&gt;Bei Angabe des Wertes &quot;false&quot; wird für das Attribut &quot;schemaLocation&quot; für xs:import&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;&gt;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; und xs:include&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;&gt;http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; der Wert der Eigenschaft &quot;schemaFile&quot; im Stereotyp &quot;xsdSchema&quot; übernommen.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_8b00279_1263994461162_348485_883'/>
					</ownedComment>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_8b00279_1263994533481_443019_887' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_8b00279_1263994533481_363297_888' value='1'/>
						</modelExtension>
					</xmi:Extension>
					<defaultValue xmi:type='uml:LiteralBoolean' xmi:id='_16_5_4_8b00279_1263994503141_733913_886'/>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_5b501fb_1237903753480_733112_969' name='fassungVom' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_14_0_5b501fb_1237903982552_435664_972' body='&lt;para&gt;Datum der Fassung.&lt;/para&gt;&#10;&lt;para&gt;Die Information dient nur zu Dokumentationszwecken und hat keine Auswirkung auf die Struktur des XML-Schema.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_14_0_5b501fb_1237903753480_733112_969'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240237334885_75529_654'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240237334885_414278_655' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_5b501fb_1237365404662_216699_969' name='namespace' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_14_0_5b501fb_1237369051599_420578_1105' body='&lt;para&gt;Der gültige Namensraum für alle &quot;xsdSchema&quot;-Pakete des Standards, sofern für das einzelne &quot;xsdSchema&quot;-Paket die gleichnamige Stereotyp-Eigenschaft nicht mit einem eigenen Wert versehen ist.&lt;/para&gt;&#10;&lt;para&gt;Bei der Erzeugung der XML-Schemata wird dieser Wert für das &quot;targetNamespace&quot;-Attribut des xs:schema-Elements&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; verwendet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_14_0_5b501fb_1237365404662_216699_969'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1240237616020_891781_662'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1240237616020_575934_663' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_14_0_5b501fb_1234272099126_652191_968' name='prefix' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_14_0_5b501fb_1235567275350_424334_1101' body='&lt;para&gt;Der gültige Prefix für alle &quot;xsdSchema&quot;-Pakete des Standards, sofern für das einzelne &quot;xsdSchema&quot;-Paket die gleichnamige Stereotyp-Eigenschaft nicht mit einem eigenem Wert versehen ist.&lt;/para&gt;&#10;&lt;para&gt;Bei der Angabe der Eigenschaft wird dessen Wert für den Namespace als XML-Präfix für die xs:schema-Elemente&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#Schemas&quot;&gt;http://www.w3.org/TR/xmlschema-1/#Schemas&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; verwendet.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_14_0_5b501fb_1234272099126_652191_968'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1249472935341_989803_268'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1249472935357_108043_269' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_12_1_8b00279_1241798590027_403877_126' name='schemaLocationBase' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_12_1_8b00279_1241799137757_23444_130' body='&lt;para&gt;Der Basispfad der SchemaLocations (z.B. &quot;http://xoev.de/schemata/xhamsterzucht/1_0&quot;).&lt;/para&gt;&#10;&lt;para&gt;Der physische Speicherort (URL exklusive Dateiname), an dem die Schemata später gefunden werden können. Bildet zusammen mit der Eigenschaft &quot;schemaFile&quot; (z.B. &quot;xhz-baukasten.xsd&quot;) des Stereotyps &quot;xsdSchema&quot; auf das Schema-Attribut &quot;schemaLocation&quot; (z.B. &quot;http://xoev.de/schemata/xhamsterzucht/1_0 xhz-baukasten.xsd&quot;) für xs:import&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&quot;&gt;http://www.w3.org/TR/xmlschema-1/#composition-schemaImport&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; und xs:include&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#compound-schema&quot;&gt;http://www.w3.org/TR/xmlschema-1/#compound-schema&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; ab - sofern für das einzelne Schema kein konkreter Wert für die Eigenschaft &quot;schemaLocation&quot; im Stereotyp &quot;xsdSchema&quot; angegeben ist.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_12_1_8b00279_1241798590027_403877_126'/>
					</ownedComment>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_12_1_8b00279_1241798631541_121928_128'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_12_1_8b00279_1241798631541_326823_129' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1431011036031_498344_572' name='elementFormDefault' visibility='private' type='_16_5_4_5b501fb_1431015003779_815461_713'>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1431015750708_996846_719' body='&lt;para&gt;Mittels dieser Eigenschaft kann für alle XML Schema-Definitionen die standardmäßige Qualifizierung der XML-Elemente vorgegeben werden, also der Wert für das XML Schema-Attribut elementFormDefault. Falls der Eigenschaft kein Wert oder der Wert &#39;qualified&#39; zugewiesen ist, wird gelten die XML-Elemente als qualifiziert.&lt;/para&gt;&#10;&#10;&lt;para&gt;Die Modell-weit geltende Vorgabe zur Qualifizierung von XML-Elementen kann sowohl auf XSD-Ebene (xsdSchema) als auch auf Element-Ebene (xsdElement) überschrieben werden.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1431011036031_498344_572'/>
					</ownedComment>
					<defaultValue xmi:type='uml:InstanceValue' xmi:id='_16_5_4_5b501fb_1431011067140_730171_575' instance='_16_5_4_1d100e5_1382428130524_790395_575'/>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_14_0_1_6370212_1213859900312_197952_954'>
				<memberEnd xmi:idref='_14_0_1_6370212_1213859900312_713314_955'/>
				<memberEnd xmi:idref='_14_0_1_6370212_1213859900312_342969_956'/>
