					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_18_0_6_5b501fb_1499769385004_775965_4340' body='Der Herausgebername (kurz) ist der gekürzte oder umgangssprachliche Name des Herausgebers.'>
