			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_5b501fb_1431956784770_391539_579' name='xsdAll'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1431956973585_218983_1054' body='&lt;para&gt;Eine UML-Klasse, die mit diesem Stereotyp versehen ist, wird im XML-Schema durch eine xs:all-Gruppe umgesetzt (anstelle einer xs:sequence- oder xs:choice-Gruppe). Die Gruppe erstreckt sich über alle Eigenschaften der mit &quot;xsdAll&quot; gekennzeichneten UML-Klasse, die mit &quot;xsdElement&quot; gekennzeichnet sind.&lt;/para&gt;&#10;&#10;&lt;para&gt;Hinweis: XML-Erweiterungen mit all-Gruppen erfordern XML Schema in der Version 1.1 und entsprechend ausgerüstete XML Schema-Validatoren.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_5b501fb_1431956784770_391539_579'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1431956883508_67421_692' name='base_Class' visibility='private' association='_16_5_4_5b501fb_1431956883507_331051_690'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_5b501fb_1431956883507_331051_690'>
				<memberEnd xmi:idref='_16_5_4_5b501fb_1431956883508_67421_692'/>
				<memberEnd xmi:idref='_16_5_4_5b501fb_1431956883508_970360_691'/>
				<navigableOwnedEnd xmi:idref='_16_5_4_5b501fb_1431956883508_970360_691'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_5b501fb_1431956883508_970360_691' name='extension_xsdAll' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1431956784770_391539_579' association='_16_5_4_5b501fb_1431956883507_331051_690'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1431956883509_975691_693'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
