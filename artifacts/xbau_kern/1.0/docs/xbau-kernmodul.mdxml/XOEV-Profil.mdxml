			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_5b501fb_1387625943764_901436_1760' name='xoevABIE'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387626921636_384991_1494' body='&lt;para&gt;Dieser Stereotyp macht kenntlich, dass ein komplexer Baustein eines XÖV-Standards mit einer aggregierten Kernkomponente (ACC) verwandt ist. Sofern der Baustein den gleichen Namen wie die in Beziehung stehende Kernkomponente besitzt, muss keine explizite Verbindung zwischen ihnen hergestellt werden. Andernfalls wird die Verbindung mit Hilfe einer UML-Abhängigkeit (Depenendy) modelliert.&lt;/para&gt; '>
					<annotatedElement xmi:idref='_16_5_4_5b501fb_1387625943764_901436_1760'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387626029610_888397_1767' name='base_Class' visibility='private' association='_16_5_4_5b501fb_1387626029610_787407_1766'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Class'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Class' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387626059629_890444_1772' name='Abweichung' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387626311502_817581_1789' body='&lt;para&gt;Über die Stereotyp-Eigenschaft &quot;Abweichung&quot; werden die Veränderungen gegenüber der jeweiligen Kernkomponente (ACC) beschrieben, welche zu einer semantischen oder strukturellen Abweichung führen und über das XÖV-Zubehör nicht automatisiert ermittelt werden können.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1387626059629_890444_1772'/>
					</ownedComment>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387626099226_774289_1773' name='MotivationDerAbweichung' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387626594629_889456_1790' body='&lt;para&gt;Eine Abweichung von der jeweiligen Kernkomponente (ACC) wird über die Stereotyp-Eigenschaft &quot;MotivationDerAbweichung&quot; begründet, sodass der fachliche Sachverhalt, welcher der Übernahme der Kernkomponentenvorgaben gegenübersteht, erkennbar wird.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1387626099226_774289_1773'/>
					</ownedComment>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Extension' xmi:id='_16_5_4_5b501fb_1387626029610_787407_1766'>
				<memberEnd xmi:idref='_16_5_4_5b501fb_1387626029610_888397_1767'/>
				<memberEnd xmi:idref='_16_5_4_5b501fb_1387626029611_314663_1768'/>
				<navigableOwnedEnd xmi:idref='_16_5_4_5b501fb_1387626029611_314663_1768'/>
				<ownedEnd xmi:type='uml:ExtensionEnd' xmi:id='_16_5_4_5b501fb_1387626029611_314663_1768' name='extension_xoevABIE' visibility='private' aggregation='composite' type='_16_5_4_5b501fb_1387625943764_901436_1760' association='_16_5_4_5b501fb_1387626029610_787407_1766'>
					<lowerValue xmi:type='uml:LiteralInteger' xmi:id='_16_5_4_5b501fb_1387626029611_762382_1769'/>
					<xmi:Extension extender='MagicDraw UML 19.0'>
						<modelExtension>
							<upperValue xmi:type='uml:LiteralUnlimitedNatural' xmi:id='_16_5_4_5b501fb_1387626029611_271552_1770' value='1'/>
						</modelExtension>
					</xmi:Extension>
				</ownedEnd>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_5b501fb_1387626155685_890016_1774' name='xoevASBIE'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387627906821_441489_1515' body='&lt;para&gt;Dieser Stereotyp macht kenntlich, dass eine Bausteineigenschaft (mit komplexer Struktur) mit einer Kernkomponenteneigenschaft (xoevBCC oder xoevASCC) in Beziehung steht. Sofern der Name der Bausteineigenschaft dem der Kernkomponenteneigenschaft entspricht, muss keine explizite Verbindung zwischen ihnen hergestellt werden. Andernfalls wird die Verbindung mit Hilfe einer UML-Abhängigkeit (Depenendy) modelliert.&lt;/para&gt; '>
					<annotatedElement xmi:idref='_16_5_4_5b501fb_1387626155685_890016_1774'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387626155688_329518_1776' name='Abweichung' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387626613009_895736_1792' body='&lt;para&gt;Über die Stereotyp-Eigenschaft &quot;Abweichung&quot; werden die Veränderungen gegenüber der jeweiligen Kernkomponenteneigenschaft (xoevBCC oder xoevASCC) beschrieben, welche zu einer semantischen oder strukturellen Abweichung führen und über das XÖV-Zubehör nicht automatisiert ermittelt werden können.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1387626155688_329518_1776'/>
					</ownedComment>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387626155689_838492_1777' name='MotivationDerAbweichung' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387626623916_550698_1793' body='&lt;para&gt;Eine Abweichung von der jeweiligen Kernkomponenteneigenschaft (xoevBCC oder xoevASCC) wird über die Stereotyp-Eigenschaft &quot;MotivationDerAbweichung&quot; begründet, sodass der fachliche Sachverhalt, welcher der Übernahme der Kernkomponentenvorgaben gegenübersteht, erkennbar wird.&lt;/para&gt;&#10;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1387626155689_838492_1777'/>
					</ownedComment>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406631071049_645545_2833' name='base_Property' visibility='private' association='_16_5_4_5b501fb_1406631071049_934057_2832'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Property'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::Property' referentType='Class'/>
						</xmi:Extension>
					</type>
				</ownedAttribute>
			</packagedElement>
			<packagedElement xmi:type='uml:Stereotype' xmi:id='_16_5_4_5b501fb_1387626627185_364086_1794' name='xoevBBIE'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387627936704_662274_1516' body='&lt;para&gt;Dieser Stereotyp macht kenntlich, dass eine Bausteineigenschaft (ohne komplexer Struktur) mit einer Kernkomponenteneigenschaft (xoevBCC oder xoevASCC) in Beziehung steht. Sofern der Name der Bausteineigenschaft dem der Kernkomponenteneigenschaft entspricht, muss keine explizite Verbindung zwischen ihnen hergestellt werden. Andernfalls wird die Verbindung mit Hilfe einer UML-Abhängigkeit (Depenendy) modelliert.&lt;/para&gt;'>
					<annotatedElement xmi:idref='_16_5_4_5b501fb_1387626627185_364086_1794'/>
				</ownedComment>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387626627188_202791_1796' name='Abweichung' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387626627190_17531_1799' body='&lt;para&gt;Über die Stereotyp-Eigenschaft &quot;Abweichung&quot; werden die Veränderungen gegenüber der jeweiligen Kernkomponenteneigenschaft (xoevBCC oder xoevASCC) beschrieben, welche zu einer semantischen oder strukturellen Abweichung führen und über das XÖV-Zubehör nicht automatisiert ermittelt werden können.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1387626627188_202791_1796'/>
					</ownedComment>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387626627189_645985_1797' name='MotivationDerAbweichung' visibility='private'>
					<type href='http://www.omg.org/spec/UML/20131001/PrimitiveTypes.xmi#String'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
							<referenceExtension referentPath='UML Standard Profile::UML2 Metamodel::PrimitiveTypes::String' referentType='PrimitiveType'/>
						</xmi:Extension>
					</type>
					<ownedComment xmi:type='uml:Comment' xmi:id='_16_5_4_5b501fb_1387626627190_284790_1800' body='&lt;para&gt;Eine Abweichung von der jeweiligen Kernkomponenteneigenschaft (xoevBCC oder xoevASCC) wird über die Stereotyp-Eigenschaft &quot;MotivationDerAbweichung&quot; begründet, sodass der fachliche Sachverhalt, welcher der Übernahme der Kernkomponentenvorgaben gegenübersteht, erkennbar wird.&lt;/para&gt;'>
						<annotatedElement xmi:idref='_16_5_4_5b501fb_1387626627189_645985_1797'/>
					</ownedComment>
				</ownedAttribute>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1406631086378_481079_2875' name='base_Property' visibility='private' association='_16_5_4_5b501fb_1406631086378_447608_2874'>
