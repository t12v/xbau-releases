			<packagedElement xmi:type='uml:Stereotype' xmi:id='_9_5_3aa0191_1142834248600_203287_6703' name='xoevBCC'>
				<ownedAttribute xmi:type='uml:Property' xmi:id='_16_5_4_5b501fb_1387626759649_50947_1510' name='base_Property' visibility='private' association='_16_5_4_5b501fb_1387626759649_838340_1509'>
					<type href='http://www.omg.org/spec/UML/20131001/UML.xmi#Property'>
						<xmi:Extension extender='MagicDraw UML 19.0'>
