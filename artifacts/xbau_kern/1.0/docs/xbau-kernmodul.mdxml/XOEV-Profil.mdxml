			<packagedElement xmi:type='uml:Stereotype' xmi:id='_11_5_6370212_1161955620211_19087_2' name='xsdKey'>
				<ownedComment xmi:type='uml:Comment' xmi:id='_11_5_6370212_1169817041843_242072_137' body='&lt;para&gt;Eine mit diesem Stereotyp gekennzeichnete UML-Abhängigkeit modelliert ein xs:key-Constraint&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; im XML-Schema. Der Name der UML-Abhängigkeit wird als Name des xs:key&lt;footnote&gt;&lt;para&gt;siehe &lt;ulink url=&quot;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&quot;&gt;http://www.w3.org/TR/xmlschema-1/#cIdentity-constraint_Definitions&lt;/ulink&gt;&lt;/para&gt;&lt;/footnote&gt; verwendet.&lt;/para&gt;'>
